# OpenClaw 保护层配置文件 v4.3
# ~/.openclaw/protection/config.env

# ============ 并发限制 ============
OPENCLAW_MAX_CONCURRENT=3
OPENCLAW_QUEUE_MAX_SIZE=30

# ============ 超时配置 ============
OPENCLAW_DIRECT_TIMEOUT=30000
OPENCLAW_STEP_TIMEOUT=60000
OPENCLAW_GLOBAL_TIMEOUT=600000
OPENCLAW_NO_OUTPUT_TIMEOUT=30000

# ============ 输出截断 ============
OPENCLAW_MAX_OUTPUT_KB=10
OPENCLAW_OUTPUT_DIR=/tmp/openclaw

# ============ 内存限制 (MB) ============
OPENCLAW_MEMORY_SOFT_MB=2000
OPENCLAW_MEMORY_HARD_MB=2500
OPENCLAW_MAX_RETRIES=3

# ============ 会话自动压缩 (旧) ============
OPENCLAW_SUMMARIZE_THRESHOLD=50
OPENCLAW_SUMMARIZE_RESERVE=5
OPENCLAW_AUTO_SUMMARIZE=true
OPENCLAW_SUMMARIZE_COOLDOWN=120000

# ============ 上下文保护 (新) ============
OPENCLAW_MSG_THRESHOLD=50           # 消息条数阈值
OPENCLAW_CHAR_THRESHOLD=102400      # 字符数阈值 (100KB)
OPENCLAW_TOKEN_RATIO=0.8            # Token使用率阈值 (80%)
OPENCLAW_TOKEN_LIMIT=131072         # Token上限 (128K)
OPENCLAW_CHECK_INTERVAL=30000       # 底层检测轮询间隔 (30秒)
OPENCLAW_COOLDOWN_SEC=120           # 压缩冷却期 (秒)

# ============ 检查点 ============
OPENCLAW_CHECKPOINT_DIR=/tmp/openclaw/checkpoints

# ============ 熔断器 ============
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT_SEC=30

# ============ 限流器 ============
RATE_LIMITER_TOKENS_PER_SEC=2
RATE_LIMITER_MAX_TOKENS=10

# ============ v4.3 新增配置 ============

# --- 安全网关 ---
RATE_LIMIT_PER_SEC=2                    # 每IP每秒请求限制
ALLOWED_COMMANDS=/usr/bin/ls,/usr/bin/cat,/usr/bin/grep,/usr/bin/echo  # 命令白名单
MAX_SPEC_SIZE_BYTES=1048576             # 任务规格大小限制 (1MB)
ALLOWED_INPUT_PATH=/tmp/openclaw/inputs/  # 允许的输入路径前缀

# --- 任务执行 ---
TASK_UID=65534                          # 任务执行用户ID (nobody)
TASK_GID=65534                          # 任务执行组ID
TASK_MEMORY_LIMIT_MB=2048               # 任务内存限制
TASK_GLOBAL_TIMEOUT_MS=600000           # 任务全局超时 (10分钟)

# --- 调度器 ---
SCHEDULER_POLL_MIN_MS=10                # 最小轮询间隔
SCHEDULER_POLL_MAX_MS=1000              # 最大轮询间隔

# --- 日志 ---
LOG_LEVEL=info
LOG_MAX_SIZE_MB=100
LOG_MAX_FILES=10