{"type":"message","id":"6952336a","parentId":"78a032da","timestamp":"2026-04-11T15:48:55.341Z","message":{"role":"toolResult","toolCallId":"call_0c696f65b8d846f1bf302ff0","toolName":"read","content":[{"type":"text","text":"{\n  \"version\": \"1.0\",\n  \"providers\": {\n    \"minimax\": {\n      \"type\": \"openai-compatible\",\n      \"baseUrl\": \"https://api.minimax.chat/v1\",\n      \"apiKey\": \"${MINIMAX_API_KEY}\"\n    },\n    \"deepseek\": {\n      \"type\": \"openai-compatible\",\n      \"baseUrl\": \"https://api.deepseek.com/v1\",\n      \"apiKey\": \"${DEEPSEEK_API_KEY}\"\n    }\n  },\n  \"models\": {\n    \"fast\": {\n      \"provider\": \"minimax\",\n      \"modelId\": \"minimax-m2.5\",\n      \"fallback\": \"deep\",\n      \"timeout\": 30000,\n      \"maxRetries\": 2\n    },\n    \"deep\": {\n      \"provider\": \"deepseek\",\n      \"modelId\": \"deepseek-chat\",\n      \"fallback\": \"fast\",\n      \"timeout\": 60000,\n      \"maxRetries\": 1\n    }\n  }\n}"}],"isError":false,"timestamp":1775922535329}}
