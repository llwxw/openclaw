{"type":"message","id":"c5c30a66","parentId":"f50a645f","timestamp":"2026-04-11T13:14:46.253Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"用户确认继续 Phase 1.5，需要修改 proxy/index.js 添加路由逻辑。先读取当前的 proxy/index.js 内容。\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"019d7cae29e1885099bcfe84940da2fb","name":"read","arguments":{"path":"/home/ai/.openclaw/proxy/index.js"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":33034,"output":58,"cacheRead":1152,"cacheWrite":0,"totalTokens":34244,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775913277883,"responseId":"019d7cae10bc42db0c683266e31a33f6"}}
{"type":"message","id":"b29ec25f","parentId":"c5c30a66","timestamp":"2026-04-11T13:14:46.309Z","message":{"role":"toolResult","toolCallId":"019d7cae29e1885099bcfe84940da2fb","toolName":"read","content":[{"type":"text","text":"require('dotenv').config();\nconst express = require('express');\nconst http = require('http');\nconst axios = require('axios');\nconst WebSocket = require('ws');\nconst path = require('path');\nconst { createProxyMiddleware } = require('http-proxy-middleware');\nconst { classify, score } = require('./clients/v8Client');\n\nconst app = express();\napp.use(express.json());\n\n// 静态文件服务\napp.use(express.static(path.join(__dirname, 'public')));\n\nconst PORT = process.env.PROXY_PORT || 3105;\nconst GATEWAY_URL = process.env.GATEWAY_URL || 'http://localhost:3108';\nconst GATEWAY_WS = process.env.GATEWAY_WS || 'ws://localhost:3108';\nconst BYPASS_MODE = process.env.BYPASS_MODE === 'true';\nconst V8_TASK_API = process.env.V8_TASK_API || 'http://localhost:3103/api/task';\nconst CONTEXT_API = process.env.CONTEXT_API || 'http://localhost:3101';\n\nlet bypass = BYPASS_MODE;\n\nconst log = (level, msg, data) => console.log(JSON.stringify({ level, time: new Date().toISOString(), msg, ...data }));\n\napp.get('/health', (req, res) => res.json({ status: 'ok', bypass }));\napp.post('/admin/bypass', (req, res) => { bypass = req.body.enabled === true; log('info', 'Bypass changed', { bypass }); res.json({ bypass }); });\n\n// 上下文管理函数\nasync function getContext() {\n  try {\n    const res = await axios.get(`${CONTEXT_API}/api/context/full`, { timeout: 2000 });\n    return res.data.messages || [];\n  } catch { return []; }\n}\n\nasync function addContextMessage(role, content) {\n  try {\n    await axios.post(`${CONTEXT_API}/api/context`, { role, content }, { timeout: 2000 });\n  } catch (err) { console.error('Context add failed:', err.message); }\n}\n\napp.post('/api/chat/send', async (req, res) => {\n  const { message, context = {} } = req.body;\n  if (!message) return res.status(400).json({ error: 'message is required' });\n\n  // 添加用户消息到上下文\n  await addContextMessage('user', message);\n\n  if (bypass) {\n    try {\n      const gwRes = await axios.post(`${GATEWAY_URL}/api/chat/send`, req.body, { timeout: 30000 });\n      return res.json(gwRes.data);\n    } catch (err) { return res.status(502).json({ error: 'Gateway unavailable' }); }\n  }\n\n  try {\n    const classification = await classify(message);\n    log('info', 'Classified', { scene: classification.scene, isTask: classification.isTask });\n\n    if (!classification.isTask) {\n      const replies = { chitchat: '你好！有什么技术问题需要帮助？', fault_recovery: '请描述具体的故障现象和已尝试的操作，我将协助恢复。', vague_request: '我不太确定你的具体需求。请具体说明。' };\n      return res.json({ reply: replies[classification.scene] || '收到', scene: classification.scene, source: 'proxy' });\n    }\n\n    const scoring = await score(message, context);\n    log('info', 'Scored', { score: scoring.score, strategy: scoring.recommendedStrategy });\n\n    if (scoring.recommendedStrategy === 'DIRECT') {\n      const payload = { type: 'command', command: message.split(' ')[0] || 'echo', args: message.split(' ').slice(1), timeout: scoring.timeout, priority: Math.floor(scoring.score / 20), metadata: { prompt: message, strategy: scoring.recommendedStrategy } };\n      const taskRes = await axios.post(V8_TASK_API, payload, { timeout: 5000 });\n      return res.json({ reply: `✅ 任务已提交 (ID: ${taskRes.data.id})`, taskId: taskRes.data.id, strategy: 'DIRECT' });\n    }\n\n    // 非 DIRECT 任务：转发给 Gateway\n    try {\n      // 获取上下文历史\n      const history = await getContext();\n      const payload = { ...req.body, history };\n      const gwRes = await axios.post(`${GATEWAY_URL}/api/chat/send`, payload, { timeout: Math.max(scoring.timeout * 1000 + 5000, 30000) });\n      \n      // 存储助手回复\n      const replyContent = gwRes.data.reply || gwRes.data.content || '';\n      await addContextMessage('assistant', replyContent);\n      \n      log('info', 'Forwarded to Gateway', { status: gwRes.status });\n      return res.json(gwRes.data);\n    } catch (gwErr) {\n      log('error', 'Gateway forward failed', { error: gwErr.message, status: gwErr.response?.status });\n      return res.status(502).json({ error: `Gateway error: ${gwErr.message}` });\n    }\n  } catch (err) {\n    log('error', 'Proxy error', { error: err.message });\n    try { \n      const gwRes = await axios.post(`${GATEWAY_URL}/api/chat/send`, req.body, { timeout: 30000 }); \n      await addContextMessage('assistant', gwRes.data.reply || '');\n      return res.json({ ...gwRes.data, fallback: true }); \n    }\n    catch { return res.status(502).json({ error: 'All services unavailable' }); }\n  }\n});\n\n// HTTP 服务器 + WebSocket\nconst server = http.createServer(app);\nconst wss = new WebSocket.Server({ server, path: '/ws' });\n\nwss.on('connection', (ws) => {\n  log('info', 'WebSocket client connected');\n  const target = new WebSocket(GATEWAY_WS);\n  \n  ws.on('message', (msg) => { if (target.readyState === WebSocket.OPEN) target.send(msg); });\n  target.on('message', (msg) => { if (ws.readyState === WebSocket.OPEN) ws.send(msg); });\n  ws.on('close', () => target.close());\n  target.on('close', () => ws.close());\n  ws.on('error', (e) => log('error', 'Client WS error', { error: e.message }));\n  target.on('error', (e) => log('error', 'Target WS error', { error: e.message }));\n});\n\n// 转发中间件：非 API 请求转发到 Gateway\nconst gatewayProxy = createProxyMiddleware({\n  target: GATEWAY_URL,\n  changeOrigin: true,\n  ws: true,\n  logLevel: 'silent',\n  onError: (err, req, res) => {\n    log('error', 'Proxy error', { error: err.message });\n    res.status(502).send('Gateway unavailable');\n  }\n});\n\n// 注意：放在 API 路由之后，确保 /api/chat/send 不被转发\napp.use('/', gatewayProxy);\n\n// WebSocket 升级处理\nserver.on('upgrade', (req, socket, head) => {\n  log('info', 'WebSocket upgrade', { url: req.url });\n  gatewayProxy.upgrade(req, socket, head);\n});\n\nserver.listen(PORT, () => log('info', `Proxy started on port ${PORT}`, { gateway: GATEWAY_URL }));\nprocess.on('SIGTERM', () => process.exit(0));\nprocess.on('SIGINT', () => process.exit(0));"}],"isError":false,"timestamp":1775913286298}}
{"type":"message","id":"a454af41","parentId":"b29ec25f","timestamp":"2026-04-11T13:15:30.784Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在我需要在这个文件中添加：\n1. 配置加载（顶部）\n2. 路由决策函数\n3. 分类器缓存\n4. 修改消息处理逻辑，在调用 classify 之前先做路由决策\n\n让我构造代码补丁。需要：\n- 在顶部 require 旁边添加 fs 和 NodeCache（如果 proxy 没装，需要检查）\n- 添加配置加载\n- 添加路由函数和日志函数\n- 修改 app.post('/api/chat/send') 中的逻辑\n\n让我一步步改。\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"019d7cae597a901c15cf12f811a4ad11","name":"edit","arguments":{"path":"/home/ai/.openclaw/proxy/index.js","edits":[{"oldText":"require('dotenv').config();\nconst express = require('express');\nconst http = require('http');\nconst axios = require('axios');\nconst WebSocket = require('ws');\nconst path = require('path');\nconst { createProxyMiddleware } = require('http-proxy-middleware');\nconst { classify, score } = require('./clients/v8Client');","newText":"require('dotenv').config();\nconst fs = require('fs');\nconst express = require('express');\nconst http = require('http');\nconst axios = require('axios');\nconst WebSocket = require('ws');\nconst path = require('path');\nconst { createProxyMiddleware } = require('http-proxy-middleware');\nconst NodeCache = require('node-cache');\nconst { classify, score } = require('./clients/v8Client');\n\n// ========== 路由配置加载 ==========\nconst MODELS_CONFIG = JSON.parse(fs.readFileSync('/home/ai/.openclaw/config/models.json'));\nconst RULES_CONFIG = JSON.parse(fs.readFileSync('/home/ai/.openclaw/config/routing_rules.json'));\nconst OPENCLAW_CONFIG = JSON.parse(fs.readFileSync('/home/ai/.openclaw/openclaw.json'));\n\n// 分类器缓存\nconst classifyCache = new NodeCache({ stdTTL: parseInt(process.env.CLASSIFIER_CACHE_TTL) || 300 });\n\n// 路由决策函数\nfunction routeAgent(userMessage, classifierResult) {\n  const rules = [...RULES_CONFIG.rules].sort((a, b) => b.priority - a.priority);\n  \n  for (const rule of rules) {\n    if (rule.condition.always) continue;\n    \n    if (rule.condition.contains) {\n      const matched = rule.condition.contains.some(kw => userMessage.includes(kw));\n      if (matched) {\n        logRouting(userMessage, rule.id, rule.target_agent);\n        return rule.target_agent;\n      }\n    }\n    \n    if (rule.condition.classifier_label && classifierResult) {\n      const matched = rule.condition.classifier_label.includes(classifierResult.scene);\n      if (matched) {\n        logRouting(userMessage, rule.id, rule.target_agent);\n        return rule.target_agent;\n      }\n    }\n  }\n  \n  const fallback = rules.find(r => r.condition.always);\n  const target = fallback ? fallback.target_agent : 'fast_agent';\n  logRouting(userMessage, 'fallback', target);\n  return target;\n}\n\nfunction logRouting(userMessage, ruleId, targetAgent) {\n  if (process.env.ROUTING_LOG_ENABLED !== 'true') return;\n  const logEntry = {\n    timestamp: new Date().toISOString(),\n    user_message: userMessage.substring(0, 100),\n    rule_triggered: ruleId,\n    target_agent: targetAgent\n  };\n  console.log(JSON.stringify(logEntry));\n}\n\n// 获取 Agent 的模型配置\nfunction getModelConfig(agentId) {\n  const agent = (OPENCLAW_CONFIG.agents?.list || []).find(a => a.id === agentId);\n  const modelRef = agent?.modelRef || 'fast';\n  const modelConfig = MODELS_CONFIG.models[modelRef];\n  const provider = MODELS_CONFIG.providers[modelConfig.provider];\n  return { modelRef, modelConfig, provider };\n}"}]}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":34694,"output":926,"cacheRead":1152,"cacheWrite":0,"totalTokens":36772,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775913286310,"responseId":"019d7cae37c07edc0959fc8fac34b6c7"}}
