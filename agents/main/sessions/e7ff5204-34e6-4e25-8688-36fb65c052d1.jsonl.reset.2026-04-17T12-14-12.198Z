es ? \"light\" : \"dark\";\n          }\n          var resolved =\n            theme === \"knot\"\n              ? mode === \"light\"\n                ? \"openknot-light\"\n                : \"openknot\"\n              : theme === \"dash\"\n                ? mode === \"light\"\n                  ? \"dash-light\"\n                  : \"dash\"\n                : mode === \"light\"\n                  ? \"light\"\n                  : \"dark\";\n          document.documentElement.setAttribute(\"data-theme\", resolved);\n          document.documentElement.setAttribute(\n            \"data-theme-mode\",\n            resolved.indexOf(\"light\") !== -1 ? \"light\" : \"dark\",\n          );\n        } catch (e) {}\n      })();\n    </script>\n    <script type=\"module\" crossorigin src=\"./assets/index-Dba6JFRP.js\"></script>\n    <link rel=\"modulepreload\" crossorigin href=\"./assets/i18n-CBV1HzVj.js\">\n    <link rel=\"modulepreload\" crossorigin href=\"./assets/directive--_7q5XUp.js\">\n    <link rel=\"modulepreload\" crossorigin href=\"./assets/format-8X3T6jaJ.js\">\n    <link rel=\"modulepreload\" crossorigin href=\"./assets/string-coerce-BcFtIWA_.js\">\n    <link rel=\"modulepreload\" crossorigin href=\"./assets/agents-utils-D3i3OOzL.js\">\n    <link rel=\"modulepreload\" crossorigin href=\"./assets/open-external-url-CFudzOX7.js\">\n    <link rel=\"modulepreload\" crossorigin href=\"./assets/icons-C1s9fbQ1.js\">\n    <link rel=\"modulepreload\" crossorigin href=\"./assets/navigation-D43qCMw3.js\">\n    <link rel=\"modulepreload\" crossorigin href=\"./assets/presenter-iVT0AIJi.js\">\n    <link rel=\"modulepreload\" crossorigin href=\"./assets/config-form-DJsjs08x.js\">\n    <link rel=\"stylesheet\" crossorigin href=\"./assets/index-Dbv_lyce.css\">\n  </head>\n  <body>\n    <openclaw-app></openclaw-app>\n  </body>\n</html>"}],"details":{"status":"completed","exitCode":0,"durationMs":214,"aggregated":"<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-