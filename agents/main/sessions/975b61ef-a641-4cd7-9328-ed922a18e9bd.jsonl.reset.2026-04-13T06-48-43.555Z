{"type":"message","id":"be2979d8","parentId":"04103266","timestamp":"2026-04-13T05:39:57.970Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The ephemeral directory doesn't exist yet. The handler needs to create it. Let me now write the modified handler.","thinkingSignature":"514042f17d7b5d3309b1817d088dae03268300351b625c8c90c366fb27e458cd"},{"type":"toolCall","id":"call_function_6uvkoew527br_1","name":"write","arguments":{"content":"// auto-score-classify hook\n// Concurrent classification (3104) + scoring (3103) on every inbound message\n// + ephemeral memory capture for meaningful messages\n\nimport fs from \"node:fs\";\nimport path from \"node:path\";\nimport http from \"node:http\";\n\nasync function fetchJSON(url, body, timeoutMs = 3000) {\n  return new Promise((resolve) => {\n    const postData = JSON.stringify(body);\n    const req = http.request(\n      url,\n      {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\", \"Content-Length\": Buffer.byteLength(postData) },\n      },\n      (res) => {\n        let data = \"\";\n        res.on(\"data\", (chunk) => (data += chunk));\n        res.on(\"end\", () => {\n          try { resolve(JSON.parse(data)); }\n          catch { resolve(null); }\n        });\n      }\n    );\n    req.on(\"error\", () => resolve(null));\n    req.setTimeout(timeoutMs, () => { req.destroy(); resolve(null); });\n    req.write(postData);\n    req.end();\n    setTimeout(() => { try { req.destroy(); } catch {} }, timeoutMs);\n  });\n}\n\nasync function runClassification(text) {\n  return fetchJSON(\"http://127.0.0.1:3104/classify\", { text }, 3000);\n}\n\nasync function runScoring(prompt) {\n  return fetchJSON(\"http://127.0.0.1:3103/api/score\", { prompt }, 3000);\n}\n\nfunction ensureDir(dir) {\n  if (!fs.existsSync(dir)) {\n    fs.mkdirSync(dir, { recursive: true });\n  }\n}\n\n// ─── Meaningfulness filter ───────────────────────────────────────────────────\nconst MEANINGFUL_PATTERNS = [\n  /记住|以后都|决定用|别用|改用|这个要记|记下来/,\n];\n\nfunction isMeaningful(text, classification, scoring) {\n  const c = classification || {};\n  const s = scoring || {};\n  \n  // 1. Explicit user intent\n  if (MEANINGFUL_PATTERNS.some(p => p.test(text))) return true;\n  \n  // 2. System-level important\n  if (c.intercepted === true) return true;\n  if (c.scene === 'fault_recovery') return true;\n  \n  // 3. High risk (>=3)\n  if ((s.factors?.risk || 0) >= 3) return true;\n  \n  // 4. MEGA task\n  if (s.recommendedStrategy === 'MEGA_TASK') return true;\n  \n  return false;\n}\n\n// ─── Ephemeral memory writer ──────────────────────────────────────────────────\nconst EPHEMERAL_DIR = path.join(\n  process.env.OPENCLAW_WORKSPACE_DIR || path.join(process.env.HOME || \"/home/ai\", \".openclaw\", \"workspace\"),\n  \"memory\",\n  \"ephemeral\"\n);\n\nfunction writeEphemeral(entry) {\n  try {\n    ensureDir(EPHEMERAL_DIR);\n    // File per hour: YYYY-MM-DD-HH.jsonl\n    const now = new Date();\n    const hourStr = now.toISOString().slice(0, 13).replace('T', '-');\n    const filePath = path.join(EPHEMERAL_DIR, `${hourStr}.jsonl`);\n    const line = JSON.stringify(entry) + '\\n';\n    fs.appendFileSync(filePath, line, 'utf-8');\n  } catch (e) {\n    // Silently ignore write errors - ephemeral should not break main flow\n  }\n}\n\n// ─── Main handler ─────────────────────────────────────────────────────────────\nexport default async function handler(event) {\n  if (event.type !== \"message\" || event.action !== \"preprocessed\") {\n    return;\n  }\n\n  const text = event.context?.bodyForAgent || \"\";\n  if (!text || text.trim().length === 0) return;\n\n  const sessionKey = event.sessionKey || \"default\";\n  const sessionDir = path.join(process.env.HOME || \"/home/ai\", \".openclaw/sessions\", sessionKey);\n  ensureDir(sessionDir);\n\n  const [classificationResult, scoringResult] = await Promise.allSettled([\n    runClassification(text),\n    runScoring(text),\n  ]);\n\n  const classification = classificationResult.status === \"fulfilled\" ? classificationResult.value : null;\n  const scoring = scoringResult.status === \"fulfilled\" ? scoringResult.value : null;\n\n  const result = {\n    classification,\n    scoring,\n    timestamp: new Date().toISOString(),\n    messagePreview: text.slice(0, 120),\n  };\n\n  const outPath = path.join(sessionDir, \"context.json\");\n  try {\n    fs.writeFileSync(outPath, JSON.stringify(result, null, 2), \"utf-8\");\n  } catch {\n    // ignore write errors silently\n  }\n\n  // ─── Ephemeral memory capture ─────────────────────────────────────────────\n  if (isMeaningful(text, classification, scoring)) {\n    writeEphemeral({\n      timestamp: new Date().toISOString(),\n      sessionKey,\n      text,\n      textPreview: text.length > 200 ? text.slice(0, 200) + '...' : text,\n      classification,\n      scoring,\n    });\n  }\n}\n","path":"/home/ai/.openclaw/hooks/auto-score-classify/handler.js"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":78754,"output":1175,"cacheRead":0,"cacheWrite":18037,"totalTokens":97966,"cost":{"input":0.0236262,"output":0.00141,"cacheRead":0,"cacheWrite":0.006763875,"total":0.031800075000000004}},"stopReason":"toolUse","timestamp":1776058766730,"responseId":"062bb48dde27188e4f312a40193649a1"}}
