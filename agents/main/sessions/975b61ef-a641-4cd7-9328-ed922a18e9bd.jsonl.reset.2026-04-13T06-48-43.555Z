{"type":"message","id":"c76bbc93","parentId":"a4393ada","timestamp":"2026-04-13T05:41:18.282Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Let me read the rest of the file, focusing on the LLM call part.","thinkingSignature":"038c46a9422a62975d94c5d532a6183dc4daca984aa5e1d0fac536fe9011d60f"},{"type":"toolCall","id":"call_function_ezz3bp28hopm_1","name":"exec","arguments":{"command":"sed -n '200,322p' ~/.openclaw/hooks/session-summary/handler.js"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":82823,"output":62,"cacheRead":18037,"cacheWrite":0,"totalTokens":100922,"cost":{"input":0.024846899999999998,"output":0.00007439999999999999,"cacheRead":0.0010822199999999998,"cacheWrite":0,"total":0.026003519999999995}},"stopReason":"toolUse","timestamp":1776058875320,"responseId":"062bb4fa8c448dd78648dfcd744363c9"}}
{"type":"message","id":"b2ca1d18","parentId":"c76bbc93","timestamp":"2026-04-13T05:41:18.376Z","message":{"role":"toolResult","toolCallId":"call_function_ezz3bp28hopm_1","toolName":"exec","content":[{"type":"text","text":"// 20s 单边超时\n    const timer = setTimeout(() => {\n      try { req.destroy(); } catch { /* noop */ }\n      doResolve(\"\");\n    }, LLM_TIMEOUT_MS);\n\n    req.on(\"close\", () => clearTimeout(timer));\n\n    req.write(postData);\n    req.end();\n  });\n}\n\n// ─── Fallback ────────────────────────────────────────────────────────────────\n\n/**\n * @param {string} content\n * @param {string} date\n * @param {string} time\n * @returns {string}\n */\nfunction buildFallbackSummary(content, date, time) {\n  const firstLine = (content.split(\"\\n\")[0] ?? \"\").slice(0, 60).replace(/[#*]/g, \"\").trim();\n  const preview = firstLine || \"会话摘要\";\n  return `# Session: ${date} ${time}\n\n## 主题\n${preview}\n\n## 关键决策\n无\n\n## 重要发现\n无\n\n## 待跟进\n见原始对话记录\n`;\n}\n\n// ─── File Writing ─────────────────────────────────────────────────────────────\n\n/**\n * @param {string} summary\n * @param {string} time\n * @returns {string}\n */\nfunction slugFromSummary(summary, time) {\n  const match = summary.match(/^## 主题$\\s*([^\\n]+)/m);\n  if (!match) return time.replace(/:/g, \"\");\n\n  return match[1]\n    .toLowerCase()\n    .replace(/[^a-z0-9\\u4e00-\\u9fff]+/g, \"-\")\n    .replace(/^-+|-+$/g, \"\")\n    .slice(0, 40) || time.replace(/:/g, \"\");\n}\n\n/**\n * @param {string} summary\n * @param {string} date\n * @param {string} time\n * @param {string} sessionKey\n * @returns {Promise<void>}\n */\nasync function writeSummaryFile(summary, date, time, sessionKey) {\n  const slug = slugFromSummary(summary, time);\n  const filename = `${date}-${slug}.md`;\n  const filePath = path.join(MEMORY_DIR, filename);\n\n  await fs.promises.mkdir(MEMORY_DIR, { recursive: true });\n\n  const fullContent = [\n    `# Session: ${date} ${time}`,\n    \"\",\n    \"<!-- summary-only -->\",\n    summary,\n    \"\",\n    `<!-- source: ${sessionKey} -->`,\n  ].join(\"\\n\");\n\n  await fs.promises.writeFile(filePath, fullContent, \"utf-8\");\n  console.log(`[session-summary] Written: ${filename}`);\n}\n\n// ─── Core ───────────────────────────────────────────────────────────────────\n\n/**\n * @param {{ type: string, action: string, sessionKey: string, context: HookContext, messages: unknown[] }} event\n */\nasync function run(event) {\n  const isTarget = event.type === \"command\" && (event.action === \"new\" || event.action === \"reset\");\n  if (!isTarget) return;\n\n  const now = new Date();\n  const date = now.toISOString().split(\"T\")[0];\n  const time = now.toISOString().split(\"T\")[1].split(\".\")[0].slice(0, 5);\n\n  // 1. 解析 session 文件路径（优先 previousSessionEntry）\n  const sessionFile = resolveSessionFile(event.context || {});\n\n  // 2. 读取消息内容\n  const content = sessionFile ? await extractMessages(sessionFile) : \"\";\n\n  // 3. 生成摘要（失败则降级）\n  const summary =\n    content.trim().length > 50\n      ? await generateSummary(content).then((t) => t || buildFallbackSummary(content, date, time))\n      : buildFallbackSummary(content || \"(无会话内容)\", date, time);\n\n  // 4. 写入 memory/（后台，不等待）\n  writeSummaryFile(summary, date, time, event.sessionKey).catch((err) => {\n    console.error(\"[session-summary] Write error:\", err);\n  });\n}\n\n// ─── Entry Point ─────────────────────────────────────────────────────────────\n\nexport default function handler(event) {\n  run(event).catch((err) => {\n    console.error(\"[session-summary] Uncaught error:\", err);\n  });\n}"}],"details":{"status":"completed","exitCode":0,"durationMs":58,"aggregated":"// 20s 单边超时\n    const timer = setTimeout(() => {\n      try { req.destroy(); } catch { /* noop */ }\n      doResolve(\"\");\n    }, LLM_TIMEOUT_MS);\n\n    req.on(\"close\", () => clearTimeout(timer));\n\n    req.write(postData);\n    req.end();\n  });\n}\n\n// ─── Fallback ────────────────────────────────────────────────────────────────\n\n/**\n * @param {string} content\n * @param {string} date\n * @param {string} time\n * @returns {string}\n */\nfunction buildFallbackSummary(content, date, time) {\n  const firstLine = (content.split(\"\\n\")[0] ?? \"\").slice(0, 60).replace(/[#*]/g, \"\").trim();\n  const preview = firstLine || \"会话摘要\";\n  return `# Session: ${date} ${time}\n\n## 主题\n${preview}\n\n## 关键决策\n无\n\n## 重要发现\n无\n\n## 待跟进\n见原始对话记录\n`;\n}\n\n// ─── File Writing ─────────────────────────────────────────────────────────────\n\n/**\n * @param {string} summary\n * @param {string} time\n * @returns {string}\n */\nfunction slugFromSummary(summary, time) {\n  const match = summary.match(/^## 主题$\\s*([^\\n]+)/m);\n  if (!match) return time.replace(/:/g, \"\");\n\n  return match[1]\n    .toLowerCase()\n    .replace(/[^a-z0-9\\u4e00-\\u9fff]+/g, \"-\")\n    .replace(/^-+|-+$/g, \"\")\n    .slice(0, 40) || time.replace(/:/g, \"\");\n}\n\n/**\n * @param {string} summary\n * @param {string} date\n * @param {string} time\n * @param {string} sessionKey\n * @returns {Promise<void>}\n */\nasync function writeSummaryFile(summary, date, time, sessionKey) {\n  const slug = slugFromSummary(summary, time);\n  const filename = `${date}-${slug}.md`;\n  const filePath = path.join(MEMORY_DIR, filename);\n\n  await fs.promises.mkdir(MEMORY_DIR, { recursive: true });\n\n  const fullContent = [\n    `# Session: ${date} ${time}`,\n    \"\",\n    \"<!-- summary-only -->\",\n    summary,\n    \"\",\n    `<!-- source: ${sessionKey} -->`,\n  ].join(\"\\n\");\n\n  await fs.promises.writeFile(filePath, fullContent, \"utf-8\");\n  console.log(`[session-summary] Written: ${filename}`);\n}\n\n// ─── Core ───────────────────────────────────────────────────────────────────\n\n/**\n * @param {{ type: string, action: string, sessionKey: string, context: HookContext, messages: unknown[] }} event\n */\nasync function run(event) {\n  const isTarget = event.type === \"command\" && (event.action === \"new\" || event.action === \"reset\");\n  if (!isTarget) return;\n\n  const now = new Date();\n  const date = now.toISOString().split(\"T\")[0];\n  const time = now.toISOString().split(\"T\")[1].split(\".\")[0].slice(0, 5);\n\n  // 1. 解析 session 文件路径（优先 previousSessionEntry）\n  const sessionFile = resolveSessionFile(event.context || {});\n\n  // 2. 读取消息内容\n  const content = sessionFile ? await extractMessages(sessionFile) : \"\";\n\n  // 3. 生成摘要（失败则降级）\n  const summary =\n    content.trim().length > 50\n      ? await generateSummary(content).then((t) => t || buildFallbackSummary(content, date, time))\n      : buildFallbackSummary(content || \"(无会话内容)\", date, time);\n\n  // 4. 写入 memory/（后台，不等待）\n  writeSummaryFile(summary, date, time, event.sessionKey).catch((err) => {\n    console.error(\"[session-summary] Write error:\", err);\n  });\n}\n\n// ─── Entry Point ─────────────────────────────────────────────────────────────\n\nexport default function handler(event) {\n  run(event).catch((err) => {\n    console.error(\"[session-summary] Uncaught error:\", err);\n  });\n}","cwd":"/home/ai/.openclaw/workspace/main"},"isError":false,"timestamp":1776058878366}}
{"type":"message","id":"d5e1f848","parentId":"b2ca1d18","timestamp":"2026-04-13T05:41:20.280Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I understand the session-summary hook structure. Let me read the LLM call part (generateSummary) which is around lines 140-210:","thinkingSignature":"647bb06a704346723f088357adf9cb6c27bc49c6195bb19fe0387c5a2691f1a1"},{"type":"toolCall","id":"call_function_yfexskuzj7dm_1","name":"exec","arguments":{"command":"sed -n '130,200p' ~/.openclaw/hooks/session-summary/handler.js"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":83790,"output":75,"cacheRead":18037,"cacheWrite":0,"totalTokens":101902,"cost":{"input":0.025137,"output":0.00008999999999999999,"cacheRead":0.0010822199999999998,"cacheWrite":0,"total":0.026309219999999998}},"stopReason":"toolUse","timestamp":1776058878381,"responseId":"062bb4fd5c577ef1c162512a574d2e98"}}
{"type":"message","id":"3e94917c","parentId":"d5e1f848","timestamp":"2026-04-13T05:41:20.376Z","message":{"role":"toolResult","toolCallId":"call_function_yfexskuzj7dm_1","toolName":"exec","content":[{"type":"text","text":"- 关键决策：列出做出的所有决策，如果没有则写\"无明确决策\"\n- 重要发现：列出任何重要信息或结论，如果没有则写\"无\"\n- 待跟进：列出任何未完成或需要后续处理的事项，如果没有则写\"无\"\n\n格式（严格按此格式，只输出内容，不输出说明）：\n## 主题\n{主题}\n\n## 关键决策\n{决策列表}\n\n## 重要发现\n{发现列表}\n\n## 待跟进\n{待办列表}\n\n对话记录：\n${sessionContent}`;\n}\n\n/**\n * 调用 v8 Router LLM 接口生成摘要。\n * 超时 20s 后自动销毁请求并降级。\n * @param {string} sessionContent\n * @returns {Promise<string>} 空字符串表示失败\n */\nasync function generateSummary(sessionContent) {\n  const prompt = buildSummaryPrompt(sessionContent);\n  const postData = JSON.stringify({\n    model: \"minimax/MiniMax-M2.7\",\n    messages: [{ role: \"user\", content: prompt }],\n    temperature: 0.3,\n    max_tokens: 600,\n  });\n\n  return new Promise((resolve) => {\n    let settled = false;\n    const doResolve = (v) => {\n      if (settled) return;\n      settled = true;\n      resolve(v);\n    };\n\n    const req = http.request(\n      \"http://127.0.0.1:3102/v1/chat/completions\",\n      {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          \"Content-Length\": Buffer.byteLength(postData),\n        },\n      },\n      (res) => {\n        let data = \"\";\n        res.on(\"data\", (c) => (data += c));\n        res.on(\"end\", () => {\n          try {\n            const parsed = JSON.parse(data);\n            const text = parsed.choices?.[0]?.message?.content;\n            doResolve(text?.trim() ?? \"\");\n          } catch {\n            doResolve(\"\");\n          }\n        });\n      }\n    );\n\n    req.on(\"error\", () => doResolve(\"\"));\n\n    // 20s 单边超时"}],"details":{"status":"completed","exitCode":0,"durationMs":63,"aggregated":"- 关键决策：列出做出的所有决策，如果没有则写\"无明确决策\"\n- 重要发现：列出任何重要信息或结论，如果没有则写\"无\"\n- 待跟进：列出任何未完成或需要后续处理的事项，如果没有则写\"无\"\n\n格式（严格按此格式，只输出内容，不输出说明）：\n## 主题\n{主题}\n\n## 关键决策\n{决策列表}\n\n## 重要发现\n{发现列表}\n\n## 待跟进\n{待办列表}\n\n对话记录：\n${sessionContent}`;\n}\n\n/**\n * 调用 v8 Router LLM 接口生成摘要。\n * 超时 20s 后自动销毁请求并降级。\n * @param {string} sessionContent\n * @returns {Promise<string>} 空字符串表示失败\n */\nasync function generateSummary(sessionContent) {\n  const prompt = buildSummaryPrompt(sessionContent);\n  const postData = JSON.stringify({\n    model: \"minimax/MiniMax-M2.7\",\n    messages: [{ role: \"user\", content: prompt }],\n    temperature: 0.3,\n    max_tokens: 600,\n  });\n\n  return new Promise((resolve) => {\n    let settled = false;\n    const doResolve = (v) => {\n      if (settled) return;\n      settled = true;\n      resolve(v);\n    };\n\n    const req = http.request(\n      \"http://127.0.0.1:3102/v1/chat/completions\",\n      {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          \"Content-Length\": Buffer.byteLength(postData),\n        },\n      },\n      (res) => {\n        let data = \"\";\n        res.on(\"data\", (c) => (data += c));\n        res.on(\"end\", () => {\n          try {\n            const parsed = JSON.parse(data);\n            const text = parsed.choices?.[0]?.message?.content;\n            doResolve(text?.trim() ?? \"\");\n          } catch {\n            doResolve(\"\");\n          }\n        });\n      }\n    );\n\n    req.on(\"error\", () => doResolve(\"\"));\n\n    // 20s 单边超时","cwd":"/home/ai/.openclaw/workspace/main"},"isError":false,"timestamp":1776058880367}}
{"type":"message","id":"b04a1458","parentId":"3e94917c","timestamp":"2026-04-13T05:41:39.173Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I understand the LLM call - it's calling `http://127.0.0.1:3102/v1/chat/completions` which is the gateway's internal LLM endpoint. This means I can use the same endpoint for the memory refinement.Now I need to modify the session-summary hook to:\n1. Read ephemeral files from the previous session\n2. Read context.json from the previous session\n3. Combine with session content for LLM refinement4. Decide entity升格 (create/update entities) in the LLM prompt\n5. Write entity filesLet me now write the updated session-summary hook. The changes I need to make:\n\n1. Add a function to read ephemeral files for a given session2. Modify the `run` function to:\n   - Load ephemeral files from the previous session's sessionKey\n   - Combine ephemeral entries with session content\n   - Pass to LLM with a richer prompt that handles entity升格\n3. Add entity writing function\n\nThe tricky part is: the ephemeral files are stored per hour (YYYY-MM-DD-HH.jsonl), but the session might span multiple hours. I need to read all ephemeral files from the current day that match the session timeframe.\n\nActually, looking at the ephemeral format: `2026-04-13-05.jsonl` (hourly). For the session-summary, I should read ALL ephemeral files for the current day (since we don't know exactly when the session started). Or I could read the most recent N hours.\n\nBut actually - here's a better approach: the ephemeral writer writes entries with a `sessionKey` field. So session-summary can:\n1. Read all ephemeral files from the current day\n2. Filter entries by `sessionKey === previousSessionKey`\n3. Process those entries\n\nNow for the LLM prompt, I need to feed it the session content alongside the ephemeral data so it can make informed decisions about which entities to promote or demote.","thinkingSignature":"ef7fc214c369c5b33df928396839259a2b3dd88aea1d3d053bd09f814561633a"},{"type":"text","text":"\n现在实现 session-summary 的 ephemeral 读取 + entity 升格逻辑：\n"},{"type":"toolCall","id":"call_function_m6ztffjr8z7t_1","name":"exec","arguments":{"command":"sed -n '80,130p' ~/.openclaw/hooks/session-summary/handler.js"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":84322,"output":457,"cacheRead":18037,"cacheWrite":0,"totalTokens":102816,"cost":{"input":0.0252966,"output":0.0005484,"cacheRead":0.0010822199999999998,"cacheWrite":0,"total":0.026927219999999998}},"stopReason":"toolUse","timestamp":1776058880380,"responseId":"062bb50037e166f0ad7f1e02b0991d54"}}
{"type":"message","id":"3db9b222","parentId":"b04a1458","timestamp":"2026-04-13T05:41:39.267Z","message":{"role":"toolResult","toolCallId":"call_function_m6ztffjr8z7t_1","toolName":"exec","content":[{"type":"text","text":"* @param {number} [messageCount=40]\n * @returns {Promise<string>}\n */\nasync function extractMessages(filePath, messageCount = 40) {\n  try {\n    const content = await fs.promises.readFile(filePath, \"utf-8\");\n    // 读取双倍行数以防 JSONL 格式行数波动\n    const lines = content.trim().split(\"\\n\").slice(-messageCount * 2);\n    /** @type {string[]} */\n    const messages = [];\n\n    for (const line of lines) {\n      if (!line.trim()) continue;\n      try {\n        /** @type {{ type: string, message?: { role: string, content: unknown } }} */\n        const entry = JSON.parse(line);\n        if (entry.type !== \"message\") continue;\n        const msg = entry.message;\n        if (!msg?.role || !msg?.content) continue;\n        if (msg.role !== \"user\" && msg.role !== \"assistant\") continue;\n\n        const text =\n          typeof msg.content === \"string\"\n            ? msg.content\n            : extractTextFromBlocks(msg.content);\n\n        if (!text || text.startsWith(\"/\")) continue;\n        messages.push(`${msg.role}: ${text}`);\n      } catch {\n        // skip malformed lines silently\n      }\n    }\n    return messages.slice(-messageCount).join(\"\\n\");\n  } catch {\n    return \"\";\n  }\n}\n\n// ─── LLM Generation ──────────────────────────────────────────────────────────\n\n/**\n * @param {string} sessionContent\n * @returns {string}\n */\nfunction buildSummaryPrompt(sessionContent) {\n  return `你是一个会话摘要生成器。\n给定以下对话记录，生成一个结构化摘要。\n\n要求：\n- 主题：一句话概括本次对话主题（少于20字）\n- 关键决策：列出做出的所有决策，如果没有则写\"无明确决策\""}],"details":{"status":"completed","exitCode":0,"durationMs":62,"aggregated":"* @param {number} [messageCount=40]\n * @returns {Promise<string>}\n */\nasync function extractMessages(filePath, messageCount = 40) {\n  try {\n    const content = await fs.promises.readFile(filePath, \"utf-8\");\n    // 读取双倍行数以防 JSONL 格式行数波动\n    const lines = content.trim().split(\"\\n\").slice(-messageCount * 2);\n    /** @type {string[]} */\n    const messages = [];\n\n    for (const line of lines) {\n      if (!line.trim()) continue;\n      try {\n        /** @type {{ type: string, message?: { role: string, content: unknown } }} */\n        const entry = JSON.parse(line);\n        if (entry.type !== \"message\") continue;\n        const msg = entry.message;\n        if (!msg?.role || !msg?.content) continue;\n        if (msg.role !== \"user\" && msg.role !== \"assistant\") continue;\n\n        const text =\n          typeof msg.content === \"string\"\n            ? msg.content\n            : extractTextFromBlocks(msg.content);\n\n        if (!text || text.startsWith(\"/\")) continue;\n        messages.push(`${msg.role}: ${text}`);\n      } catch {\n        // skip malformed lines silently\n      }\n    }\n    return messages.slice(-messageCount).join(\"\\n\");\n  } catch {\n    return \"\";\n  }\n}\n\n// ─── LLM Generation ──────────────────────────────────────────────────────────\n\n/**\n * @param {string} sessionContent\n * @returns {string}\n */\nfunction buildSummaryPrompt(sessionContent) {\n  return `你是一个会话摘要生成器。\n给定以下对话记录，生成一个结构化摘要。\n\n要求：\n- 主题：一句话概括本次对话主题（少于20字）\n- 关键决策：列出做出的所有决策，如果没有则写\"无明确决策\"","cwd":"/home/ai/.openclaw/workspace/main"},"isError":false,"timestamp":1776058899258}}
{"type":"message","id":"97d125ce","parentId":"3db9b222","timestamp":"2026-04-13T05:41:46.203Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I have a full picture. I need to:\n\n1. Add a function `readEphemeralEntries(sessionKey)` that reads ephemeral files and filters by sessionKey\n2. Modify `buildSummaryPrompt` to include ephemeral entries and ask for entity升格\n3. Modify `writeSummaryFile` or add a new `writeEntityFiles` function\n4. Modify `run` to call the ephemeral reading and pass to LLM\n\nLet me write the updated session-summary handler. I'll read the full file first to make sure I get all the pieces right.","thinkingSignature":"b3942d2574b6ccc3534f810dc42aa4239d0e55fdd9924dd33f974a0e830907f1"},{"type":"toolCall","id":"call_function_os8htwv9pg87_1","name":"exec","arguments":{"command":"sed -n '1,79p' ~/.openclaw/hooks/session-summary/handler.js"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":85174,"output":160,"cacheRead":18037,"cacheWrite":0,"totalTokens":103371,"cost":{"input":0.025552199999999997,"output":0.000192,"cacheRead":0.0010822199999999998,"cacheWrite":0,"total":0.026826419999999997}},"stopReason":"toolUse","timestamp":1776058899272,"responseId":"062bb512fbe8600d0853c479e44e5142"}}
{"type":"message","id":"0d29e9cc","parentId":"97d125ce","timestamp":"2026-04-13T05:41:46.299Z","message":{"role":"toolResult","toolCallId":"call_function_os8htwv9pg87_1","toolName":"exec","content":[{"type":"text","text":"/**\n * session-summary hook\n *\n * 触发时机: /new 或 /reset\n * 行为: 读取上一个 session 的内容，调 LLM 生成结构化摘要，写入 memory/\n * 降级: LLM 失败时写规则摘要，不报错\n */\n\nimport fs from \"node:fs\";\nimport path from \"node:path\";\nimport os from \"node:os\";\nimport http from \"node:http\";\n\n// ─── Constants ────────────────────────────────────────────────────────────────\n\nconst MEMORY_DIR = path.join(\n  process.env.OPENCLAW_WORKSPACE_DIR ||\n    path.join(os.homedir(), \".openclaw\", \"workspace\"),\n  \"memory\"\n);\nconst LLM_TIMEOUT_MS = 20_000;\n\n// ─── Types (JSDoc) ─────────────────────────────────────────────────────────\n\n/**\n * @typedef {Object} SessionEntry\n * @property {string} [sessionFile]\n * @property {string} [sessionId]\n */\n\n/**\n * @typedef {Object} HookContext\n * @property {SessionEntry} [previousSessionEntry]\n * @property {SessionEntry} [sessionEntry]\n */\n\n// ─── Session File Resolution ──────────────────────────────────────────────────\n\n/**\n * 从 context 中提取 session 文件路径。\n * 优先使用 previousSessionEntry（旧 session，即刚结束的那个）。\n * @param {HookContext} context\n * @returns {string|null}\n */\nfunction resolveSessionFile(context) {\n  const prev = context?.previousSessionEntry;\n  if (prev?.sessionFile) return prev.sessionFile;\n\n  const curr = context?.sessionEntry;\n  if (curr?.sessionFile) return curr.sessionFile;\n\n  return null;\n}\n\n// ─── Message Extraction ──────────────────────────────────────────────────────\n\n/**\n * @param {unknown} content\n * @returns {string}\n */\nfunction extractTextFromBlocks(content) {\n  if (Array.isArray(content)) {\n    for (const block of content) {\n      if (\n        block &&\n        typeof block === \"object\" &&\n        block.type === \"text\" &&\n        typeof block.text === \"string\"\n      ) {\n        return block.text;\n      }\n    }\n  }\n  return \"\";\n}\n\n/**\n * 从 .jsonl 文件中提取最新 N 条 user/assistant 消息。\n * @param {string} filePath"}],"details":{"status":"completed","exitCode":0,"durationMs":62,"aggregated":"/**\n * session-summary hook\n *\n * 触发时机: /new 或 /reset\n * 行为: 读取上一个 session 的内容，调 LLM 生成结构化摘要，写入 memory/\n * 降级: LLM 失败时写规则摘要，不报错\n */\n\nimport fs from \"node:fs\";\nimport path from \"node:path\";\nimport os from \"node:os\";\nimport http from \"node:http\";\n\n// ─── Constants ────────────────────────────────────────────────────────────────\n\nconst MEMORY_DIR = path.join(\n  process.env.OPENCLAW_WORKSPACE_DIR ||\n    path.join(os.homedir(), \".openclaw\", \"workspace\"),\n  \"memory\"\n);\nconst LLM_TIMEOUT_MS = 20_000;\n\n// ─── Types (JSDoc) ─────────────────────────────────────────────────────────\n\n/**\n * @typedef {Object} SessionEntry\n * @property {string} [sessionFile]\n * @property {string} [sessionId]\n */\n\n/**\n * @typedef {Object} HookContext\n * @property {SessionEntry} [previousSessionEntry]\n * @property {SessionEntry} [sessionEntry]\n */\n\n// ─── Session File Resolution ──────────────────────────────────────────────────\n\n/**\n * 从 context 中提取 session 文件路径。\n * 优先使用 previousSessionEntry（旧 session，即刚结束的那个）。\n * @param {HookContext} context\n * @returns {string|null}\n */\nfunction resolveSessionFile(context) {\n  const prev = context?.previousSessionEntry;\n  if (prev?.sessionFile) return prev.sessionFile;\n\n  const curr = context?.sessionEntry;\n  if (curr?.sessionFile) return curr.sessionFile;\n\n  return null;\n}\n\n// ─── Message Extraction ──────────────────────────────────────────────────────\n\n/**\n * @param {unknown} content\n * @returns {string}\n */\nfunction extractTextFromBlocks(content) {\n  if (Array.isArray(content)) {\n    for (const block of content) {\n      if (\n        block &&\n        typeof block === \"object\" &&\n        block.type === \"text\" &&\n        typeof block.text === \"string\"\n      ) {\n        return block.text;\n      }\n    }\n  }\n  return \"\";\n}\n\n/**\n * 从 .jsonl 文件中提取最新 N 条 user/assistant 消息。\n * @param {string} filePath","cwd":"/home/ai/.openclaw/workspace/main"},"isError":false,"timestamp":1776058906291}}
{"type":"message","id":"74f619bf","parentId":"0d29e9cc","timestamp":"2026-04-13T05:43:16.701Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I have the full picture. Let me write the complete updated session-summary handler that includes ephemeral reading and entity升格. I'll make these key changes:\n\n1. Add `EPHEMERAL_DIR` constant\n2. Add `readEphemeralEntries(sessionKey)` function\n3. Modify `buildSummaryPrompt` to include ephemeral entries and ask for entity升格4. Add `writeEntityFile(name, content)` function\n5. Modify `run()` to read ephemeral and handle entity升格\n\nThe LLM prompt needs to ask for entity升格 decisions. The output format should be something like:\n```\n## 摘要\n{summary content}\n\n## entities_to_write\nENTITY: name: xxx, action: create|update, file: xxx, content: xxx\nENTITY: ...\n\n\n```\n\nOr I could have the LLM output JSON. Let me use a structured format where the LLM outputs the summary plus entity actions. Now I'll write the complete updated file.","thinkingSignature":"d14cd5130e481d84e45da48d640ef51227659b80c68556eee53a745aa7cdfe2c"},{"type":"toolCall","id":"call_function_kwokqgjapxuw_1","name":"write","arguments":{"content":"/**\n * session-summary hook\n *\n * 触发时机: /new 或 /reset\n * 行为: \n *   1. 读取上一个 session 的内容\n *   2. 读取 ephemeral/ 中的记忆碎片\n *   3. 调 LLM 生成结构化摘要 + entity 升格决策\n *   4. 写入 memory/YYYY-MM-DD-summary.md\n *   5. 执行 entity 升格（创建/更新 memory/entities/*.md）\n * 降级: LLM 失败时写规则摘要，不报错\n */\n\nimport fs from \"node:fs\";\nimport path from \"node:path\";\nimport os from \"node:os\";\nimport http from \"node:http\";\n\n// ─── Constants ────────────────────────────────────────────────────────────────\n\nconst MEMORY_DIR = path.join(\n  process.env.OPENCLAW_WORKSPACE_DIR ||\n    path.join(os.homedir(), \".openclaw\", \"workspace\"),\n  \"memory\"\n);\nconst EPHEMERAL_DIR = path.join(MEMORY_DIR, \"ephemeral\");\nconst ENTITIES_DIR = path.join(MEMORY_DIR, \"entities\");\nconst LLM_TIMEOUT_MS = 20_000;\n\n// ─── Types (JSDoc) ─────────────────────────────────────────────────────────\n\n/**\n * @typedef {Object} SessionEntry\n * @property {string} [sessionFile]\n * @property {string} [sessionId]\n */\n\n/**\n * @typedef {Object} HookContext\n * @property {SessionEntry} [previousSessionEntry]\n * @property {SessionEntry} [sessionEntry]\n */\n\n/**\n * @typedef {Object} EphemeralEntry\n * @property {string} timestamp\n * @property {string} sessionKey\n * @property {string} text\n * @property {string} textPreview\n * @property {object} classification\n * @property {object} scoring\n */\n\n// ─── Session File Resolution ──────────────────────────────────────────────────\n\n/**\n * 从 context 中提取 session 文件路径。\n * 优先使用 previousSessionEntry（旧 session，即刚结束的那个）。\n * @param {HookContext} context\n * @returns {string|null}\n */\nfunction resolveSessionFile(context) {\n  const prev = context?.previousSessionEntry;\n  if (prev?.sessionFile) return prev.sessionFile;\n\n  const curr = context?.sessionEntry;\n  if (curr?.sessionFile) return curr.sessionFile;\n\n  return null;\n}\n\n// ─── Message Extraction ──────────────────────────────────────────────────────\n\n/**\n * @param {unknown} content\n * @returns {string}\n */\nfunction extractTextFromBlocks(content) {\n  if (Array.isArray(content)) {\n    for (const block of content) {\n      if (\n        block &&\n        typeof block === \"object\" &&\n        block.type === \"text\" &&\n        typeof block.text === \"string\"\n      ) {\n        return block.text;\n      }\n    }\n  }\n  return \"\";\n}\n\n/**\n * 从 .jsonl 文件中提取最新 N 条 user/assistant 消息。\n * @param {string} filePath\n * @param {number} [messageCount=40]\n * @returns {Promise<string>}\n */\nasync function extractMessages(filePath, messageCount = 40) {\n  try {\n    const content = await fs.promises.readFile(filePath, \"utf-8\");\n    const lines = content.trim().split(\"\\n\").slice(-messageCount * 2);\n    /** @type {string[]} */\n    const messages = [];\n\n    for (const line of lines) {\n      if (!line.trim()) continue;\n      try {\n        /** @type {{ type: string, message?: { role: string, content: unknown } }} */\n        const entry = JSON.parse(line);\n        if (entry.type !== \"message\") continue;\n        const msg = entry.message;\n        if (!msg?.role || !msg?.content) continue;\n        if (msg.role !== \"user\" && msg.role !== \"assistant\") continue;\n\n        const text =\n          typeof msg.content === \"string\"\n            ? msg.content\n            : extractTextFromBlocks(msg.content);\n\n        if (!text || text.startsWith(\"/\")) continue;\n        messages.push(`${msg.role}: ${text}`);\n      } catch {\n        // skip malformed lines silently\n      }\n    }\n    return messages.slice(-messageCount).join(\"\\n\");\n  } catch {\n    return \"\";\n  }\n}\n\n// ─── Ephemeral Memory Reading ─────────────────────────────────────────────────\n\n/**\n * 读取当天的 ephemeral 文件，按 sessionKey 过滤。\n * @param {string} sessionKey\n * @returns {Promise<{entries: EphemeralEntry[], preview: string}>}\n */\nasync function readEphemeralEntries(sessionKey) {\n  /** @type {EphemeralEntry[]} */\n  const allEntries = [];\n  \n  try {\n    const today = new Date().toISOString().slice(0, 10); // YYYY-MM-DD\n    const files = await fs.promises.readdir(EPHEMERAL_DIR);\n    \n    for (const file of files) {\n      if (!file.endsWith('.jsonl') || !file.startsWith(today)) continue;\n      const filePath = path.join(EPHEMERAL_DIR, file);\n      try {\n        const content = await fs.promises.readFile(filePath, 'utf-8');\n        const lines = content.trim().split('\\n');\n        for (const line of lines) {\n          if (!line.trim()) continue;\n          try {\n            const entry = JSON.parse(line);\n            if (entry.sessionKey === sessionKey) {\n              allEntries.push(entry);\n            }\n          } catch { /* skip */ }\n        }\n      } catch { /* skip file errors */ }\n    }\n  } catch { /* ephemeral dir may not exist */ }\n  \n  // 去重（相同 text 的条目只保留最新）\n  const seen = new Set();\n  const uniqueEntries = allEntries.filter(e => {\n    const key = e.text.slice(0, 100);\n    if (seen.has(key)) return false;\n    seen.add(key);\n    return true;\n  });\n  \n  // 限制最多 20 条，防止 token 爆炸\n  const entries = uniqueEntries.slice(-20);\n  \n  // 生成预览文本\n  const preview = entries.length > 0\n    ? entries.map(e => `[${e.classification?.scene || '?'}] score=${e.scoring?.score || 0} \"${e.textPreview || e.text.slice(0, 80)}\"`).join('\\n')\n    : '';\n  \n  return { entries, preview };\n}\n\n// ─── LLM Generation ────────────────────────────────────────────────────────────\n\n/**\n * @param {string} sessionContent\n * @param {string} ephemeralPreview\n * @returns {string}\n */\nfunction buildSummaryPrompt(sessionContent, ephemeralPreview) {\n  return `你是一个会话摘要生成器，同时负责记忆升格决策。\n\n给定以下对话记录和实时捕获的记忆碎片，生成：\n1. 一个结构化摘要\n2. 需要升格为 entity 页的记忆条目（只有真正重要的、涉及系统/项目/偏好的才升格）\n\n## 对话记录：\n${sessionContent || \"(无会话内容)\"}\n\n## 记忆碎片（来自 ephemeral/，按 sessionKey 聚合）：\n${ephemeralPreview || \"(无碎片)\"}\n\n要求：\n- 主题：一句话概括，少于20字\n- 关键决策：列出所有决策，没有则写\"无明确决策\"\n- 重要发现：列出有价值的结论/教训，没有则写\"无\"\n- 待跟进：列出未完成事项，没有则写\"无\"\n\n## entity 升格决策：\n识别记忆碎片中值得创建或更新 entity 页的内容。只有以下类型才升格：\n- 系统组件状态变化（如：3104修好了、3103配置改了）\n- 用户偏好发现（如：喜欢中文、务实风格）\n- 项目进度更新（如：项目X现在做到哪了）\n- 关键结论或教训（如：方案A比方案B好，别再踩这个坑）\n\n格式（严格按此格式，摘要和entity分开）：\n---\n## 摘要\n## 主题\n{主题}\n\n## 关键决策\n{决策列表}\n\n## 重要发现\n{发现列表}\n\n## 待跟进\n{待办列表}\n\n## entities\n{如果需要升格，格式：ENTITY|create|entity-name|文件路径|第1行标题|正文内容（多行）\n如果没有entity需要升格，写：NONE\n示例：ENTITY|create|scene-classifier|memory/entities/scene-classifier.md|# Entity: scene-classifier|## 基本信息\\n- 状态: 已修复\\n## 更新\\n### 2026-04-13\\n修复了...}\n---`;\n}\n\n/**\n * @param {string} sessionContent\n * @returns {string}\n */\nfunction buildFallbackPrompt(sessionContent) {\n  return `你是一个会话摘要生成器。\n给定以下对话记录，生成一个结构化摘要。\n\n## 对话记录：\n${sessionContent}\n\n要求：\n- 主题：一句话概括，少于20字\n- 关键决策：列出所有决策，没有则写\"无明确决策\"\n- 重要发现：列出有价值的结论/教训，没有则写\"无\"\n- 待跟进：列出未完成事项，没有则写\"无\"\n\n格式（严格按此格式）：\n## 主题\n{主题}\n\n## 关键决策\n{决策列表}\n\n## 重要发现\n{发现列表}\n\n## 待跟进\n{待办列表}`;\n}\n\n/**\n * 调用 gateway LLM 接口生成摘要。\n * 超时 20s 后自动销毁请求并降级。\n * @param {string} sessionContent\n * @param {string} ephemeralPreview\n * @returns {Promise<{summary: string, entities: Array<{action:string,name:string,file:string,content:string}>}>}\n */\nasync function generateSummaryWithEntities(sessionContent, ephemeralPreview) {\n  const prompt = buildSummaryPrompt(sessionContent, ephemeralPreview);\n  \n  const postData = JSON.stringify({\n    model: \"minimax/MiniMax-M2.7\",\n    messages: [{ role: \"user\", content: prompt }],\n    temperature: 0.3,\n    max_tokens: 800,\n  });\n\n  return new Promise((resolve) => {\n    let settled = false;\n    const doResolve = (v) => {\n      if (settled) return;\n      settled = true;\n      resolve(v);\n    };\n\n    const req = http.request(\n      \"http://127.0.0.1:3102/v1/chat/completions\",\n      {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          \"Content-Length\": Buffer.byteLength(postData),\n        },\n      },\n      (res) => {\n        let data = \"\";\n        res.on(\"data\", (c) => (data += c));\n        res.on(\"end\", () => {\n          try {\n            const parsed = JSON.parse(data);\n            const text = parsed.choices?.[0]?.message?.content || \"\";\n            const result = parseLLMOutput(text.trim());\n            doResolve(result);\n          } catch {\n            doResolve(generateFallbackResult(sessionContent));\n          }\n        });\n      }\n    );\n\n    req.on(\"error\", () => doResolve(generateFallbackResult(sessionContent)));\n\n    // 20s 单边超时\n    const timer = setTimeout(() => {\n      try { req.destroy(); } catch { /* noop */ }\n      doResolve(generateFallbackResult(sessionContent));\n    }, LLM_TIMEOUT_MS);\n\n    req.on(\"close\", () => clearTimeout(timer));\n\n    req.write(postData);\n    req.end();\n  });\n}\n\n/**\n * 解析 LLM 输出，提取摘要和 entity 升格指令。\n * @param {string} text\n * @returns {{summary: string, entities: Array<{action:string,name:string,file:string,content:string}>}}\n */\nfunction parseLLMOutput(text) {\n  const entities = [];\n  \n  // 提取 entity 块\n  const entityMatch = text.match(/## entities\\n([\\s\\S]*?)(?:---|$)/);\n  const entityBlock = entityMatch ? entityMatch[1].trim() : '';\n  \n  if (entityBlock && entityBlock !== 'NONE') {\n    const lines = entityBlock.split('\\n');\n    for (const line of lines) {\n      const parts = line.split('|');\n      if (parts.length >= 5 && parts[0] === 'ENTITY') {\n        const action = parts[1].trim(); // create | update\n        const name = parts[2].trim();\n        const file = parts[3].trim();\n        const content = parts.slice(4).join('|').trim();\n        entities.push({ action, name, file, content });\n      }\n    }\n  }\n  \n  // 提取摘要部分\n  let summary = text.replace(/## entities\\n[\\s\\S]*?(?:---|$)/, '').trim();\n  // 去掉 ## 摘要 标记（如果LLM输出了）\n  summary = summary.replace(/^## 摘要\\s*/, '');\n  \n  return { summary: summary.trim(), entities };\n}\n\n/**\n * @param {string} sessionContent\n * @returns {{summary: string, entities: Array}}\n */\nfunction generateFallbackResult(sessionContent) {\n  const firstLine = (sessionContent.split(\"\\n\")[0] ?? \"\").slice(0, 60).replace(/[#*]/g, \"\").trim();\n  const summary = `# Session 摘要\n\n## 主题\n${firstLine || \"会话摘要\"}\n\n## 关键决策\n无\n\n## 重要发现\n无\n\n## 待跟进\n见原始对话记录\n`;\n  return { summary, entities: [] };\n}\n\n// ─── Entity Writing ───────────────────────────────────────────────────────────\n\n/**\n * @param {string} name\n * @param {string} content\n * @returns {Promise<void>}\n */\nasync function writeEntityFile(name, content) {\n  try {\n    await fs.promises.mkdir(ENTITIES_DIR, { recursive: true });\n    const filePath = path.join(ENTITIES_DIR, `${name}.md`);\n    const header = `# Entity: ${name}\\n\\n`;\n    await fs.promises.writeFile(filePath, header + content + '\\n', 'utf-8');\n    console.log(`[session-summary] Entity written: ${name}.md`);\n  } catch (e) {\n    console.error(`[session-summary] Entity write failed: ${name}`, e);\n  }\n}\n\n// ─── Fallback ────────────────────────────────────────────────────────────────\n\n/**\n * @param {string} content\n * @param {string} date\n * @param {string} time\n * @returns {string}\n */\nfunction buildFallbackSummary(content, date, time) {\n  const firstLine = (content.split(\"\\n\")[0] ?? \"\").slice(0, 60).replace(/[#*]/g, \"\").trim();\n  const preview = firstLine || \"会话摘要\";\n  return `# Session: ${date} ${time}\n\n## 主题\n${preview}\n\n## 关键决策\n无\n\n## 重要发现\n无\n\n## 待跟进\n见原始对话记录\n`;\n}\n\n// ─── File Writing ─────────────────────────────────────────────────────────────\n\n/**\n * @param {string} summary\n * @param {string} date\n * @param {string} time\n * @param {string} sessionKey\n * @returns {Promise<void>}\n */\nasync function writeSummaryFile(summary, date, time, sessionKey) {\n  const slug = slugFromSummary(summary, time);\n  const filename = `${date}-${slug}.md`;\n  const filePath = path.join(MEMORY_DIR, filename);\n\n  await fs.promises.mkdir(MEMORY_DIR, { recursive: true });\n\n  const fullContent = [\n    `# Session: ${date} ${time}`,\n    \"\",\n    \"<!-- summary-only -->\",\n    summary,\n    \"\",\n    `<!-- source: ${sessionKey} -->`,\n  ].join(\"\\n\");\n\n  await fs.promises.writeFile(filePath, fullContent, \"utf-8\");\n  console.log(`[session-summary] Written: ${filename}`);\n}\n\n/**\n * @param {string} summary\n * @param {string} time\n * @returns {string}\n */\nfunction slugFromSummary(summary, time) {\n  const match = summary.match(/^## 主题$\\s*([^\\n]+)/m);\n  if (!match) return time.replace(/:/g, \"\");\n\n  return match[1]\n    .toLowerCase()\n    .replace(/[^a-z0-9\\u4e00-\\u9fff]+/g, \"-\")\n    .replace(/^-+|-+$/g, \"\")\n    .slice(0, 40) || time.replace(/:/g, \"\");\n}\n\n// ─── Core ─────────────────────────────────────────────────────────────────────\n\n/**\n * @param {{ type: string, action: string, sessionKey: string, context: HookContext, messages: unknown[] }} event\n */\nasync function run(event) {\n  const isTarget = event.type === \"command\" && (event.action === \"new\" || event.action === \"reset\");\n  if (!isTarget) return;\n\n  const now = new Date();\n  const date = now.toISOString().split(\"T\")[0];\n  const time = now.toISOString().split(\"T\")[1].split(\".\")[0].slice(0, 5);\n\n  // 1. 解析 session 文件路径（优先 previousSessionEntry）\n  const sessionFile = resolveSessionFile(event.context || {});\n\n  // 2. 读取消息内容\n  const content = sessionFile ? await extractMessages(sessionFile) : \"\";\n\n  // 3. 读取 ephemeral 记忆碎片\n  const previousSessionKey = event.context?.previousSessionEntry?.sessionFile\n    ? path.basename(event.context.previousSessionEntry.sessionFile, '.jsonl')\n    : event.sessionKey;\n  const { entries, preview: ephemeralPreview } = await readEphemeralEntries(previousSessionKey);\n\n  // 4. 生成摘要 + entity 升格（失败则降级）\n  const { summary, entities } = content.trim().length > 50\n    ? await generateSummaryWithEntities(content, ephemeralPreview)\n    : { summary: buildFallbackSummary(content || \"(无会话内容)\", date, time), entities: [] };\n\n  // 5. 写入 memory/（后台，不等待）\n  writeSummaryFile(summary, date, time, event.sessionKey).catch((err) => {\n    console.error(\"[session-summary] Write error:\", err);\n  });\n\n  // 6. 执行 entity 升格（后台，不等待）\n  for (const entity of entities) {\n    if (entity.action === 'create' || entity.action === 'update') {\n      writeEntityFile(entity.name, entity.content).catch((err) => {\n        console.error(\"[session-summary] Entity write error:\", err);\n      });\n    }\n  }\n}\n\n// ─── Entry Point ─────────────────────────────────────────────────────────────\n\nexport default function handler(event) {\n  run(event).catch((err) => {\n    console.error(\"[session-summary] Uncaught error:\", err);\n  });\n}\n","path":"/home/ai/.openclaw/hooks/session-summary/handler.js"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":85814,"output":4225,"cacheRead":18037,"cacheWrite":0,"totalTokens":108076,"cost":{"input":0.0257442,"output":0.00507,"cacheRead":0.0010822199999999998,"cacheWrite":0,"total":0.03189642}},"stopReason":"toolUse","timestamp":1776058906303,"responseId":"062bb519c7419b1e8c6a1a887885e945"}}
