────┐  ┌─────────┐\"\necho \"    │ DIRECT  │   │ STEP_   │                    │ PARALLEL │  │ MEGA_   │\"\necho \"    │  ≤20分  │   │ARCHIVE  │                    │ _SHARDS  │  │ TASK    │\"\necho \"    │  30s   │   │ 21-40分 │                    │ 61-80分  │  │ >80分   │\"\necho \"    │         │   │  60s   │                    │ 120-160s │  │ 7200s   │\"\necho \"    └─────────┘   └─────────┘                    └──────────┘  └─────────┘\"\necho \"\"\necho \"━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\"\necho \"                              二、核心组件\"\necho \"━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\"\necho \"\"\necho \"┌─────────────────┬──────────────────────────────────────────────────────────┐\"\necho \"│ 组件            │ 功能                                                      │\"\necho \"├─────────────────┼──────────────────────────────────────────────────────────┤\"\necho \"│ v8_classifier   │ 场景分类: task_multi_step, fault_recovery, chitchat...   │\"\necho \"│ v8_scorer       │ 6因子评分: logic, risk, duration, resource, uncertainty  │\"\necho \"│ Router (3102)   │ 任务路由, 反向代理                                        │\"\necho \"│ Context API     │ 上下文管理 (3101)                                         │\"\necho \"│ Classifier API  │ 分类服务 (3104)                                           │\"\necho \"│ Scorer API      │ 评分服务 (3103)                                           │\"\necho \"│ Gateway         │ 网关服务 (18789)                                          │\"\necho \"└─────────────────┴──────────────────────────────────────────────────────────┘\"\necho \"\"\necho \"━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\"\necho \"                              三、安全分层 (SOUL.md)\"\necho \"━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\"\necho \"\"\necho \"┌─────────────────┬──────────────────────────────────────────────────────────┐\"\necho \"│ 层级            │ 职责                                                      │\"\necho \"├─────────────────┼──────────────────────────────────────────────────────────┤\"\necho \"│ 系统层          │ 硬拦截: CRITICAL拒绝、高危检测、任务状态注入               │\"\necho \"│ 模型层          │ 软约束: 风格适配、歧义澄清、风险警告                       │\"\necho \"└─────────────────┴──────────────────────────────────────────────────────────┘\"\necho \"\"\necho \"┌─────────────────┬──────────────────────────────────────────────────────────┐\"\necho \"│ 风险等级        │ 定义                                                      │\"\necho \"├─────────────────┼──────────────────────────────────────────────────────────┤\"\necho \"│ LOW             │ 纯信息查询，无副作用                                      │\"\necho \"│ MEDIUM          │ 产出代码或配置                                            │\"\necho \"│ HIGH            │ 可能导致服务中断/数据丢失，有回滚                         │\"\necho \"│ CRITICAL        │ 不可逆破坏、安全崩塌、涉及他人权益 (系统层直接拒绝)        │\"\necho \"└─────────────────┴──────────────────────────────────────────────────────────┘\"\necho \"\"\necho \"━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\"\necho \"                              四、执行策略\"\necho \"━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\"\necho \"\"\necho \"│ 分数   │ 策略            │ 超时   │ 内存      │\"\necho \"│--------│-----------------│--------│-----------│\"\necho \"│ ≤20    │ DIRECT          │ 30s    │ -         │\"\necho \"│ 21-40  │ STEP_ARCHIVE    │ 60s    │ 1024MB    │\"\necho \"│ 41-60  │ SPAWN_SUBAGENT  │ 180s   │ 2048MB    │\"\necho \"│ 61-80  │ PARALLEL_SHARDS │ 160s   │ 2048MB    │\"\necho \"│ >80    │ MEGA_TASK       │ 7200s  │ 8192MB    │\"\necho \"\"\necho \"━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\"\necho \"                              五、子代理机制\"\necho \"━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\"\necho \"\"\necho \"  进度格式: [PROGRESS] <percent>% | <step>/<total> | <description>\"\necho \"\"\necho \"  心跳规则: 30s无输出→提示 | 60s无产出→警告 | 超时前5s→警告\"\necho \"\"\necho \"  子代理类型: runtime=subagent / runtime=acp\"\necho \"\"\necho \"━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\"\necho \"                              六、Skills (29个)\"\necho \"━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\"\necho \"\"\necho \"  核心: task_orchestrator, v8_classifier, v8_scorer, proactivity, self-improving\"\necho \"  工具: multi-search-engine, github-manager, vercel-deploy\"\necho \"  飞书: feishu-doc, feishu-drive, feishu-wiki, feishu-perm\"\necho \"  编码: coding-agent, superpowers, skill-creator\"\necho \"\"\necho \"━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\"\necho \"                              七、LLM Wiki 知识库\"\necho \"━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\"\necho \"\"\necho \"  核心页面: 31个\"\necho \"  脚本: auto-lint.sh (自动维护)\"\necho \"  规则: 融合优先，30上限，绝不偷懒\"\necho \"\"\necho \"  流程: Ingest → Think → Write-back → Query → Lint\"\necho \"\"\necho \"╚════════════════════════════════════════════════════════════════════════════╝\""}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":113104,"output":1494,"cacheRead":0,"cacheWrite":0,"totalTokens":114598,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775909334981,"responseId":"chatcmpl-b8e2ea3f-250f-452e-baf2-60efd6b8d273"}}
{"type":"message","id":"70f8b18d","parentId":"0e4b2f76","timestamp":"2026-04-11T12:09:18.083Z","message":{"role":"toolResult","toolCallId":"call_2c7ea30692184758a5465d10","toolName":"exec","content":[{"type":"text","text":"╔════════════════════════════════════════════════════════════════════════════╗\n║                         OpenClaw 完整框架                                  ║\n╚════════════════════════════════════════════════════════════════════════════╝\n\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n                              一、整体架构\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n                    ┌─────────────────────────────────────┐\n                    │           用户消息入口              │\n                    └─────────────────┬───────────────────┘\n                                      ↓\n                    ┌─────────────────────────────────────┐\n                    │         v8_classifier              │\n                    │      (场景分类: 9种场景)            │\n                    └─────────────────┬───────────────────┘\n                                      ↓\n                    ┌─────────────────────────────────────┐\n                    │          v8_scorer                 │\n                    │      (6因子评分: 0-100分)           │\n                    └─────────────────┬───────────────────┘\n                                      ↓\n         ┌──────────────┬──────────────┴───────────────┬──────────────┐\n         ↓              ↓                               ↓              ↓\n    ┌─────────┐   ┌─────────┐                    ┌──────────┐  ┌─────────┐\n    │ DIRECT  │   │ STEP_   │                    │ PARALLEL │  │ MEGA_   │\n    │  ≤20分  │   │ARCHIVE  │                    │ _SHARDS  │  │ TASK    │\n    │  30s   │   │ 21-40分 │                    │ 61-80分  │  │ >80分   │\n    │         │   │  60s   │                    │ 120-160s │  │ 7200s   │\n    └─────────┘   └─────────┘                    └──────────┘  └─────────┘\n\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n                              二、核心组件\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n┌─────────────────┬──────────────────────────────────────────────────────────┐\n│ 组件            │ 功能                                                      │\n├─────────────────┼──────────────────────────────────────────────────────────┤\n│ v8_classifier   │ 场景分类: task_multi_step, fault_recovery, chitchat...   │\n│ v8_scorer       │ 6因子评分: logic, risk, duration, resource, uncertainty  │\n│ Router (3102)   │ 任务路由, 反向代理                                        │\n│ Context API     │ 上下文管理 (3101)                                         │\n│ Classifier API  │ 分类服务 (3104)                                           │\n│ Scorer API      │ 评分服务 (3103)                                           │\n│ Gateway         │ 网关服务 (18789)                                          │\n└─────────────────┴──────────────────────────────────────────────────────────┘\n\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n                              三、安全分层 (SOUL.md)\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n┌─────────────────┬──────────────────────────────────────────────────────────┐\n│ 层级            │ 职责                                                      │\n├─────────────────┼──────────────────────────────────────────────────────────┤\n│ 系统层          │ 硬拦截: CRITICAL拒绝、高危检测、任务状态注入               │\n│ 模型层          │ 软约束: 风格适配、歧义澄清、风险警告                       │\n└─────────────────┴──────────────────────────────────────────────────────────┘\n\n┌─────────────────┬──────────────────────────────────────────────────────────┐\n│ 风险等级        │ 定义                                                      │\n├─────────────────┼──────────────────────────────────────────────────────────┤\n│ LOW             │ 纯信息查询，无副作用                                      │\n│ MEDIUM          │ 产出代码或配置                                            │\n│ HIGH            │ 可能导致服务中断/数据丢失，有回滚                         │\n│ CRITICAL        │ 不可逆破坏、安全崩塌、涉及他人权益 (系统层直接拒绝)        │\n└─────────────────┴──────────────────────────────────────────────────────────┘\n\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n                              四、执行策略\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n│ 分数   │ 策略            │ 超时   │ 内存      │\n│--------│-----------------│--------│-----------│\n│ ≤20    │ DIRECT          │ 30s    │ -         │\n│ 21-40  │ STEP_ARCHIVE    │ 60s    │ 1024MB    │\n│ 41-60  │ SPAWN_SUBAGENT  │ 180s   │ 2048MB    │\n│ 61-80  │ PARALLEL_SHARDS │ 160s   │ 2048MB    │\n│ >80    │ MEGA_TASK       │ 7200s  │ 8192MB    │\n\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n                              五、子代理机制\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n  进度格式: [PROGRESS] <percent>% | <step>/<total> | <description>\n\n  心跳规则: 30s无输出→提示 | 60s无产出→警告 | 超时前5s→警告\n\n  子代理类型: runtime=subagent / runtime=acp\n\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n                              六、Skills (29个)\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n  核心: task_orchestrator, v8_classifier, v8_scorer, proactivity, self-improving\n  工具: multi-search-engine, github-manager, vercel-deploy\n  飞书: feishu-doc, feishu-drive, feishu-wiki, feishu-perm\n  编码: coding-agent, superpowers, skill-creator\n\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n                              七、LLM Wiki 知识库\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n  核心页面: 31个\n  脚本: auto-lint.sh (自动维护)\n  规则: 融合优先，30上限，绝不偷懒\n\n  流程: Ingest → Think → Write-back → Query → Lint\n\n╚════════════════════════════════════════════════════════════════════════════╝"}],"details":{"status":"completed","exitCode":0,"durationMs":65,"aggregated":"╔════════════════════════════════════════════════════════════════════════════╗\n║                         OpenClaw 完整框架                                  ║\n╚════════════════════════════════════════════════════════════════════════════╝\n\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n                              一、整体架构\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n                    ┌─────────────────────────────────────┐\n                    │           用户消息入口              │\n                    └─────────────────┬───────────────────┘\n                                      ↓\n                    ┌─────────────────────────────────────┐\n                    │         v8_classifier              │\n                    │      (场景分类: 9种场景)            │\n                    └─────────────────┬───────────────────┘\n                                      ↓\n                    ┌─────────────────────────────────────┐\n                    │          v8_scorer                 │\n                    │      (6因子评分: 0-100分)           │\n                    └─────────────────┬───────────────────┘\n                                      ↓\n         ┌──────────────┬──────────────┴───────────────┬──────────────┐\n         ↓              ↓                               ↓              ↓\n    ┌─────────┐   ┌─────────┐                    ┌──────────┐  ┌─────────┐\n    │ DIRECT  │   │ STEP_   │                    │ PARALLEL │  │ MEGA_   │\n    │  ≤20分  │   │ARCHIVE  │                    │ _SHARDS  │  │ TASK    │\n    │  30s   │   │ 21-40分 │                    │ 61-80分  │  │ >80分   │\n    │         │   │  60s   │                    │ 120-160s │  │ 7200s   │\n    └─────────┘   └─────────┘                    └──────────┘  └─────────┘\n\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━