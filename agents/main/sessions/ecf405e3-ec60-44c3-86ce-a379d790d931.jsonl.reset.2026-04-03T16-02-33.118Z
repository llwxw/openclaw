{"type":"message","id":"cdb600f6","parentId":"188d68d4","timestamp":"2026-04-03T15:09:14.176Z","message":{"role":"assistant","content":[{"type":"text","text":"让我创建一个更直接的测试："},{"type":"toolCall","id":"call_00_k8D9NR7DlN8HLNKCKVZn2ZuS","name":"write","arguments":{"path":"/mnt/d/cod/test_codingplan.py","content":"#!/usr/bin/env python3\n\"\"\"\nCodingPlan模型测试脚本\n测试模型的基本功能和编码能力\n\"\"\"\n\nimport subprocess\nimport json\nimport time\n\ndef test_codingplan_api():\n    \"\"\"测试CodingPlan API\"\"\"\n    print(\"=\" * 60)\n    print(\"CodingPlan模型测试\")\n    print(\"=\" * 60)\n    \n    # 测试1：简单问候\n    print(\"\\n1. 简单问候测试:\")\n    test_simple_greeting()\n    \n    # 测试2：编码任务\n    print(\"\\n2. 编码能力测试:\")\n    test_coding_ability()\n    \n    # 测试3：中文理解\n    print(\"\\n3. 中文理解测试:\")\n    test_chinese_understanding()\n\ndef test_simple_greeting():\n    \"\"\"测试简单问候\"\"\"\n    payload = {\n        \"model\": \"minimax-m2.5\",\n        \"messages\": [{\"role\": \"user\", \"content\": \"Hello! Say hi and tell me what you can do.\"}],\n        \"max_tokens\": 150\n    }\n    \n    result = call_api(payload)\n    if result:\n        content = result.get('choices', [{}])[0].get('message', {}).get('content', '')\n        reasoning = result.get('choices', [{}])[0].get('message', {}).get('reasoning_content', '')\n        print(f\"响应: {content[:100]}...\" if content else f\"推理: {reasoning[:100]}...\")\n\ndef test_coding_ability():\n    \"\"\"测试编码能力\"\"\"\n    payload = {\n        \"model\": \"minimax-m2.5\",\n        \"messages\": [{\"role\": \"user\", \"content\": \"Write a Python function to calculate factorial.\"}],\n        \"max_tokens\": 200\n    }\n    \n    result = call_api(payload)\n    if result:\n        content = result.get('choices', [{}])[0].get('message', {}).get('content', '')\n        print(f\"代码响应: {content[:150]}...\")\n\ndef test_chinese_understanding():\n    \"\"\"测试中文理解\"\"\"\n    payload = {\n        \"model\": \"minimax-m2.5\",\n        \"messages\": [{\"role\": \"user\", \"content\": \"用中文解释什么是递归，并给出一个简单的Python示例。\"}],\n        \"max_tokens\": 250\n    }\n    \n    result = call_api(payload)\n    if result:\n        content = result.get('choices', [{}])[0].get('message', {}).get('content', '')\n        reasoning = result.get('choices', [{}])[0].get('message', {}).get('reasoning_content', '')\n        print(f\"中文响应: {content[:120]}...\" if content else f\"中文推理: {reasoning[:120]}...\")\n\ndef call_api(payload):\n    \"\"\"调用CodingPlan API\"\"\"\n    api_key = \"J99ouXWKXO8Zg5tLqv92YVsPNFhwuZc-z6z2ioeg7VE\"\n    url = \"https://zhenze-huhehaote.cmecloud.cn/api/coding/v1/chat/completions\"\n    \n    curl_cmd = [\n        \"curl\", \"-s\", \"-X\", \"POST\", url,\n        \"-H\", \"Content-Type: application/json\",\n        \"-H\", f\"Authorization: Bearer {api_key}\",\n        \"-d\", json.dumps(payload),\n        \"--max-time\", \"10\"\n    ]\n    \n    try:\n        result = subprocess.run(curl_cmd, capture_output=True, text=True, timeout=15)\n        if result.returncode == 0:\n            return json.loads(result.stdout)\n        else:\n            print(f\"API调用失败: {result.stderr}\")\n            return None\n    except Exception as e:\n        print(f\"API调用异常: {e}\")\n        return None\n\nif __name__ == \"__main__\":\n    test_codingplan_api()"}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-chat","usage":{"input":32008,"output":926,"cacheRead":18816,"cacheWrite":0,"totalTokens":51750,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775228917830,"responseId":"7b52d255-36d7-4304-893e-cacf82984a86"}}
