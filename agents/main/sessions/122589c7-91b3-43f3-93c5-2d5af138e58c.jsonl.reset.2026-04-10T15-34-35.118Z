{"type":"message","id":"988437e9","parentId":"1ba7a348","timestamp":"2026-04-10T06:42:14.694Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在开始创建缺失的模块文件。\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"call_4f7ea73545984d35a711a368","name":"write","arguments":{"path":"/home/ai/.openclaw/v8/src/scoring/rule-tuner.js","content":"#!/usr/bin/env node\n/**\n * rule-tuner.js - 评分规则自动调优工具\n * 基于历史任务数据自动调整策略阈值\n * \n * 使用: node rule-tuner.js --config config/tuner.yaml --output tuning_report.json\n */\n\nconst fs = require('fs');\nconst path = require('path');\nconst Database = require('better-sqlite3');\n\nconst DEFAULT_CONFIG = {\n  data_source: './data/tasks.db',\n  min_samples: 50,\n  adjustments: {\n    timeout_factor: 1.2,\n    threshold_shift: 5\n  },\n  strategies: {\n    DIRECT: { max_score: 20 },\n    STEP_ARCHIVE: { max_score: 40 },\n    SPAWN_SUBAGENT: { max_score: 60 },\n    PARALLEL_SHARDS: { max_score: 80 }\n  }\n};\n\nfunction parseArgs() {\n  const args = process.argv.slice(2);\n  const config = { ...DEFAULT_CONFIG };\n  let outputFile = 'tuning_report.json';\n  \n  for (let i = 0; i < args.length; i++) {\n    if (args[i] === '--config' && args[i + 1]) {\n      const configPath = path.resolve(args[i + 1]);\n      if (fs.existsSync(configPath)) {\n        const fileConfig = YAML.parse(fs.readFileSync(configPath, 'utf-8'));\n        Object.assign(config, fileConfig);\n      }\n      i++;\n    } else if (args[i] === '--output' && args[i + 1]) {\n      outputFile = args[i + 1];\n      i++;\n    }\n  }\n  return { config, outputFile };\n}\n\nfunction analyzeStrategyPerformance(db, strategy) {\n  const stmt = db.prepare(`\n    SELECT \n      COUNT(*) as total,\n      SUM(CASE WHEN status = 'failed' THEN 1 ELSE 0 END) as failed,\n      AVG(exit_code) as avg_exit_code,\n      AVG(timeout) as avg_timeout,\n      AVG(actual_duration_ms) as avg_duration,\n      percentile_90(CAST(actual_duration_ms AS REAL)) as p90_duration,\n      percentile_95(CAST(actual_duration_ms AS REAL)) as p95_duration,\n      percentile_99(CAST(actual_duration_ms AS REAL)) as p99_duration\n    FROM tasks \n    WHERE metadata->>'strategy' = ?\n      AND created_at > datetime('now', '-30 days')\n  `);\n  \n  return stmt.get(strategy);\n}\n\nfunction generateRecommendations(analysis, config) {\n  const recommendations = [];\n  const { adjustments } = config;\n  \n  // DIRECT 策略分析\n  if (analysis.DIRECT) {\n    const { total, failed, avg_timeout, p95_duration } = analysis.DIRECT;\n    if (total > 0) {\n      const failRate = (failed / total) * 100;\n      \n      if (failRate > 10) {\n        recommendations.push({\n          strategy: 'DIRECT',\n          issue: `失败率 ${failRate.toFixed(1)}% 超过 10%`,\n          action: '降低 DIRECT 评分阈值',\n          suggestion: `将 DIRECT 最大分数从 ${config.strategies.DIRECT.max_score} 降至 ${Math.max(10, config.strategies.DIRECT.max_score - adjustments.threshold_shift)}`\n        });\n      }\n      \n      if (p95_duration && avg_timeout && p95_duration > avg_timeout * 1000) {\n        recommendations.push({\n          strategy: 'DIRECT',\n          issue: `P95 耗时 ${(p95_duration/1000).toFixed(1)}s 超过超时 ${avg_timeout}s`,\n          action: '增加 DIRECT 超时或降低阈值',\n          suggestion: `超时系数调整为 ${adjustments.timeout_factor}`\n        });\n      }\n    }\n  }\n  \n  // SPAWN_SUBAGENT 策略分析\n  if (analysis.SPAWN_SUBAGENT) {\n    const { total, p95_duration, avg_timeout } = analysis.SPAWN_SUBAGENT;\n    if (total > 0 && p95_duration && avg_timeout) {\n      if (p95_duration > avg_timeout * 1000 * adjustments.timeout_factor) {\n        recommendations.push({\n          strategy: 'SPAWN_SUBAGENT',\n          issue: `P95 耗时 ${(p95_duration/1000).toFixed(1)}s 超过建议超时`,\n          action: '提高超时或降低评分阈值',\n          suggestion: `将 SPAWN_SUBAGENT 阈值从 ${config.strategies.SPAWN_SUBAGENT.max_score} 调整`\n        });\n      }\n    }\n  }\n  \n  return recommendations;\n}\n\nasync function main() {\n  const { config, outputFile } = parseArgs();\n  \n  console.log('=== Rule Tuner 开始分析 ===');\n  console.log(`数据源: ${config.data_source}`);\n  \n  const dbPath = path.resolve(config.data_source);\n  \n  if (!fs.existsSync(dbPath)) {\n    console.log('数据库不存在，跳过分析');\n    process.exit(0);\n  }\n  \n  const db = new Database(dbPath, { readonly: true });\n  \n  const strategies = ['DIRECT', 'STEP_ARCHIVE', 'SPAWN_SUBAGENT', 'PARALLEL_SHARDS'];\n  const analysis = {};\n  \n  for (const strategy of strategies) {\n    console.log(`分析 ${strategy}...`);\n    analysis[strategy] = analyzeStrategyPerformance(db, strategy);\n  }\n  \n  db.close();\n  \n  const recommendations = generateRecommendations(analysis, config);\n  \n  const report = {\n    generated_at: new Date().toISOString(),\n    data_source: dbPath,\n    analysis,\n    recommendations,\n    current_config: config.strategies,\n    suggested_config: config.strategies // 可以基于 recommendations 生成\n  };\n  \n  fs.writeFileSync(outputFile, JSON.stringify(report, null, 2));\n  console.log(`\\n分析报告已保存: ${outputFile}`);\n  console.log(`\\n建议数量: ${recommendations.length}`);\n  \n  if (recommendations.length > 0) {\n    console.log('\\n建议:');\n    recommendations.forEach((r, i) => {\n      console.log(`  ${i + 1}. [${r.strategy}] ${r.issue}`);\n      console.log(`     → ${r.suggestion}`);\n    });\n  }\n}\n\nmain().catch(console.error);\n\n// percentile_90 实现（SQLite 扩展）\nDatabase.prototype.prepare = function(sql) {\n  const stmt = Database.prototype.prepare.apply(this, arguments);\n  const originalRun = stmt.run.bind(stmt);\n  const originalGet = stmt.get.bind(stmt);\n  const originalAll = stmt.all.bind(stmt);\n  \n  // 注册自定义函数\n  this.createAggregate('percentile_90', {\n    init: () => [],\n    step: (arr, val) => { if (val !== null) arr.push(val); },\n    finalize: (arr) => {\n      if (arr.length === 0) return null;\n      arr.sort((a, b) => a - b);\n      const idx = Math.floor(arr.length * 0.9);\n      return arr[idx];\n    }\n  });\n  \n  return stmt;\n};"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":118811,"output":1555,"cacheRead":0,"cacheWrite":0,"totalTokens":120366,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775803306921,"responseId":"chatcmpl-3b2f3e12-e9ad-4063-a18e-185e3c21e14f"}}
