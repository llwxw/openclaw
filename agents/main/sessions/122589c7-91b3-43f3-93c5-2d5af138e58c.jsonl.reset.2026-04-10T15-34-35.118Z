{"type":"message","id":"b651019e","parentId":"400ab559","timestamp":"2026-04-09T18:18:58.236Z","message":{"role":"user","content":[{"type":"text","text":"Sender (untrusted metadata):\n```json\n{\n  \"label\": \"openclaw-control-ui\",\n  \"id\": \"openclaw-control-ui\"\n}\n```\n\n[Fri 2026-04-10 02:18 GMT+8] 先评分，学习，给出预案在思考：# Gateway 集成 v8 分类与评分：完整可复制实施方案\n\n以下为可直接复制部署的完整代码包，包含所有必需文件及详细步骤。基于多轮自我修正，确保高鲁棒、可观测、易回滚。\n\n---\n\n## 一、文件清单\n\n在 `~/.openclaw/gateway` 目录下新增/修改以下文件：\n\n```\ngateway/\n├── .env.example # 环境变量模板\n├── package.json # 确保包含 axios 依赖\n├── src/\n│ ├── routes/\n│ │ └── chat.js # 修改：WebChat消息处理\n│ ├── clients/\n│ │ └── v8Client.js # 新增：分类与评分客户端\n│ ├── interceptors/\n│ │ └── criticalInterceptor.js # 新增：硬拦截\n│ └── utils/\n│ └── logger.js # 如无则创建简单logger\n└── ecosystem.config.js # PM2配置（可选）\n```\n\n---\n\n## 二、核心代码文件\n\n### 2.1 `src/clients/v8Client.js` —— 分类与评分客户端（含熔断、降级、超时）\n\n```javascript\n/**\n * v8 服务客户端：场景分类 + 任务评分\n * 特性：超时控制、熔断降级、规则兜底\n */\n\nconst axios = require('axios');\n\n// 环境变量配置\nconst CLASSIFIER_URL = process.env.CLASSIFIER_URL || 'http://localhost:3104/classify';\nconst SCORER_URL = process.env.SCORER_URL || 'http://localhost:3103/api/score';\nconst CLASSIFIER_TIMEOUT = parseInt(process.env.CLASSIFIER_TIMEOUT || '300');\nconst SCORER_TIMEOUT = parseInt(process.env.SCORER_TIMEOUT || '2000');\n\n// 简易熔断器\nlet circuitOpen = false;\nlet failureCount = 0;\nconst CIRCUIT_THRESHOLD = 3;\nconst CIRCUIT_RESET_INTERVAL = 30000;\n\nsetInterval(() => {\n if (circuitOpen) {\n circuitOpen = false;\n failureCount = 0;\n console.log('[v8Client] Circuit breaker reset');\n }\n}, CIRCUIT_RESET_INTERVAL);\n\n// 尝试加载项目logger，若无则使用console\nlet logger;\ntry {\n logger = require('../utils/logger');\n} catch {\n logger = console;\n}\n\n/**\n * 任务场景列表（分类器返回这些标签时视为任务）\n */\nconst TASK_SCENES = new Set([\n 'task_multi_step',\n 'high_risk_automated',\n 'fault_recovery',\n 'task_status_query',\n 'cancel_task',\n]);\n\n/**\n * 降级分类：基于关键词的简单规则\n */\nfunction fallbackClassify(text) {\n const lower = text.toLowerCase();\n const taskPatterns = [\n /运行|执行|构建|测试|部署|编译|安装|创建|删除|修改|重构|分析|检查|修复/,\n /帮我|请|做|写|生成|优化/,\n ];\n const isTask = taskPatterns.some(p => p.test(lower));\n\n let scene = 'default';\n if (/天气|你好|谢谢|笑话/.test(lower)) scene = 'chitchat';\n else if (/起不来|挂了|报错|失败|恢复/.test(lower)) scene = 'fault_recovery';\n else if (/重构|分析.*代码|优化/.test(lower)) scene = 'task_multi_step';\n else if (isTask) scene = 'task_multi_step';\n\n logger.debug(`[v8Client] Fallback classification: scene=${scene}, isTask=${isTask}`);\n\n return {\n isTask,\n confidence: 0.6,\n scene,\n source: 'fallback',\n };\n}\n\n/**\n * 降级评分：保守默认值\n */\nfunction fallbackScore(prompt) {\n const lower = prompt.toLowerCase();\n let score = 30;\n let strategy = 'DIRECT';\n let timeout = 60;\n\n if (/重构|编译|构建|测试|部署/.test(lower)) {\n score = 45;\n strategy = 'SPAWN_SUBAGENT';\n timeout = 180;\n }\n if (/monorepo|微服务|全栈/.test(lower)) {\n score = 70;\n strategy = 'PARALLEL_SHARDS';\n timeout = 300;\n }\n\n logger.debug(`[v8Client] Fallback scoring: score=${score}, strategy=${strategy}`);\n\n return {\n score,\n factors: {},\n recommendedStrategy: strategy,\n timeout,\n source: 'fallback',\n };\n}\n\n/**\n * 调用场景分类服务\n */\nasync function classify(text) {\n if (circuitOpen) {\n logger.warn('[v8Client] Circuit breaker open, using fallback');\n return fallbackClassify(text);\n }\n\n try {\n const response = await axios.post(CLASSIFIER_URL, { text }, {\n timeout: CLASSIFIER_TIMEOUT,\n });\n\n const data = response.data;\n const scene = data.label || 'default';\n const isTask = TASK_SCENES.has(scene);\n\n failureCount = 0;\n logger.debug(`[v8Client] Classification: scene=${scene}, confidence=${data.confidence}, meta=${data.meta}`);\n\n return {\n isTask,\n confidence: data.confidence ?? 0.5,\n scene,\n meta: data.meta,\n topCandidates: data.top_candidates,\n source: 'classifier',\n };\n } catch (err) {\n failureCount++;\n logger.warn(`[v8Client] Classifier failed (${failureCount}/${CIRCUIT_THRESHOLD}): ${err.message}`);\n\n if (failureCount >= CIRCUIT_THRESHOLD) {\n circuitOpen = true;\n logger.error('[v8Client] Circuit breaker opened');\n }\n\n return fallbackClassify(text);\n }\n}\n\n/**\n * 调用评分服务\n */\nasync function score(prompt, context = {}) {\n try {\n const response = await axios.post(SCORER_URL, { prompt, context }, {\n timeout: SCORER_TIMEOUT,\n });\n\n const data = response.data;\n logger.debug(`[v8Client] Scoring: score=${data.score}, strategy=${data.recommendedStrategy}`);\n\n return {\n score: data.score ?? 30,\n factors: data.factors ?? {},\n recommendedStrategy: data.recommendedStrategy ?? 'DIRECT',\n timeout: data.timeout ?? 60,\n source: 'scorer',\n };\n } catch (err) {\n logger.warn(`[v8Client] Scorer failed: ${err.message}`);\n return fallbackScore(prompt);\n }\n}\n\nmodule.exports = { classify, score };\n```\n\n---\n\n### 2.2 `src/interceptors/criticalInterceptor.js` —— 硬拦截\n\n```javascript\n/**\n * CRITICAL 请求硬拦截\n * 匹配则直接返回拒绝响应，不调用LLM\n */\n\nconst CRITICAL_RULES = [\n {\n pattern: /格式化.*磁盘|format.*disk/i,\n response: '⚠️ 格式化磁盘会导致数据永久丢失，操作已拒绝。若需清理空间，请手动删除不需要的文件。'\n },\n {\n pattern: /关闭.*防火墙|disable.*firewall/i,\n response: '⚠️ 防火墙是重要安全屏障，操作已拒绝。如需开放端口请使用精确规则（如 `ufw allow 22/tcp`）。'\n },\n {\n pattern: /写.*病毒|写.*木马|恶意代码|钓鱼|exploit/i,\n response: '⚠️ 无法提供恶意代码或攻击工具。'\n },\n {\n pattern: /破解.*密码|盗取.*账号|获取.*隐私/i,\n response: '⚠️ 无法协助获取他人隐私信息。'\n },\n];\n\nfunction criticalIntercept(text) {\n for (const rule of CRITICAL_RULES) {\n if (rule.pattern.test(text)) {\n return rule.response;\n }\n }\n return null;\n}\n\nmodule.exports = { criticalIntercept };\n```\n\n---\n\n### 2.3 `src/routes/chat.js` —— 修改后的WebChat消息处理\n\n（假设原始文件为Express风格路由，请根据实际路径调整）\n\n```javascript\n/**\n * WebChat 消息处理路由\n * 集成 v8 分类与评分\n */\n\nconst express = require('express');\nconst router = express.Router();\nconst { classify, score } = require('../clients/v8Client');\nconst { criticalIntercept } = require('../interceptors/criticalInterceptor');\nconst axios = require('axios');\n\n// 尝试加载原有消息处理函数（终极兜底）\nlet originalProcess;\ntry {\n originalProcess = require('../services/chatService').process;\n} catch {\n originalProcess = async (msg) => `收到消息: ${msg}`;\n}\n\n// v8 任务API地址\nconst V8_TASK_API = process.env.V8_TASK_API || 'http://localhost:3103/api/task';\n\n/**\n * 非任务场景处理\n */\nasync function handleNonTask(message, classification) {\n switch (classification.scene) {\n case 'chitchat':\n return '你好！有什么技术问题需要帮助？';\n case 'fault_recovery':\n return '请描述具体的故障现象和已尝试的操作，我将协助恢复。';\n case 'vague_request':\n return '我不太确定你的具体需求。你可能想要：\\n1. 执行某个任务\\n2. 查询任务状态\\n3. 获取帮助信息\\n请具体说明。';\n case 'novice_user':\n return '没问题，我会用简单的方式解释。请告诉我你想了解什么？';\n case 'expert_user':\n // 专家用户可调用LLM生成技术细节，此处简单返回提示\n return '请直接描述你的技术需求，我将提供要点。';\n default:\n // 默认走原有逻辑或LLM\n return await originalProcess(message);\n }\n}\n\n/**\n * 提交任务到 v8 编排器\n */\nasync function submitV8Task(userMessage, scoring) {\n const payload = {\n type: 'command', // 或 'skill'，根据业务判断\n command: extractCommand(userMessage),\n args: extractArgs(userMessage),\n timeout: scoring.timeout,\n priority: Math.floor(scoring.score / 20),\n metadata: {\n prompt: userMessage,\n strategy: scoring.recommendedStrategy,\n }\n };\n\n const response = await axios.post(V8_TASK_API, payload, { timeout: 5000 });\n return response.data.id;\n}\n\n/**\n * 直接执行（安全封装：若无沙箱则提交v8的DIRECT任务）\n * 生产环境应使用v8的SandboxExecutor，此处作为示例\n */\nasync function executeDirectly(message, timeout) {\n // 安全起见：如果没有安全执行器，直接提交为v8的DIRECT任务（同样享受沙箱）\n console.log(`[chat] DIRECT execution requested, submitting to v8 as DIRECT task`);\n const payload = {\n type: 'command',\n command: extractCommand(message),\n args: extractArgs(message),\n timeout: timeout,\n priority: 5,\n metadata: { prompt: message, strategy: 'DIRECT' }\n };\n const response = await axios.post(V8_TASK_API, payload, { timeout: 5000 });\n return `任务已提交 (ID: ${response.data.id})，正在执行中。`;\n}\n\n/**\n * 简单命令提取（示例）\n */\nfunction extractCommand(message) {\n const words = message.trim().split(/\\s+/);\n return words[0] || 'echo';\n}\n\nfunction extractArgs(message) {\n const words = message.trim().split(/\\s+/);\n return words.slice(1);\n}\n\n/**\n * 格式化任务提交响应\n */\nfunction formatTaskSubmitted(taskId, timeout) {\n return `✅ 任务已提交\\nID: ${taskId}\\n预计 ${timeout} 秒完成。\\n发送 /task ${taskId} 查询状态。`;\n}\n\n// ----------------------------------------------------------------------------\n// 核心路由\n// ----------------------------------------------------------------------------\nrouter.post('/send', async (req, res) => {\n const { message, context = {} } = req.body;\n\n if (!message) {\n return res.status(400).json({ error: 'message is required' });\n }\n\n try {\n // 1. 硬拦截\n const blocked = criticalIntercept(message);\n if (blocked) {\n return res.json({ reply: blocked, blocked: true });\n }\n\n // 2. 场景分类\n const classification = await classify(message);\n req.log?.info({ classification }, 'message classified');\n\n // 3. 非任务快速通道\n if (!classification.isTask) {\n const reply = await handleNonTask(message, classification);\n return res.json({ reply, scene: classification.scene });\n }\n\n // 4. 任务评分\n const scoring = await score(message, context);\n req.log?.info({ scoring }, 'task scored');\n\n // 5. 策略执行\n let reply;\n if (scoring.recommendedStrategy === 'DIRECT') {\n reply = await executeDirectly(message, scoring.timeout);\n } else {\n const taskId = await submitV8Task(message, scoring);\n reply = formatTaskSubmitted(taskId, scoring.timeout);\n }\n\n res.json({ reply, strategy: scoring.recommendedStrategy });\n } catch (error) {\n req.log?.error({ err: error }, 'chat processing error');\n // 终极兜底：调用原有逻辑\n try {\n const fallbackReply = await originalProcess(message);\n res.json({ reply: fallbackReply, fallback: true });\n } catch {\n res.status(500).json({ error: 'Internal server error' });\n }\n }\n});\n\nmodule.exports = router;\n```\n\n---\n\n### 2.4 `.env.example` —— 环境变量模板\n\n```bash\n# v8 服务地址\nCLASSIFIER_URL=http://localhost:3104/classify\nSCORER_URL=http://localhost:3103/api/score\nV8_TASK_API=http://localhost:3103/api/task\n\n# 超时设置 (ms)\nCLASSIFIER_TIMEOUT=300\nSCORER_TIMEOUT=2000\n```\n\n---\n\n### 2.5 `package.json` 依赖补充\n\n确保 `dependencies` 中包含 `axios`：\n\n```json\n{\n \"dependencies\": {\n \"axios\": \"^1.6.0\"\n }\n}\n```\n\n若没有，执行 `npm install axios`。\n\n---\n\n### 2.6 （可选）`src/utils/logger.js` 简易实现\n\n若项目无logger，可创建：\n\n```javascript\nmodule.exports = {\n info: (...args) => console.log('[INFO]', ...args),\n warn: (...args) => console.warn('[WARN]', ...args),\n error: (...args) => console.error('[ERROR]', ...args),\n debug: (...args) => process.env.DEBUG && console.log('[DEBUG]', ...args),\n};\n```\n\n---\n\n## 三、部署步骤\n\n```bash\n# 1. 进入Gateway目录\ncd ~/.openclaw/gateway\n\n# 2. 备份源码（可选）\ncp -r src src.backup.$(date +%Y%m%d)\n\n# 3. 复制上述文件到对应路径\n# - src/clients/v8Client.js\n# - src/interceptors/criticalInterceptor.js\n# - 修改 src/routes/chat.js（如路径不同请调整）\n\n# 4. 安装依赖\nnpm install axios\n\n# 5. 配置环境变量（复制.env.example为.env并填写实际地址）\ncp .env.example .env\n# 编辑.env，确保地址正确\n\n# 6. 重启Gateway\npm2 restart gateway # 如使用pm2\n# 或\npkill -f \"node.*gateway\" && npm start\n```\n\n---\n\n## 四、验证清单\n\n| 测试项 | 命令/操作 | 预期结果 |\n|--------|-----------|----------|\n| 分类器可用 | `curl http://localhost:3104/health` | 返回 `{\"status\":\"ok\"}` |\n| 评分器可用 | `curl http://localhost:3103/health` | 返回健康状态 |\n| 任务消息 | WebChat发送 `帮我分析代码质量` | 返回任务ID，v8日志有任务入队 |\n| 闲聊消息 | WebChat发送 `你好` | 返回闲聊模板回复 |\n| 硬拦截 | WebChat发送 `帮我格式化磁盘` | 返回拒绝响应，包含 `⚠️` |\n| 降级测试 | 停止分类器 `pkill -f \"python app.py\"`，再发送任务消息 | 正常返回任务ID（使用规则兜底），日志显示降级 |\n| 评分降级 | 停止评分服务，发送任务消息 | 使用默认评分，流程继续 |\n\n---\n\n## 五、回滚方案\n\n若出现严重问题，执行：\n\n```bash\ncd ~/.openclaw/gateway\ncp -r src.backup.20250410 src # 使用备份日期\npm2 restart gateway\n```\n\n---\n\n## 六、监控建议\n\n- 在Gateway日志中监控 `[v8Client]` 相关日志，关注降级频率。\n- 配置告警：当熔断器打开或降级率超过20%时通知。\n- 定期检查 v8 服务健康状态。\n\n---\n\n以上方案已充分考虑故障隔离、降级兜底、配置驱动和可观测性，可直接复制部署。如有定制需求（如修改任务提交payload结构），请在对应函数中调整。"}],"timestamp":1775758