{"type":"message","id":"86331639","parentId":"6f197a8b","timestamp":"2026-04-10T05:52:46.674Z","message":{"role":"user","content":[{"type":"text","text":"Sender (untrusted metadata):\n```json\n{\n  \"label\": \"openclaw-control-ui\",\n  \"id\": \"openclaw-control-ui\"\n}\n```\n\n[Fri 2026-04-10 13:52 GMT+8] 先学习一下：是的，我们需要先确保代理代码具备完整的转发功能，否则 UI 会丢失。以下是修改后的完整代理代码，关键点在于使用 http-proxy-middleware 将非 API 请求透明转发给 Gateway 3108。\n\n🔧 第一步：安装转发中间件\nbash\ncd ~/.openclaw/proxy\nnpm install http-proxy-middleware\n📄 第二步：替换 index.js 为以下完整代码\njavascript\nrequire('dotenv').config();\nconst express = require('express');\nconst http = require('http');\nconst axios = require('axios');\nconst WebSocket = require('ws');\nconst { createProxyMiddleware } = require('http-proxy-middleware');\nconst { classify, score } = require('./clients/v8Client');\n\nconst app = express();\napp.use(express.json());\n\nconst PORT = process.env.PROXY_PORT || 3102;\nconst BYPASS_MODE = process.env.BYPASS_MODE === 'true';\nconst V8_TASK_API = process.env.V8_TASK_API || 'http://localhost:3103/api/task';\nconst GATEWAY_TARGET = process.env.GATEWAY_TARGET || 'http://localhost:3108';\nconst GATEWAY_WS_URL = process.env.GATEWAY_WS_URL || 'ws://localhost:3108';\n\nconst logger = {\n info: (msg, data) => console.log(JSON.stringify({ level: 'info', ts: new Date().toISOString(), msg, ...data })),\n warn: (msg, data) => console.warn(JSON.stringify({ level: 'warn', ts: new Date().toISOString(), msg, ...data })),\n error: (msg, data) => console.error(JSON.stringify({ level: 'error', ts: new Date().toISOString(), msg, ...data })),\n};\n\n// ==================== 智能分类评分 API ====================\napp.post('/api/chat/send', async (req, res) => {\n const { message, context = {} } = req.body;\n if (!message) return res.status(400).json({ error: 'message required' });\n\n if (BYPASS_MODE) {\n return res.json({ reply: `[Bypass] 收到：${message}` });\n }\n\n try {\n // 1. 分类\n const cls = await classify(message);\n logger.info({ scene: cls.scene, isTask: cls.isTask }, 'Classified');\n\n if (!cls.isTask) {\n const reply = getNonTaskReply(cls.scene);\n return res.json({ reply, scene: cls.scene });\n }\n\n // 2. 评分\n const scr = await score(message, context);\n logger.info({ score: scr.score, strategy: scr.recommendedStrategy }, 'Scored');\n\n // 3. 提交 v8 任务\n const taskId = await submitV8Task(message, scr);\n const reply = `✅ 任务已提交 (ID: ${taskId})，预计 ${scr.timeout}s 完成。`;\n return res.json({ reply, taskId, strategy: scr.recommendedStrategy });\n\n } catch (err) {\n logger.error({ error: err.message }, 'API error');\n res.status(500).json({ error: 'Internal error' });\n }\n});\n\nfunction getNonTaskReply(scene) {\n const replies = {\n chitchat: '你好！有什么技术问题？',\n fault_recovery: '请描述故障现象...',\n vague_request: '请具体说明你的需求。',\n default: '收到消息。'\n };\n return replies[scene] || replies.default;\n}\n\nasync function submitV8Task(message, scoring) {\n const payload = {\n type: 'command',\n command: message.trim().split(/\\s+/)[0] || 'echo',\n args: message.trim().split(/\\s+/).slice(1),\n timeout: scoring.timeout,\n priority: Math.floor(scoring.score / 20),\n metadata: { prompt: message, strategy: scoring.recommendedStrategy }\n };\n const res = await axios.post(V8_TASK_API, payload, { timeout: 5000 });\n return res.data.id;\n}\n\n// ==================== 转发所有非 API 请求到 Gateway ====================\nconst gatewayProxy = createProxyMiddleware({\n target: GATEWAY_TARGET,\n changeOrigin: true,\n ws: true,\n logLevel: 'silent',\n onError: (err, req, res) => {\n logger.error({ error: err.message }, 'Proxy error');\n res.status(502).send('Gateway temporarily unavailable');\n }\n});\n\n// 注意：一定要放在 API 路由之后，确保 /api/chat/send 不被转发\napp.use('/', gatewayProxy);\n\n// ==================== WebSocket 升级处理 ====================\nconst server = http.createServer(app);\nconst wss = new WebSocket.Server({ noServer: true });\n\nserver.on('upgrade', (req, socket, head) => {\n logger.info({ url: req.url }, 'WebSocket upgrade');\n // 交给 http-proxy-middleware 处理升级\n gatewayProxy.upgrade(req, socket, head);\n});\n\n// ==================== 启动服务 ====================\nserver.listen(PORT, () => {\n logger.info({ port: PORT, gateway: GATEWAY_TARGET }, 'Proxy started');\n});\n\n// 优雅关闭\nprocess.on('SIGTERM', () => server.close());\nprocess.on('SIGINT', () => server.close());\n⚙️ 第三步：配置 .env\nbash\ncd ~/.openclaw/proxy\ncat > .env << 'EOF'\nPROXY_PORT=3102\nCLASSIFIER_URL=http://localhost:3104/classify\nSCORER_URL=http://localhost:3103/api/score\nV8_TASK_API=http://localhost:3103/api/task\nGATEWAY_TARGET=http://localhost:3108\nGATEWAY_WS_URL=ws://localhost:3108\nBYPASS_MODE=false\nEOF\n🚀 第四步：释放 3102 并启动代理\nbash\n# 1. 彻底释放 3102\nfuser -k 3102/tcp\nsystemctl --user stop openclaw-router.service 2>/dev/null\nsystemctl --user disable openclaw-router.service 2>/dev/null\n\n# 2. 确认端口空闲\nss -tlnp | grep 3102\n\n# 3. 启动代理\ncd ~/.openclaw/proxy\nnode index.js\n观察日志，应看到 Proxy started on 3102, gateway: http://localhost:3108。\n\n✅ 第五步：验证\n浏览器访问 http://localhost:3102/chat，应显示 Gateway 原生 UI。\n\n发送任务消息（如“帮我分析代码”），应返回任务 ID。\n\n🔙 回退（如 UI 异常）\nbash\n# 停止代理\npkill -f \"node.*proxy/index.js\"\n\n# 如需恢复 3102 的原始服务（如果有），可重启旧 Router\nsystemctl --user start openclaw-router.service # 如果之前启用过\n请按上述步骤执行，尤其是确认代理代码已替换并安装了 http-proxy-middleware。完成后反馈验证结果。"}],"timestamp":1775800366662}}
