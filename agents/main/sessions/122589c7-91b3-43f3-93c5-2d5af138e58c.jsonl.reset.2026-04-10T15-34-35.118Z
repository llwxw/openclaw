{"type":"message","id":"794c3bac","parentId":"838f0deb","timestamp":"2026-04-10T06:43:38.619Z","message":{"role":"toolResult","toolCallId":"019d76212023680e7a984741031ef1cb","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nScene Classifier API 服务\n启动: python api_server.py\n访问: http://localhost:8080\n\"\"\"\n\nimport os\nimport sys\nos.environ['HF_ENDPOINT'] = 'https://hf-mirror.com'\n\nfrom fastapi import FastAPI, HTTPException\nfrom pydantic import BaseModel\nfrom fastapi.middleware.cors import CORSMiddleware\nimport uvicorn\nimport time\n\n# 添加路径\nsys.path.insert(0, '/home/ai/.openclaw/workspace/skills/scene-classifier')\n\nfrom pipeline.orchestrator import PipelineOrchestrator\nfrom feedback.collector import FeedbackCollector\nfrom classifier.rule_classifier import RuleClassifier\n\napp = FastAPI(title=\"Scene Classifier API\", version=\"2.0\")\n\n# CORS 支持\napp.add_middleware(\n    CORSMiddleware,\n    allow_origins=[\"*\"],\n    allow_credentials=True,\n    allow_methods=[\"*\"],\n    allow_headers=[\"*\"],\n)\n\n# 初始化\ntry:\n    pipeline = PipelineOrchestrator()\n    feedback = FeedbackCollector()\n    rule_classifier = RuleClassifier()\n    print(\"Pipeline initialized\")\nexcept Exception as e:\n    pipeline = None\n    rule_classifier = RuleClassifier()\n    print(f\"Pipeline init failed: {e}, using rule-based fallback\")\n\n# 熔断器状态\ncircuit_breaker = {\n    \"failures\": 0,\n    \"last_failure\": 0,\n\n[96 more lines in file. Use offset=51 to continue.]"}],"isError":false,"timestamp":1775803418606}}
