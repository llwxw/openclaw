{"type":"message","id":"5a7a0f29","parentId":"75fcadc5","timestamp":"2026-04-09T18:25:56.481Z","message":{"role":"user","content":[{"type":"text","text":"Sender (untrusted metadata):\n```json\n{\n  \"label\": \"openclaw-control-ui\",\n  \"id\": \"openclaw-control-ui\"\n}\n```\n\n[Fri 2026-04-10 02:25 GMT+8] 先评分，学习，给出预案并思考：# 前置代理方案：\n\n## 一、架构决策\n\n- **独立端口**：代理监听 `3105`，WebChat 连接此端口，Gateway 保持 `3102` 不变。\n- **零侵入**：Gateway 无任何修改，未来升级不受影响。\n- **高可用**：代理内置熔断、超时、降级，自身故障时可配置旁路直连 Gateway。\n- **可观测**：结构化日志、健康检查端点。\n\n---\n\n## 二、部署架构图\n\n```\nWebChat 客户端\n │\n ▼\n Proxy (3105) ──┬── 分类器 (3104)\n └── 评分引擎 (3103)\n │\n ▼\n Gateway (3102) ── 执行 / LLM\n```\n\n---\n\n## 三、代理服务实现（Node.js）\n\n### 3.1 项目结构\n\n```\n~/.openclaw/proxy/\n├── package.json\n├── .env\n├── index.js\n└── clients/\n └── v8Client.js # 复用之前设计的客户端\n```\n\n### 3.2 `package.json`\n\n```json\n{\n \"name\": \"openclaw-proxy\",\n \"version\": \"1.0.0\",\n \"main\": \"index.js\",\n \"scripts\": {\n \"start\": \"node index.js\"\n },\n \"dependencies\": {\n \"axios\": \"^1.6.0\",\n \"express\": \"^4.18.2\",\n \"dotenv\": \"^16.0.3\"\n }\n}\n```\n\n### 3.3 `.env`\n\n```bash\nPROXY_PORT=3105\nGATEWAY_URL=http://localhost:3102\nCLASSIFIER_URL=http://localhost:3104/classify\nSCORER_URL=http://localhost:3103/api/score\nV8_TASK_API=http://localhost:3103/api/task\nCLASSIFIER_TIMEOUT=300\nSCORER_TIMEOUT=2000\nBYPASS_MODE=false # 若 true，直接转发到 Gateway，不调用 v8\nLOG_LEVEL=info\n```\n\n### 3.4 `clients/v8Client.js`\n\n（与之前 Gateway 集成时提供的完全一致，此处不再重复，确保 `classify` 和 `score` 函数导出）\n\n### 3.5 `index.js` —— 代理主逻辑\n\n```javascript\nrequire('dotenv').config();\nconst express = require('express');\nconst axios = require('axios');\nconst { classify, score } = require('./clients/v8Client');\nconst { criticalIntercept } = require('./interceptors/criticalInterceptor'); // 可选\n\nconst app = express();\napp.use(express.json());\n\nconst PORT = process.env.PROXY_PORT || 3105;\nconst GATEWAY_URL = process.env.GATEWAY_URL || 'http://localhost:3102';\nconst BYPASS_MODE = process.env.BYPASS_MODE === 'true';\nconst V8_TASK_API = process.env.V8_TASK_API || 'http://localhost:3103/api/task';\n\n// 简易日志\nconst logger = {\n info: (msg, data) => console.log(JSON.stringify({ level: 'info', msg, ...data })),\n warn: (msg, data) => console.warn(JSON.stringify({ level: 'warn', msg, ...data })),\n error: (msg, data) => console.error(JSON.stringify({ level: 'error', msg, ...data })),\n};\n\n// 健康检查\napp.get('/health', (req, res) => {\n res.json({ status: 'ok', bypass: BYPASS_MODE });\n});\n\n// 切换旁路模式（紧急开关）\napp.post('/admin/bypass', (req, res) => {\n BYPASS_MODE = req.body.enabled === true;\n logger.info(`Bypass mode ${BYPASS_MODE ? 'enabled' : 'disabled'}`);\n res.json({ bypass: BYPASS_MODE });\n});\n\n// 核心消息处理\napp.post('/api/chat/send', async (req, res) => {\n const { message, context = {} } = req.body;\n if (!message) {\n return res.status(400).json({ error: 'message is required' });\n }\n\n // 旁路模式：直接转发 Gateway\n if (BYPASS_MODE) {\n logger.info('Bypass mode, forwarding to Gateway');\n try {\n const gwRes = await axios.post(`${GATEWAY_URL}/api/chat/send`, req.body, {\n timeout: 30000,\n });\n return res.json(gwRes.data);\n } catch (err) {\n logger.error('Gateway forward failed', { error: err.message });\n return res.status(502).json({ error: 'Gateway unavailable' });\n }\n }\n\n try {\n // 1. 硬拦截（可选）\n const blocked = criticalIntercept?.(message);\n if (blocked) {\n logger.info('Request blocked', { message: message.slice(0, 50) });\n return res.json({ reply: blocked, blocked: true });\n }\n\n // 2. 分类\n const classification = await classify(message);\n logger.info('Classified', { scene: classification.scene, isTask: classification.isTask });\n\n // 3. 非任务场景：使用快速模板回复，不打扰 Gateway\n if (!classification.isTask) {\n const reply = getNonTaskReply(classification.scene);\n return res.json({ reply, scene: classification.scene, source: 'proxy' });\n }\n\n // 4. 任务场景：评分\n const scoring = await score(message, context);\n logger.info('Scored', { score: scoring.score, strategy: scoring.recommendedStrategy });\n\n // 5. 策略路由\n if (scoring.recommendedStrategy === 'DIRECT') {\n // DIRECT 任务：提交到 v8 任务 API（享受沙箱）\n const taskId = await submitV8Task(message, scoring);\n const reply = formatTaskSubmitted(taskId, scoring.timeout);\n return res.json({ reply, taskId, strategy: 'DIRECT' });\n } else {\n // 非 DIRECT 任务：转发给 Gateway 执行（Gateway 会调用 v8 或自行处理）\n // 同时附加上下文信息，让 Gateway 可以跳过重复评分（如果支持）\n const enhancedBody = {\n ...req.body,\n _proxy: {\n scene: classification.scene,\n score: scoring.score,\n strategy: scoring.recommendedStrategy,\n timeout: scoring.timeout,\n }\n };\n const gwRes = await axios.post(`${GATEWAY_URL}/api/chat/send`, enhancedBody, {\n timeout: Math.max(scoring.timeout * 1000 + 5000, 30000),\n });\n // 如果 Gateway 返回了结果，直接透传\n return res.json(gwRes.data);\n }\n } catch (error) {\n logger.error('Proxy processing error', { error: error.message, stack: error.stack });\n // 降级：直接转发到 Gateway（兜底）\n try {\n const gwRes = await axios.post(`${GATEWAY_URL}/api/chat/send`, req.body, {\n timeout: 30000,\n });\n return res.json({ ...gwRes.data, fallback: true });\n } catch (gwError) {\n return res.status(502).json({ error: 'All services unavailable' });\n }\n }\n});\n\n// 辅助函数\nfunction getNonTaskReply(scene) {\n const replies = {\n chitchat: '你好！有什么技术问题需要帮助？',\n fault_recovery: '请描述具体的故障现象和已尝试的操作，我将协助恢复。',\n vague_request: '我不太确定你的具体需求。你可能想要：\\n1. 执行某个任务\\n2. 查询任务状态\\n3. 获取帮助信息\\n请具体说明。',\n novice_user: '没问题，我会用简单的方式解释。请告诉我你想了解什么？',\n expert_user: '请直接描述你的技术需求，我将提供要点。',\n default: '收到消息，正在处理。'\n };\n return replies[scene] || replies.default;\n}\n\nasync function submitV8Task(userMessage, scoring) {\n const payload = {\n type: 'command',\n command: extractCommand(userMessage),\n args: extractArgs(userMessage),\n timeout: scoring.timeout,\n priority: Math.floor(scoring.score / 20),\n metadata: {\n prompt: userMessage,\n strategy: scoring.recommendedStrategy,\n }\n };\n const response = await axios.post(V8_TASK_API, payload, { timeout: 5000 });\n return response.data.id;\n}\n\nfunction extractCommand(message) {\n const words = message.trim().split(/\\s+/);\n return words[0] || 'echo';\n}\n\nfunction extractArgs(message) {\n const words = message.trim().split(/\\s+/);\n return words.slice(1);\n}\n\nfunction formatTaskSubmitted(taskId, timeout) {\n return `✅ 任务已提交\\nID: ${taskId}\\n预计 ${timeout} 秒完成。\\n发送 /task ${taskId} 查询状态。`;\n}\n\n// 启动服务\napp.listen(PORT, () => {\n logger.info(`Proxy listening on port ${PORT}, bypass: ${BYPASS_MODE}`);\n});\n\n// 优雅关闭\nprocess.on('SIGTERM', () => process.exit(0));\nprocess.on('SIGINT', () => process.exit(0));\n```\n\n### 3.6 可选：`interceptors/criticalInterceptor.js`\n\n与之前相同，可直接复制到 `interceptors/` 目录，并在 `index.js` 中引入。\n\n---\n\n## 四、部署与启动\n\n### 4.1 安装依赖\n\n```bash\ncd ~/.openclaw/proxy\nnpm install\n```\n\n### 4.2 配置环境变量\n\n编辑 `.env`，确保各项地址正确。\n\n### 4.3 启动代理\n\n```bash\nnpm start\n# 或使用 PM2\npm2 start index.js --name openclaw-proxy\npm2 save\n```\n\n### 4.4 修改 WebChat 连接地址\n\n将 WebChat 配置中的 API 地址改为 `http://localhost:3105`（原为 `3102`）。\n\n---\n\n## 五、验证清单\n\n| 测试项 | 操作 | 预期 |\n|--------|------|------|\n| 健康检查 | `curl http://localhost:3105/health` | `{\"status\":\"ok\"}` |\n| 闲聊消息 | WebChat 发送 `你好` | 返回快速模板，不调用 Gateway |\n| 任务消息 | WebChat 发送 `帮我分析代码` | 返回任务ID，v8 队列有任务 |\n| 降级开关 | `curl -X POST http://localhost:3105/admin/bypass -d '{\"enabled\":true}' -H \"Content-Type: application/json\"` | 旁路模式开启，消息直接转发 Gateway |\n| 分类器故障 | 停止 3104 服务后发送任务消息 | 降级规则分类，流程继续 |\n| 评分器故障 | 停止 3103 服务后发送任务消息 | 降级默认评分，任务仍能提交 |\n\n---\n\n## 六、多轮修正要点\n\n- **第一轮**：代理直接返回非任务模板，避免 Gateway 被闲聊请求打扰，降低负载。\n- **第二轮**：增加旁路开关，紧急情况下可一键绕过所有 v8 逻辑，恢复原始行为。\n- **第三轮**：DIRECT 策略的任务直接提交 v8 API，避免 Gateway 仍需处理 DIRECT 执行，保持 Gateway 轻量。\n- **第四轮**：非 DIRECT 任务转发给 Gateway，并携带 `_proxy` 元数据，便于未来 Gateway 优化。\n- **第五轮**：全局兜底转发，确保任何异常不阻塞用户消息。\n\n---\n\n## 七、监控与告警\n\n- 监控代理日志中 `Classified` 和 `Scored` 事件频率。\n- 当降级转发（`fallback: true`）频繁出现时告警。\n- 通过 `/health` 集成到现有监控系统。\n\n---\n\n## 八、回滚方案\n\n1. 将 WebChat 配置改回直连 `3102`。\n2. 停止代理服务：`pm2 stop openclaw-proxy`。\n\n无任何数据丢失或状态污染。\n\n---"}],"timestamp":1775759156461}}
