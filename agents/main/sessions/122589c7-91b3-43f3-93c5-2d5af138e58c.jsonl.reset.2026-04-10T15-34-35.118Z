{"type":"message","id":"8034fd09","parentId":"8a39cdc4","timestamp":"2026-04-09T17:58:24.765Z","message":{"role":"toolResult","toolCallId":"call_0329b30a9ae7482199d94824","toolName":"read","content":[{"type":"text","text":"import { GatewayClient } from './gatewayClient';\nimport { ApiClient } from './apiClient';\nimport { MessageQueue } from './queue';\nimport { AppConfig, GatewayMessage } from './types';\nimport { getLogger } from './logger';\n\nexport class MessageHandler {\n  constructor(\n    private apiClient: ApiClient,\n    private queue: MessageQueue | null,\n    private config: AppConfig,\n    private gatewayClient: GatewayClient\n  ) {}\n\n  async handle(msgData: any): Promise<void> {\n    const text = msgData[this.config.behavior.messageField];\n    if (!text || typeof text !== 'string') {\n      getLogger().debug({ msgData }, 'Message missing text field, skipping');\n      return;\n    }\n    getLogger().info({ text }, 'Processing message');\n    const startTime = Date.now();\n\n    let intent = 'unknown';\n    let score: number | string = 'N/A';\n    try {\n      const [intentRes, scoreRes] = await Promise.allSettled([\n        this.apiClient.detectIntent(text),\n        this.apiClient.getScore(text),\n      ]);\n      if (intentRes.status === 'fulfilled') intent = intentRes.value;\n      if (scoreRes.status === 'fulfilled') score = scoreRes.value;\n    } catch (err) {\n      getLogger().error({ err, text }, 'Failed to call intent/score APIs');\n    }\n\n    const duration = Date.now() - startTime;\n    getLogger().info({ text, intent, score, duration }, 'Analysis complete');\n\n    if (this.config.reply.enabled && this.gatewayClient.isConnected()) {\n      let reply = this.config.reply.template || '';\n      reply = reply.replace('{{intent}}', intent).replace('{{score}}', String(score));\n      this.gatewayClient.send({ type: 'reply', content: reply });\n    }\n  }\n\n  async replayQueuedMessages(): Promise<void> {\n    if (!this.queue) return;\n    const messages = await this.queue.peek(20);\n    if (messages.length === 0) return;\n\n[13 more lines in file. Use offset=51 to continue.]"}],"isError":false,"timestamp":1775757504753}}
