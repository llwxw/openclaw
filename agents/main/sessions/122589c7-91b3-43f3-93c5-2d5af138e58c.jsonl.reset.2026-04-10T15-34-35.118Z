.textContent = '处理中...';\n      try {\n        const res = await fetch(API + '/api/chat/send', {\n          method: 'POST',\n          headers: {'Content-Type': 'application/json'},\n          body: JSON.stringify({message: text})\n        });\n        const data = await res.json();\n        status.textContent = 'scene: ' + (data.scene || 'unknown');\n        addMsg('assistant', data.reply || JSON.stringify(data));\n      } catch (e) {\n        addMsg('assistant', '错误: ' + e.message);\n      }\n    }\n    \n    input.addEventListener('keypress', e => { if (e.key === 'Enter') send(); });\n    status.textContent = '已连接 (3105 智能入口)';\n  </script>\n</body>\n</html>\nEOF\n\necho \"完成\""}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":63754,"output":695,"cacheRead":0,"cacheWrite":0,"totalTokens":64449,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775789587284,"responseId":"chatcmpl-388fece4-0cae-4f69-bfe1-161eefbdab07"}}
