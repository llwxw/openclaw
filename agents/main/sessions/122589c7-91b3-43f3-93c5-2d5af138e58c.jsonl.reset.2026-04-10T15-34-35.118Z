{"type":"message","id":"9b07d5a2","parentId":"36fbcb03","timestamp":"2026-04-09T18:04:29.845Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在创建 v8Client.ts 文件。\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n## 步骤 1：创建 v8Client.ts\n\n\n"},{"type":"toolCall","id":"call_8a13f3ec7c8e4522a52b2c1a","name":"write","arguments":{"content":"import axios from 'axios';\nimport { getLogger } from '../logger';\n\nconst logger = getLogger();\n\n// 环境变量配置\nconst CLASSIFIER_URL = process.env.CLASSIFIER_URL || 'http://localhost:3104/classify';\nconst SCORER_URL = process.env.SCORER_URL || 'http://localhost:3103/api/score';\nconst CLASSIFIER_TIMEOUT = parseInt(process.env.CLASSIFIER_TIMEOUT || '500');\nconst SCORER_TIMEOUT = parseInt(process.env.SCORER_TIMEOUT || '2000');\n\n// 熔断器状态\nlet circuitOpen = false;\nlet failureCount = 0;\nconst CIRCUIT_THRESHOLD = 3;\n\nexport interface ClassificationResult {\n  isTask: boolean;\n  confidence: number;\n  scene: string;\n  meta?: string;\n  topCandidates?: Array<[string, number]>;\n  source: 'classifier' | 'fallback';\n}\n\nexport interface ScoringResult {\n  score: number;\n  factors: Record<string, number>;\n  recommendedStrategy: string;\n  timeout: number;\n  source: 'scorer' | 'fallback';\n}\n\n/**\n * 调用场景分类服务 (3104)\n */\nexport async function classify(text: string): Promise<ClassificationResult> {\n  if (circuitOpen) {\n    logger.warn('Circuit breaker open, using fallback classification');\n    return fallbackClassify(text);\n  }\n\n  try {\n    const response = await axios.post(CLASSIFIER_URL, { text }, {\n      timeout: CLASSIFIER_TIMEOUT,\n    });\n\n    const data = response.data;\n    const scene = data.scene || data.label || 'default';\n    const isTask = isTaskScene(scene);\n\n    logger.debug({ scene, confidence: data.confidence, meta: data.meta }, 'Classification result');\n\n    // 重置失败计数\n    failureCount = 0;\n\n    return {\n      isTask,\n      confidence: data.confidence ?? 0.5,\n      scene,\n      meta: data.meta,\n      topCandidates: data.top_candidates,\n      source: 'classifier',\n    };\n  } catch (error) {\n    failureCount++;\n    const errMsg = error instanceof Error ? error.message : String(error);\n    logger.warn({ err: errMsg, failureCount }, 'Classifier request failed');\n\n    if (failureCount >= CIRCUIT_THRESHOLD) {\n      circuitOpen = true;\n      logger.error('Circuit breaker opened due to repeated failures');\n    }\n\n    return fallbackClassify(text);\n  }\n}\n\n/**\n * 调用评分服务 (3103)\n */\nexport async function score(prompt: string, context?: Record<string, any>): Promise<ScoringResult> {\n  try {\n    const response = await axios.post(SCORER_URL, { prompt, context }, {\n      timeout: SCORER_TIMEOUT,\n    });\n\n    const data = response.data;\n    logger.debug({ score: data.score, strategy: data.recommendedStrategy }, 'Scoring result');\n\n    return {\n      score: data.score ?? 30,\n      factors: data.factors ?? {},\n      recommendedStrategy: data.recommendedStrategy ?? 'DIRECT',\n      timeout: data.timeout ?? 60,\n      source: 'scorer',\n    };\n  } catch (error) {\n    const errMsg = error instanceof Error ? error.message : String(error);\n    logger.warn({ err: errMsg }, 'Scorer request failed');\n    return fallbackScore(prompt);\n  }\n}\n\n// ----------------------------------------------------------------------------\n// 内部辅助函数\n// ----------------------------------------------------------------------------\n\nfunction isTaskScene(scene: string): boolean {\n  const taskScenes = [\n    'task_multi_step',\n    'high_risk_automated',\n    'fault_recovery',\n    'task_status_query',\n    'cancel_task',\n  ];\n  return taskScenes.includes(scene);\n}\n\nfunction fallbackClassify(text: string): ClassificationResult {\n  const lower = text.toLowerCase();\n  \n  const taskPatterns = [\n    /运行|执行|构建|测试|部署|编译|安装|创建|删除|修改|重构|分析|检查|修复/,\n    /帮我|请|做|写|生成|优化/,\n  ];\n  const isTask = taskPatterns.some(p => p.test(lower));\n\n  let scene = 'default';\n  if (/天气|你好|谢谢|笑话/.test(lower)) {\n    scene = 'chitchat';\n  } else if (/起不来|挂了|报错|失败|恢复/.test(lower)) {\n    scene = 'fault_recovery';\n  } else if (/重构|分析.*代码|优化/.test(lower)) {\n    scene = 'task_multi_step';\n  } else if (isTask) {\n    scene = 'task_multi_step';\n  }\n\n  logger.debug({ scene, isTask }, 'Fallback classification');\n\n  return {\n    isTask,\n    confidence: 0.6,\n    scene,\n    source: 'fallback',\n  };\n}\n\nfunction fallbackScore(prompt: string): ScoringResult {\n  const lower = prompt.toLowerCase();\n  let score = 30;\n  let strategy = 'DIRECT';\n  let timeout = 60;\n\n  if (/重构|编译|构建|测试|部署/.test(lower)) {\n    score = 45;\n    strategy = 'SPAWN_SUBAGENT';\n    timeout = 180;\n  }\n  if (/monorepo|微服务|全栈/.test(lower)) {\n    score = 70;\n    strategy = 'PARALLEL_SHARDS';\n    timeout = 300;\n  }\n\n  logger.debug({ score, strategy }, 'Fallback scoring');\n\n  return {\n    score,\n    factors: {},\n    recommendedStrategy: strategy,\n    timeout,\n    source: 'fallback',\n  };\n}","path":"/home/ai/openclaw-listener/src/clients/v8Client.ts"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":115882,"output":1233,"cacheRead":0,"cacheWrite":0,"totalTokens":117115,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775757850087,"responseId":"chatcmpl-04720a65-c0c1-4c6b-a61f-2265499f0453"}}
