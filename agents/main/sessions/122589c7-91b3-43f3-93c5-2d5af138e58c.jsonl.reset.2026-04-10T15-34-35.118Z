{"type":"message","id":"bb5c9f2f","parentId":"243f85fb","timestamp":"2026-04-10T06:43:20.516Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"接下来创建 strategy-analyzer.js - 策略分析报告生成器\n\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"call_16c2815cd6f2403bb915f4d1","name":"write","arguments":{"path":"/home/ai/.openclaw/v8/src/observability/strategy-analyzer.js","content":"#!/usr/bin/env node\n/**\n * strategy-analyzer.js - 策略分析报告生成器\n * 定期分析任务失败模式，输出优化建议\n * \n * 使用: node strategy-analyzer.js --days 7 --output report.md\n */\n\nconst fs = require('fs');\nconst path = require('path');\nconst Database = require('better-sqlite3');\n\nfunction parseArgs() {\n  const args = process.argv.slice(2);\n  let days = 7;\n  let outputFile = 'strategy_report.md';\n  let dbPath = './data/tasks.db';\n  \n  for (let i = 0; i < args.length; i++) {\n    if (args[i] === '--days' && args[i + 1]) {\n      days = parseInt(args[i + 1]);\n      i++;\n    } else if (args[i] === '--output' && args[i + 1]) {\n      outputFile = args[i + 1];\n      i++;\n    } else if (args[i] === '--db' && args[i + 1]) {\n      dbPath = args[i + 1];\n      i++;\n    }\n  }\n  \n  return { days, outputFile, dbPath };\n}\n\nfunction getDateRange(days) {\n  const end = new Date();\n  const start = new Date();\n  start.setDate(start.getDate() - days);\n  return { start: start.toISOString(), end: end.toISOString() };\n}\n\nfunction analyzeStrategy(db, strategy, startDate, endDate) {\n  const stmt = db.prepare(`\n    SELECT \n      COUNT(*) as total,\n      SUM(CASE WHEN status = 'completed' THEN 1 ELSE 0 END) as completed,\n      SUM(CASE WHEN status = 'failed' THEN 1 ELSE 0 END) as failed,\n      SUM(CASE WHEN status = 'timeout' THEN 1 ELSE 0 END) as timeout,\n      AVG(actual_duration_ms) as avg_duration,\n      AVG(CAST(metadata->>'score' AS REAL)) as avg_score,\n      MIN(actual_duration_ms) as min_duration,\n      MAX(actual_duration_ms) as max_duration\n    FROM tasks \n    WHERE metadata->>'strategy' = ?\n      AND created_at BETWEEN ? AND ?\n  `);\n  \n  return stmt.get(strategy, startDate, endDate);\n}\n\nfunction analyzeFailurePatterns(db, startDate, endDate) {\n  const stmt = db.prepare(`\n    SELECT \n      metadata->>'strategy' as strategy,\n      metadata->>'reason' as reason,\n      COUNT(*) as count,\n      AVG(actual_duration_ms) as avg_duration\n    FROM tasks \n    WHERE status IN ('failed', 'timeout')\n      AND created_at BETWEEN ? AND ?\n    GROUP BY strategy, reason\n    ORDER BY count DESC\n    LIMIT 10\n  `);\n  \n  return stmt.all(startDate, endDate);\n}\n\nfunction analyzeTimeoutPatterns(db, startDate, endDate) {\n  const stmt = db.prepare(`\n    SELECT \n      metadata->>'strategy' as strategy,\n      COUNT(*) as count,\n      AVG(actual_duration_ms) as avg_timeout,\n      AVG(CAST(metadata->>'timeout' AS REAL)) as expected_timeout,\n      (AVG(actual_duration_ms) / AVG(CAST(metadata->>'timeout' AS REAL)) * 100) as timeout_ratio\n    FROM tasks \n    WHERE status = 'timeout'\n      AND created_at BETWEEN ? AND ?\n    GROUP BY strategy\n  `);\n  \n  return stmt.all(startDate, endDate);\n}\n\nfunction generateMarkdownReport(days, strategyStats, failurePatterns, timeoutPatterns) {\n  const now = new Date().toISOString().split('T')[0];\n  const startDate = new Date();\n  startDate.setDate(startDate.getDate() - days);\n  \n  let md = `# 策略分析报告 (${startDate.toISOString().split('T')[0]} ~ ${now})\n\n生成时间: ${now}\n分析周期: ${days} 天\n\n---\n\n## 一、总体统计\n\n| 策略 | 总数 | 完成 | 失败 | 超时 | 完成率 | 平均耗时 |\n|------|------|------|------|------|--------|----------|\n`;\n\n  const strategyNames = ['DIRECT', 'STEP_ARCHIVE', 'SPAWN_SUBAGENT', 'PARALLEL_SHARDS', 'MEGA_TASK'];\n  \n  for (const strategy of strategyNames) {\n    const stats = strategyStats[strategy];\n    if (!stats || stats.total === 0) continue;\n    \n    const completionRate = ((stats.completed / stats.total) * 100).toFixed(1);\n    const avgDuration = stats.avg_duration ? (stats.avg_duration / 1000).toFixed(1) + 's' : '-';\n    \n    md += `| ${strategy} | ${stats.total} | ${stats.completed} | ${stats.failed} | ${stats.timeout} | ${completionRate}% | ${avgDuration} |\\n`;\n  }\n\n  md += `\n---\n\n## 二、失败模式分析\n\n`;\n  \n  if (failurePatterns.length > 0) {\n    md += `| 策略 | 原因 | 次数 | 平均耗时 |\\n|------|------|------|----------|\\n`;\n    for (const pattern of failurePatterns) {\n      const avgDur = pattern.avg_duration ? (pattern.avg_duration / 1000).toFixed(1) + 's' : '-';\n      md += `| ${pattern.strategy || '-'} | ${pattern.reason || '未知'} | ${pattern.count} | ${avgDur} |\\n`;\n    }\n  } else {\n    md += '无失败记录\\n';\n  }\n\n  md += `\n---\n\n## 三、超时分析\n\n`;\n  \n  if (timeoutPatterns.length > 0) {\n    md += `| 策略 | 超时次数 | 平均实际超时 | 期望超时 | 超时比率 |\\n|------|----------|--------------|----------|----------|\\n`;\n    for (const pattern of timeoutPatterns) {\n      const ratio = pattern.timeout_ratio ? pattern.timeout_ratio.toFixed(1) + '%' : '-';\n      const avgTimeout = pattern.avg_timeout ? (pattern.avg_timeout / 1000).toFixed(1) + 's' : '-';\n      const expectedTimeout = pattern.expected_timeout ? (pattern.expected_timeout / 1000).toFixed(1) + 's' : '-';\n      md += `| ${pattern.strategy} | ${pattern.count} | ${avgTimeout} | ${expectedTimeout} | ${ratio} |\\n`;\n    }\n  } else {\n    md += '无超时记录\\n';\n  }\n\n  md += `\n---\n\n## 四、优化建议\n\n`;\n\n  const suggestions = [];\n  \n  // 基于统计数据生成建议\n  for (const strategy of strategyNames) {\n    const stats = strategyStats[strategy];\n    if (!stats || stats.total === 0) continue;\n    \n    const failRate = (stats.failed / stats.total) * 100;\n    const timeoutRate = (stats.timeout / stats.total) * 100;\n    \n    if (failRate > 10) {\n      suggestions.push(`- **${strategy}** 失败率 ${failRate.toFixed(1)}% 超过 10%，建议降低评分阈值或改进错误处理`);\n    }\n    \n    if (timeoutRate > 5) {\n      suggestions.push(`- **${strategy}** 超时率 ${timeoutRate.toFixed(1)}% 超过 5%，建议增加超时时间`);\n    }\n  }\n  \n  // 基于超时分析生成建议\n  for (const pattern of timeoutPatterns) {\n    if (pattern.timeout_ratio && pattern.timeout_ratio > 100) {\n      suggestions.push(`- **${pattern.strategy}** 实际超时超过期望超时，建议将超时时间调整为 ${(pattern.avg_timeout * 1.2 / 1000).toFixed(0)}s`);\n    }\n  }\n  \n  if (suggestions.length > 0) {\n    md += suggestions.join('\\n');\n  } else {\n    md += '各项指标正常，无需优化\\n';\n  }\n\n  md += `\n---\n\n*本报告由 strategy-analyzer.js 自动生成*\n`;\n\n  return md;\n}\n\nasync function main() {\n  const { days, outputFile, dbPath } = parseArgs();\n  \n  console.log(`=== Strategy Analyzer (${days}天) ===`);\n  \n  const absDbPath = path.resolve(dbPath);\n  \n  if (!fs.existsSync(absDbPath)) {\n    console.log('数据库不存在');\n    const emptyReport = `# 策略分析报告\\n\\n数据库不存在，请先运行任务编排器生成数据。`;\n    fs.writeFileSync(outputFile, emptyReport);\n    console.log(`空报告已保存: ${outputFile}`);\n    process.exit(0);\n  }\n  \n  const db = new Database(absDbPath, { readonly: true });\n  const { start, end } = getDateRange(days);\n  \n  console.log(`分析周期: ${start} ~ ${end}`);\n  \n  const strategyStats = {};\n  const strategyNames = ['DIRECT', 'STEP_ARCHIVE', 'SPAWN_SUBAGENT', 'PARALLEL_SHARDS', 'MEGA_TASK'];\n  \n  for (const strategy of strategyNames) {\n    console.log(`分析 ${strategy}...`);\n    strategyStats[strategy] = analyzeStrategy(db, strategy, start, end);\n  }\n  \n  console.log('分析失败模式...');\n  const failurePatterns = analyzeFailurePatterns(db, start, end);\n  \n  console.log('分析超时模式...');\n  const timeoutPatterns = analyzeTimeoutPatterns(db, start, end);\n  \n  db.close();\n  \n  const report = generateMarkdownReport(days, strategyStats, failurePatterns, timeoutPatterns);\n  \n  fs.writeFileSync(outputFile, report);\n  console.log(`\\n报告已保存: ${outputFile}`);\n}\n\nmain().catch(console.error);"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":121947,"output":2126,"cacheRead":0,"cacheWrite":0,"totalTokens":124073,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775803363635,"responseId":"chatcmpl-d05f281e-8cb5-4535-bcd9-8daeaed0e05c"}}
