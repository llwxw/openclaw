{"type":"message","id":"98d133ef","parentId":"c9afea31","timestamp":"2026-03-31T08:30:23.221Z","message":{"role":"toolResult","toolCallId":"call_00_9NrqjlJXbOKBAo3UiNW9DY5Y","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env node\r\n\r\nconst { Command } = require('commander');\r\nconst fs = require('fs');\r\nconst path = require('path');\r\n\r\nconst program = new Command();\r\n\r\nprogram\r\n  .description('生成MBTI人格提示词')\r\n  .argument('<mbti>', 'MBTI类型（如INTJ、INFP等）')\r\n  .option('-o, --output <file>', '输出文件，默认为标准输出', 'stdout')\r\n  .action((mbti, options) => {\r\n    const dataPath = path.join(__dirname, '../lib/data/mbti.json');\r\n    if (!fs.existsSync(dataPath)) {\r\n      console.error('错误：MBTI数据文件不存在');\r\n      process.exit(1);\r\n    }\r\n    const mbtiData = JSON.parse(fs.readFileSync(dataPath, 'utf8'));\r\n    const upperMbti = mbti.toUpperCase();\r\n    if (!mbtiData[upperMbti]) {\r\n      console.error(`错误：不支持的MBTI类型 \"${mbti}\"`);\r\n      console.error('支持的MBTI类型：', Object.keys(mbtiData).join(', '));\r\n      process.exit(1);\r\n    }\r\n    const data = mbtiData[upperMbti];\r\n    const output = `角色人格类型：${upperMbti}\r\n主导功能：${data.dom}\r\n辅助功能：${data.aux}\r\n第三功能：${data.tert}\r\n劣势功能：${data.inf}\r\n核心恐惧：${data.fear}\r\n典型行为：${data.behavior}`;\r\n    \r\n    if (options.output === 'stdout') {\r\n      console.log(output);\r\n    } else {\r\n      fs.writeFileSync(options.output, output);\r\n      console.log(`已输出到 ${options.output}`);\r\n    }\r\n  });\r\n\r\nprogram.parse();\r\n"}],"isError":false,"timestamp":1774945823218}}
