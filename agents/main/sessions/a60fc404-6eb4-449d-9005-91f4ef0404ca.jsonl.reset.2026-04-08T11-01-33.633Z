{"type":"message","id":"10385ae4","parentId":"ec653728","timestamp":"2026-04-08T06:19:59.860Z","message":{"role":"toolResult","toolCallId":"019d6bbe9cc6d84be539aab28afc8415","toolName":"read","content":[{"type":"text","text":"function setupGracefulShutdown(server, scheduler, taskStore, logger) {\n  let shuttingDown = false;\n\n  const shutdown = async (signal) => {\n    if (shuttingDown) return;\n    shuttingDown = true;\n    logger.info({ signal }, 'Starting graceful shutdown...');\n\n    server.close(async () => {\n      logger.info('HTTP server closed');\n    });\n\n    await scheduler.stop();\n    await taskStore.close();\n\n    logger.info('Shutdown complete');\n    process.exit(0);\n  };\n\n  process.on('SIGTERM', () => shutdown('SIGTERM'));\n  process.on('SIGINT', () => shutdown('SIGINT'));\n}\n\nmodule.exports = { setupGracefulShutdown };\n"}],"isError":false,"timestamp":1775629199850}}
