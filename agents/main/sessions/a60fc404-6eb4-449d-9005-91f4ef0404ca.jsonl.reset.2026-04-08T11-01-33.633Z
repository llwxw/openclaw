{"type":"message","id":"1423f7e7","parentId":"afd12b74","timestamp":"2026-04-08T07:52:37.915Z","message":{"role":"toolResult","toolCallId":"019d6c1422ce827283cfcdbb01f53aaa","toolName":"read","content":[{"type":"text","text":"      const result = await this.db.get('SELECT * FROM tasks WHERE id = ?', candidate.id);\n      await this.db.run('COMMIT');\n      return result;\n    } catch (err) {\n      await this.db.run('ROLLBACK').catch(() => {});\n      throw err;\n    }\n  }\n\n  _startBatchWriter() {\n    this.flushTimer = setInterval(async () => {\n      if (this.writeQueue.length === 0 || this.isClosing) return;\n\n      const batch = this.writeQueue.splice(0, this.batchSize);\n      try {\n        await this.db.run('BEGIN TRANSACTION');\n        for (const item of batch) {\n          await this.db.run(item.sql, item.params);\n        }\n        await this.db.run('COMMIT');\n      } catch (err) {\n        this.emit('error', err);\n        this.writeQueue.unshift(...batch);\n      }\n    }, this.flushInterval);\n\n[77 more lines in file. Use offset=170 to continue.]"}],"isError":false,"timestamp":1775634757904}}
{"type":"message","id":"97a3e08d","parentId":"1423f7e7","timestamp":"2026-04-08T07:53:03.946Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Let me update the _startBatchWriter function to add exponential backoff.\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"019d6c139f50674ade0aaf6c9f548633","name":"edit","arguments":{"edits":[{"newText":"  /**\n   * M2 修复：批量写入增加指数退避\n   */\n  _startBatchWriter() {\n    let backoffMs = 10;\n    const maxBackoffMs = 5000;\n    let consecutiveFailures = 0;\n\n    this.flushTimer = setInterval(async () => {\n      if (this.writeQueue.length === 0 || this.isClosing) {\n        // 成功后重置退避\n        backoffMs = 10;\n        consecutiveFailures = 0;\n        return;\n      }\n\n      const batch = this.writeQueue.splice(0, this.batchSize);\n      try {\n        await this.db.run('BEGIN TRANSACTION');\n        for (const item of batch) {\n          await this.db.run(item.sql, item.params);\n        }\n        await this.db.run('COMMIT');\n        // 成功后重置\n        backoffMs = 10;\n        consecutiveFailures = 0;\n      } catch (err) {\n        consecutiveFailures++;\n        this.emit('error', err);\n        this.writeQueue.unshift(...batch);\n        \n        // 指数退避\n        await new Promise(resolve => setTimeout(resolve, backoffMs));\n        backoffMs = Math.min(backoffMs * 2, maxBackoffMs);\n        \n        this.logger?.warn({ \n          consecutiveFailures, \n          backoffMs, \n          queueLength: this.writeQueue.length \n        }, 'Batch write failed, applying exponential backoff');\n      }\n    }, this.flushInterval);","oldText":"  _startBatchWriter() {\n    this.flushTimer = setInterval(async () => {\n      if (this.writeQueue.length === 0 || this.isClosing) return;\n\n      const batch = this.writeQueue.splice(0, this.batchSize);\n      try {\n        await this.db.run('BEGIN TRANSACTION');\n        for (const item of batch) {\n          await this.db.run(item.sql, item.params);\n        }\n        await this.db.run('COMMIT');\n      } catch (err) {\n        this.emit('error', err);\n        this.writeQueue.unshift(...batch);\n      }\n    }, this.flushInterval);"}],"path":"/home/ai/.openclaw/v8/src/persistence/TaskStore.js"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":2023,"output":580,"cacheRead":140672,"cacheWrite":0,"totalTokens":143275,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775634757923,"responseId":"019d6c13925d288dcbdb3693ae773cca"}}
