{"type":"message","id":"12e69f47","parentId":"08a2f6c0","timestamp":"2026-04-08T05:25:12.425Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"创建评分模块适配层（桥接 v7）。\n\n\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"019d6b8cb14fac806f59fdeea1c9430f","name":"exec","arguments":{"command":"cat > ~/.openclaw/v8/src/scoring/adapter.js << 'EOF'\n/**\n * 评分模块适配层 - 桥接 v7 评分逻辑\n * \n * 优先尝试加载 v7 评分模块，如果失败则使用内置简化实现\n */\n\nlet v7Scoring = null;\nlet v7QuickScore = null;\n\n// 尝试加载 v7 评分模块\ntry {\n  v7Scoring = require('../../../skills/task-orchestrator-v7/scoring.js');\n  v7QuickScore = require('../../../skills/task-orchestrator-v7/quick_score.js');\n} catch (err) {\n  console.warn('v7 scoring module not found, using built-in scorer');\n}\n\n/**\n * 评分入口函数\n * @param {string} prompt - 任务描述\n * @param {object} context - 可选上下文\n * @returns {object} 评分结果\n */\nfunction scoreTask(prompt, context = {}) {\n  // 如果 v7 可用，使用 v7\n  if (v7QuickScore && v7QuickScore.quickScore) {\n    try {\n      const raw = v7QuickScore.quickScore(prompt);\n      return {\n        score: raw.totalScore || raw.score || 0,\n        factors: raw.factors || {},\n        recommendedStrategy: raw.strategy || 'DIRECT',\n        timeout: raw.timeout || 30\n      };\n    } catch (err) {\n      console.warn('v7 scoring failed, using built-in scorer:', err.message);\n    }\n  }\n  \n  // 内置简化评分实现\n  return builtInScore(prompt, context);\n}\n\nfunction builtInScore(prompt, context = {}) {\n  let score = 0;\n  const factors = {\n    logicComplexity: 1,\n    risk: 1,\n    estimatedDuration: 1,\n    resourceCost: 1,\n    uncertainty: 1,\n    dependencyComplexity: 1\n  };\n\n  if (prompt.includes('refactor')) { factors.logicComplexity = 3; score += 3; }\n  if (prompt.includes('delete') || prompt.includes('rm ')) { factors.risk = 3; score += 3; }\n  if (prompt.includes('build') || prompt.includes('compile')) { factors.estimatedDuration = 3; score += 3; }\n  if (prompt.includes('test')) { factors.resourceCost = 2; score += 2; }\n  if (prompt.includes('api') || prompt.includes('http') || prompt.includes('fetch')) { factors.uncertainty = 2; score += 2; }\n  if (prompt.includes('monorepo') || prompt.includes('workspace')) { factors.dependencyComplexity = 3; score += 3; }\n  \n  // 代码行数估计\n  if (prompt.length > 500) { score += 2; factors.estimatedDuration = 3; }\n  else if (prompt.length > 200) { score += 1; factors.estimatedDuration = 2; }\n\n  let strategy = 'DIRECT';\n  let timeout = 30;\n  \n  if (score > 80) { strategy = 'MEGA_TASK'; timeout = 7200; }\n  else if (score > 60) { strategy = 'PARALLEL_SHARDS'; timeout = 160; }\n  else if (score > 40) { strategy = 'SPAWN_SUBAGENT'; timeout = 120; }\n  else if (score > 20) { strategy = 'STEP_ARCHIVE'; timeout = 60; }\n\n  return { score, factors, recommendedStrategy: strategy, timeout };\n}\n\nmodule.exports = { scoreTask, builtInScore };\nEOF"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":8790,"output":802,"cacheRead":111104,"cacheWrite":0,"totalTokens":120696,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775625875081,"responseId":"019d6b8ca1e5750e7951b1f4ecc4f46c"}}
