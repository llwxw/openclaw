{"type":"message","id":"f3e90932","parentId":"a22453e9","timestamp":"2026-04-08T05:32:50.447Z","message":{"role":"toolResult","toolCallId":"019d6b938923588ac664c32d4e471733","toolName":"exec","content":[{"type":"text","text":"=== 检查 SQLite 原子 dequeue 实现 ===\n   * 原子性 dequeue - 使用 BEGIN IMMEDIATE 防止多调度器实例重复取任务\n   */\n  async dequeue() {\n    const now = Date.now();\n    const leaseExpires = now + this.leaseTimeoutMs;\n\n--\n        `BEGIN IMMEDIATE;\n         UPDATE tasks\n         SET status = 'running', lease_expires = ?, updated_at = ?\n         WHERE id = (\n           SELECT id FROM tasks\n           WHERE status = 'pending'\n--\n        `BEGIN IMMEDIATE;"}],"details":{"status":"completed","exitCode":0,"durationMs":54,"aggregated":"=== 检查 SQLite 原子 dequeue 实现 ===\n   * 原子性 dequeue - 使用 BEGIN IMMEDIATE 防止多调度器实例重复取任务\n   */\n  async dequeue() {\n    const now = Date.now();\n    const leaseExpires = now + this.leaseTimeoutMs;\n\n--\n        `BEGIN IMMEDIATE;\n         UPDATE tasks\n         SET status = 'running', lease_expires = ?, updated_at = ?\n         WHERE id = (\n           SELECT id FROM tasks\n           WHERE status = 'pending'\n--\n        `BEGIN IMMEDIATE;","cwd":"/home/ai/.openclaw/workspace"},"isError":false,"timestamp":1775626370436}}
