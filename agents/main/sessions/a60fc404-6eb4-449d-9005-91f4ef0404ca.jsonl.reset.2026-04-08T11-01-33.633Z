复杂度特征\n      logic: {\n        low: /\\b(if|for|while|case)\\b/,\n        medium: /\\b(function|=>|switch|try|catch)\\b/,\n        high: /\\b(recursive|async|await|Promise\\.all|reduce|map-filter)\\b/,\n        extreme: /\\b(generator|iterator|proxy|reflect|async\\*|yield\\*)\\b/\n      },\n      // 风险特征\n      risk: {\n        network: /\\b(curl|wget|fetch|axios|http\\.request|https\\.request)\\b/,\n        external: /\\b(exec|spawn|eval|require|import|pip install|npm install|yarn)\\b/,\n        interactive: /\\b(input|readline|prompt|stdin|child_process)\\b/,\n        file: /\\b(writeFile|writeFileSync|rm -rf|unlink|mkdir)\\b/,\n        system: /\\b(sudo|chmod|chown|system|shell)\\b/\n      },\n      // 时长预估特征\n      duration: {\n        long: /\\b(sleep|wait|tar|gzip|make|compile|build|docker build|podman build)\\b/,\n        medium: /\\b(git clone|docker pull|pip install|npm install|yarn|apt-get)\\b/,\n        quick: /\\b(grep|find|awk|sed|cat|head|tail|ls|cd)\\b/\n      },\n      // 资源消耗特征\n      resource: {\n        heavy: /\\b(gcc|clang|cargo|cmake|rustc|go build)\\b/,\n        medium: /\\b(node|python|java|ruby|php|go run)\\b/,\n        light: /\\b(bash|sh|perl|ruby -e)\\b/,\n        io: /\\b(cp|mv|rsync|scp|dd|ddrescue)\\b/\n      },\n      // 不确定性特征\n      uncertainty: {\n        externalApi: /\\b(api|API|REST|GraphQL|webhook|WebHook)\\b/,\n        flaky: /\\b(maybe|perhaps|possibly|不确定|随机)\\b/,\n        experimental: /\\b(beta|alpha|experimental|preview)\\b/,\n        timing: /\\b(race|timeout|retry|backoff|exponential)\\b/\n      },\n      // 依赖复杂度特征\n      dependency: {\n        manyDeps: /\\b(dependencies|requires|imports|package\\.json|requirements\\.txt)\\b/,\n        version: /\\b(version|~|\\^|>=|<=|==)\\b/,\n        monorepo: /\\b(monorepo|workspace|lerna|nx|turbo)\\b/\n      }\n    };\n  }\n  \n  /**\n   * 多源输入适配\n   * 支持: taskSpec 对象、纯文本、消息数组\n   */\n  adaptInput(input) {\n    if (!input) return { type: 'empty', spec: {} };\n    \n    // 情况1: 已经是 taskSpec 对象\n    if (typeof input === 'object' && 'spec' in input) {\n      return { type: 'taskSpec', spec: input.spec, original: input };\n    }\n    \n    // 情况2: 纯文本描述\n    if (typeof input === 'string') {\n      return { type: 'text', spec: { description: input }, original: input };\n    }\n    \n    // 情况3: 消息数组 (从对话历史提取任务)\n    if (Array.isArray(input)) {\n      const lastMsg = input[input.length - 1];\n      const spec = {\n        description: lastMsg?.content || '',\n        messageHistory: input.slice(-5)\n      };\n      return { type: 'messages', spec, original: input };\n    }\n    \n    // 情况4: 直接对象\n    if (typeof input === 'object') {\n      return { type: 'object', spec: input, original: input };\n    }\n    \n    return { type: 'unknown', spec: {}, original: input };\n  }\n  \n  /**\n   * 核心评分算法 - 详细因子计算\n   */\n  calculateFactors(spec) {\n    const specStr = JSON.stringify(spec);\n    const factors = {};\n    \n    // 1. 逻辑复杂度 (0-3)\n    factors.logic = this._calcLogicScore(specStr);\n    \n    // 2. 风险度 (0-3)\n    factors.risk = this._calcRiskScore(specStr);\n    \n    // 3. 预估时长 (0-3)\n    factors.duration = this._calcDurationScore(specStr);\n    \n    // 4. 资源消耗 (0-3)\n    factors.resource = this._calcResourceScore(specStr);\n    \n    // 5. 不确定性 (0-3) - 新增维度\n    factors.uncertainty = this._calcUncertaintyScore(specStr, spec);\n    \n    // 6. 依赖复杂度 (0-3) - 新增维度\n    factors.dependency = this._calcDependencyScore(specStr);\n    \n    // 计算加权总分\n    factors.total = this._calcWeightedTotal(factors);\n    \n    return factors;\n  }\n  \n  _calcLogicScore(str) {\n    const fl = this.featureLibrary.logic;\n    let score = 0;\n    \n    if (fl.extreme.test(str)) return 3;\n    if (fl.high.test(str)) score = 2;\n    else if (fl.medium.test(str)) score = 1;\n    \n    // 统计复杂度\n    const branchCount = (str.match(/\\b(if|for|while|case|function|=>|switch)\\b/g) || []).length;\n    if (branchCount > 10) score = Math.min(3, score + 1);\n    \n    return Math.min(3, score);\n  }\n  \n  _calcRiskScore(str) {\n    const fl = this.featureLibrary.risk;\n    let score = 0;\n    \n    if (fl.system.test(str)) return 3;\n    if (fl.file.test(str)) score = Math.max(score, 2);\n    if (fl.interactive.test(str)) score = Math.max(score, 3);\n    if (fl.external.test(str)) score = Math.max(score, 2);\n    if (fl.network.test(str)) score = Math.max(score, 1);\n    \n    return Math.min(3, score);\n  }\n  \n  _calcDurationScore(str) {\n    const fl = this.featureLibrary.duration;\n    \n    if (fl.long.test(str)) return 3;\n    if (fl.medium.test(str)) return 2;\n    if (fl.quick.test(str)) return 0;\n    return 1;\n  }\n  \n  _calcResourceScore(str) {\n    const fl = this.featureLibrary.resource;\n    \n    if (fl.heavy.test(str)) return 3;\n    if (fl.medium.test(str)) return 2;\n    if (fl.io.test(str)) return 1;\n    if (fl.light.test(str)) return 0;\n    return 1;\n  }\n  \n  _calcUncertaintyScore(str, spec) {\n    const fl = this.featureLibrary.uncertainty;\n    let score = 0;\n    \n    if (fl.flaky.test(str)) score = Math.max(score, 2);\n    if (fl.experimental.test(str)) score = Math.max(score, 2);\n    if (fl.timing.test(str)) score = Math.max(score, 1);\n    if (fl.externalApi.test(str)) score = Math.max(score, 1);\n    \n    // 从 spec 推断不确定性\n    if (spec?.options?.length > 3) score = Math.max(score, 2);\n    if (spec?.conditional) score = Math.max(score, 1);\n    \n    return Math.min(3, score);\n  }\n  \n  _calcDependencyScore(str) {\n    const fl = this.featureLibrary.dependency;\n    let score = 0;\n    \n    if (fl.monorepo.test(str)) return 3;\n    if (fl.manyDeps.test(str)) score = 2;\n    if (fl.version.test(str)) score = 1;\n    \n    // 统计包管理器特征\n    const pkgCount = (str.match(/(npm|yarn|pnpm|pip|cargo|go get|bundler)/g) || []).length;\n    if (pkgCount > 2) score = Math.max(score, 2);\n    \n    return Math.min(3, score);\n  }\n  \n  _calcWeightedTotal(factors) {\n    let total = 0;\n    for (const [key, weight] of Object.entries(this.weights)) {\n      total += (factors[key] || 0) * weight;\n    }\n    return Math.round(total * 10) / 10;\n  }\n  \n  /**\n   * 权重自适应学习\n   * 根据历史评分与实际表现调整权重\n   */\n  learnFromOutcome(scoredFactors, outcome) {\n    if (!this.adaptiveLearning) return;\n    \n    this.scoringHistory.push({ factors: scoredFactors, outcome, timestamp: Date.now() });\n    \n    if (this.scoringHistory.length > this.learningWindow) {\n      this.scoringHistory.shift();\n    }\n    \n    if (this.scoringHistory.length >= 5) {\n      this._adaptWeights();\n    }\n  }\n  \n  _adaptWeights() {\n    const recent = this.scoringHistory.slice(-10);\n    const successRate = recent.filter(r => r.outcome.success).length / recent.length;\n    \n    if (successRate < 0.5) {\n      this.weights.risk = Math.min(2.5, this.weights.risk + 0.1);\n    }\n  }\n  \n  /**\n   * 主评分入口 (带缓存)\n   */\n  score(input, options = {}) {\n    const adapted = this.adaptInput(input);\n    const cacheKey = JSON.stringify(adapted.spec);\n    \n    // 检查缓存\n    if (!options.noCache && this.scoreCache.has(cacheKey)) {\n      const cached = this.scoreCache.get(cacheKey);\n      if (Date.now() - cached.timestamp < this.cacheTTL) {\n        return { ...cached.result, fromCache: true };\n      }\n    }\n    \n    const factors = this.calculateFactors(adapted.spec);\n    \n    const result = {\n      ...factors,\n      inputType: adapted.type,\n      timestamp: Date.now()\n    };\n    \n    this.scoreCache.set(cacheKey, { result, timestamp: Date.now() });\n    \n    if (this.scoreCache.size > 100) {\n      const firstKey = this.scoreCache.keys().next().value;\n      this.scoreCache.delete(firstKey);\n    }\n    \n    return result;\n  }\n  \n  clearCache() {\n    this.scoreCache.clear();\n  }\n  \n  getWeights() {\n    return { ...this.weights };\n  }\n  \n  setWeights(newWeights) {\n    this.weights = { ...this.weights, ...newWeights };\n  }\n}\n\nexport const taskScorerV7 = new TaskScorerV7();\nexport default taskScorerV7;\n```\n\n---\n\n继续读取其他文件..."}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":57199,"output":3041,"cacheRead":384,"cacheWrite":0,"totalTokens":60624,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"stop","timestamp":1775618477045,"responseId":"019d6b1b09e5625c2cf86819c570f3e5"}}
