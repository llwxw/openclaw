{"type":"message","id":"01d79018","parentId":"60300670","timestamp":"2026-04-08T05:52:38.652Z","message":{"role":"toolResult","toolCallId":"019d6ba5c4ae56ef194c9e5ce8b4b4d0","toolName":"read","content":[{"type":"text","text":"server:\n  port: 3103\n  host: \"0.0.0.0\"\n\ndatabase:\n  path: \"./data/tasks.db\"\n  wal: true\n  synchronous: \"NORMAL\"\n  busyTimeout: 5000\n\nscheduler:\n  pollIntervalMin: 10\n  pollIntervalMax: 1000\n  leaseTimeoutSec: 60\n  staleRecoveryIntervalSec: 60\n  maxConcurrentTasks: 10\n\nexecutor:\n  workspaceRoot: \"/tmp/openclaw-workspace\"\n  allowedCommands:\n    - \"npm\"\n    - \"npx\"\n    - \"node\"\n    - \"python\"\n    - \"python3\"\n    - \"make\"\n    - \"go\"\n    - \"cargo\"\n    - \"git\"\n    - \"ls\"\n    - \"echo\"\n    - \"cat\"\n    - \"mkdir\"\n    - \"rm\"\n    - \"sleep\"\n    - \"cat\"\n    - \"mkdir\"\n  maxOutputBytes: 10485760\n  idleTimeoutSec: 30\n  memoryLimitMB: 512\n  cpuTimeLimitSec: 300\n  uid: 65534\n  gid: 65534\n\nsecurity:\n  rateLimit:\n    enabled: true\n    maxPerSecond: 2\n    burst: 5\n  secretMasking:\n    enabled: true\n    patterns:\n      - \"password\"\n      - \"token\"\n      - \"secret\"\n      - \"key\"\n      - \"authorization\"\n\ncontext:\n  maxContextTokens: 128000\n  summarizeThreshold: 0.8\n  chunkSize: 4096\n\nlogging:\n  level: \"info\"\n  format: \"json\"\n  file: \"./logs/openclaw.log\"\n\nhealth:\n  disk:\n    path: \"/\"\n    warningThreshold: 85\n    criticalThreshold: 95\n  memory:\n    warningThreshold: 80\n    criticalThreshold: 90\n"}],"isError":false,"timestamp":1775627558640}}
