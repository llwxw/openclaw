{"type":"message","id":"ba37a621","parentId":"815040fa","timestamp":"2026-04-08T05:25:54.398Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在创建优雅停机模块和主入口文件。\n\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"019d6b8dbd15ea0f1c4ecf7b4abc2f5a","name":"exec","arguments":{"command":"cat > ~/.openclaw/v8/src/utils/gracefulShutdown.js << 'EOF'\nfunction setupGracefulShutdown(server, scheduler, taskStore, logger) {\n  let shuttingDown = false;\n\n  const shutdown = async (signal) => {\n    if (shuttingDown) return;\n    shuttingDown = true;\n    logger.info({ signal }, 'Starting graceful shutdown...');\n\n    server.close(async () => {\n      logger.info('HTTP server closed');\n    });\n\n    await scheduler.stop();\n    await taskStore.close();\n\n    logger.info('Shutdown complete');\n    process.exit(0);\n  };\n\n  process.on('SIGTERM', () => shutdown('SIGTERM'));\n  process.on('SIGINT', () => shutdown('SIGINT'));\n}\n\nmodule.exports = { setupGracefulShutdown };\nEOF"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":1699,"output":193,"cacheRead":119808,"cacheWrite":0,"totalTokens":121700,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775625944020,"responseId":"019d6b8db3319668552b6218b3c075c6"}}
