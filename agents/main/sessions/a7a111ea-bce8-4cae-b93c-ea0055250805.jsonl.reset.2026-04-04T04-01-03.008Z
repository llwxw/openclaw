         streamingContent: '',\r\n        })\r\n        get().addRecentFile(path)\r\n      },\r\n\r\n      saveFile: async (content: string) => {\r\n        const { currentFile } = get()\r\n        if (!currentFile) return\r\n        set({ currentFile: { ...currentFile, content } })\r\n      },\r\n\r\n      setAIOutput: (output: string) => set({ aiOutput: output }),\r\n      setStreamingContent: (content: string) => set({ streamingContent: content }),\r\n      setIsGenerating: (val: boolean) => set({ isGenerating: val }),\r\n      setIsStreaming: (val: boolean) => set({ isStreaming: val }),\r\n\r\n      resetWorkspace: () => set({\r\n        currentFile: null,\r\n        aiOutput: '',\r\n        streamingContent: '',\r\n        isGenerating: false,\r\n\n[34 more lines in file. Use offset=81 to continue.]"}],"isError":false,"timestamp":1775274422032}}
