EOUT_LEVELS.LONG;\r\n  return TIMEOUT_LEVELS.NORMAL;\r\n}\r\n\r\n// 硬编码豆包API配置 - 作为回退机制\r\nconst HARCODED_DOUBAO_CONFIG = {\r\n  apiKey: 'bef1c53c-e4da-4067-abf0-182c4f0daa7c',\r\n  endpointIds: {\r\n    pro: 'ep-20260401204837-jklzh',      // 豆包 Seed-2.0 Pro","cwd":"/home/ai/.openclaw/workspace"},"isError":false,"timestamp":1775273917206}}
