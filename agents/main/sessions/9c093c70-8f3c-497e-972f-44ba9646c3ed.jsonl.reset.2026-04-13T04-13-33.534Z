{"type":"message","id":"25c39734","parentId":"48c8ba3f","timestamp":"2026-04-12T19:25:20.410Z","message":{"role":"toolResult","toolCallId":"call_function_fyls2ap60q63_1","toolName":"exec","content":[{"type":"text","text":"// ws-proxy.js\n// 高鲁棒 WebSocket 代理 + 自动任务评分 + 实时提示\n// 版本: 2.0.0\n\nconst WebSocket = require('ws');\nconst crypto = require('crypto');\nconst { detectIntent } = require('./intentDetector');\nconst { computeFineScore, getExecutionPlan } = require('./scoring');\n\n// ========== 配置（支持环境变量） ==========\nconst CONFIG = {\n gatewayWsUrl: process.env.OPENCLAW_WS_URL || 'ws://localhost:3108', // Gateway 端口\n proxyPort: parseInt(process.env.PROXY_WS_PORT || '3103', 10),\n heartbeatIntervalMs: parseInt(process.env.HEARTBEAT_INTERVAL_MS || '30000', 10),\n connectionTimeoutMs: parseInt(process.env.CONNECTION_TIMEOUT_MS || '10000', 10),\n maxReconnectAttempts: parseInt(process.env.MAX_RECONNECT_ATTEMPTS || '5', 10),\n reconnectBaseDelayMs: parseInt(process.env.RECONNECT_BASE_DELAY_MS || '1000', 10),\n maxCachedMessages: parseInt(process.env.MAX_CACHED_MESSAGES || '100', 10),\n maxMessageSizeBytes: parseInt(process.env.MAX_MESSAGE_SIZE_BYTES || '1048576', 10),\n enableRateLimit: process.env.ENABLE_RATE_LIMIT !== 'false', // 默认开启\n rateLimitPerSec: parseInt(process.env.RATE_LIMIT_PER_SEC || '10', 10),\n healthPort: parseInt(process.env.HEALTH_PORT || '3104', 10),\n // 评分相关配置\n enableScoring: process.env.ENABLE_SCORING !== 'false',\n scoringTimeoutMs: parseInt(process.env.SCORING_TIMEOUT_MS || '2000', 10),\n sendHint: process.env.SEND_HINT !== 'false',\n hintCooldownMs: parseInt(process.env.HINT_COOLDOWN_MS || '5000', 10),\n};\n\n// ========== 辅助函数 ==========\n---\nexpress\nws"}],"details":{"status":"completed","exitCode":0,"durationMs":49,"aggregated":"// ws-proxy.js\n// 高鲁棒 WebSocket 代理 + 自动任务评分 + 实时提示\n// 版本: 2.0.0\n\nconst WebSocket = require('ws');\nconst crypto = require('crypto');\nconst { detectIntent } = require('./intentDetector');\nconst { computeFineS