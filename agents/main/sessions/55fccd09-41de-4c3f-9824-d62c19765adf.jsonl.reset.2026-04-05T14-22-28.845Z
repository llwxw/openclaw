{"type":"message","id":"05ec1ff9","parentId":"3266858c","timestamp":"2026-04-05T07:18:49.858Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"我需要实现超大任务执行器，包含分片并行、检查点续传和结果聚合。这是v7.0的重要功能。\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"019d5c7fe1b89cea87b6bf30477631e0","name":"write","arguments":{"content":"/**\n * OpenClaw 超大任务执行器 v7.0\n * \n * 功能：\n * - 自动分片策略（文件列表、数值范围、哈希）\n * - 并行执行（多核利用）\n * - 检查点与断点续传\n * - 结果聚合\n * \n * 存放位置: ~/.openclaw/workspace/skills/task-orchestrator-v7/mega_executor.js\n */\n\nimport { spawn } from 'child_process';\nimport * as fs from 'fs/promises';\nimport * as path from 'path';\nimport * as os from 'os';\nimport crypto from 'crypto';\n\n// 检查点存储目录\nconst CHECKPOINT_DIR = path.join(process.env.HOME || '/home/ai', '.openclaw', 'checkpoints');\n\nclass MegaExecutor {\n  constructor(options = {}) {\n    this.maxConcurrent = options.maxConcurrent || Math.max(1, os.cpus().length - 2);\n    this.checkpointDir = options.checkpointDir || CHECKPOINT_DIR;\n    this.defaultShardSize = options.defaultShardSize || 50;\n    this.enableCheckpoint = options.enableCheckpoint !== false;\n    this.timeoutMs = options.timeoutMs || 300000; // 5分钟默认超时\n  }\n\n  /**\n   * 初始化检查点目录\n   */\n  async init() {\n    await fs.mkdir(this.checkpointDir, { recursive: true });\n  }\n\n  /**\n   * 主入口：执行超大任务\n   */\n  async execute(taskSpec, options = {}) {\n    const {\n      mode = 'files',           // files | range | hash\n      shardSize = this.defaultShardSize,\n      command,\n      onProgress,\n      resume = false\n    } = options;\n\n    // 生成任务ID\n    const taskId = this._generateTaskId(taskSpec);\n    \n    // 获取分片\n    let shards = [];\n    if (resume) {\n      shards = await this._loadRemainingShards(taskId);\n    } else {\n      shards = await this._createShards(taskSpec, mode, shardSize);\n    }\n\n    if (shards.length === 0) {\n      return { success: true, output: 'No work to do', shardsProcessed: 0 };\n    }\n\n    // 并行执行\n    const results = await this._executeParallel(\n      taskId, \n      shards, \n      command, \n      onProgress\n    );\n\n    // 聚合结果\n    const aggregated = this._aggregateResults(results);\n\n    // 清理检查点\n    if (this.enableCheckpoint) {\n      await this._cleanupCheckpoint(taskId);\n    }\n\n    return {\n      success: aggregated.success,\n      output: aggregated.output,\n      shardsProcessed: shards.length,\n      totalShards: shards.length,\n      results: results.slice(0, 10) // 只返回前10个详细结果\n    };\n  }\n\n  /**\n   * 生成任务ID\n   */\n  _generateTaskId(spec) {\n    const str = typeof spec === 'string' ? spec : JSON.stringify(spec);\n    return crypto.createHash('md5').update(str).digest('hex').substring(0, 8);\n  }\n\n  /**\n   * 创建分片\n   */\n  async _createShards(taskSpec, mode, shardSize) {\n    switch (mode) {\n      case 'files':\n        return this._shardByFiles(taskSpec, shardSize);\n      case 'range':\n        return this._shardByRange(taskSpec, shardSize);\n      case 'hash':\n        return this._shardByHash(taskSpec, shardSize);\n      default:\n        // 默认单任务\n        return [{ index: 0, data: taskSpec }];\n    }\n  }\n\n  /**\n   * 文件列表分片\n   */\n  async _shardByFiles(inputDir, shardSize) {\n    const files = await this._globFiles(inputDir);\n    const shards = [];\n    \n    for (let i = 0; i < files.length; i += shardSize) {\n      shards.push({\n        index: shards.length,\n        files: files.slice(i, i + shardSize),\n        range: [i, Math.min(i + shardSize, files.length) - 1]\n      });\n    }\n    \n    return shards;\n  }\n\n  /**\n   * 递归获取文件列表\n   */\n  async _globFiles(dir) {\n    const files = [];\n    \n    try {\n      const entries = await fs.readdir(dir, { withFileTypes: });\n      \n      for (const entry of entries) {\n        const fullPath = path.join(dir, entry.name);\n        \n        if (entry.isDirectory()) {\n          const subFiles = await this._globFiles(fullPath);\n          files.push(...subFiles);\n        } else if (entry.isFile()) {\n          files.push(fullPath);\n        }\n      }\n    } catch (e) {\n      // 如果输入是文件而非目录，直接返回\n      if (typeof dir === 'string') {\n        files.push(dir);\n      }\n    }\n    \n    return files;\n  }\n\n  /**\n   * 数值范围分片\n   */\n  _shardByRange(spec, shardSize) {\n    const { start = 1, end = 100 } = spec;\n    const shards = [];\n    \n    for (let i = start; i <= end; i += shardSize) {\n      shards.push({\n        index: shards.length,\n        start: i,\n        end: Math.min(i + shardSize - 1, end),\n        data: { start: i, end: Math.min(i + shardSize - 1, end) }\n      });\n    }\n    \n    return shards;\n  }\n\n  /**\n   * 哈希分片\n   */\n  _shardByHash(items, shardSize) {\n    const shards = [];\n    const numShards = Math.ceil(items.length / shardSize);\n    \n    for (let i = 0; i < numShards; i++) {\n      const shardItems = items.slice(i * shardSize, (i + 1) * shardSize);\n      shards.push({\n        index: i,\n        items: shardItems,\n        hash: crypto.createHash('md5').update(JSON.stringify(shardItems)).digest('hex').substring(0, 8)\n      });\n    }\n    \n    return shards;\n  }\n\n  /**\n   * 并行执行分片\n   */\n  async _executeParallel(taskId, shards, command, onProgress) {\n    const results = [];\n    let completed = 0;\n    const total = shards.length;\n    \n    // 使用信号量控制并发\n    const semaphore = Promise.all(\n      Array(this.maxConcurrent).fill(null)\n    );\n    \n    // 分批执行\n    for (let i = 0; i < shards.length; i += this.maxConcurrent) {\n      const batch = shards.slice(i, i + this.maxConcurrent);\n      \n      const batchResults = await Promise.all(\n        batch.map(async (shard) => {\n          const result = await this._executeShard(taskId, shard, command);\n          \n          // 更新进度\n          completed++;\n          const progress = Math.round((completed / total) * 100);\n          onProgress?.(progress, completed, total);\n          \n          // 保存检查点\n          if (this.enableCheckpoint) {\n            await this._saveCheckpoint(taskId, shard.index, result);\n          }\n          \n          return { shard, result };\n        })\n      );\n      \n      results.push(...batchResults);\n    }\n    \n    return results;\n  }\n\n  /**\n   * 执行单个分片\n   */\n  async _executeShard(taskId, shard, command) {\n    return new Promise((resolve) => {\n      const startTime = Date.now();\n      let stdout = '';\n      let stderr = '';\n      \n      // 根据分片类型构建命令\n      const cmd = this._buildCommand(command, shard);\n      \n      const child = spawn(cmd.shell, cmd.args, {\n        stdio: ['pipe', 'pipe', 'pipe'],\n        env: { ...process.env, ...cmd.env }\n      });\n      \n      const timeout = setTimeout(() => {\n        child.kill('SIGKILL');\n        resolve({\n          success: false,\n          error: 'Timeout',\n          duration: Date.now() - startTime\n        });\n      }, this.timeoutMs);\n      \n      child.stdout.on('data', (data) => { stdout += data.toString(); });\n      child.stderr.on('data', (data) => { stderr += data.toString(); });\n      \n      child.on('close', (code) => {\n        clearTimeout(timeout);\n        resolve({\n          success: code === 0,\n          code,\n          stdout: stdout.substring(0, 10000), // 限制输出长度\n          stderr: stderr.substring(0, 5000),\n          duration: Date.now() - startTime,\n          shardIndex: shard.index\n        });\n      });\n      \n      child.on('error', (err) => {\n        clearTimeout(timeout);\n        resolve({\n          success: false,\n          error: err.message,\n          duration: Date.now() - startTime,\n          shardIndex: shard.index\n        });\n      });\n    });\n  }\n\n  /**\n   * 构建命令\n   */\n  _buildCommand(command, shard) {\n    // 如果 command 是函数，使用它生成命令\n    if (typeof command === 'function') {\n      return command(shard);\n    }\n    \n    // 如果是字符串模板\n    if (typeof command === 'string') {\n      return {\n        shell: '/bin/bash',\n        args: ['-c', command.replace('${shard}', JSON.stringify(shard.data || shard.files || shard))],\n        env: {}\n      };\n    }\n    \n    // 默认：直接执行\n    return {\n      shell: '/bin/echo',\n      args: [JSON.stringify(shard)],\n      env: {}\n    };\n  }\n\n  /**\n   * 保存检查点\n   */\n  async _saveCheckpoint(taskId, shardIndex, result) {\n    const checkpointFile = path.join(this.checkpointDir, `${taskId}_${shardIndex}.json`);\n    await fs.writeFile(checkpointFile, JSON.stringify({\n      shardIndex,\n      result,\n      completedAt: Date.now()\n    }));\n  }\n\n  /**\n   * 加载剩余未完成的分片\n   */\n  async _loadRemainingShards(taskId) {\n    // 找到所有该任务的检查点\n    const files = await fs.readdir(this.checkpointDir);\n    const completed = new Set();\n    \n    for (const file of files) {\n      if (file.startsWith(taskId)) {\n        const index = parseInt(file.split('_')[1]?.replace('.json', ''));\n        if (!isNaN(index)) {\n          completed.add(index);\n        }\n      }\n    }\n    \n    // 返回未完成的分片索引\n    return Array.from(completed).sort((a, b) => a - b).map(i => ({ index: i, resumed: true }));\n  }\n\n  /**\n   * 清理检查点\n   */\n  async _cleanupCheckpoint(taskId) {\n    const files = await fs.readdir(this.checkpointDir);\n    \n    for (const file of files) {\n      if (file.startsWith(taskId)) {\n        await fs.unlink(path.join(this.checkpointDir, file));\n      }\n    }\n  }\n\n  /**\n   * 聚合结果\n   */\n  _aggregateResults(results) {\n    const outputs = [];\n    let successCount = 0;\n    let failedCount = 0;\n    \n    for (const { result } of results) {\n      if (result.success) {\n        successCount++;\n        if (result.stdout) {\n          outputs.push(result.stdout);\n        }\n      } else {\n        failedCount++;\n      }\n    }\n    \n    return {\n      success: failedCount === 0,\n      output: outputs.join('\\n'),\n      successCount,\n      failedCount,\n      totalCount: results.length\n    };\n  }\n}\n\n// 导出单例\nexport const megaExecutor = new MegaExecutor();\nexport default megaExecutor;","file":"~/.openclaw/workspace/skills/task-orchestrator-v7/mega_executor.js"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":6871,"output":2571,"cacheRead":74112,"cacheWrite":0,"totalTokens":83554,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775373366114,"responseId":"019d5c7face2e66e86ba56a0ed10918f"}}
