{"type":"message","id":"833ea4ce","parentId":"2ba9ebf0","timestamp":"2026-04-05T07:20:32.755Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"分片并行模块已创建。现在创建上下文保护模块。\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"019d5c82380be2de804222c4aa028107","name":"write","arguments":{"content":"/**\n * OpenClaw 上下文保护模块 v7.0\n * \n * 功能：\n * - 增量 token 计数（精确计算）\n * - 智能压缩策略\n * - 检查点备份\n * - 手动触发命令\n * \n * 存放位置: ~/.openclaw/workspace/skills/task-orchestrator-v7/context_protector.js\n */\n\nimport * as fs from 'fs/promises';\nimport * as path from 'path';\n\n// 存储目录\nconst STORAGE_DIR = path.join(process.env.HOME || '/home/ai', '.openclaw', 'context');\nconst BACKUP_SUFFIX = '.backup';\n\nclass ContextProtector {\n  constructor(options = {}) {\n    this.storageDir = options.storageDir || STORAGE_DIR;\n    this.maxMessages = options.maxMessages || 50;\n    this.maxChars = options.maxChars || 100 * 1024; // 100KB\n    this.maxTokens = options.maxTokens || 150000;   // GPT-4 上下文限制的 80%\n    this.keepRecent = options.keepRecent || 10;\n    this.enableBackup = options.enableBackup !== false;\n    \n    this.messages = [];\n    this.totalTokens = 0;\n    this.lastCompressAt = 0;\n  }\n\n  /**\n   * 初始化\n   */\n  async init() {\n    await fs.mkdir(this.storageDir, { recursive: true });\n  }\n\n  /**\n   * 添加消息（增量 token 计数）\n   */\n  async addMessage(role, content, metadata = {}) {\n    const tokenCount = await this._countTokens(content);\n    \n    this.messages.push({\n      role,\n      content,\n      metadata,\n      timestamp: Date.now(),\n      tokens: tokenCount\n    });\n    \n    this.totalTokens += tokenCount;\n    \n    // 检查是否需要压缩\n    if (this.shouldCompress()) {\n      await this.compress();\n    }\n    \n    return {\n      messageCount: this.messages.length,\n      totalTokens: this.totalTokens,\n      shouldCompress: this.shouldCompress()\n    };\n  }\n\n  /**\n   * 检查是否需要压缩\n   */\n  shouldCompress() {\n    const msgCount = this.messages.length;\n    const totalChars = this.messages.reduce((sum, m) => sum + (m.content?.length || 0), 0);\n    \n    return (\n      msgCount >= this.maxMessages ||\n      totalChars >= this.maxChars ||\n      this.totalTokens >= this.maxTokens\n    );\n  }\n\n  /**\n   * 增量 token 计数（简单实现，使用 TikToken 风格估算）\n   * 生产环境建议使用 tiktoken 库\n   */\n  async _countTokens(text) {\n    if (!text) return 0;\n    \n    // 简单估算：中文字符 × 2 + 英文单词 × 1.3 + 特殊字符\n    const chineseChars = (text.match(/[\\u4e00-\\u9fa5]/g) || []).length;\n    const englishWords = (text.match(/[a-zA-Z0-9_]+/g) || []).length;\n    \n    // TikToken 风格估算\n    // 汉字约 1.5 tokens/字符，英文约 0.25 tokens/字符\n    return Math.ceil(chineseChars * 1.5 + englishWords * 0.25 + text.length * 0.25);\n  }\n\n  /**\n   * 压缩上下文\n   */\n  async compress(force = false) {\n    if (!force && !this.shouldCompress()) {\n      return { skipped: true, reason: 'Not needed' };\n    }\n    \n    // 备份当前上下文\n    if (this.enableBackup) {\n      await this._backup();\n    }\n    \n    const beforeCount = this.messages.length;\n    const beforeTokens = this.totalTokens;\n    \n    // 策略1：保留最近 N 条\n    const recent = this.messages.slice(-this.keepRecent);\n    \n    // 策略2：对早前的消息生成摘要\n    const toSummarize = this.messages.slice(0, -this.keepRecent);\n    \n    if (toSummarize.length > 0) {\n      // 生成摘要（这里使用简单实现，生产环境可调用 LLM）\n      const summary = this._generateSummary(toSummarize);\n      recent.unshift({\n        role: 'system',\n        content: `[上下文压缩] 之前的 ${toSummarize.length} 条消息已压缩为摘要：${summary}`,\n        metadata: { type: 'compression_summary', originalCount: toSummarize.length },\n        timestamp: Date.now(),\n        tokens: await this._countTokens(summary)\n      });\n      \n      this.totalTokens = recent.reduce((sum, m) => sum + m.tokens, 0);\n    }\n    \n    this.messages = recent;\n    this.lastCompressAt = Date.now();\n    \n    return {\n      beforeCount,\n      afterCount: this.messages.length,\n      beforeTokens,\n      afterTokens: this.totalTokens,\n      compressed: toSummarize.length,\n      timestamp: this.lastCompressAt\n    };\n  }\n\n  /**\n   * 生成简单摘要（简化版）\n   */\n  _generateSummary(messages) {\n    // 提取关键信息\n    const roles = [...new Set(messages.map(m => m.role))];\n    const totalLength = messages.reduce((sum, m) => sum + (m.content?.length || 0), 0);\n    \n    return `[{${roles.join(',')}} 消息, 约 ${Math.round(totalLength/1000)}K 字符]`;\n  }\n\n  /**\n   * 备份当前上下文\n   */\n  async _backup() {\n    const backupFile = path.join(\n      this.storageDir, \n      `context_${Date.now()}${BACKUP_SUFFIX}.json`\n    );\n    \n    await fs.writeFile(backupFile, JSON.stringify({\n      messages: this.messages,\n      totalTokens: this.totalTokens,\n      compressedAt: this.lastCompressAt\n    }, null, 2));\n  }\n\n  /**\n   * 回滚到上一个备份\n   */\n  async rollback() {\n    const files = await fs.readdir(this.storageDir);\n    const backups = files\n      .filter(f => f.endsWith(BACKUP_SUFFIX + '.json'))\n      .sort()\n      .reverse();\n    \n    if (backups.length === 0) {\n      return { success: false, reason: 'No backup found' };\n    }\n    \n    const latestBackup = path.join(this.storageDir, backups[0]);\n    const data = JSON.parse(await fs.readFile(latestBackup, 'utf8'));\n    \n    this.messages = data.messages;\n    this.totalTokens = data.totalTokens;\n    this.lastCompressAt = data.compressedAt || 0;\n    \n    return {\n      success: true,\n      restoredFrom: backups[0],\n      messageCount: this.messages.length\n    };\n  }\n\n  /**\n   * 获取状态\n   */\n  getStatus() {\n    const totalChars = this.messages.reduce((sum, m) => sum + (m.content?.length || 0), 0);\n    \n    return {\n      messageCount: this.messages.length,\n      totalTokens: this.totalTokens,\n      totalChars,\n      tokenRatio: (this.totalTokens / this.maxTokens * 100).toFixed(1) + '%',\n      shouldCompress: this.shouldCompress(),\n      lastCompressAt: this.lastCompressAt\n    };\n  }\n\n  /**\n   * 获取消息历史\n   */\n  getMessages(limit = null) {\n    if (limit) {\n      return this.messages.slice(-limit);\n    }\n    return this.messages;\n  }\n\n  /**\n   * 手动触发压缩\n   */\n  async summarize() {\n    return this.compress(true);\n  }\n}\n\n// 导出单例\nexport const contextProtector = new ContextProtector();\nexport default contextProtector;","file":"~/.openclaw/workspace/skills/task-orchestrator-v7/context_protector.js"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":2828,"output":1708,"cacheRead":80768,"cacheWrite":0,"totalTokens":85304,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775373529892,"responseId":"019d5c822ae6f4f3e49d34287c81730f"}}
