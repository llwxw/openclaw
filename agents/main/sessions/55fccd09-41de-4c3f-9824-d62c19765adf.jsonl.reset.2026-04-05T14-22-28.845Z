{"type":"message","id":"0053ff3c","parentId":"14e82fc3","timestamp":"2026-04-05T07:13:48.298Z","message":{"role":"toolResult","toolCallId":"019d5c7d8687bb5863e91258844f65f8","toolName":"sessions_history","content":[{"type":"text","text":"{\n  \"sessionKey\": \"agent:main:subagent:4ba01455-9f9d-443d-aa2d-1eb6a1af0398\",\n  \"messages\": [\n    {\n      \"role\": \"assistant\",\n      \"content\": [\n        {\n          \"type\": \"thinking\",\n          \"thinking\": \"现在我有了足够的信息来实现 v7.0。我将创建一个完整的模块，包含以下核心部分：\\n\\n1. **评分因子垂直拓展** - 多源输入适配、因子计算详细算法、权重自适应\\n2. **路由决策垂直拓展** - 动态阈值调整、用户覆盖机制、分数到路由的映射配置化\\n3. **上下文保护** - 增量 token 计数与压缩、压缩策略优化\\n4. 其他模块的核心逻辑\\n\\n让我开始创建文件：\\n\"\n        },\n        {\n          \"type\": \"text\",\n          \"text\": \"\\n\\n现在我已经了解了现有保护层架构。开始实现 v7.0 任务编排核心模块：\\n\"\n        },\n        {\n          \"type\": \"toolCall\",\n          \"id\": \"019d5c78fdaffbbe592c134a6a086337\",\n          \"name\": \"write\",\n          \"arguments\": {\n            \"content\": \"/**\\n * OpenClaw 任务编排系统 v7.0\\n * \\n * 核心模块：评分因子 + 路由决策 + 上下文保护\\n * \\n * 存放位置: ~/.openclaw/workspace/skills/task-orchestrator-v7/\\n * \\n * 八大核心模块:\\n * 1. 评分因子垂直拓展 - 多源输入适配、因子计算详细算法、权重自适应\\n * 2. 路由决策垂直拓展 - 动态阈值调整、用户覆盖机制、分数到路由的映射配置化\\n * 3. 超大任务执行器 - 自动分片策略、检查点与断点续传、结果聚合\\n * 4. 上下文保护 - 增量 token 计数与压缩、压缩策略优化\\n * 5. 子代理进度上报 - 自适应心跳间隔、输出解析容错、限流与聚合\\n * 6. 安全模块 - 命令白名单动态管理、路径沙箱、敏感信息脱敏\\n * 7. 效率优化 - 评分结果缓存、异步日志、连接池\\n * 8. 部署与运维 - 健康检查端点、Prometheus 指标、配置热重载、日志轮转\\n */\\n\\nimport * as fs from 'fs';\\nimport * as path from 'path';\\nimport * as os from 'os';\\n\\n// ============ 模块1: 评分因子垂直拓展 =============\\n/**\\n * 评分因子系统 v7.0\\n * - 多源输入适配: 支持 taskSpec、文本、对话历史\\n * - 因子计算详细算法: 细分每个评分维度\\n * - 权重自适应: 根据历史表现动态调整权重\\n */\\nclass TaskScorerV7 {\\n  constructor(options = {}) {\\n    // 基础阈值\\n    this.thresholds = options.thresholds || {\\n      direct: 2,\\n      step: 5,\\n      spawn: 8,\\n      multi: 12\\n    };\\n    \\n    // 因子权重配置 (可调整)\\n    this.weights = options.weights || {\\n      logic: 1.0,\\n      risk: 1.5,        // 风险权重最高\\n      duration: 0.8,\\n      resource: 0.8,\\n      uncertainty: 1.2, // 不确定性权重\\n      dependency: 1.0   // 依赖复杂度\\n    };\\n    \\n    // 缓存\\n    this.scoreCache = new Map();\\n    this.cacheTTL = options.cacheTTL || 30000; // 30秒缓存\\n    \\n    // 权重自适应学习\\n    this.weightHistory = [];\\n    this.adaptiveLearning = options.adaptiveLearning !== false;\\n    this.learningWindow = 20; // 学习窗口大小\\n    \\n    // 评分历史（用于权重自适应）\\n    this.scoringHistory = [];\\n    \\n    // 命令特征库\\n    this.featureLibrary = this._initFeatureLibrary();\\n  }\\n  \\n  _initFeatureLibrary() {\\n    return {\\n      // 逻辑复杂度特征\\n      logic: {\\n        low: /\\\\b(if|for|while|case)\\\\b/,\\n        medium: /\\\\b(function|=>|switch|try|catch)\\\\b/,\\n        high: /\\\\b(recursive|async|await|Promise\\\\.all|reduce|map-filter)\\\\b/,\\n        extreme: /\\\\b(generator|iterator|proxy|reflect|async\\\\*|yield\\\\*)\\\\b/\\n      },\\n      // 风险特征\\n      risk: {\\n        network: /\\\\b(curl|wget|fetch|axios|http\\\\.request|https\\\\.request)\\\\b/,\\n        external: /\\\\b(exec|spawn|eval|require|import|pip install|npm install|yarn)\\\\b/,\\n        interactive: /\\\\b(input|readline|prompt|stdin|child_process)\\\\b/,\\n        file: /\\\\b(writeFile|writeFileSync|rm -rf|unlink|mkdir)\\\\b/,\\n        system: /\\\\b(sudo|chmod|chown|system|shell)\\\\b/\\n      },\\n      // 时长预估特征\\n      duration: {\\n        long: /\\\\b(sleep|wait|tar|gzip|make|compile|build|docker build|podman build)\\\\b/,\\n        medium: /\\\\b(git clone|docker pull|pip install|npm install|yarn|apt-get)\\\\b/,\\n        quick: /\\\\b(grep|find|awk|sed|cat|head|tail|ls|cd)\\\\b/\\n      },\\n      // 资源消耗特征\\n      resource: {\\n        heavy: /\\\\b(gcc|clang|cargo|cmake|rustc|go build)\\\\b/,\\n        medium: /\\\\b(node|python|java|ruby|php|go run)\\\\b/,\\n        light: /\\\\b(bash|sh|perl|ruby -e)\\\\b/,\\n        io: /\\\\b(cp|mv|rsync|scp|dd|ddrescue)\\\\b/\\n      },\\n      // 不确定性特征\\n      uncertainty: {\\n        externalApi: /\\\\b(api|API|REST|GraphQL|webhook|WebHook)\\\\b/,\\n        flaky: /\\\\b(maybe|perhaps|possibly|不确定|随机)\\\\b/,\\n        experimental: /\\\\b(beta|alpha|experimental|preview)\\\\b/,\\n        timing: /\\\\b(race|timeout|retry|backoff|exponential)\\\\b/\\n      },\\n      // 依赖复杂度特征\\n      dependency: {\\n        manyDeps: /\\\\b(dependencies|requires|imports|package\\\\.json|requirements\\\\.txt)\\\\b/,\\n        version: /\\\\b(version|~|\\\\^|>=|<=|==)\\\\b/,\\n        monorepo: /\\\\b(monorepo|workspace|lerna|nx|turbo)\\\\b/\\n      }\\n    };\\n  }\\n  \\n  /**\\n   * 多源输入适配\\n   * 支持: taskSpec 对象、纯文本、消息数组\\n   */\\n  adaptInput(input) {\\n    if (!input) return { type: 'empty', spec: {} };\\n    \\n    // 情况1: 已经是 taskSpec 对象\\n    if (typeof input === 'object' && 'spec' in input) {\\n      return { type: 'taskSpec', spec: input.spec, original: input };\\n    }\\n    \\n    // 情况2: 纯文本描述\\n    if (typeof input === 'string') {\\n      return { type: 'text', spec: { description: input }, original: input };\\n    }\\n    \\n    // 情况3: 消息数组 (从对话历史提取任务)\\n    if (Array.isArray(input)) {\\n      const lastMsg = input[input.length - 1];\\n      const spec = {\\n        description: lastMsg?.content || '',\\n        messageHistory: input.slice(-5)\\n      };\\n      return { type: 'messages', spec, original: input };\\n    }\\n    \\n    // 情况4: 直接对象\\n    if (typeof input === 'object') {\\n      return { type: 'object', spec: input, original: input };\\n    }\\n    \\n    return { type: 'unknown', spec: {}, original: input };\\n  }\\n  \\n  /**\\n   * 核心评分算法 - 详细因子计算\\n   */\\n  calculateFactors(spec) {\\n    const specStr = JSON.stringify(spec);\\n    const factors = {};\\n    \\n    // 1. 逻辑复杂度 (0-3)\\n    factors.logic = this._calcLogicScore(specStr);\\n    \\n    // 2. 风险度 (0-3)\\n    factors.risk = this._calcRiskScore(specStr);\\n    \\n    // 3. 预估时长 (0-3)\\n    factors.duration = this._calcDurationScore(specStr);\\n    \\n    // 4. 资源消耗 (0-3)\\n    factors.resource = this._calcResourceScore(specStr);\\n    \\n    // 5. 不确定性 (0-3) - 新增维度\\n    factors.uncertainty = this._calcUncertaintyScore(specStr, spec);\\n    \\n    // 6. 依赖复杂度 (0-3) - 新增维度\\n    factors.dependency = this._calcDependencyScore(specStr);\\n    \\n    // 计算加权总分\\n    factors.total = this._calcWeightedTotal(factors);\\n    \\n    return factors;\\n  }\\n  \\n  _calcLogicScore(str) {\\n    const fl = this.featureLibrary.logic;\\n    let score = 0;\\n    \\n    if (fl.extreme.test(str)) return 3;\\n    if (fl.high.test(str)) score = 2;\\n    else if (fl.medium.test(str)) score = 1;\\n    \\n    // 统计复杂度\\n    const branchCount = (str.match(/\\\\b(if|for|while|case|function|=>|switch)\\\\b/g) || []).length;\\n    if (branchCount > 10) score = Math.min(3, score + 1);\\n    \\n    return Math.min(3, score);\\n  }\\n  \\n  _calcRiskScore(str) {\\n    const fl = this.featureLibrary.risk;\\n    let score = 0;\\n    \\n    if (fl.system.test(str)) return 3;\\n    if (fl.file.test(str)) score = Math.max(score, 2);\\n    if (fl.interactive.test(str)) score = Math.max(score, 3);\\n    if (fl.external.test(str)) score = Math.max(score, 2);\\n    if (fl.network.test(str)) score = Math.max(score, 1);\\n    \\n    return Math.min(3, score);\\n  }\\n  \\n  _calcDurationScore(str) {\\n    const fl = this.featureLibrary.duration;\\n    \\n    if (fl.long.test(str)) return 3;\\n    if (fl.medium.test(str)) return 2;\\n    if (fl.quick.test(str)) return 0;\\n    return 1;\\n  }\\n  \\n  _calcResourceScore(str) {\\n    const fl = this.featureLibrary.resource;\\n    \\n    if (fl.heavy.test(str)) return 3;\\n    if (fl.medium.test(str)) return 2;\\n    if (fl.io.test(str)) return 1;\\n    if (fl.light.test(str)) return 0;\\n    return 1;\\n  }\\n  \\n  _calcUncertaintyScore(str, spec) {\\n    const fl = this.featureLibrary.uncertainty;\\n    let score = 0;\\n    \\n    if (fl.flaky.test(str)) score = Math.max(score, 2);\\n    if (fl.experimental.test(str)) score = Math.max(score, 2);\\n    if (fl.timing.test(str)) score = Math.max(score, 1);\\n    if (fl.externalApi.test(str)) score = Math.max(score, 1);\\n    \\n    // 从 spec 推断不确定性\\n    if (spec?.options?.length > 3) score = Math.max(score, 2);\\n    if (spec?.conditional) score = Math.max(score, 1);\\n    \\n    return Math.min(3, score);\\n  }\\n  \\n  _calcDependencyScore(str) {\\n    const fl = this.featureLibrary.dependency;\\n    let score = 0;\\n    \\n    if (fl.monorepo.test(str)) return 3;\\n    if (fl.manyDeps.test(str)) score = 2;\\n    if (fl.version.test(str)) score = 1;\\n    \\n    // 统计包管理器特征\\n    const pkgCount = (str.match(/(npm|yarn|pnpm|pip|cargo|go get|bundler)/g) || []).length;\\n    if (pkgCount > 2) score = Math.max(score, 2);\\n    \\n    return Math.min(3, score);\\n  }\\n  \\n  _calcWeightedTotal(factors) {\\n    let total = 0;\\n    for (const [key, weight] of Object.entries(this.weights)) {\\n      total += (factors[key] || 0) * weight;\\n    }\\n    return Math.round(total * 10) / 10;\\n  }\\n  \\n  /**\\n   * 权重自适应学习\\n   * 根据历史评分与实际表现调整权重\\n   */\\n  learnFromOutcome(scoredFactors, outcome) {\\n    if (!this.adaptiveLearning) return;\\n    \\n    this.scoringHistory.push({ factors: scoredFactors, outcome, timestamp: Date.now() });\\n    \\n    // 只保留最近的学习窗口\\n    if (this.scoringHistory.length > this.learningWindow) {\\n      this.scoringHistory.shift();\\n    }\\n    \\n    // 简单的权重调整逻辑\\n    if (this.scoringHistory.length >= 5) {\\n      this._adaptWeights();\\n    }\\n  }\\n  \\n  _adaptWeights() {\\n    // 计算各因子与outcome的相关性，调整权重\\n    // 这里是一个简化的实现\\n    const recent = this.scoringHistory.slice(-10);\\n    const successRate = recent.filter(r => r.outcome.success).length / recent.length;\\n    \\n    // 根据成功率微调权重\\n    if (successRate < 0.5) {\\n      // 成功率低，增加风险权重\\n      this.weights.risk = Math.min(2.5, this.weights.risk + 0.1);\\n    }\\n  }\\n  \\n  /**\\n   * 主评分入口 (带缓存)\\n   */\\n  score(input, options = {}) {\\n    const adapted = this.adaptInput(input);\\n    const cacheKey = JSON.stringify(adapted.spec);\\n    \\n    // 检查缓存\\n    if (!options.noCache && this.scoreCache.has(cacheKey)) {\\n      const cached = this.scoreCache.get(cacheKey);\\n      if (Date.now() - cached.timestamp < this.cacheTTL) {\\n        return { ...cached.result, fromCache: true };\\n      }\\n    }\\n    \\n    // 计算因子\\n    const factors = this.calculateFactors(adapted.spec);\\n    \\n    // 添加输入类型信息\\n    const result = {\\n      ...factors,\\n      inputType: adapted.type,\\n      timestamp: Date.now()\\n    };\\n    \\n    // 缓存结果\\n    this.scoreCache.set(cacheKey, { result, timestamp: Date.now() });\\n    \\n    // 限制缓存大小\\n    if (this.scoreCache.size > 100) {\\n      const firstKey = this.scoreCache.keys().next().value;\\n      this.scoreCache.delete(firstKey);\\n    }\\n    \\n    return result;\\n  }\\n  \\n  /**\\n   * 清除缓存\\n   */\\n  clearCache() {\\n    this.scoreCache.clear();\\n  }\\n  \\n  /**\\n   * 获取权重配置\\n   */\\n  getWeights() {\\n    return { ...this.weights };\\n  }\\n  \\n  /**\\n   * 动态调整权重\\n   */\\n  setWeights(newWeights) {\\n    this.weights = { ...this.weights, ...newWeights };\\n  }\\n}\\n\\nexport const taskScorerV7 = new TaskScorerV7();\\nexport default taskScorerV7;\",\n            \"filePath\": \"~/.openclaw/workspace/skills/task-orchestrator-v7/scoring.js\"\n          }\n        }\n      ],\n      \"api\": \"openai-completions\",\n      \"provider\": \"codingplan\",\n      \"model\": \"minimax-m2.5\",\n      \"stopReason\": \"toolUse\",\n      \"timestamp\": 1775372942891,\n      \"responseId\": \"019d5c78b0f083f85f0351a418a57684\",\n      \"__openclaw\": {\n        \"id\": \"89578245\",\n        \"seq\": 11\n      }\n    },\n    {\n      \"role\": \"assistant\",\n      \"content\": [\n        {\n          \"type\": \"thinking\",\n          \"thinking\": \"现在让我创建路由决策模块 v7.0。\\n\"\n        },\n        {\n          \"type\": \"text\",\n          \"text\": \"\\n\\n\\n\"\n        }\n      ],\n      \"api\": \"openai-completions\",\n      \"provider\": \"codingplan\",\n      \"model\": \"minimax-m2.5\",\n      \"stopReason\": \"aborted\",\n      \"timestamp\": 1775373107321,\n      \"responseId\": \"019d5c7b3555d2b8125157d879f0ad01\",\n      \"errorMessage\": \"Request was aborted\",\n      \"__openclaw\": {\n        \"id\": \"0a4f24c8\",\n        \"seq\": 13\n      }\n    }\n  ],\n  \"truncated\": true,\n  \"droppedMessages\": false,\n  \"contentTruncated\": true,\n  \"contentRedacted\": false,\n  \"bytes\": 12669\n}"}],"details":{"sessionKey":"agent:main:subagent:4ba01455-9f9d-443d-aa2d-1eb6a1af0398","messages":[{"role":"assistant","content":[{"type":"thinking","thinking":"现在我有了足够的信息来实现 v7.0。我将创建一个完整的模块，包含以下核心部分：\n\n1. **评分因子垂直拓展** - 多源输入适配、因子计算详细算法、权重自适应\n2. **路由决策垂直拓展** - 动态阈值调整、用户覆盖机制、分数到路由的映射配置化\n3. **上下文保护** - 增量 token 计数与压缩、压缩策略优化\n4. 其他模块的核心逻辑\n\n让我开始创建文件：\n"},{"type":"text","text":"\n\n现在我已经了解了现有保护层架构。开始实现 v7.0 任务编排核心模块：\n"},{"type":"toolCall","id":"019d5c78fdaffbbe592c134a6a086337","name":"write","arguments":{"content":"/**\n * OpenClaw 任务编排系统 v7.0\n * \n * 核心模块：评分因子 + 路由决策 + 上下文保护\n * \n * 存放位置: ~/.openclaw/workspace/skills/task-orchestrator-v7/\n * \n * 八大核心模块:\n * 1. 评分因子垂直拓展 - 多源输入适配、因子计算详细算法、权重自适应\n * 2. 路由决策垂直拓展 - 动态阈值调整、用户覆盖机制、分数到路由的映射配置化\n * 3. 超大任务执行器 - 自动分片策略、检查点与断点续传、结果聚合\n * 4. 上下文保护 - 增量 token 计数与压缩、压缩策略优化\n * 5. 子代理进度上报 - 自适应心跳间隔、输出解析容错、限流与聚合\n * 6. 安全模块 - 命令白名单动态管理、路径沙箱、敏感信息脱敏\n * 7. 效率优化 - 评分结果缓存、异步日志、连接池\n * 8. 部署与运维 - 健康检查端点、Prometheus 指标、配置热重载、日志轮转\n */\n\nimport * as fs from 'fs';\nimport * as path from 'path';\nimport * as os from 'os';\n\n// ============ 模块1: 评分因子垂直拓展 =============\n/**\n * 评分因子系统 v7.0\n * - 多源输入适配: 支持 taskSpec、文本、对话历史\n * - 因子计算详细算法: 细分每个评分维度\n * - 权重自适应: 根据历史表现动态调整权重\n */\nclass TaskScorerV7 {\n  constructor(options = {}) {\n    // 基础阈值\n    this.thresholds = options.thresholds || {\n      direct: 2,\n      step: 5,\n      spawn: 8,\n      multi: 12\n    };\n    \n    // 因子权重配置 (可调整)\n    this.weights = options.weights || {\n      logic: 1.0,\n      risk: 1.5,        // 风险权重最高\n      duration: 0.8,\n      resource: 0.8,\n      uncertainty: 1.2, // 不确定性权重\n      dependency: 1.0   // 依赖复杂度\n    };\n    \n    // 缓存\n    this.scoreCache = new Map();\n    this.cacheTTL = options.cacheTTL || 30000; // 30秒缓存\n    \n    // 权重自适应学习\n    this.weightHistory = [];\n    this.adaptiveLearning = options.adaptiveLearning !== false;\n    this.learningWindow = 20; // 学习窗口大小\n    \n    // 评分历史（用于权重自适应）\n    this.scoringHistory = [];\n    \n    // 命令特征库\n    this.featureLibrary = this._initFeatureLibrary();\n  }\n  \n  _initFeatureLibrary() {\n    return {\n      // 逻辑复杂度特征\n      logic: {\n        low: /\\b(if|for|while|case)\\b/,\n        medium: /\\b(function|=>|switch|try|catch)\\b/,\n        high: /\\b(recursive|async|await|Promise\\.all|reduce|map-filter)\\b/,\n        extreme: /\\b(generator|iterator|proxy|reflect|async\\*|yield\\*)\\b/\n      },\n      // 风险特征\n      risk: {\n        network: /\\b(curl|wget|fetch|axios|http\\.request|https\\.request)\\b/,\n        external: /\\b(exec|spawn|eval|require|import|pip install|npm install|yarn)\\b/,\n        interactive: /\\b(input|readline|prompt|stdin|child_process)\\b/,\n        file: /\\b(writeFile|writeFileSync|rm -rf|unlink|mkdir)\\b/,\n        system: /\\b(sudo|chmod|chown|system|shell)\\b/\n      },\n      // 时长预估特征\n      duration: {\n        long: /\\b(sleep|wait|tar|gzip|make|compile|build|docker build|podman build)\\b/,\n        medium: /\\b(git clone|docker pull|pip install|npm install|yarn|apt-get)\\b/,\n        quick: /\\b(grep|find|awk|sed|cat|head|tail|ls|cd)\\b/\n      },\n      // 资源消耗特征\n      resource: {\n        heavy: /\\b(gcc|clang|cargo|cmake|rustc|go build)\\b/,\n        medium: /\\b(node|python|java|ruby|php|go run)\\b/,\n        light: /\\b(bash|sh|perl|ruby -e)\\b/,\n        io: /\\b(cp|mv|rsync|scp|dd|ddrescue)\\b/\n      },\n      // 不确定性特征\n      uncertainty: {\n        externalApi: /\\b(api|API|REST|GraphQL|webhook|WebHook)\\b/,\n        flaky: /\\b(maybe|perhaps|possibly|不确定|随机)\\b/,\n        experimental: /\\b(beta|alpha|experimental|preview)\\b/,\n        timing: /\\b(race|timeout|retry|backoff|exponential)\\b/\n      },\n      // 依赖复杂度特征\n      dependency: {\n        manyDeps: /\\b(dependencies|requires|imports|package\\.json|requirements\\.txt)\\b/,\n        version: /\\b(version|~|\\^|>=|<=|==)\\b/,\n        monorepo: /\\b(monorepo|workspace|lerna|nx|turbo)\\b/\n      }\n    };\n  }\n  \n  /**\n   * 多源输入适配\n   * 支持: taskSpec 对象、纯文本、消息数组\n   */\n  adaptInput(input) {\n    if (!input) return { type: 'empty', spec: {} };\n    \n    // 情况1: 已经是 taskSpec 对象\n    if (typeof input === 'object' && 'spec' in input) {\n      return { type: 'taskSpec', spec: input.spec, original: input };\n    }\n    \n    // 情况2: 纯文本描述\n    if (typeof input === 'string') {\n      return { type: 'text', spec: { description: input }, original: input };\n    }\n    \n    // 情况3: 消息数组 (从对话历史提取任务)\n    if (Array.isArray(input)) {\n      const lastMsg = input[input.length - 1];\n      const spec = {\n        description: lastMsg?.content || '',\n        messageHistory: input.slice(-5)\n      };\n      return { type: 'messages', spec, original: input };\n    }\n    \n    // 情况4: 直接对象\n    if (typeof input === 'object') {\n      return { type: 'object', spec: input, original: input };\n    }\n    \n    return { type: 'unknown', spec: {}, original: input };\n  }\n  \n  /**\n   * 核心评分算法 - 详细因子计算\n   */\n  calculateFactors(spec) {\n    const specStr = JSON.stringify(spec);\n    const factors = {};\n    \n    // 1. 逻辑复杂度 (0-3)\n    factors.logic = this._calcLogicScore(specStr);\n    \n    // 2. 风险度 (0-3)\n    factors.risk = this._calcRiskScore(specStr);\n    \n    // 3. 预估时长 (0-3)\n    factors.duration = this._calcDurationScore(specStr);\n    \n    // 4. 资源消耗 (0-3)\n    factors.resource = this._calcResourceScore(specStr);\n    \n    // 5. 不确定性 (0-3) - 新增维度\n    factors.uncertainty = this._calcUncertaintyScore(specStr, spec);\n    \n    // 6. 依赖复杂度 (0-3) - 新增维度\n    factors.dependency = this._calcDependencyScore(specStr);\n    \n    // 计算加权总分\n    factors.total = this._calcWeightedTotal(factors);\n    \n    return factors;\n  }\n  \n  _calcLogicScore(str) {\n    const fl = this.featureLibrary.logic;\n    let score = 0;\n    \n    if (fl.extreme.test(str)) return 3;\n    if (fl.high.test(str)) score = 2;\n    else if (fl.medium.test(str)) score = 1;\n    \n    // 统计复杂度\n    const branchCount = (str.match(/\\b(if|for|while|case|function|=>|switch)\\b/g) || []).length;\n    if (branchCount > 10) score = Math.min(3, score + 1);\n    \n    return Math.min(3, score);\n  }\n  \n  _calcRiskScore(str) {\n    const fl = this.featureLibrary.risk;\n    let score = 0;\n    \n    if (fl.system.test(str)) return 3;\n    if (fl.file.test(str)) score = Math.max(score, 2);\n    if (fl.interactive.test(str)) score = Math.max(score, 3);\n    if (fl.external.test(str)) score = Math.max(score, 2);\n    if (fl.network.test(str)) score = Math.max(score, 1);\n    \n    return Math.min(3, score);\n  }\n  \n  _calcDurationScore(str) {\n    const fl = this.featureLibrary.duration;\n    \n    if (fl.long.test(str)) return 3;\n    if (fl.medium.test(str)) return 2;\n    if (fl.quick.test(str)) return 0;\n    return 1;\n  }\n  \n  _calcResourceScore(str) {\n    const fl = this.featureLibrary.resource;\n    \n    if (fl.heavy.test(str)) return 3;\n    if (fl.medium.test(str)) return 2;\n    if (fl.io.test(str)) return 1;\n    if (fl.light.test(str)) return 0;\n    return 1;\n  }\n  \n  _calcUncertaintyScore(str, spec) {\n    const fl = this.featureLibrary.uncertainty;\n    let score = 0;\n    \n    if (fl.flaky.test(str)) score = Math.max(score, 2);\n    if (fl.experimental.test(str)) score = Math.max(score, 2);\n    if (fl.timing.test(str)) score = Math.max(score, 1);\n    if (fl.externalApi.test(str)) score = Math.max(score, 1);\n    \n    // 从 spec 推断不确定性\n    if (spec?.options?.length > 3) score = Math.max(score, 2);\n    if (spec?.conditional) score = Math.max(score, 1);\n    \n    return Math.min(3, score);\n  }\n  \n  _calcDependencyScore(str) {\n    const fl = this.featureLibrary.dependency;\n    let score = 0;\n    \n    if (fl.monorepo.test(str)) return 3;\n    if (fl.manyDeps.test(str)) score = 2;\n    if (fl.version.test(str)) score = 1;\n    \n    // 统计包管理器特征\n    const pkgCount = (str.match(/(npm|yarn|pnpm|pip|cargo|go get|bundler)/g) || []).length;\n    if (pkgCount > 2) score = Math.max(score, 2);\n    \n    return Math.min(3, score);\n  }\n  \n  _calcWeightedTotal(factors) {\n    let total = 0;\n    for (const [key, weight] of Object.entries(this.weights)) {\n      total += (factors[key] || 0) * weight;\n    }\n    return Math.round(total * 10) / 10;\n  }\n  \n  /**\n   * 权重自适应学习\n   * 根据历史评分与实际表现调整权重\n   */\n  learnFromOutcome(scoredFactors, outcome) {\n    if (!this.adaptiveLearning) return;\n    \n    this.scoringHistory.push({ factors: scoredFactors, outcome, timestamp: Date.now() });\n    \n    // 只保留最近的学习窗口\n    if (this.scoringHistory.length > this.learningWindow) {\n      this.scoringHistory.shift();\n    }\n    \n    // 简单的权重调整逻辑\n    if (this.scoringHistory.length >= 5) {\n      this._adaptWeights();\n    }\n  }\n  \n  _adaptWeights() {\n    // 计算各因子与outcome的相关性，调整权重\n    // 这里是一个简化的实现\n    const recent = this.scoringHistory.slice(-10);\n    const successRate = recent.filter(r => r.outcome.success).length / recent.length;\n    \n    // 根据成功率微调权重\n    if (successRate < 0.5) {\n      // 成功率低，增加风险权重\n      this.weights.risk = Math.min(2.5, this.weights.risk + 0.1);\n    }\n  }\n  \n  /**\n   * 主评分入口 (带缓存)\n   */\n  score(input, options = {}) {\n    const adapted = this.adaptInput(input);\n    const cacheKey = JSON.stringify(adapted.spec);\n    \n    // 检查缓存\n    if (!options.noCache && this.scoreCache.has(cacheKey)) {\n      const cached = this.scoreCache.get(cacheKey);\n      if (Date.now() - cached.timestamp < this.cacheTTL) {\n        return { ...cached.result, fromCache: true };\n      }\n    }\n    \n    // 计算因子\n    const factors = this.calculateFactors(adapted.spec);\n    \n    // 添加输入类型信息\n    const result = {\n      ...factors,\n      inputType: adapted.type,\n      timestamp: Date.now()\n    };\n    \n    // 缓存结果\n    this.scoreCache.set(cacheKey, { result, timestamp: Date.now() });\n    \n    // 限制缓存大小\n    if (this.scoreCache.size > 100) {\n      const firstKey = this.scoreCache.keys().next().value;\n      this.scoreCache.delete(firstKey);\n    }\n    \n    return result;\n  }\n  \n  /**\n   * 清除缓存\n   */\n  clearCache() {\n    this.scoreCache.clear();\n  }\n  \n  /**\n   * 获取权重配置\n   */\n  getWeights() {\n    return { ...this.weights };\n  }\n  \n  /**\n   * 动态调整权重\n   */\n  setWeights(newWeights) {\n    this.weights = { ...this.weights, ...newWeights };\n  }\n}\n\nexport const taskScorerV7 = new TaskScorerV7();\nexport default taskScorerV7;","filePath":"~/.openclaw/workspace/skills/task-orchestrator-v7/scoring.js"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","stopReason":"toolUse","timestamp":1775372942891,"responseId":"019d5c78b0f083f85f0351a418a57684","__openclaw":{"id":"89578245","seq":11}},{"role":"assistant","content":[{"type":"thinking","thinking":"现在让我创建路由决策模块 v7.0。\n"},{"type":"text","text":"\n\n\n"}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","stopReason":"aborted","timestamp":1775373107321,"responseId":"019d5c7b3555d2b8125157d879f0ad01","errorMessage":"Request was aborted","__openclaw":{"id":"0a4f24c8","seq":13}}],"truncated":true,"droppedMessages":false,"contentTruncated":true,"contentRedacted":false,"bytes":12669},"isError":false,"timestamp":1775373228291}}
