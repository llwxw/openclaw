{"type":"message","id":"d4507949","parentId":"c6ddc1a8","timestamp":"2026-04-05T06:20:25.937Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create the scripts for task_orchestrator to make it more modular, as suggested in the report. Let me create the scripts directory with the modular components.\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"call_f6a9a1b0bc5b47028ee2641c","name":"write","arguments":{"content":"// task_orchestrator/scripts/scoring.js\n// ========================= 评分路由模块 =========================\n// 复用 task-weight-estimator 的评分逻辑\n\nconst COMPLEXITY_THRESHOLDS = [1, 5, 10];\nconst UNCERTAINTY_PATTERNS = {\n  network: /\\b(curl|wget|npm install|pip install|git clone|docker pull|fetch|axios)\\b/,\n  interactive: /\\b(input|read|prompt|await)\\b/,\n  localApi: /(localhost|127\\.0\\.0\\.1|\\.test\\.com)/\n};\n\nfunction computeComplexity(taskSpec) {\n  if (!taskSpec || typeof taskSpec !== 'string') return 0;\n  const cmdCount = (taskSpec.match(/&&|;|\\n/g) || []).length + 1;\n  if (cmdCount <= COMPLEXITY_THRESHOLDS[0]) return 0;\n  if (cmdCount <= COMPLEXITY_THRESHOLDS[1]) return 1;\n  if (cmdCount <= COMPLEXITY_THRESHOLDS[2]) return 2;\n  return 3;\n}\n\nfunction computeUncertainty(taskSpec) {\n  if (!taskSpec || typeof taskSpec !== 'string') return 0;\n  if (UNCERTAINTY_PATTERNS.interactive.test(taskSpec)) return 3;\n  if (UNCERTAINTY_PATTERNS.network.test(taskSpec)) return 2;\n  if (UNCERTAINTY_PATTERNS.localApi.test(taskSpec)) return 1;\n  return 0;\n}\n\nfunction evaluate(taskSpec) {\n  const complexity = computeComplexity(taskSpec);\n  const uncertainty = computeUncertainty(taskSpec);\n  const total = Math.min(6, complexity + uncertainty);\n  const weight = Math.floor(total * 10 / 6);\n  return { complexity, uncertainty, total, weight };\n}\n\nfunction route(score) {\n  // 路由决策\n  if (score.total <= 1) {\n    return { mode: 'DIRECT', timeout: 30 };\n  } else if (score.total <= 3) {\n    return { mode: 'STEP_ARCHIVE', timeout: 60 };\n  } else if (score.total <= 5) {\n    return { mode: 'SPAWN_SUBAGENT', timeout: 120 };\n  } else {\n    return { mode: 'MULTI_SUBAGENT', timeout: 300 };\n  }\n}\n\nmodule.exports = { evaluate, route, computeComplexity, computeUncertainty };","file":"~/.openclaw/workspace/skills/task_orchestrator/scripts/scoring.js"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":21536,"output":605,"cacheRead":0,"cacheWrite":0,"totalTokens":22141,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775370018684,"responseId":"chatcmpl-6968c9c9-2066-4bbf-a869-8e4d4f1ec859"}}
