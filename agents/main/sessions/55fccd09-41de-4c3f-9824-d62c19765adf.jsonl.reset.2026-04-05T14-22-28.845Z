{"type":"message","id":"184736cf","parentId":"a9e6d1b7","timestamp":"2026-04-05T07:44:42.357Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"用户让我在主线程继续完成剩余的模块。这不需要评分，因为这是用户明确的指示。让我直接在主线程实现 security.js 和 optimizer.js。\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"call_a2b86c5e5703450eaa2a015d","name":"exec","arguments":{"command":"# 直接在主线程完成 security.js\ncat > ~/.openclaw/workspace/skills/task-orchestrator-v7/security.js << 'EOF'\n/**\n * OpenClaw 安全模块 v7.0\n * \n * 功能：\n * - 命令白名单动态管理\n * - 路径沙箱\n * - 敏感信息脱敏增强\n */\n\nimport fs from 'fs';\nimport path from 'path';\nimport { spawn } from 'child_process';\n\nclass SecurityModule {\n  constructor(options = {}) {\n    this.whitelistFile = options.whitelistFile || \n      path.join(process.env.HOME || '/home/ai', '.openclaw', 'security_whitelist.json');\n    this.sandboxDir = options.sandboxDir || \n      path.join(process.env.HOME || '/home/ai', '.openclaw', 'sandbox');\n    this.sensitivePatterns = options.sensitivePatterns || [\n      /password\\s*=\\s*[\"']?[^\"'\\s]+[\"']?/gi,\n      /token\\s*=\\s*[a-f0-9]{32,}/gi,\n      /api[_-]?key\\s*=\\s*[\"']?[^\"'\\s]+[\"']?/gi,\n      /Authorization:\\s*Bearer\\s+[a-zA-Z0-9._-]+/gi,\n      /secret\\s*=\\s*[\"']?[^\"'\\s]+[\"']?/gi,\n    ];\n    this.whitelist = [];\n    this._loadWhitelist();\n  }\n\n  _loadWhitelist() {\n    try {\n      if (fs.existsSync(this.whitelistFile)) {\n        const data = JSON.parse(fs.readFileSync(this.whitelistFile, 'utf8'));\n        this.whitelist = data.whitelist || [];\n      }\n    } catch (e) {\n      this.whitelist = [];\n    }\n    // 默认白名单\n    if (this.whitelist.length === 0) {\n      this.whitelist = [\n        '/usr/bin/ls', '/usr/bin/cat', '/usr/bin/grep', '/usr/bin/find',\n        '/usr/bin/head', '/usr/bin/tail', '/usr/bin wc', '/usr/bin/sort',\n        '/bin/bash', '/bin/sh', '/usr/bin/node', '/usr/bin/python3',\n      ];\n    }\n  }\n\n  /** 检查命令是否在白名单 */\n  isAllowed(command) {\n    const cmdStr = typeof command === 'string' ? command : command.cmd;\n    const parts = cmdStr.split(' ');\n    const baseCmd = parts[0];\n    \n    // 检查绝对路径\n    if (this.whitelist.includes(baseCmd)) return true;\n    \n    // 检查正则模式\n    for (const pattern of this.whitelist) {\n      if (pattern.startsWith('^')) {\n        const regex = new RegExp(pattern);\n        if (regex.test(baseCmd)) return true;\n      }\n    }\n    \n    return false;\n  }\n\n  /** 路径沙箱检查 */\n  safeResolve(baseDir, userPath) {\n    const resolved = path.resolve(baseDir, userPath);\n    if (!resolved.startsWith(baseDir)) {\n      throw new Error('Path traversal detected');\n    }\n    return resolved;\n  }\n\n  /** 敏感信息脱敏 */\n  redact(text) {\n    if (!text) return text;\n    let result = text;\n    for (const pattern of this.sensitivePatterns) {\n      result = result.replace(pattern, (match) => {\n        return match.replace(/=.*/, '=***');\n      });\n    }\n    return result;\n  }\n\n  /** 添加到白名单 */\n  addToWhitelist(cmd) {\n    if (!this.whitelist.includes(cmd)) {\n      this.whitelist.push(cmd);\n      this._saveWhitelist();\n    }\n  }\n\n  /** 从白名单移除 */\n  removeFromWhitelist(cmd) {\n    this.whitelist = this.whitelist.filter(c => c !== cmd);\n    this._saveWhitelist();\n  }\n\n  _saveWhitelist() {\n    try {\n      fs.mkdirSync(path.dirname(this.whitelistFile), { recursive: true });\n      fs.writeFileSync(this.whitelistFile, JSON.stringify({ whitelist: this.whitelist }, null, 2));\n    } catch (e) {}\n  }\n\n  /** 安全执行 */\n  safeExecute(command, options = {}) {\n    return new Promise((resolve, reject) => {\n      if (!this.isAllowed(command)) {\n        reject(new Error('Command not in whitelist'));\n        return;\n      }\n      \n      const cmd = typeof command === 'string' ? { shell: '/bin/bash', args: ['-c', command] } : command;\n      \n      // 脱敏日志\n      const safeCmd = this.redact(cmd.args?.join(' ') || cmd.shell);\n      console.log('[Security] Executing:', safeCmd);\n      \n      const child = spawn(cmd.shell, cmd.args, { stdio: 'pipe', ...options });\n      let stdout = '', stderr = '';\n      \n      child.stdout.on('data', d => stdout += d);\n      child.stderr.on('data', d => stderr += d);\n      \n      child.on('close', code => {\n        resolve({\n          code,\n          stdout: this.redact(stdout),\n          stderr: this.redact(stderr)\n        });\n      });\n      \n      child.on('error', reject);\n    });\n  }\n\n  getStatus() {\n    return {\n      whitelistCount: this.whitelist.length,\n      patternsCount: this.sensitivePatterns.length,\n      sandboxDir: this.sandboxDir\n    };\n  }\n}\n\nexport const security = new SecurityModule();\nexport default security;\nEOF\n\necho \"✅ security.js 已创建\"\n\n# 创建 optimizer.js\ncat > ~/.openclaw/workspace/skills/task-orchestrator-v7/optimizer.js << 'EOF'\n/**\n * OpenClaw 效率优化模块 v7.0\n * \n * 功能：\n * - 评分结果缓存 (LRU)\n * - 异步日志\n * - 健康检查端点\n */\n\nimport http from 'http';\nimport crypto from 'crypto';\n\nclass Optimizer {\n  constructor(options = {}) {\n    this.cacheTTL = options.cacheTTL || 3600000; // 1小时\n    this.maxCacheKeys = options.maxCacheKeys || 1000;\n    this.cache = new Map();\n    this.logBuffer = [];\n    this.healthPort = options.healthPort || 18791;\n    this.server = null;\n    \n    // 指标统计\n    this.stats = {\n      cacheHits: 0,\n      cacheMisses: 0,\n      tasksTotal: 0,\n      tasksByRoute: { DIRECT: 0, STEP_ARCHIVE: 0, SPAWN_SUBAGENT: 0, MULTI_SUBAGENT: 0 },\n      compressions: 0,\n    };\n  }\n\n  /** LRU 缓存 - 评分结果 */\n  getCachedScore(taskSpec) {\n    const key = this._hashTaskSpec(taskSpec);\n    const cached = this.cache.get(key);\n    \n    if (cached && Date.now() - cached.timestamp < this.cacheTTL) {\n      this.stats.cacheHits++;\n      return cached.score;\n    }\n    \n    this.stats.cacheMisses++;\n    return null;\n  }\n\n  /** 设置缓存 */\n  setCachedScore(taskSpec, score) {\n    const key = this._hashTaskSpec(taskSpec);\n    \n    // LRU 淘汰\n    if (this.cache.size >= this.maxCacheKeys) {\n      const firstKey = this.cache.keys().next().value;\n      this.cache.delete(firstKey);\n    }\n    \n    this.cache.set(key, { score, timestamp: Date.now() });\n  }\n\n  _hashTaskSpec(spec) {\n    const str = typeof spec === 'string' ? spec : JSON.stringify(spec);\n    return crypto.createHash('sha256').update(str).digest('hex').substring(0, 16);\n  }\n\n  /** 异步日志 - 不阻塞主线程 */\n  asyncLog(message, level = 'info') {\n    this.logBuffer.push({\n      timestamp: Date.now(),\n      level,\n      message: typeof message === 'string' ? message : JSON.stringify(message)\n    });\n    \n    // 异步写入（简化版，实际可用 pino/winston）\n    if (this.logBuffer.length >= 10) {\n      this._flushLogs();\n    }\n  }\n\n  _flushLogs() {\n    if (this.logBuffer.length === 0) return;\n    const logs = this.logBuffer.splice(0);\n    // 实际应该写入文件，这里简化为输出\n    // console.log('[Optimizer] Flushed', logs.length, 'logs');\n  }\n\n  /** 启动健康检查服务 */\n  startHealthServer() {\n    if (this.server) return;\n    \n    this.server = http.createServer((req, res) => {\n      res.setHeader('Access-Control-Allow-Origin', '*');\n      res.setHeader('Content-Type', 'application/json');\n      \n      if (req.url === '/health') {\n        res.end(JSON.stringify({\n          status: 'ok',\n          uptime: process.uptime(),\n          memory: process.memoryUsage(),\n          cache: {\n            size: this.cache.size,\n            hits: this.stats.cacheHits,\n            misses: this.stats.cacheMisses,\n            hitRate: this.stats.cacheHits / (this.stats.cacheHits + this.stats.cacheMisses) * 100 || 0\n          },\n          tasks: this.stats\n        }));\n      } else if (req.url === '/metrics') {\n        res.end(JSON.stringify(this.stats));\n      } else {\n        res.statusCode = 404;\n        res.end('Not Found');\n      }\n    });\n    \n    this.server.listen(this.healthPort, () => {\n      console.log(`[Optimizer] Health server: http://127.0.0.1:${this.healthPort}`);\n    });\n  }\n\n  /** 停止健康检查服务 */\n  stopHealthServer() {\n    if (this.server) {\n      this.server.close();\n      this.server = null;\n    }\n  }\n\n  /** 更新统计 */\n  updateStats(type, value) {\n    if (type in this.stats) {\n      this.stats[type]++;\n    }\n    if (type === 'route' && value in this.stats.tasksByRoute) {\n      this.stats.tasksByRoute[value]++;\n    }\n  }\n\n  getStatus() {\n    return {\n      cacheSize: this.cache.size,\n      cacheTTL: this.cacheTTL,\n      stats: this.stats,\n      healthServer: this.server ? 'running' : 'stopped'\n    };\n  }\n}\n\nexport const optimizer = new Optimizer();\nexport default optimizer;\nEOF\n\necho \"✅ optimizer.js 已创建\"\n\n# 验证\necho -e \"\\n=== 验证 ===\"\nls -la ~/.openclaw/workspace/skills/task-orchestrator-v7/*.js | wc -l\necho \"个模块\""}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":96800,"output":2298,"cacheRead":0,"cacheWrite":0,"totalTokens":99098,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775375047619,"responseId":"chatcmpl-ad473c74-5e79-48d5-bd24-39246fa19d93"}}
