{"type":"message","id":"5e011835","parentId":"0f635416","timestamp":"2026-04-05T08:58:03.211Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"用户确认执行，开始创建意图判断模块。\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"call_ed1876d9daa147b891c5a4f9","name":"write","arguments":{"content":"/**\n * 意图判断模块 - 区分任务与询问\n * \n * 五维设计：科学性、鲁棒性、灵活性、可嵌入性、效率性\n * \n * 功能：\n * - 当前消息特征提取\n * - 对话上下文特征\n * - 长期记忆特征（可选）\n * - 综合评分判断是否为任务\n */\n\nimport scoring from './scoring.js';\nimport optimizer from './optimizer.js';\n\n// 特征权重\nconst WEIGHTS = {\n  current: 0.6,\n  context: 0.3,\n  memory: 0.1\n};\n\n// 动作动词列表\nconst ACTION_VERBS = [\n  '写', '做', '执行', '运行', '处理', '分析', '检查', '修复', '重构', \n  '生成', '编译', '部署', '删除', '创建', '修改', '更新', '添加',\n  '写', 'run', 'exec', 'execute', 'build', 'deploy', 'create', 'delete',\n  'write', 'make', 'do', 'process', 'analyze', 'check', 'fix', 'refactor'\n];\n\n// 请求词\nconst REQUEST_WORDS = ['帮我', '请', '麻烦', '帮忙', '帮我', 'please', 'help'];\n\n// 疑问词\nconst QUESTION_WORDS = [\n  '能不能', '可不可以', '是否', '吗', '什么', '为什么', '怎么', '如何',\n  '?', 'can you', 'could you', 'is it', 'what is', 'how to', 'how do'\n];\n\n/**\n * 提取当前消息特征\n */\nfunction extractCurrentFeatures(message) {\n  if (!message) return 0;\n  \n  let score = 0;\n  const msg = message.trim();\n  \n  // 动作动词 +2\n  if (ACTION_VERBS.some(v => msg.toLowerCase().includes(v.toLowerCase()))) {\n    score += 2;\n  }\n  \n  // 请求词 +1\n  if (REQUEST_WORDS.some(w => msg.toLowerCase().includes(w.toLowerCase()))) {\n    score += 1;\n  }\n  \n  // 目标对象（包含路径或具体名词）+1\n  // 排除纯疑问词开头的情况\n  const hasTarget = /[\\w\\-\\/\\.\\\\_]+/.test(msg) && \n                    !QUESTION_WORDS.some(w => msg.startsWith(w));\n  if (hasTarget) {\n    score += 1;\n  }\n  \n  // 疑问词 -2（强负向）\n  if (QUESTION_WORDS.some(w => msg.toLowerCase().includes(w.toLowerCase()))) {\n    score -= 2;\n  }\n  \n  // 祈使句式（以动词开头，无主语）+1\n  const isImperative = /^[写做执运处检修重生了]/.test(msg);\n  if (isImperative) {\n    score += 1;\n  }\n  \n  return score;\n}\n\n/**\n * 提取上下文特征\n */\nfunction extractContextFeatures(message, history = []) {\n  if (!history || history.length === 0) return 0;\n  \n  let score = 0;\n  const msg = message.trim().toLowerCase();\n  \n  // 确认词：当前是\"是、好、做、继续\"等\n  const isConfirm = /^(是|好|做|继续|可以|行|嗯|ok|yes|yep)$/i.test(msg);\n  \n  // 获取上一轮助手消息\n  const lastAssistantMsg = history[history.length - 1]?.content || '';\n  \n  // 如果当前是确认回复，且上一轮有任务提议\n  if (isConfirm && /(要不要|是否|可以执行|需要我帮你|要帮你)/i.test(lastAssistantMsg)) {\n    score += 2;\n  }\n  \n  // 重复请求：消息中带\"再、又、也、还\"\n  if (/(再|又|也|还|again|also)/.test(msg)) {\n    score += 1;\n  }\n  \n  // 检查对话状态（消息中提到任务相关词）\n  if (/任务|文件|代码|项目/.test(msg)) {\n    score += 1;\n  }\n  \n  return score;\n}\n\n/**\n * 提取记忆特征（可选）\n */\nasync function extractMemoryFeatures(message, memoryStore = null) {\n  if (!memoryStore) return 0;\n  \n  let score = 0;\n  \n  try {\n    // 查询相似历史\n    const similar = await memoryStore.query(message, 1);\n    if (similar.length > 0 && similar[0].score > 0.8) {\n      score += 2;\n    }\n    \n    // 检查重复请求\n    const repeated = await memoryStore.query(message, 1, { type: 'task' });\n    if (repeated.length > 0 && /(又|再|还|again)/.test(message)) {\n      score += 1;\n    }\n  } catch (e) {\n    // 静默失败，降级为无记忆模式\n  }\n  \n  return score;\n}\n\n/**\n * 综合判断是否为任务\n * @param {string} message - 用户消息\n * @param {Array} history - 对话历史 (可选)\n * @param {Object} memoryStore - 记忆存储 (可选)\n * @returns {Object} { isTask, confidence, details }\n */\nexport async function isTaskCommand(message, history = [], memoryStore = null) {\n  if (!message || typeof message !== 'string') {\n    return { isTask: false, confidence: 0, details: { error: 'invalid input' } };\n  }\n  \n  // 1. 当前消息特征\n  const currentScore = extractCurrentFeatures(message);\n  \n  // 2. 上下文特征\n  const contextScore = extractContextFeatures(message, history);\n  \n  // 3. 记忆特征（异步）\n  let memoryScore = 0;\n  if (memoryStore) {\n    memoryScore = await extractMemoryFeatures(message, memoryStore);\n  }\n  \n  // 综合得分\n  const totalScore = currentScore * WEIGHTS.current + \n                     contextScore * WEIGHTS.context + \n                     memoryScore * WEIGHTS.memory;\n  \n  // 阈值判断\n  const THRESHOLD = 1.5;\n  const isTask = totalScore >= THRESHOLD;\n  const confidence = totalScore / 3; // 归一化到 0-1\n  \n  return {\n    isTask,\n    confidence: Math.min(1, confidence),\n    score: totalScore,\n    details: {\n      current: currentScore,\n      context: contextScore,\n      memory: memoryScore,\n      threshold: THRESHOLD\n    }\n  };\n}\n\n/**\n * 快速判断（不带上下文和记忆）\n */\nexport function isTaskQuick(message) {\n  return isTaskCommand(message, [], null);\n}\n\n/**\n * 测试用例验证\n */\nexport function runTests() {\n  const tests = [\n    { msg: '检查一下代码', ctx: [], mem: false, expect: true },\n    { msg: '你能不能做到？', ctx: [], mem: false, expect: false },\n    { msg: '帮我写个文件', ctx: [], mem: false, expect: true },\n    { msg: '好', ctx: ['要帮你检查吗？'], mem: false, expect: true },\n    { msg: '再检查一次', ctx: [], mem: true, expect: true },\n    { msg: '这个函数怎么用？', ctx: [], mem: false, expect: false },\n  ];\n  \n  console.log('=== 意图判断测试 ===');\n  for (const t of tests) {\n    const result = isTaskCommand(t.msg, t.ctx, null);\n    const pass = result.isTask === t.expect;\n    console.log(`${pass ? '✅' : '❌'} \"${t.msg}\" → ${result.isTask ? '任务' : '询问'} (${result.score.toFixed(1)})`);\n  }\n}\n\nexport default { isTaskCommand, isTaskQuick, runTests };","file":"~/.openclaw/workspace/skills/task-orchestrator-v7/intent_detector.js"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":143727,"output":1772,"cacheRead":0,"cacheWrite":0,"totalTokens":145499,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775379455019,"responseId":"chatcmpl-5bbd845c-8777-4441-9961-6c21a0907c7f"}}
