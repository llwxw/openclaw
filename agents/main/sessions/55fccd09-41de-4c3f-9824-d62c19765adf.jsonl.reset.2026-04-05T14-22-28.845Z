orMemory && message && message.length > 30) {\n        await vectorMemory.add(message, { type: 'user_message', userId, taskId });\n      }\n      return message;\n    },\n\n    beforeTask: async (taskSpec, context) => {\n      await loadDependencies();\n      if (taskWeightEstimator && taskSpec) {\n        const result = taskWeightEvaluator.evaluate(taskSpec);\n        context.taskWeight = result;\n        if (scoring) {\n          context.taskRoute = scoring.route(result);\n        }\n        console.log(`[AutoOrchestrator] 评分: ${result.total}/6 (${result.suggestion})`);\n      }\n      return taskSpec;\n    },\n\n    afterTask: async (result, context) => {\n      await loadDependencies();\n      if (vectorMemory && result && typeof result === 'string' && result.length > 50) {\n        await vectorMemory.add(result, { type: 'task_result' });\n      }\n      return result;\n    }\n  },\n\n  api: {\n    evaluate: (taskSpec) => taskWeightEstimator?.evaluate(taskSpec),\n    getRoute: (taskSpec) => {\n      if (!taskWeightEstimator || !scoring) return null;\n      const score = taskWeightEstimator.evaluate(taskSpec);\n      return scoring.route(score);\n    },\n    searchMemory: (keywords) => vectorMemory?.query(keywords),\n    remember: (text, metadata) => vectorMemory?.add(text, metadata)\n  }\n};\nEOF\n\necho \"✅ 已恢复 v1.0 版本\"\n\n# 语法检查\nnode --check ~/.openclaw/workspace/skills/auto-orchestrator/skill.js && echo \"✅ 语法正确\""}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":429,"output":885,"cacheRead":64000,"cacheWrite":0,"totalTokens":65314,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775371735476,"responseId":"019d5c66c8d5a57f6a9e40e08bdf85e2"}}
