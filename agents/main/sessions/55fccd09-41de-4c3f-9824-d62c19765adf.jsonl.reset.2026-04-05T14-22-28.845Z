{"type":"message","id":"3e236883","parentId":"adb07d7c","timestamp":"2026-04-05T07:52:15.721Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"npm 不可用。让我重写 openclaw-router.js 使用 Node.js 原生 http 模块，不依赖 express。\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"call_c25dbdbaf4a64f0a9056ef80","name":"exec","arguments":{"command":"# 重写使用原生 http 模块\ncat > ~/.openclaw/workspace/skills/task-orchestrator-v7/openclaw-router.js << 'ENDOFFILE'\n/**\n * OpenClaw Router v7.0 - 反向代理中间件\n * 使用 Node.js 原生模块，无需额外依赖\n * \n * 启动: node openclaw-router.js\n */\n\nimport http from 'http';\nimport { exec } from 'child_process';\nimport scoring from './scoring.js';\nimport megaExecutor from './mega_executor.js';\nimport contextProtector from './context_protector.js';\nimport progressReporter from './progress_reporter.js';\nimport security from './security.js';\nimport optimizer from './optimizer.js';\n\nconst PORT = process.env.ROUTER_PORT || 3002;\nconst GATEWAY_URL = process.env.OPENCLAW_GATEWAY || 'http://127.0.0.1:18789';\n\n// ==================== 路由决策 ====================\nfunction getExecutionPlan(score, scaleIndex = 0) {\n  if (score <= 2) return { mode: 'DIRECT', timeoutSec: 30 };\n  if (score <= 5) return { mode: 'STEP_ARCHIVE', stepTimeoutSec: 60 };\n  if (score <= 8) return { mode: 'SPAWN_SUBAGENT', timeoutSec: 120 };\n  if (score <= 12) return { mode: 'PARALLEL_SHARDS', timeoutSec: 300, shardSize: 10 };\n  return { mode: 'MEGA_TASK', timeoutSec: 7200, memLimitMB: 8192 };\n}\n\n// ==================== 执行函数 ====================\nfunction executeDirect(taskSpec, timeoutSec = 30) {\n  return new Promise((resolve, reject) => {\n    const proc = exec(taskSpec, { timeout: timeoutSec * 1000 });\n    let stdout = '', stderr = '';\n    proc.stdout?.on('data', d => stdout += d);\n    proc.stderr?.on('data', d => stderr += d);\n    proc.on('close', code => code === 0 ? resolve({ stdout, stderr }) : reject(new Error(stderr || `Exit ${code}`)));\n    proc.on('error', reject);\n  });\n}\n\nasync function executeStepArchive(taskSpec, stepTimeoutSec = 60) {\n  const steps = taskSpec.split(/&&|;/).map(s => s.trim()).filter(s => s);\n  const results = [];\n  for (let i = 0; i < steps.length; i++) {\n    results.push(await executeDirect(steps[i], stepTimeoutSec));\n    progressReporter.reportProgress('step', { current: i + 1, total: steps.length });\n  }\n  return results;\n}\n\n// ==================== HTTP 服务器 ====================\nconst server = http.createServer(async (req, res) => {\n  res.setHeader('Access-Control-Allow-Origin', '*');\n  res.setHeader('Content-Type', 'application/json');\n\n  const url = req.url;\n\n  // 健康检查\n  if (url === '/health' && req.method === 'GET') {\n    res.end(JSON.stringify({ status: 'ok', version: '7.0', uptime: process.uptime() }));\n    return;\n  }\n\n  // 评分\n  if (url === '/api/score' && req.method === 'POST') {\n    let body = await readBody(req);\n    let { taskSpec } = JSON.parse(body);\n    if (!taskSpec) return res.end(JSON.stringify({ error: 'taskSpec required' }));\n\n    let cached = optimizer.getCachedScore(taskSpec);\n    if (cached) return res.end(JSON.stringify({ ...cached, cached: true }));\n\n    const score = scoring.score(taskSpec);\n    const plan = getExecutionPlan(score.total);\n    optimizer.setCachedScore(taskSpec, { ...score, ...plan });\n\n    res.end(JSON.stringify({ score, plan, cached: false }));\n    return;\n  }\n\n  // 任务执行\n  if (url === '/api/task' && req.method === 'POST') {\n    let body = await readBody(req);\n    let { taskSpec } = JSON.parse(body);\n    if (!taskSpec) return res.end(JSON.stringify({ error: 'taskSpec required' }));\n\n    try {\n      const safeSpec = security.redact(taskSpec);\n      console.log(`[Router] 任务: ${safeSpec.substring(0, 30)}...`);\n\n      if (!security.isAllowed(taskSpec.split(' ')[0])) {\n        return res.end(JSON.stringify({ error: 'Command not allowed', code: 403 }));\n      }\n\n      let cached = optimizer.getCachedScore(taskSpec);\n      const score = cached || scoring.score(taskSpec);\n      const plan = getExecutionPlan(score.total);\n\n      await contextProtector.addMessage('user', taskSpec);\n      const startTime = Date.now();\n\n      let result;\n      switch (plan.mode) {\n        case 'DIRECT': result = await executeDirect(taskSpec, plan.timeoutSec); break;\n        case 'STEP_ARCHIVE': result = await executeStepArchive(taskSpec, plan.stepTimeoutSec); break;\n        default: result = await megaExecutor.execute(taskSpec, { mode: 'range' });\n      }\n\n      const duration = Date.now() - startTime;\n      optimizer.updateStats('tasksTotal');\n      optimizer.updateStats('route', plan.mode);\n\n      res.end(JSON.stringify({ success: true, mode: plan.mode, duration, score: score.total }));\n    } catch (err) {\n      res.end(JSON.stringify({ error: err.message, success: false }));\n    }\n    return;\n  }\n\n  // 上下文状态\n  if (url === '/api/context/status' && req.method === 'GET') {\n    res.end(JSON.stringify(contextProtector.getStatus()));\n    return;\n  }\n\n  res.statusCode = 404;\n  res.end(JSON.stringify({ error: 'Not Found' }));\n});\n\nfunction readBody(req) {\n  return new Promise((resolve, reject) => {\n    let body = '';\n    req.on('data', chunk => body += chunk);\n    req.on('end', () => resolve(body));\n    req.on('error', reject);\n  });\n}\n\n// ==================== 启动 ====================\nasync function main() {\n  await contextProtector.init();\n  await megaExecutor.init();\n  optimizer.startHealthServer();\n\n  server.listen(PORT, () => {\n    console.log(`\n╔════════════════════════════════════════╗\n║  OpenClaw Router v7.0 已启动            ║\n║  端口: ${PORT}                             ║\n║  端点:                                   ║\n║  POST /api/task - 执行任务              ║\n║  POST /api/score - 获取评分             ║\n║  GET  /health - 健康检查                ║\n╚════════════════════════════════════════╝\n    `);\n  });\n}\n\nmain().catch(console.error);\nENDOFFILE\n\n# 测试\nnode --input-type=module -e \"\nimport('/home/ai/.openclaw/workspace/skills/task-orchestrator-v7/openclaw-router.js').then(m => {\n  console.log('✅ openclaw-router.js 加载成功 (无需 npm 依赖)');\n}).catch(e => console.log('❌', e.message));\n\""}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":105807,"output":1563,"cacheRead":0,"cacheWrite":0,"totalTokens":107370,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775375511514,"responseId":"chatcmpl-f5a3dcce-bca5-4096-ac6f-6d4fcddbd23c"}}
