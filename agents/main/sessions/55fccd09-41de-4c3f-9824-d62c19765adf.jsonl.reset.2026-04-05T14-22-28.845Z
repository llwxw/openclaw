{"type":"message","id":"beac27a5","parentId":"1b9524b1","timestamp":"2026-04-05T06:20:18.668Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create the vector-memory skill.js with full implementation.\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"call_1d0175df99b14166b10f898b","name":"write","arguments":{"content":"// ~/.openclaw/workspace/skills/vector-memory/skill.js\n// ========================= 向量记忆 v2.0 =========================\n// 基于五维最优解设计：TF-IDF风格词频匹配 + 时间衰减排序\n\nconst fs = require('fs').promises;\nconst path = require('path');\n\nconst STORAGE_PATH = path.join(process.env.HOME || '/home/ai', '.openclaw', 'vector_memory.json');\nconst MAX_ENTRIES = 1000;\n\nclass VectorMemory {\n  constructor() {\n    this.entries = [];\n    this.initialized = false;\n  }\n\n  async load() {\n    try {\n      const data = await fs.readFile(STORAGE_PATH, 'utf8');\n      this.entries = JSON.parse(data);\n      console.log(`[VectorMemory] Loaded ${this.entries.length} entries`);\n    } catch (err) {\n      // 文件不存在或损坏，创建空存储\n      this.entries = [];\n      await this.save();\n      console.log(`[VectorMemory] Initialized new storage at ${STORAGE_PATH}`);\n    }\n    this.initialized = true;\n  }\n\n  async save() {\n    try {\n      const dir = path.dirname(STORAGE_PATH);\n      await fs.mkdir(dir, { recursive: true });\n      // 只保留最近 MAX_ENTRIES 条\n      await fs.writeFile(STORAGE_PATH, JSON.stringify(this.entries.slice(-MAX_ENTRIES), null, 2));\n    } catch (err) {\n      console.error(`[VectorMemory] Save error:`, err.message);\n    }\n  }\n\n  async add(text, metadata = {}) {\n    if (!text || typeof text !== 'string') return null;\n    \n    const id = `${Date.now()}-${Math.random().toString(36).substr(2, 8)}`;\n    const entry = {\n      id,\n      text: text.substring(0, 10000), // 限制长度\n      metadata,\n      timestamp: Date.now()\n    };\n    \n    this.entries.push(entry);\n    await this.save();\n    return id;\n  }\n\n  async query(keywords, limit = 5) {\n    if (!keywords || typeof keywords !== 'string') return [];\n    \n    const terms = keywords.toLowerCase().split(/\\s+/).filter(t => t.length > 0);\n    if (terms.length === 0) return [];\n    \n    const now = Date.now();\n    const scored = this.entries.map(entry => {\n      const lowerText = entry.text.toLowerCase();\n      \n      // TF-IDF 风格词频匹配\n      let score = terms.reduce((acc, term) => {\n        return acc + (lowerText.includes(term) ? 1 : 0);\n      }, 0);\n      \n      // 时间衰减：24小时内权重 1.0，之后每天衰减 0.1 (10天完全失效)\n      const ageHours = (now - entry.timestamp) / (1000 * 3600);\n      const timeBonus = Math.max(0, 1 - ageHours / 240);\n      \n      return { entry, score: score + timeBonus };\n    });\n    \n    // 排序并返回 top N\n    scored.sort((a, b) => b.score - a.score);\n    return scored.slice(0, limit).map(s => s.entry);\n  }\n\n  async getAll() {\n    return this.entries;\n  }\n\n  async search(query, limit = 5) {\n    // 兼容旧版别名\n    return this.query(query, limit);\n  }\n}\n\nlet memory = null;\n\nmodule.exports = {\n  name: 'vector-memory',\n  version: '2.0.0',\n  description: '长期记忆（关键词索引 + 持久化）',\n\n  async init() {\n    if (!memory) {\n      memory = new VectorMemory();\n      await memory.load();\n    }\n    return memory;\n  },\n\n  async add(text, metadata) {\n    if (!memory) await module.exports.init();\n    return memory.add(text, metadata);\n  },\n\n  async query(keywords, limit) {\n    if (!memory) await module.exports.init();\n    return memory.query(keywords, limit);\n  },\n\n  async search(query, limit) {\n    if (!memory) await module.exports.init();\n    return memory.search(query, limit);\n  },\n\n  async getAll() {\n    if (!memory) await module.exports.init();\n    return memory.getAll();\n  },\n\n  hooks: {\n    onUserMessage: async (message, userId, taskId) => {\n      try {\n        if (!memory) await module.exports.init();\n        // 只记录有意义的消息（长度 > 50）\n        if (message && message.length > 50) {\n          await memory.add(message, { type: 'user_message', userId, taskId });\n          console.log(`[VectorMemory] Stored user message (${message.length} chars)`);\n        }\n      } catch (err) {\n        console.error(`[VectorMemory] Hook error:`, err.message);\n      }\n    }\n  }\n};","file":"~/.openclaw/workspace/skills/vector-memory/skill.js"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":20407,"output":1091,"cacheRead":0,"cacheWrite":0,"totalTokens":21498,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775370003592,"responseId":"chatcmpl-a3d14d64-e654-41df-b8b3-b136894b5cb1"}}
