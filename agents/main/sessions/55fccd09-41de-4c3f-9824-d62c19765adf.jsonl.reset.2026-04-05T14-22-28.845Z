/react-dom\":\"^19.2.3\",\"@vitejs/plugin-react\":\"^4.0.4\",\"@vitest/ui\":\"^4.1.2\",\"electron\":\"^41.1.0\",\"electron-builder\":\"^26.8.1\",\"esbuild\":\"^0.24.2\",\"jsdom\":\"^29.0.1\",\"nodemon\":\"^3.1.14\",\"npm-run-all\":\"^4.1.5\",\"typescript\":\"^6.0.2\",\"vite\":\"^4.3.9\",\"vitest\":\"^4.1.2\"},\"dependencies\":{\"@electron-toolkit/utils\":\"^4.0.0\",\"@xenova/transformers\":\"^2.17.2\",\"antd\":\"^6.3.4\",\"axios\":\"^1.14.0\",\"echarts\":\"^6.0.0\",\"echarts-for-react\":\"^3.0.6\",\"electron-store\":\"^11.0.2\",\"graphology\":\"^0.26.0\",\"graphology-metrics\":\"^2.4.0\",\"js-yaml\":\"^4.1.1\",\"monaco-editor\":\"^0.55.1\",\"react\":\"^19.2.4\",\"react-dom\":\"^19.2.4\",\"vectra\":\"^0.12.3\",\"zustand\":\"^5.0.12\"}}\n=== 主要源码 ===\nmain\nrenderer\n\n=== 文档 ===\n# AI小说创作助手 - 方案与实现总结\r\n\r\n## 一、方案概述\r\n\r\n### 1.1 核心架构理念\r\n- **极简存储**：所有数据用文件夹和纯文本文件（Markdown + YAML）保存，无需数据库。\r\n- **工具即脚本**：AI生成、情节规划、人格分析等封装为独立命令行工具，按需调用。\r\n- **记忆靠目录**：文件夹层级自然形成情节结构，文件名和元数据提供索引。\r\n- **幻觉靠上下文**：工具运行时自动读取相关文件，构建完整上下文传递给AI。\r\n- **个人使用**：不涉及协作、权限、实时同步，所有数据本地存储，工具离线可用。\r\n\r\n### 1.2 文件组织规范\r\n```\r\nmy-novel/                       # 小说项目根目录\r\n├── project.yaml                # 项目元数据\r\n├── characters/                 # 人物文件夹\r\n├── plots/                      # 情节文件夹\r\n├── settings/                   # 世界观设定文件夹\r\n├── relationships.yaml          # 人物关系索引\r\n├── notes/                      # 个人笔记（可选）\r\n└── .ai-context/                # AI上下文缓存（自动生成）\r\n```\r\n\r\n### 1.3 技术栈\r\n- **运行时**：Node.js\r\n- **命令行框架**：Commander.js\r\n- **文件解析**：js-yaml, marked\r\n- **AI集成**：Axios (支持DeepSeek、OpenAI等)\r\n- **数据格式**：YAML (配置), JSON (静态数据), Markdown (章节内容)","cwd":"/home/ai/.openclaw/workspace"},"isError":false,"timestamp":1775390060409}}
