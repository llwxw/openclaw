{"type":"message","id":"c9038120","parentId":"44e734ea","timestamp":"2026-04-05T06:21:04.849Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create the subagent_executor.js for the task_orchestrator.\n\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"call_50a0dbef1d684fe4be2cbd6c","name":"write","arguments":{"content":"// task_orchestrator/scripts/subagent_executor.js\n// ========================= 子代理执行器 =========================\n// 支持进度上报、心跳检测、无产出警告\n\nconst { spawn } = require('child_process');\n\nclass SubagentExecutor {\n  constructor() {\n    this.activeTasks = new Map();\n    this.progressInterval = 30 * 1000; // 30秒心跳\n  }\n\n  /**\n   * 执行子代理任务\n   * @param {Object} options - 执行选项\n   * @param {string} options.task - 任务描述\n   * @param {string} options.runtime - subagent | acp\n   * @param {number} options.timeout - 超时时间(秒)\n   * @param {Function} options.onProgress - 进度回调 [PROGRESS]\n   * @param {Function} options.onHeartbeat - 心跳回调\n   */\n  async execute(options) {\n    const { task, runtime = 'subagent', timeout = 120, onProgress, onHeartbeat } = options;\n    \n    const taskId = `task-${Date.now()}-${Math.random().toString(36).substr(2, 6)}`;\n    let output = '';\n    let lastProgressTime = Date.now();\n    \n    return new Promise((resolve, reject) => {\n      // 模拟子代理执行（实际应调用 sessions_spawn）\n      const child = spawn('sleep', [Math.min(timeout, 10).toString()], {\n        stdio: ['pipe', 'pipe', 'pipe']\n      });\n\n      this.activeTasks.set(taskId, { child, startTime: Date.now() });\n\n      // 心跳检测\n      const heartbeat = setInterval(() => {\n        const idle = Date.now() - lastProgressTime;\n        \n        if (idle > this.progressInterval) {\n          onHeartbeat?.(`[${taskId}] 心跳：任务仍在运行 (${Math.floor(idle/1000)}s 无新输出)`);\n        }\n      }, this.progressInterval);\n\n      child.stdout.on('data', (data) => {\n        const text = data.toString();\n        output += text;\n        lastProgressTime = Date.now();\n        \n        // 解析进度标记\n        const progressMatch = text.match(/\\[PROGRESS\\]\\s*(\\d+)%/);\n        if (progressMatch) {\n          onProgress?.(parseInt(progressMatch[1]));\n        }\n      });\n\n      child.stderr.on('data', (data) => {\n        output += data.toString();\n      });\n\n      child.on('close', (code) => {\n        clearInterval(heartbeat);\n        this.activeTasks.delete(taskId);\n        \n        if (code === 0) {\n          resolve({ taskId, output, success: true });\n        } else {\n          reject(new Error(`Task ${taskId} exited with code ${code}`));\n        }\n      });\n\n      child.on('error', (err) => {\n        clearInterval(heartbeat);\n        this.activeTasks.delete(taskId);\n        reject(err);\n      });\n    });\n  }\n\n  /**\n   * 并行执行多个子代理\n   */\n  async executeParallel(tasks, onProgress) {\n    const results = await Promise.allSettled(\n      tasks.map(task => this.execute({ ...task, onProgress }))\n    );\n    \n    return results.map((r, i) => ({\n      task: tasks[i].task,\n      ...(r.status === 'fulfilled' ? { success: true, result: r.value } : { success: false, error: r.reason })\n    }));\n  }\n\n  /**\n   * 获取活跃任务状态\n   */\n  getActiveTasks() {\n    const now = Date.now();\n    return Array.from(this.activeTasks.entries()).map(([id, task]) => ({\n      id,\n      duration: now - task.startTime,\n      pid: task.child.pid\n    }));\n  }\n\n  /**\n   * 终止任务\n   */\n  kill(taskId) {\n    const task = this.activeTasks.get(taskId);\n    if (task) {\n      task.child.kill();\n      this.activeTasks.delete(taskId);\n      return true;\n    }\n    return false;\n  }\n}\n\nmodule.exports = SubagentExecutor;","file":"~/.openclaw/workspace/skills/task_orchestrator/scripts/subagent_executor.js"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":22882,"output":939,"cacheRead":0,"cacheWrite":0,"totalTokens":