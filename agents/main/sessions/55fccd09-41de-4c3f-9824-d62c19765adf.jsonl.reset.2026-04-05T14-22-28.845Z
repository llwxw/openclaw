{"type":"message","id":"6252bf55","parentId":"0fb1d8e6","timestamp":"2026-04-05T07:49:18.703Z","message":{"role":"user","content":[{"type":"text","text":"Sender (untrusted metadata):\n```json\n{\n  \"label\": \"openclaw-control-ui\",\n  \"id\": \"openclaw-control-ui\"\n}\n```\n\n[Sun 2026-04-05 15:49 GMT+8] 还有这个：您说得对，我上一轮回复中**没有明确写出反向代理中间件的代码**，只列出了 security 和 optimizer。实际上，反向代理中间件是 **整个 v7.0 的核心入口**，它负责拦截请求、调用评分、选择执行器、转发给 OpenClaw Gateway。\n\n下面我把 **完整的反向代理中间件代码** 和 **集成所有模块的最终版** 一并给出。您只需要一个文件 `openclaw-router.js`，即可启动全自动服务。\n\n---\n\n## 最终版：集成所有模块的 `openclaw-router.js`\n\n```javascript\n// openclaw-router.js\n// 反向代理中间件 + 评分路由 + 超大任务执行 + 上下文保护 + 安全 + 效率优化\n\nconst express = require('express');\nconst { createProxyMiddleware } = require('http-proxy-middleware');\nconst { computeFineScore, getExecutionPlan } = require('./scoring');\nconst { executeMegaTask } = require('./mega_executor');\nconst contextProtector = require('./context_protector');\nconst { redactSensitive, isCommandAllowed } = require('./security');\nconst { getCachedScore, setCachedScore, logger } = require('./optimizer');\nconst { spawnWithProgress } = require('./progress_reporter');\n\nconst GATEWAY_URL = process.env.OPENCLAW_GATEWAY || 'http://localhost:3000';\nconst PORT = process.env.ROUTER_PORT || 3002;\n\nconst app = express();\napp.use(express.json({ limit: '10mb' }));\n\n// 健康检查\napp.get('/health', (req, res) => res.json({ status: 'ok', uptime: process.uptime() }));\n\n// 核心拦截路由\napp.post('/api/task', async (req, res, next) => {\n try {\n let taskSpec = req.body.taskSpec || req.body.command || req.body.cmd;\n if (!taskSpec) return next();\n\n // 1. 安全：敏感信息脱敏（日志）\n const safeSpec = redactSensitive(taskSpec);\n logger.info({ taskSpec: safeSpec }, 'Received task');\n\n // 2. 安全：命令白名单检查（可选）\n if (!isCommandAllowed(taskSpec)) {\n return res.status(403).json({ error: 'Command not allowed' });\n }\n\n // 3. 效率：评分缓存\n let score = getCachedScore(taskSpec);\n if (!score) {\n score = await computeFineScore(taskSpec);\n setCachedScore(taskSpec, score);\n }\n\n // 4. 路由决策\n const plan = getExecutionPlan(score.totalScore, score.factors.scaleIndex);\n logger.info({ score: score.totalScore, mode: plan.mode }, 'Routing decision');\n\n // 5. 执行任务（根据路由模式）\n let result;\n switch (plan.mode) {\n case 'DIRECT':\n result = await executeDirect(taskSpec, plan.timeoutSec);\n break;\n case 'STEP_ARCHIVE':\n result = await executeStepArchive(taskSpec, plan.stepTimeoutSec);\n break;\n case 'SPAWN_SUBAGENT':\n result = await spawnWithProgress(taskSpec, [], plan.timeoutSec, plan.memLimitMB, (msg) => console.log(`[PROGRESS] ${msg}`));\n break;\n case 'PARALLEL_SHARDS':\n result = await executeParallelShards(taskSpec, plan);\n break;\n case 'MEGA_TASK':\n result = await executeMegaTask(taskSpec, plan, (msg) => console.log(`[MEGA] ${msg}`));\n break;\n default:\n return res.status(400).json({ error: 'Unsupported routing mode' });\n }\n\n // 6. 记录上下文（可选）\n await contextProtector.addMessage('system', `Task ${taskSpec} completed with mode ${plan.mode}`);\n\n res.json({ success: true, output: result });\n } catch (err) {\n logger.error({ error: err.message }, 'Task execution failed');\n res.status(500).json({ error: err.message });\n }\n});\n\n// 转发其他请求到 Gateway\napp.use('/', createProxyMiddleware({\n target: GATEWAY_URL,\n changeOrigin: true,\n onError: (err, req, res) => res.status(502).json({ error: 'Gateway unreachable' })\n}));\n\n// 辅助执行函数（简化）\nasync function executeDirect(taskSpec, timeoutSec) {\n const { exec } = require('child_process');\n return new Promise((resolve, reject) => {\n const proc = exec(taskSpec, { timeout: timeoutSec * 1000 });\n proc.stdout.pipe(process.stdout);\n proc.stderr.pipe(process.stderr);\n proc.on('exit', (code) => code === 0 ? resolve() : reject(new Error(`Exit ${code}`)));\n });\n}\n\nasync function executeStepArchive(taskSpec, stepTimeoutSec) {\n // 按步骤拆分（假设用 && 分隔）\n const steps = taskSpec.split('&&').map(s => s.trim());\n for (let i = 0; i < steps.length; i++) {\n await executeDirect(steps[i], stepTimeoutSec);\n }\n}\n\nasync function executeParallelShards(taskSpec, plan) {\n // 简单分片：按文件列表模拟\n const shards = [taskSpec, taskSpec]; // 实际应实现 splitInput\n const promises = shards.map(shard => spawnWithProgress(shard, [], plan.timeoutSec, plan.memLimitMB));\n await Promise.all(promises);\n}\n\napp.listen(PORT, () => {\n console.log(`OpenClaw Router listening on ${PORT}, forwarding to ${GATEWAY_URL}`);\n});\n```\n\n---\n\n## 配套模块（只需放在同一目录）\n\n您已经写好的 `scoring.js`、`mega_executor.js`、`context_protector.js`、`progress_reporter.js` 保持不变。 \n再补充 `security.js` 和 `optimizer.js`（如上一轮回复所述）。\n\n---\n\n## 启动方式\n\n```bash\n# 1. 安装依赖\nnpm install express http-proxy-middleware node-cache pino\n\n# 2. 启动中间件\nnode openclaw-router.js\n\n# 3. 让用户将任务请求发到 http://localhost:3002/api/task\n```\n\n---\n\n## 验证\n\n```bash\ncurl -X POST http://localhost:3002/api/task \\\n -H \"Content-Type: application/json\" \\\n -d '{\"taskSpec\":\"ls -la\"}'\n```\n\n日志应显示评分和路由决策，并正常执行。\n\n---\n\n**现在反向代理中间件已完整给出**，并与所有模块集成。您只需复制上述 `openclaw-router.js` 到您的项目目录，确保其他模块文件存在，即可运行全自动任务编排系统。"}],"timestamp":1775375358692}}
{"type":"message","id":"e67f8244","parentId":"6252bf55","timestamp":"2026-04-05T07:50:46.976Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"用户给了一个完整的反向代理中间件代码，这是 v7.0 的核心入口。需要我来创建这个文件。\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"019d5c9d843509969a89cd2a245fcf8d","name":"exec","arguments":{"command":"# 创建完整的反向代理中间件\ncat > ~/.openclaw/workspace/skills/task-orchestrator-v7/openclaw-router.js << 'ENDOFFILE'\n/**\n * OpenClaw Router - 反向代理中间件 + 评分路由 + 全自动任务编排\n * \n * 功能：\n * - 拦截任务请求，调用评分\n * - 根据评分选择执行模式\n * - 集成安全、上下文保护、效率优化\n * \n * 启动：node openclaw-router.js\n */\n\nimport express from 'express';\nimport scoring from './scoring.js';\nimport megaExecutor from './mega_executor.js';\nimport contextProtector from './context_protector.js';\nimport progressReporter from './progress_reporter.js';\nimport security from './security.js';\nimport optimizer from './optimizer.js';\n\nconst GATEWAY_URL = process.env.OPENCLAW_GATEWAY || 'http://127.0.0.1:18789';\nconst PORT = process.env.ROUTER_PORT || 3002;\n\nconst app = express();\napp.use(express.json({ limit: '10mb' }));\n\n// ==================== 辅助函数 ====================\n\n// 直接执行\nasync function executeDirect(taskSpec, timeoutSec = 30) {\n  const { exec } = await import('child_process');\n  return new Promise((resolve, reject) => {\n    const proc = exec(taskSpec, { timeout: timeoutSec * 1000 });\n    let stdout = '', stderr = '';\n    proc.stdout?.on('data', d => stdout += d);\n    proc.stderr?.on('data', d => stderr += d);\n    proc.on('close', code => {\n      if (code === 0) resolve({ stdout, stderr });\n      else reject(new Error(`Exit ${code}: ${stderr}`));\n    });\n    proc.on('error', reject);\n  });\n}\n\n// 分步执行\nasync function executeStepArchive(taskSpec, stepTimeoutSec = 60) {\n  const steps = taskSpec.split(/&&|;/).map(s => s.trim()).filter(s => s);\n  const results = [];\n  for (let i = 0; i < steps.length; i++) {\n    const result = await executeDirect(steps[i], stepTimeoutSec);\n    results.push(result);\n    // 更新进度\n    progressReporter.reportProgress('step', { current: i + 1, total: steps.length });\n  }\n  return results;\n}\n\n// 并行分片执行\nasync function executeParallelShards(taskSpec, plan) {\n  // 使用 mega_executor\n  const result = await megaExecutor.execute(taskSpec, {\n    mode: 'range',\n    shardSize: plan.shardSize || 10,\n    onProgress: (p, curr, total) => progressReporter.reportProgress('shard', { progress: p, current: curr, total })\n  });\n  return result;\n}\n\n// ==================== 路由决策 ====================\n\nfunction getExecutionPlan(score, scaleIndex = 0) {\n  let mode = 'DIRECT';\n  let timeoutSec = 30;\n  let stepTimeoutSec = 60;\n  let memLimitMB = null;\n  let shardSize = 50;\n\n  if (score <= 2) {\n    mode = 'DIRECT';\n    timeoutSec = 30;\n  } else if (score <= 5) {\n    mode = 'STEP_ARCHIVE';\n    stepTimeoutSec = 60;\n  } else if (score <= 8) {\n    mode = 'SPAWN_SUBAGENT';\n    timeoutSec = 120;\n  } else if (score <= 12) {\n    mode = 'PARALLEL_SHARDS';\n    timeoutSec = 300;\n    shardSize = 10;\n  } else {\n    mode = 'MEGA_TASK';\n    timeoutSec = 7200;\n    memLimitMB = 8192;\n  }\n\n  return { mode, timeoutSec, stepTimeoutSec, memLimitMB, shardSize, scaleIndex };\n}\n\n// ==================== 中间件核心 ====================\n\n// 健康检查\napp.get('/health', (req, res) => {\n  res.json({\n    status: 'ok',\n    uptime: process.uptime(),\n    version: '7.0',\n    modules: {\n      scoring: !!scoring,\n      megaExecutor: !!megaExecutor,\n      contextProtector: !!contextProtector,\n      security: !!security,\n      optimizer: !!optimizer\n    }\n  });\n});\n\n// 评分端点\napp.post('/api/score', (req, res) => {\n  const { taskSpec } = req.body;\n  if (!taskSpec) return res.status(400).json({ error: 'taskSpec required' });\n  \n  // 安全脱敏\n  const safeSpec = security.redact(taskSpec);\n  \n  // 缓存检查\n  const cached = optimizer.getCachedScore(taskSpec);\n  if (cached) {\n    return res.json({ ...cached, cached: true });\n  }\n  \n  // 评分\n  const score = scoring.score(taskSpec);\n  const plan = getExecutionPlan(score.total, score.scaleIndex);\n  \n  // 缓存结果\n  optimizer.setCachedScore(taskSpec, { ...score, ...plan });\n  \n  res.json({ score, plan, cached: false });\n});\n\n// 核心任务执行端点\napp.post('/api/task', async (req, res) => {\n  try {\n    const taskSpec = req.body.taskSpec || req.body.command || req.body.cmd;\n    if (!taskSpec) {\n      return res.status(400).json({ error: 'taskSpec required' });\n    }\n\n    // 1. 安全：脱敏日志\n    const safeSpec = security.redact(taskSpec);\n    console.log(`[Router] 收到任务: ${safeSpec.substring(0, 50)}...`);\n\n    // 2. 安全：命令白名单\n    if (!security.isAllowed(taskSpec.split(' ')[0])) {\n      return res.status(403).json({ error: 'Command not allowed' });\n    }\n\n    // 3. 缓存检查\n    let cached = optimizer.getCachedScore(taskSpec);\n    let score, plan;\n    \n    if (cached) {\n      score = cached;\n      plan = getExecutionPlan(score.total);\n      console.log(`[Router] 缓存命中: ${score.total}分`);\n    } else {\n      // 4. 评分\n      score = scoring.score(taskSpec);\n      plan = getExecutionPlan(score.total, score.scaleIndex);\n      optimizer.setCachedScore(taskSpec, { ...score, ...plan });\n      console.log(`[Router] 评分: ${score.total}分 → ${plan.mode}`);\n    }\n\n    // 5. 上下文保护\n    await contextProtector.addMessage('user', taskSpec);\n\n    // 6. 根据路由模式执行\n    let result;\n    const startTime = Date.now();\n\n    switch (plan.mode) {\n      case 'DIRECT':\n        result = await executeDirect(taskSpec, plan.timeoutSec);\n        break;\n      case 'STEP_ARCHIVE':\n        result = await executeStepArchive(taskSpec, plan.stepTimeoutSec);\n        break;\n      case 'SPAWN_SUBAGENT':\n      case 'PARALLEL_SHARDS':\n        result = await executeParallelShards(taskSpec, plan);\n        break;\n      case 'MEGA_TASK':\n        result = await megaExecutor.execute(taskSpec, {\n          mode: 'range',\n          onProgress: (p) => console.log(`[MEGA] ${p}%`)\n        });\n        break;\n      default:\n        return res.status(400).json({ error: `Unsupported mode: ${plan.mode}` });\n    }\n\n    const duration = Date.now() - startTime;\n\n    // 7. 记录结果\n    await contextProtector.addMessage('assistant', JSON.stringify(result).substring(0, 500));\n    \n    // 8. 更新统计\n    optimizer.updateStats('tasksTotal');\n    optimizer.updateStats('route', plan.mode);\n\n    console.log(`[Router] 完成: ${plan.mode}, 耗时${duration}ms`);\n\n    res.json({\n      success: true,\n      mode: plan.mode,\n      duration,\n      score: score.total,\n      output: security.redact(JSON.stringify(result).substring(0, 1000))\n    });\n\n  } catch (err) {\n    console.error(`[Router] 错误: ${err.message}`);\n    res.status(500).json({ error: err.message });\n  }\n});\n\n// 上下文状态\napp.get('/api/context/status', (req, res) => {\n  res.json(contextProtector.getStatus());\n});\n\n// 清理缓存\napp.post('/api/cache/clear', (req, res) => {\n  optimizer.cache?.clear();\n  res.json({ success: true });\n});\n\n// ==================== 启动 ====================\n\nasync function main() {\n  // 初始化模块\n  await contextProtector.init();\n  await megaExecutor.init();\n  optimizer.startHealthServer();\n\n  app.listen(PORT, () => {\n    console.log(`\n╔═══════════════════════════════════════════════════╗\n║   OpenClaw Router v7.0 已启动                      ║\n║   监听端口: ${PORT}                                ║\n║   Gateway: ${GATEWAY_URL}                        ║\n║                                                      ║\n║   端点:                                            ║\n║   POST /api/task  - 执行任务                       ║\n║   POST /api/score  - 获取评分                      ║\n║   GET  /health    - 健康检查                       ║\n║   GET  /api/context/status - 上下文状态            ║\n╚═══════════════════════════════════════════════════╝\n    `);\n  });\n}\n\nmain().catch(console.error);\nENDOFFILE\n\necho \"✅ openclaw-router.js 已创建\"\n\n# 验证\nnode --check ~/.openclaw/workspace/skills/task-orchestrator-v7/openclaw-router.js && echo \"✅ 语法正确\""}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":1740,"output":2125,"cacheRead":100736,"cacheWrite":0,"totalTokens":104601,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775375358698,"responseId":"019d5c9d782220305926bb16a5a97711"}}
