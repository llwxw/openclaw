{"type":"message","id":"15e28acc","parentId":"89ba887d","timestamp":"2026-04-05T06:20:52.015Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now create context_protector.js for the task_orchestrator.\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"019d5c4c08f150f4445c6c95b3a86739","name":"write","arguments":{"content":"// task_orchestrator/scripts/context_protector.js\n// ========================= 上下文保护器 =========================\n// 自动压缩上下文，防止溢出\n\nconst fs = require('fs').promises;\nconst path = require('path');\n\nconst CONTEXT_FILE = path.join(process.env.HOME || '/home/ai', '.openclaw', 'context_archive.json');\nconst MAX_MESSAGES = 50;\nconst MAX_CHARS = 100 * 1024; // 100KB\nconst MAX_TOKEN_RATIO = 0.8;\n\nclass ContextProtector {\n  constructor() {\n    this.messages = [];\n    this.archive = [];\n  }\n\n  async load() {\n    try {\n      const data = await fs.readFile(CONTEXT_FILE, 'utf8');\n      this.archive = JSON.parse(data);\n    } catch {\n      this.archive = [];\n    }\n  }\n\n  async save() {\n    const dir = path.dirname(CONTEXT_FILE);\n    await fs.mkdir(dir, { recursive: true });\n    await fs.writeFile(CONTEXT_FILE, JSON.stringify(this.archive.slice(-100), null, 2));\n  }\n\n  addMessage(role, content, taskId = null) {\n    this.messages.push({ role, content, taskId, timestamp: Date.now() });\n    return this.shouldCompress();\n  }\n\n  shouldCompress() {\n    const msgCount = this.messages.length;\n    const totalChars = this.messages.reduce((sum, m) => sum + (m.content?.length || 0), 0);\n    \n    return msgCount >= MAX_MESSAGES || totalChars >= MAX_CHARS;\n  }\n\n  async compress() {\n    if (this.messages.length === 0) return;\n    \n    // 保留最近 10 条，压缩其余\n    const recent = this.messages.slice(-10);\n    const toArchive = this.messages.slice(0, -10);\n    \n    const summary = toArchive.length > 0 \n      ? `[压缩 ${toArchive.length} 条消息]` \n      : '';\n    \n    this.archive.push({ \n      timestamp: Date.now(), \n      messages: toArchive,\n      summary \n    });\n    \n    await this.save();\n    this.messages = recent;\n    \n    return { archived: toArchive.length, remaining: recent.length };\n  }\n\n  async getArchive(query = null) {\n    if (!query) return this.archive.slice(-10);\n    // 简单关键词搜索\n    return this.archive.filter(a => \n      JSON.stringify(a).toLowerCase().includes(query.toLowerCase())\n    );\n  }\n\n  getStats() {\n    const totalChars = this.messages.reduce((sum, m) => sum + (m.content?.length || 0), 0);\n    return {\n      messageCount: this.messages.length,\n      totalChars,\n      archiveCount: this.archive.length,\n      shouldCompress: this.shouldCompress()\n    };\n  }\n}\n\nmodule.exports = ContextProtector;","file":"~/.openclaw/workspace/skills/task_orchestrator/scripts/context_protector.js"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":2910,"output":659,"cacheRead":19328,"cacheWrite":0,"totalTokens":22897,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775370025955,"responseId":"019d5c4c01a7b993b0d2137f798d2a85"}}
