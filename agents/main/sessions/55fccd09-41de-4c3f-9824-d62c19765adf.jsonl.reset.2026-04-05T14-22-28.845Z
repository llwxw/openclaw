{"type":"message","id":"be621da0","parentId":"b3662e1b","timestamp":"2026-04-05T06:44:25.661Z","message":{"role":"toolResult","toolCallId":"019d5c62a5a639ab26d0679b5315e020","toolName":"read","content":[{"type":"text","text":"// ~/.openclaw/workspace/skills/auto-orchestrator/skill.js\n// ========================= 自动编排入口 v1.0 =========================\n// 自动集成: task-weight-estimator + vector-memory + task_orchestrator\n// 作为前置拦截器，在任务执行前自动评分并记录记忆\n\nconst path = require('path');\n\n// 延迟加载依赖技能\nlet taskWeightEstimator = null;\nlet vectorMemory = null;\nlet scoring = null;\n\nasync function loadDependencies() {\n  if (!taskWeightEstimator) {\n    try {\n      taskWeightEstimator = require('/home/ai/.openclaw/workspace/skills/task-weight-estimator/skill.js');\n      scoring = require('/home/ai/.openclaw/workspace/skills/task_orchestrator/scripts/scoring.js');\n      console.log('[AutoOrchestrator] Loaded task-weight-estimator');\n    } catch (e) {\n      console.error('[AutoOrchestrator] Failed to load dependencies:', e.message);\n    }\n  }\n  if (!vectorMemory) {\n    try {\n      vectorMemory = require('/home/ai/.openclaw/workspace/skills/vector-memory/skill.js');\n      await vectorMemory.init();\n      console.log('[AutoOrchestrator] Loaded vector-memory');\n    } catch (e) {\n      console.error('[AutoOrchestrator] Failed to load vector-memory:', e.message);\n    }\n  }\n}\n\nmodule.exports = {\n  name: 'auto-orchestrator',\n  version: '1.0.0',\n  description: '自动编排入口 - 任务评分 + 记忆存储 + 执行路由',\n\n  async init() {\n    await loadDependencies();\n    console.log('[AutoOrchestrator] Initialized - 任务评分和记忆功能已启用');\n  },\n\n  hooks: {\n    // 用户消息前置拦截：评分 + 记录记忆\n    onUserMessage: async (message, userId, taskId) => {\n      await loadDependencies();\n      \n      // 1. 自动记录重要消息到 vector-memory\n      if (vectorMemory && message && message.length > 30) {\n        try {\n          // 跳过包含 skill.js 或 hook 的内部消息\n          if (!message.includes('【') && !message.includes('hook')) {\n            await vectorMemory.add(message, { type: 'user_message', userId, taskId });\n          }\n        } catch (e) {\n          // 静默失败，不影响主流程\n        }\n      }\n      \n      // 返回原消息，不做任何修改\n      return message;\n    },\n\n    // 任务执行前评分\n    beforeTask: async (taskSpec, context) => {\n      await loadDependencies();\n      \n      // 调用 task-weight-estimator 评分\n      if (taskWeightEstimator && taskSpec) {\n        const result = taskWeightEstimator.evaluate(taskSpec);\n        context.taskWeight = result;\n        \n        // 同时也计算路由\n        if (scoring) {\n          const route = scoring.route(result);\n          context.taskRoute = route;\n        }\n        \n        console.log(`[AutoOrchestrator] 任务评分: total=${result.total}, suggestion=${result.suggestion}`);\n      }\n      \n      return taskSpec;\n    },\n\n    // 任务完成后记录\n    afterTask: async (result, context) => {\n      await loadDependencies();\n      \n      // 存储任务结果到记忆\n      if (vectorMemory && result && typeof result === 'string' && result.length > 50) {\n        try {\n          await vectorMemory.add(result, { \n            type: 'task_result', \n            taskWeight: context.taskWeight?.total \n          });\n        } catch (e) {\n          // 静默失败\n        }\n      }\n      \n      return result;\n    }\n  },\n\n  // 供其他技能调用的 API\n  api: {\n    // 评分\n    evaluate: (taskSpec) => taskWeightEstimator?.evaluate(taskSpec),\n    \n    // 路由建议\n    getRoute: (taskSpec) => {\n      if (!taskWeightEstimator || !scoring) return null;\n      const score = taskWeightEstimator.evaluate(taskSpec);\n      return scoring.route(score);\n    },\n    \n    // 记忆查询\n    searchMemory: (keywords) => vectorMemory?.query(keywords),\n    \n    // 存储记忆\n    remember: (text, metadata) => vectorMemory?.add(text, metadata)\n  }\n};"}],"isError":false,"timestamp":1775371465654}}
{"type":"message","id":"d81d8806","parentId":"be621da0","timestamp":"2026-04-05T06:45:35.790Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在让我更新 auto-orchestrator 来集成保护层的 API：\n\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"019d5c62191e4c74c27c6437d6139c0c","name":"write","arguments":{"content":"// ~/.openclaw/workspace/skills/auto-orchestrator/skill.js\n// ========================= 自动编排入口 v1.1 =========================\n// 自动集成: task-weight-estimator + vector-memory + task_orchestrator + 保护层API\n// 作为前置拦截器，在任务执行前自动评分并记录记忆\n\nconst path = require('path');\n\n// 保护层服务地址\nconst PROTECTION_API = 'http://127.0.0.1:18790';\nconst CONTEXT_API = `${PROTECTION_API}/api/context`;\nconst HEALTH_API = `${PROTECTION_API}/health`;\n\n// 延迟加载依赖技能\nlet taskWeightEstimator = null;\nlet vectorMemory = null;\nlet scoring = null;\nlet protectionLayer = null;\n\n// 保护层 API 调用\nasync function callProtectionAPI(endpoint, data = null) {\n  try {\n    const url = `${CONTEXT_API}/${endpoint}`;\n    const options = {\n      method: data ? 'POST' : 'GET',\n      headers: { 'Content-Type': 'application/json' },\n      signal: AbortSignal.timeout(2000)\n    };\n    if (data) options.body = JSON.stringify(data);\n    \n    const res = await fetch(url, options);\n    return await res.json();\n  } catch (e) {\n    console.log('[AutoOrchestrator] Protection API 调用失败:', e.message);\n    return null;\n  }\n}\n\n// 检查保护层服务健康状态\nasync function checkProtectionHealth() {\n  try {\n    const res = await fetch(HEALTH_API, { signal: AbortSignal.timeout(1000) });\n    return res.ok;\n  } catch {\n    return false;\n  }\n}\n\nasync function loadDependencies() {\n  if (!taskWeightEstimator) {\n    try {\n      taskWeightEstimator = require('/home/ai/.openclaw/workspace/skills/task-weight-estimator/skill.js');\n      scoring = require('/home/ai/.openclaw/workspace/skills/task_orchestrator/scripts/scoring.js');\n      console.log('[AutoOrchestrator] Loaded task-weight-estimator');\n    } catch (e) {\n      console.error('[AutoOrchestrator] Failed to load dependencies:', e.message);\n    }\n  }\n  if (!vectorMemory) {\n    try {\n      vectorMemory = require('/home/ai/.openclaw/workspace/skills/vector-memory/skill.js');\n      await vectorMemory.init();\n      console.log('[AutoOrchestrator] Loaded vector-memory');\n    } catch (e) {\n      console.error('[AutoOrchestrator] Failed to load vector-memory:', e.message);\n    }\n  }\n  // 加载保护层\n  if (!protectionLayer) {\n    try {\n      protectionLayer = await import('/home/ai/.openclaw/protection/task_scorer.js');\n      protectionLayer = protectionLayer.default;\n      console.log('[AutoOrchestrator] Loaded protection layer');\n    } catch (e) {\n      console.log('[AutoOrchestrator] Protection layer not available:', e.message);\n    }\n  }\n}\n\nmodule.exports = {\n  name: 'auto-orchestrator',\n  version: '1.1.0',\n  description: '自动编排入口 - 任务评分 + 记忆存储 + 执行路由 + 保护层集成',\n\n  async init() {\n    await loadDependencies();\n    \n    // 检查保护层服务状态\n    const protected = await checkProtectionHealth();\n    console.log('[AutoOrchestrator] Protection API:', protected ? '✅ 在线' : '❌ 离线');\n    console.log('[AutoOrchestrator] Initialized - 全自动模式已启用');\n  },\n\n  hooks: {\n    // 用户消息前置拦截：评分 + 记录记忆 + 上报保护层\n    onUserMessage: async (message, userId, taskId) => {\n      await loadDependencies();\n      \n      // 1. 自动记录到本地 vector-memory\n      if (vectorMemory && message && message.length > 30) {\n        try {\n          if (!message.includes('【') && !message.includes('hook')) {\n            await vectorMemory.add(message, { type: 'user_message', userId, taskId });\n          }\n        } catch (e) {\n          // 静默失败\n        }\n      }\n      \n      // 2. 上报到保护层 context_server\n      try {\n        await callProtectionAPI('add', {\n          role: 'user',\n          content: message,\n          userId,\n          taskId,\n          timestamp: Date.now()\n        });\n      } catch (e) {\n        // 静默失败\n      }\n      \n      return message;\n    },\n\n    // 任务执行前评分（双评分机制）\n    beforeTask: async (taskSpec, context) => {\n      await loadDependencies();\n      \n      // ===== 本地评分 =====\n      if (taskWeightEstimator && taskSpec) {\n        const localResult = taskWeightEstimator.evaluate(taskSpec);\n        context.taskWeight = localResult;\n        \n        if (scoring) {\n          const route = scoring.route(localResult);\n          context.taskRoute = route;\n        }\n        \n        console.log(`[AutoOrchestrator] 本地评分: total=${localResult.total}, ${localResult.suggestion}`);\n      }\n      \n      // ===== 保护层评分（4维） =====\n      if (protectionLayer && taskSpec) {\n        try {\n          const protectedResult = protectionLayer.routeTask(taskSpec);\n          context.protectionRoute = {\n            route: protectedResult.route,\n            timeout: protectedResult.timeoutSec,\n            score: protectedResult.score,\n            load: protectedResult.load,\n            isDowngraded: protectedResult.isDowngraded\n          };\n          \n          console.log(`[AutoOrchestrator] 保护层评分: ${protectedResult.route}, 超时${protectedResult.timeoutSec}秒, 负载CPU:${protectedResult.load?.cpuPercent || 'N/A'}%`);\n          \n          // 如果保护层建议更保守，采用保护层的建议\n          if (protectedResult.timeoutSec > (context.taskRoute?.timeout || 30)) {\n            context.taskRoute = { \n              mode: protectedResult.route, \n              timeout: protectedResult.timeoutSec \n            };\n          }\n        } catch (e) {\n          console.log('[AutoOrchestrator] Protection scoring failed:', e.message);\n        }\n      }\n      \n      return taskSpec;\n    },\n\n    // 任务完成后记录\n    afterTask: async (result, context) => {\n      await loadDependencies();\n      \n      // 本地记忆\n      if (vectorMemory && result && typeof result === 'string' && result.length > 50) {\n        try {\n          await vectorMemory.add(result, { \n            type: 'task_result', \n            taskWeight: context.taskWeight?.total \n          });\n        } catch (e) {}\n      }\n      \n      // 上报到保护层\n      try {\n        await callProtectionAPI('add', {\n          role: 'assistant',\n          content: typeof result === 'string' ? result : JSON.stringify(result),\n          timestamp: Date.now()\n        });\n      } catch (e) {}\n      \n      return result;\n    }\n  },\n\n  // 供其他技能调用的 API\n  api: {\n    // 本地评分\n    evaluate: (taskSpec) => taskWeightEstimator?.evaluate(taskSpec),\n    \n    // 保护层评分（4维 + 负载降级）\n    evaluateProtected: (taskSpec) => {\n      if (!protectionLayer) return null;\n      return protectionLayer.routeTask(taskSpec);\n    },\n    \n    // 路由建议\n    getRoute: (taskSpec) => {\n      if (!taskWeightEstimator || !scoring) return null;\n      const score = taskWeightEstimator.evaluate(taskSpec);\n      return scoring.route(score);\n    },\n    \n    // 获取保护层路由\n    getProtectionRoute: (taskSpec) => {\n      if (!protectionLayer) return null;\n      return protectionLayer.routeTask(taskSpec);\n    },\n    \n    // 记忆查询\n    searchMemory: (keywords) => vectorMemory?.query(keywords),\n    \n    // 存储记忆\n    remember: (text, metadata) => vectorMemory?.add(text, metadata),\n    \n    // 保护层状态\n    getProtectionStatus: async () => {\n      const healthy = await checkProtectionHealth();\n      if (!healthy) return { status: 'offline' };\n      \n      const status = await callProtectionAPI('status');\n      return { status: 'online', ...status };\n    }\n  }\n};","file":"~/.openclaw/workspace/skills/auto-orchestrator/skill.js"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":8201,"output":1800,"cacheRead":50304,"cacheWrite":0,"totalTokens":60305,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775371465662,"responseId":"019d5c620d8fc66ca5cb05256f66677e"}}
