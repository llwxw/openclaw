{"type":"message","id":"8046555e","parentId":"a84a8fd9","timestamp":"2026-04-05T07:42:02.405Z","message":{"role":"toolResult","toolCallId":"019d5c96c34953407a1bc9b368c3d2c4","toolName":"read","content":[{"type":"text","text":"/**\n * OpenClaw 任务编排系统 v7.0\n * 模块5: 子代理进度上报\n * \n * 功能:\n * - 自适应心跳间隔: 根据任务复杂度动态调整心跳频率\n * - 输出解析容错: 健壮的正则解析，支持多种格式\n * - 限流与聚合: 避免刷屏，聚合短时间内的多次更新\n * \n * 存放位置: ~/.openclaw/workspace/skills/task-orchestrator-v7/\n */\n\nimport EventEmitter from 'events';\n\n/**\n * 进度解析结果\n * @typedef {Object} ProgressParseResult\n * @property {number} percent - 进度百分比 (0-100)\n * @property {number} step - 当前步骤\n * @property {number} total - 总步骤数\n * @property {string} description - 步骤描述\n * @property {boolean} valid - 是否有效解析\n */\n\n/**\n * 心跳状态\n * @typedef {Object} HeartbeatState\n * @property {number} lastHeartbeat - 上次心跳时间戳\n * @property {number} interval - 当前心跳间隔(ms)\n * @property {number} missedCount - 连续 missed 次数\n */\n\nclass ProgressReporter extends EventEmitter {\n  constructor(options = {}) {\n    super();\n    \n    // 配置\n    this.config = {\n      // 基础心跳间隔 (ms)\n      baseInterval: options.baseInterval || 30000,\n      // 最小心跳间隔 (ms)\n      minInterval: options.minInterval || 5000,\n      // 最大心跳间隔 (ms)\n      maxInterval: options.maxInterval || 120000,\n      // 自适应系数 (任务越复杂，心跳越频繁)\n      complexityFactor: options.complexityFactor || 1.5,\n      // 输出限流间隔 (ms) - 同一任务的多次进度更新会被聚合\n      throttleInterval: options.throttleInterval || 1000,\n      // 无产出警告阈值 (ms)\n      noOutputWarning: options.noOutputWarning || 30000,\n\n[377 more lines in file. Use offset=51 to continue.]"}],"isError":false,"timestamp":1775374922397}}
