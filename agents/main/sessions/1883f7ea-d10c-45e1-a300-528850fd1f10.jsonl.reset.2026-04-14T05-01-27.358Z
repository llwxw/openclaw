{"type":"message","id":"10106e70","parentId":"9ae7adb5","timestamp":"2026-04-13T12:20:31.352Z","message":{"role":"toolResult","toolCallId":"call_function_5e1l3u4p3vvr_3","toolName":"exec","content":[{"type":"text","text":"import { defineConfig } from 'vite'\r\nimport react from '@vitejs/plugin-react'\r\nimport { resolve } from 'path'\r\n\r\n// Vite 配置 - 使用 src/renderer 作为根目录，包含API代理解决CORS问题\r\nexport default defineConfig({\r\n  plugins: [react()],\r\n  root: resolve(__dirname, 'src/renderer'),\r\n  base: './',\r\n  define: {\r\n    'process.env': {},\r\n  },\r\n  server: {\r\n    port: 3004,\r\n    host: '127.0.0.1',\r\n    strictPort: true,\r\n    open: false,\r\n    proxy: {\r\n      // 豆包 API 代理\r\n      '/proxy/doubao': {\r\n        target: 'https://ark.cn-beijing.volces.com',\r\n        changeOrigin: true,\r\n        secure: true,\r\n        rewrite: (path) => path.replace(/^\\/proxy\\/doubao/, ''),\r\n        timeout: 300000,\r\n        proxyTimeout: 300000,\r\n      },\r\n      // DeepSeek API 代理\r\n      '/proxy/deepseek': {\r\n        target: 'https://api.deepseek.com',\r\n        changeOrigin: true,\r\n        secure: true,\r\n        rewrite: (path) => path.replace(/^\\/proxy\\/deepseek/, ''),\r\n        timeout: 300000,\r\n        proxyTimeout: 300000,\r\n      },\r\n      // Kimi API 代理\r\n      '/proxy/kimi': {\r\n        target: 'https://api.moonshot.cn',\r\n        changeOrigin: true,\r\n        secure: true,\r\n        rewrite: (path) => path.replace(/^\\/proxy\\/kimi/, ''),\r\n        timeout: 300000,\r\n        proxyTimeout: 300000,\r\n      },\r\n      // OpenAI API 代理\r\n      '/proxy/openai': {\r\n        target: 'https://api.openai.com',\r\n        changeOrigin: true,\r\n        secure: true,\r\n        rewrite: (path) => path.replace(/^\\/proxy\\/openai/, ''),\r\n        timeout: 300000,\r\n        proxyTimeout: 300000,\r\n      },\r\n      // Qwen API 代理\r\n      '/proxy/qwen': {\r\n        target: 'https://dashscope.aliyuncs.com',\r\n      