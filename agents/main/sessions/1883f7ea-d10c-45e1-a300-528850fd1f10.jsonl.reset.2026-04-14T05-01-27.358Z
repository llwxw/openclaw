{"type":"message","id":"382145be","parentId":"628f9490","timestamp":"2026-04-13T12:14:20.018Z","message":{"role":"toolResult","toolCallId":"call_function_4dhe8mthzgkm_1","toolName":"exec","content":[{"type":"text","text":"257 /mnt/d/aafuzhi/axs/src/renderer/src/components/AIToolsPanel.tsx\n  135 /mnt/d/aafuzhi/axs/src/renderer/src/components/Editor.tsx\n  140 /mnt/d/aafuzhi/axs/src/renderer/src/components/FactsPanel.tsx\n  200 /mnt/d/aafuzhi/axs/src/renderer/src/components/OutlineTree.tsx\n  232 /mnt/d/aafuzhi/axs/src/renderer/src/components/Workbench.tsx\n  155 /mnt/d/aafuzhi/axs/src/renderer/src/services/aiModels.ts\n  172 /mnt/d/aafuzhi/axs/src/renderer/src/services/factExtractor.ts\n 1291 total"}],"details":{"status":"completed","exitCode":0,"durationMs":71,"aggregated":"257 /mnt/d/aafuzhi/axs/src/renderer/src/components/AIToolsPanel.tsx\n  135 /mnt/d/aafuzhi/axs/src/renderer/src/components/Editor.tsx\n  140 /mnt/d/aafuzhi/axs/src/renderer/src/components/FactsPanel.tsx\n  200 /mnt/d/aafuzhi/axs/src/renderer/src/components/OutlineTree.tsx\n  232 /mnt/d/aafuzhi/axs/src/renderer/src/components/Workbench.tsx\n  155 /mnt/d/aafuzhi/axs/src/renderer/src/services/aiModels.ts\n  172 /mnt/d/aafuzhi/axs/src/renderer/src/services/factExtractor.ts\n 1291 total","cwd":"/home/ai/.openclaw/workspace/main"},"isError":false,"timestamp":1776082460008}}
{"type":"message","id":"9ceb29f8","parentId":"382145be","timestamp":"2026-04-13T12:14:20.030Z","message":{"role":"toolResult","toolCallId":"call_function_4dhe8mthzgkm_2","toolName":"exec","content":[{"type":"text","text":"total 36\ndrwxrwxrwx 1 ai ai 4096 Apr 10 00:37 .\ndrwxrwxrwx 1 ai ai 4096 Apr  5 20:25 ..\n-rwxrwxrwx 1 ai ai 6632 Apr 10 00:37 AIToolsPanel.tsx\n-rwxrwxrwx 1 ai ai 3690 Apr 10 00:37 Editor.tsx\n-rwxrwxrwx 1 ai ai 4346 Apr 10 00:37 FactsPanel.tsx\n-rwxrwxrwx 1 ai ai 5436 Apr 10 00:37 OutlineTree.tsx\n-rwxrwxrwx 1 ai ai 6909 Apr 10 00:37 Workbench.tsx"}],"details":{"status":"completed","exitCode":0,"durationMs":71,"aggregated":"total 36\ndrwxrwxrwx 1 ai ai 4096 Apr 10 00:37 .\ndrwxrwxrwx 1 ai ai 4096 Apr  5 20:25 ..\n-rwxrwxrwx 1 ai ai 6632 Apr 10 00:37 AIToolsPanel.tsx\n-rwxrwxrwx 1 ai ai 3690 Apr 10 00:37 Editor.tsx\n-rwxrwxrwx 1 ai ai 4346 Apr 10 00:37 FactsPanel.tsx\n-rwxrwxrwx 1 ai ai 5436 Apr 10 00:37 OutlineTree.tsx\n-rwxrwxrwx 1 ai ai 6909 Apr 10 00:37 Workbench.tsx","cwd":"/home/ai/.openclaw/workspace/main"},"isError":false,"timestamp":1776082460018}}
{"type":"message","id":"cd1e60d4","parentId":"9ceb29f8","timestamp":"2026-04-13T12:14:20.045Z","message":{"role":"toolResult","toolCallId":"call_function_4dhe8mthzgkm_3","toolName":"read","content":[{"type":"text","text":"/**\n * AI 模型服务\n * 不同任务自动选择最合适的模型\n */\n\nexport type AIModel = 'doubao-pro' | 'doubao-lite' | 'doubao-mini' | 'deepseek-reasoner'\nexport type TaskType = 'creative' | 'summary' | 'classification' | 'logic' | 'extraction'\n\n// 模型能力映射\nconst ModelTaskMapping: Record<TaskType, AIModel> = {\n  creative: 'doubao-pro',         // 章节生成、创意续写\n  summary: 'doubao-lite',         // 摘要、结构化分析\n  classification: 'doubao-mini',  // 极速分类\n  logic: 'deepseek-reasoner',     // 逻辑校验、一致性检查\n  extraction: 'doubao-lite',      // 事实提取\n}\n\n// 模型配置\ninterface ModelConfig {\n  maxTokens: number\n  temperature: number\n  topP: number\n  presencePenalty: number\n  frequencyPenalty: number\n}\n\nconst ModelConfigs: Record<AIModel, ModelConfig> = {\n  'doubao-pro': {\n    maxTokens: 4096,\n    temperature: 0.8,\n    topP: 0.9,\n    presencePenalty: 0.1,\n    frequencyPenalty: 0.1,\n  },\n  'doubao-lite': {\n    maxTokens: 2048,\n    temperature: 0.3,\n    topP: 0.85,\n    presencePenalty: 0.0,\n    frequencyPenalty: 0.0,\n  },\n  'doubao-mini': {\n    maxTokens: 1024,\n    temperature: 0.1,\n    topP: 0.7,\n    presencePenalty: 0.0,\n    frequencyPenalty: 0.0,\n  },\n  'deepseek-reasoner': {\n    maxTokens: 8192,\n    temperature: 0.2,\n    topP: 0.95,\n    presencePenalty: 0.0,\n    frequencyPenalty: 0.0,\n  },\n}\n\nclass AIModelService {\n  /**\n   * 根据任务类型选择最优模型\n   */\n  selectModel(taskType: TaskType): AIModel {\n    return ModelTaskMapping[taskType] || 'doubao-pro'\n  }\n\n  /**\n   * 获取模型配置\n   */\n  getModelConfig(model: AIModel): ModelConfig {\n    return ModelConfigs[model] || ModelConfigs['doubao-pro']\n  }\n\n  /**\n   * 调用 AI 模型 (非流式)\n   */\n  async call(\n    taskType: TaskType,\n    prompt: string,\n    options?: Partial<ModelConfig> & { systemPrompt?: string }\n  ): Promise<{ success: boolean; content?: string; error?: string }> {\n    try {\n      const model = this.selectModel(taskType)\n      const config = { ...this.getModelConfig(model), ...options }\n\n      const result = await window.electronAPI.ai.call(prompt, {\n        model,\n        ...config,\n        systemPrompt: options?.systemPrompt,\n      })\n\n      return result\n    } catch (error: any) {\n      return { success: false, error: error.message }\n    }\n  }\n\n  /**\n   * 流式调用 AI 模型\n   */\n  async stream(\n    taskType: TaskType,\n    prompt: string,\n    onChunk: (chunk: string, done: boolean) => void,\n    onError?: (error: string) => void,\n    options?: Partial<ModelConfig> & { systemPrompt?: string }\n  ): Promise<void> {\n    try {\n      const model = this.selectModel(taskType)\n      const config = { ...this.getModelConfig(model), ...options }\n\n      // 监听流式输出\n      const removeChunkListener = window.electronAPI.ai.onStreamChunk((chunk) => {\n        if (chunk.done) {\n          onChunk('', true)\n          removeChunkListener()\n          removeErrorListener()\n        } else {\n          onChunk(chunk.content, false)\n        }\n      })\n\n      // 监听错误\n      const removeErrorListener = window.electronAPI.ai.onStreamError((error) => {\n        if (onError) onError(error)\n        removeChunkListener()\n        removeErrorListener()\n      })\n\n      // 发起流式请求\n      await window.electronAPI.ai.stream(prompt, {\n        model,\n        ...config,\n        systemPrompt: options?.systemPrompt,\n      })\n    } catch (error: any) {\n      if (onError) onError(error.message)\n    }\n  }\n\n  /**\n   * 测试模型连接\n   */\n  async testConnection(model: AIModel): Promise<boolean> {\n    try {\n      const result = await window.electronAPI.ai.testConnection(model)\n      return result.success && result.result\n    } catch {\n      return false\n    }\n  }\n}\n\n// 单例导出\nconst aiModelService = new AIModelService()\nexport default aiModelService\n"}],"isError":false,"timestamp":1776082460036}}
{"type":"message","id":"f5b29075","parentId":"cd1e60d4","timestamp":"2026-04-13T12:14:22.781Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me look at more components to get a fuller picture of what's implemented.","thinkingSignature":"94306061557cd4f072d849a147c442d3bc817fe35021039b5322f60e5cc9853e"},{"type":"toolCall","id":"call_function_chuua17malxi_1","name":"read","arguments":{"path":"/mnt/d/aafuzhi/axs/src/renderer/src/components/AIToolsPanel.tsx"}},{"type":"toolCall","id":"call_function_chuua17malxi_2","name":"read","arguments":{"path":"/mnt/d/aafuzhi/axs/src/renderer/src/components/Workbench.tsx"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":11711,"output":100,"cacheRead":19262,"cacheWrite":0,"totalTokens":31073,"cost":{"input":0.0035133,"output":0.00011999999999999999,"cacheRead":0.0011557199999999998,"cacheWrite":0,"total":0.00478902}},"stopReason":"toolUse","timestamp":1776082460045,"responseId":"062c111bd63dc9dd4fa5fcadaa01f68f"}}
{"type":"message","id":"9f0a2aca","parentId":"f5b29075","timestamp":"2026-04-13T12:14:22.857Z","message":{"role":"toolResult","toolCallId":"call_function_chuua17malxi_1","toolName":"read","content":[{"type":"text","text":"import { useState } from 'react'\nimport { Button, Space, Card, Input, message, Spin } from 'antd'\nimport {\n  EditOutlined,\n  ExpandOutlined,\n  CheckCircleOutlined,\n  ThunderboltOutlined\n} from '@ant-design/icons'\nimport aiModelService from '../services/aiModels'\nimport factExtractor from '../services/factExtractor'\n\nconst { TextArea } = Input\n\ninterface AIToolsPanelProps {\n  chapterContent: string\n  chapterPath: string | null\n  onInsertText: (text: string) => void\n}\n\nconst AIToolsPanel = ({ chapterContent, chapterPath, onInsertText }: AIToolsPanelProps) => {\n  const [generating, setGenerating] = useState(false)\n  const [result, setResult] = useState('')\n  const [prompt, setPrompt] = useState('')\n\n  // 智能续写\n  const handleContinue = async () => {\n    if (!chapterContent) {\n      message.warning('请先选择章节并编写内容')\n      return\n    }\n\n    setGenerating(true)\n    setResult('')\n    \n    try {\n      // 获取最后500个字符作为上下文\n      const context = chapterContent.slice(-500)\n      const fullPrompt = `请继续写下面的小说内容，风格保持一致，衔接自然：\n\n${context}\n\n续写内容：`\n\n      await aiModelService.stream(\n        'creative',\n        fullPrompt,\n        (chunk, done) => {\n          setResult(prev => prev + chunk)\n        },\n        (error) => {\n          message.error(`续写失败：${error}`)\n        }\n      )\n    } catch (error) {\n      message.error('续写失败')\n    } finally {\n      setGenerating(false)\n    }\n  }\n\n  // 定向扩写\n  const handleExpand = async () => {\n    if (!prompt) {\n      message.warning('请输入扩写要求')\n      return\n    }\n\n    setGenerating(true)\n    setResult('')\n\n    try {\n      const fullPrompt = `请根据以下要求扩写小说内容：\n要求：${prompt}\n上下文：\n${chapterContent.slice(-1000)}\n\n扩写后的内容：`\n\n      await aiModelService.stream(\n        'creative',\n        fullPrompt,\n        (chunk, done) => {\n          setResult(prev => prev + chunk)\n        },\n        (error) => {\n          message.error(`扩写失败：${error}`)\n        }\n      )\n    } catch (error) {\n      message.error('扩写失败')\n    } finally {\n      setGenerating(false)\n    }\n  }\n\n  // 逻辑校验\n  const handleCheck = async () => {\n    if (!chapterContent) {\n      message.warning('请先选择章节')\n      return\n    }\n\n    setGenerating(true)\n    setResult('')\n\n    try {\n      const result = await aiModelService.call(\n        'logic',\n        chapterContent,\n        {\n          systemPrompt: `请检查以下小说章节内容的逻辑一致性，找出矛盾点、战力崩坏、情节不合理的地方，给出修改建议。`\n        }\n      )\n\n      if (result.success && result.content) {\n        setResult(result.content)\n      } else {\n        message.error(result.error || '校验失败')\n      }\n    } catch (error) {\n      message.error('逻辑校验失败')\n    } finally {\n      setGenerating(false)\n    }\n  }\n\n  // 提取事实\n  const handleExtract = async () => {\n    if (!chapterContent || !chapterPath) {\n      message.warning('请先选择章节')\n      return\n    }\n\n    setGenerating(true)\n    setResult('')\n\n    try {\n      // 提取章节号\n      const chapterMatch = chapterPath.match(/第(\\d+)章/)\n      const chapterNumber = chapterMatch ? parseInt(chapterMatch[1]) : 1\n\n      const facts = await factExtractor.extract(chapterContent, chapterNumber)\n      \n      if (facts.length === 0) {\n        setResult('未提取到任何事实')\n        return\n      }\n\n      // 格式化结果\n      let output = `提取到 ${facts.length} 条事实：\\n\\n`\n      facts.forEach((fact, index) => {\n        output += `${index + 1}. [${fact.type}] ${fact.subject}${fact.object ? ' → ' + fact.object : ''}\\n`\n        output += `   ${fact.content} (置信度: ${(fact.confidence * 100).toFixed(0)}%)\\n\\n`\n      })\n\n      output += `是否保存到事实台账？`\n      setResult(output)\n    } catch (error) {\n      message.error('事实提取失败')\n    } finally {\n      setGenerating(false)\n    }\n  }\n\n  // 应用生成结果\n  const handleApply = () => {\n    if (!result) return\n    onInsertText(result)\n    message.success('已插入内容')\n    setResult('')\n  }\n\n  return (\n    <div style={{ height: '100%', display: 'flex', flexDirection: 'column' }}>\n      <div style={{ padding: 16, borderBottom: '1px solid #e8e8e8' }}>\n        <h3 style={{ margin: '0 0 10px 0' }}>AI 工具</h3>\n        <Space direction=\"vertical\" style={{ width: '100%' }}>\n          <Button\n            type=\"primary\"\n            block\n            icon={<EditOutlined />}\n            onClick={handleContinue}\n            loading={generating}\n            disabled={!chapterContent}\n          >\n            智能续写\n          </Button>\n          <Button\n            block\n            icon={<ExpandOutlined />}\n            onClick={handleExpand}\n            loading={generating}\n            disabled={!chapterContent}\n          >\n            定向扩写\n          </Button>\n          <Button\n            block\n            icon={<CheckCircleOutlined />}\n            onClick={handleCheck}\n            loading={generating}\n            disabled={!chapterContent}\n          >\n            逻辑校验\n          </Button>\n          <Button\n            block\n            icon={<ThunderboltOutlined />}\n            onClick={handleExtract}\n            loading={generating}\n            disabled={!chapterContent}\n          >\n            提取事实\n          </Button>\n\n          <TextArea\n            placeholder=\"输入扩写/修改要求（可选）\"\n            rows={3}\n            value={prompt}\n            onChange={(e) => setPrompt(e.target.value)}\n          />\n        </Space>\n      </div>\n\n      <div style={{ flex: 1, overflow: 'auto', padding: 16 }}>\n        {generating ? (\n          <div style={{ textAlign: 'center', padding: 40 }}>\n            <Spin tip=\"AI 生成中...\" />\n          </div>\n        ) : result ? (\n          <Card\n            size=\"small\"\n            title=\"AI 生成结果\"\n            extra={\n              <Button\n                type=\"link\"\n                size=\"small\"\n                onClick={handleApply}\n              >\n                插入到编辑器\n              </Button>\n            }\n            style={{ whiteSpace: 'pre-wrap', wordBreak: 'break-all' }}\n          >\n            {result}\n          </Card>\n        ) : (\n          <div style={{ color: '#999', textAlign: 'center', padding: 40 }}>\n            选择上方工具开始使用 AI 辅助创作\n          </div>\n        )}\n      </div>\n    </div>\n  )\n}\n\nexport default AIToolsPanel\n"}],"isError":false,"timestamp":1776082462848}}
{"type":"message","id":"77fae557","parentId":"9f0a2aca","timestamp":"2026-04-13T12:14:22.865Z","message":{"role":"toolResult","toolCallId":"call_function_chuua17malxi_2","toolName":"read","content":[{"type":"text","text":"import { useState, useEffect } from 'react'\nimport { Layout, Menu, Button, message } from 'antd'\nimport {\n  SaveOutlined,\n  FolderOpenOutlined,\n  BookOutlined,\n  UserOutlined,\n  SettingOutlined,\n  ThunderboltOutlined\n} from '@ant-design/icons'\nimport OutlineTree from './OutlineTree'\nimport Editor from './Editor'\nimport FactsPanel from './FactsPanel'\nimport AIToolsPanel from './AIToolsPanel'\nimport type { MenuProps } from 'antd'\n\nconst { Sider, Content } = Layout\n\ntype TabKey = 'outline' | 'characters' | 'settings' | 'facts' | 'ai'\n\n// 左侧菜单\nconst siderMenuItems: MenuProps['items'] = [\n  { key: 'outline', icon: <BookOutlined />, label: '大纲导航' },\n  { key: 'characters', icon: <UserOutlined />, label: '角色管理' },\n  { key: 'settings', icon: <SettingOutlined />, label: '世界设定' },\n  { key: 'facts', icon: <ThunderboltOutlined />, label: '事实台账' },\n]\n\nconst Workbench = () => {\n  const [activeTab, setActiveTab] = useState<TabKey>('outline')\n  const [activeChapter, setActiveChapter] = useState<string | null>(null)\n  const [chapterContent, setChapterContent] = useState('')\n  const [projectRoot, setProjectRoot] = useState<string | null>(null)\n  const [isDirty, setIsDirty] = useState(false)\n  const [autoSaveTimer, setAutoSaveTimer] = useState<NodeJS.Timeout | null>(null)\n\n  // 初始化项目\n  useEffect(() => {\n    const init = async () => {\n      const root = await window.electronAPI.getProjectRoot()\n      setProjectRoot(root)\n    }\n    init()\n  }, [])\n\n  // 自动保存\n  useEffect(() => {\n    if (isDirty && activeChapter) {\n      if (autoSaveTimer) clearTimeout(autoSaveTimer)\n      \n      const timer = setTimeout(() => {\n        handleSave()\n      }, 5000) // 5秒防抖自动保存\n      \n      setAutoSaveTimer(timer)\n    }\n\n    return () => {\n      if (autoSaveTimer) clearTimeout(autoSaveTimer)\n    }\n  }, [chapterContent, isDirty])\n\n  // 打开项目\n  const handleOpenProject = async () => {\n    const directory = await window.electronAPI.openDirectory()\n    if (directory) {\n      setProjectRoot(directory)\n      message.success(`已打开项目：${directory}`)\n    }\n  }\n\n  // 保存章节\n  const handleSave = async () => {\n    if (!activeChapter || !chapterContent) return\n\n    try {\n      const result = await window.electronAPI.writeFile(activeChapter, chapterContent)\n      if (result.success) {\n        setIsDirty(false)\n        message.success('已保存')\n      } else {\n        message.error(`保存失败：${result.error}`)\n      }\n    } catch (error) {\n      message.error('保存失败')\n    }\n  }\n\n  // 章节选择\n  const handleChapterSelect = async (filePath: string) => {\n    if (isDirty) {\n      // 提示保存\n      const confirm = window.confirm('当前章节有未保存的内容，是否保存？')\n      if (confirm) await handleSave()\n    }\n\n    setActiveChapter(filePath)\n    \n    // 读取章节内容\n    try {\n      const result = await window.electronAPI.readFile(filePath)\n      if (result.success && result.content) {\n        setChapterContent(result.content)\n        setIsDirty(false)\n      }\n    } catch (error) {\n      message.error('读取章节失败')\n    }\n  }\n\n  // 内容变化\n  const handleContentChange = (value: string | undefined) => {\n    if (value === undefined) return\n    setChapterContent(value)\n    setIsDirty(true)\n  }\n\n  // 快捷键保存\n  useEffect(() => {\n    const handleKeyDown = (e: KeyboardEvent) => {\n      if ((e.ctrlKey || e.metaKey) && e.key === 's') {\n        e.preventDefault()\n        handleSave()\n      }\n    }\n    window.addEventListener('keydown', handleKeyDown)\n    return () => window.removeEventListener('keydown', handleKeyDown)\n  }, [activeChapter, chapterContent])\n\n  return (\n    <Layout style={{ height: '100vh' }}>\n      {/* 顶部工具栏 */}\n      <Layout.Header\n        style={{\n          display: 'flex',\n          alignItems: 'center',\n          padding: '0 20px',\n          background: '#fff',\n          borderBottom: '1px solid #e8e8e8',\n          justifyContent: 'space-between'\n        }}\n      >\n        <div style={{ display: 'flex', alignItems: 'center', gap: 20 }}>\n          <h2 style={{ margin: 0 }}>🍅 番茄小说创作助手</h2>\n          {projectRoot && <span style={{ color: '#999' }}>当前项目：{projectRoot}</span>}\n        </div>\n        <div style={{ display: 'flex', gap: 10 }}>\n          <Button\n            icon={<FolderOpenOutlined />}\n            onClick={handleOpenProject}\n          >\n            打开项目\n          </Button>\n          <Button\n            icon={<SaveOutlined />}\n            type=\"primary\"\n            onClick={handleSave}\n            disabled={!isDirty || !activeChapter}\n          >\n            保存 {isDirty ? '*' : ''}\n          </Button>\n        </div>\n      </Layout.Header>\n\n      <Layout>\n        {/* 左侧边栏 */}\n        <Sider width={64} theme=\"light\">\n          <Menu\n            mode=\"inline\"\n            selectedKeys={[activeTab]}\n            items={siderMenuItems}\n            onClick={({ key }) => setActiveTab(key as TabKey)}\n            style={{ height: '100%', borderRight: 0 }}\n          />\n        </Sider>\n\n        {/* 左侧内容区 */}\n        <Sider width={280} theme=\"light\" style={{ borderRight: '1px solid #e8e8e8' }}>\n          {activeTab === 'outline' && projectRoot && (\n            <OutlineTree\n              projectRoot={projectRoot}\n              activeChapter={activeChapter}\n              onSelect={handleChapterSelect}\n            />\n          )}\n          {activeTab === 'characters' && <div>角色管理（开发中）</div>}\n          {activeTab === 'settings' && <div>世界设定（开发中）</div>}\n          {activeTab === 'facts' && <FactsPanel />}\n        </Sider>\n\n        {/* 中间编辑区 */}\n        <Content style={{ background: '#fff' }}>\n          {activeChapter ? (\n            <Editor\n              value={chapterContent}\n              onChange={handleContentChange}\n              filePath={activeChapter}\n            />\n          ) : (\n            <div\n              style={{\n                display: 'flex',\n                height: '100%',\n                alignItems: 'center',\n                justifyContent: 'center',\n                color: '#999',\n                fontSize: 18,\n              }}\n            >\n              请在左侧选择章节，或打开一个小说项目\n            </div>\n          )}\n        </Content>\n\n        {/* 右侧AI工具区 */}\n        <Sider width={320} theme=\"light\" style={{ borderLeft: '1px solid #e8e8e8' }}>\n          <AIToolsPanel\n            chapterContent={chapterContent}\n            chapterPath={activeChapter}\n            onInsertText={(text) => {\n              // 插入到编辑器光标位置\n              setChapterContent(prev => prev + text)\n              setIsDirty(true)\n            }}\n          />\n        </Sider>\n      </Layout>\n    </Layout>\n  )\n}\n\nexport default Workbench\n"}],"isError":false,"timestamp":1776082462857}}
{"type":"message","id":"0265c49b","parentId":"77fae557","timestamp":"2026-04-13T12:14:28.589Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Let me also check the other key files like factExtractor, OutlineTree, and the stores to get a full picture.","thinkingSignature":"d65027a151912be188f53fba342475c6485b84241eff924e6d1e1699757265e6"},{"type":"toolCall","id":"call_function_fzu78rgs3gxt_1","name":"read","arguments":{"path":"/mnt/d/aafuzhi/axs/src/renderer/src/services/factExtractor.ts"}},{"type":"toolCall","id":"call_function_fzu78rgs3gxt_2","name":"read","arguments":{"path":"/mnt/d/aafuzhi/axs/src/renderer/src/components/OutlineTree.tsx"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":15084,"output":106,"cacheRead":19262,"cacheWrite":0,"totalTokens":34452,"cost":{"input":0.0045252,"output":0.0001272,"cacheRead":0.0011557199999999998,"cacheWrite":0,"total":0.00580812}},"stopReason":"toolUse","timestamp":1776082462866,"responseId":"062c111e6b18491f91a7b9c1b8937d06"}}
{"type":"message","id":"169b98c3","parentId":"0265c49b","timestamp":"2026-04-13T12:14:28.664Z","message":{"role":"toolResult","toolCallId":"call_function_fzu78rgs3gxt_1","toolName":"read","content":[{"type":"text","text":"/**\n * 事实提取服务\n * 自动从章节内容中提取战力、物品、关系、伏笔等事实\n */\n\nimport aiModelService from './aiModels'\nimport db, { Fact } from '../db'\n\n// 提取结果类型\nexport interface ExtractedFact extends Omit<Fact, 'id' | 'createdAt'> {\n  confidence: number // 置信度 0-1\n}\n\nclass FactExtractor {\n  /**\n   * 从章节内容提取事实\n   */\n  async extract(\n    chapterContent: string,\n    chapterNumber: number\n  ): Promise<ExtractedFact[]> {\n    try {\n      const systemPrompt = `\n你是小说事实提取专家。请从以下章节内容中提取关键事实信息，返回严格的JSON格式数组。\n\n提取规则：\n1. 战力信息(type=\"power\")：角色的等级、实力、功法等\n2. 物品信息(type=\"item\")：武器、丹药、宝物等\n3. 关系信息(type=\"relation\")：角色之间的关系（朋友、敌人、师徒、夫妻等）\n4. 伏笔信息(type=\"foreshadow\")：后续可能用到的线索、未解开的谜团\n\n每个事实必须包含：\n- type: 类型（power/item/relation/foreshadow）\n- subject: 主体（如\"林枫\"）\n- object: 客体（可选，如\"青云子\"）\n- content: 事实描述（如\"林枫修炼到炼气三层\"）\n- chapterStart: 章节号（传入的 ${chapterNumber}）\n- chapterEnd: 章节号（传入的 ${chapterNumber}）\n- confidence: 置信度 0-1\n\n返回格式示例：\n[\n  {\n    \"type\": \"power\",\n    \"subject\": \"林枫\",\n    \"object\": \"\",\n    \"content\": \"林枫突破到炼气三层，实力提升三倍\",\n    \"chapterStart\": ${chapterNumber},\n    \"chapterEnd\": ${chapterNumber},\n    \"confidence\": 0.95\n  }\n]\n\n只返回JSON，不要其他内容。\n`\n\n      const result = await aiModelService.call(\n        'extraction',\n        chapterContent,\n        { systemPrompt }\n      )\n\n      if (!result.success || !result.content) {\n        return []\n      }\n\n      // 解析提取结果\n      let extractedFacts: ExtractedFact[]\n      try {\n        extractedFacts = JSON.parse(result.content.trim())\n      } catch (parseError) {\n        console.error('解析提取结果失败:', parseError)\n        return []\n      }\n\n      return extractedFacts\n    } catch (error) {\n      console.error('事实提取失败:', error)\n      return []\n    }\n  }\n\n  /**\n   * 批量保存事实到数据库\n   */\n  async saveFacts(facts: Omit<Fact, 'id' | 'createdAt'>[]): Promise<string[]> {\n    const savedIds: string[] = []\n\n    for (const fact of facts) {\n      const result = await db.addFact(fact)\n      if (result.success && result.id) {\n        savedIds.push(result.id)\n      }\n    }\n\n    return savedIds\n  }\n\n  /**\n   * 自动提取并保存（用户确认后调用）\n   */\n  async extractAndSave(\n    chapterContent: string,\n    chapterNumber: number\n  ): Promise<string[]> {\n    const facts = await this.extract(chapterContent, chapterNumber)\n    // 过滤置信度低于0.7的结果\n    const highConfidenceFacts = facts.filter(f => f.confidence >= 0.7)\n    return this.saveFacts(highConfidenceFacts)\n  }\n\n  /**\n   * 验证事实一致性\n   */\n  async verifyConsistency(\n    newFacts: ExtractedFact[],\n    existingFacts: Fact[]\n  ): Promise<Array<{ fact: ExtractedFact; conflict?: Fact; message: string }>> {\n    const conflicts: Array<{ fact: ExtractedFact; conflict?: Fact; message: string }> = []\n\n    for (const newFact of newFacts) {\n      // 检查是否与现有事实冲突\n      const conflicting = existingFacts.find(f => {\n        if (f.subject !== newFact.subject) return false\n        \n        // 相同主体的战力信息冲突检查\n        if (f.type === 'power' && newFact.type === 'power') {\n          // 简单的冲突检测：如果新事实表明战力下降但没有合理解释\n          const oldLevel = this.extractPowerLevel(f.content)\n          const newLevel = this.extractPowerLevel(newFact.content)\n          return oldLevel !== null && newLevel !== null && newLevel < oldLevel\n        }\n        \n        // 关系信息冲突检查\n        if (f.type === 'relation' && newFact.type === 'relation') {\n          return f.object === newFact.object && f.content !== newFact.content\n        }\n        \n        return false\n      })\n\n      if (conflicting) {\n        conflicts.push({\n          fact: newFact,\n          conflict: conflicting,\n          message: `检测到事实冲突：现有记录 \"${conflicting.content}\" 与新提取的 \"${newFact.content}\" 不一致`\n        })\n      }\n    }\n\n    return conflicts\n  }\n\n  /**\n   * 辅助方法：提取战力等级\n   */\n  private extractPowerLevel(content: string): number | null {\n    const regex = /炼气(\\d+)/i\n    const match = content.match(regex)\n    if (match) return parseInt(match[1])\n    \n    const regex2 = /筑基(\\d+)/i\n    const match2 = content.match(regex2)\n    if (match2) return parseInt(match2[1]) + 10 // 筑基阶段+10\n    \n    return null\n  }\n}\n\n// 单例导出\nconst factExtractor = new FactExtractor()\nexport default factExtractor\n"}],"isError":false,"timestamp":1776082468656}}
{"type":"message","id":"f9665fec","parentId":"169b98c3","timestamp":"2026-04-13T12:14:28.674Z","message":{"role":"toolResult","toolCallId":"call_function_fzu78rgs3gxt_2","toolName":"read","content":[{"type":"text","text":"import { useState, useEffect } from 'react'\nimport { Tree, Spin, Empty, message } from 'antd'\nimport { FileOutlined, FolderOutlined } from '@ant-design/icons'\nimport type { DataNode } from 'antd/es/tree'\nimport path from 'path'\n\ninterface OutlineTreeProps {\n  projectRoot: string\n  activeChapter: string | null\n  onSelect: (filePath: string) => void\n}\n\ninterface FileEntry {\n  name: string\n  isDirectory: boolean\n  isFile: boolean\n  path: string\n  children?: FileEntry[]\n}\n\nconst OutlineTree = ({ projectRoot, activeChapter, onSelect }: OutlineTreeProps) => {\n  const [treeData, setTreeData] = useState<DataNode[]>([])\n  const [loading, setLoading] = useState(false)\n  const [expandedKeys, setExpandedKeys] = useState<string[]>([])\n\n  // 读取目录结构\n  const loadDirectory = async (dirPath: string): Promise<FileEntry[]> => {\n    try {\n      const entries = await window.electronAPI.readdir(dirPath)\n      if (!Array.isArray(entries)) return []\n      \n      const result: FileEntry[] = []\n      \n      for (const entry of entries) {\n        const fullPath = path.join(dirPath, entry.name)\n        \n        if (entry.isDirectory) {\n          const children = await loadDirectory(fullPath)\n          result.push({\n            name: entry.name,\n            isDirectory: true,\n            isFile: false,\n            path: fullPath,\n            children\n          })\n        } else if (entry.isFile && entry.name.endsWith('.md')) {\n          result.push({\n            name: entry.name.replace('.md', ''),\n            isDirectory: false,\n            isFile: true,\n            path: fullPath\n          })\n        }\n      }\n      \n      return result.sort((a, b) => {\n        // 目录排在前面，然后是文件\n        if (a.isDirectory && !b.isDirectory) return -1\n        if (!a.isDirectory && b.isDirectory) return 1\n        // 按名称排序\n        return a.name.localeCompare(b.name)\n      })\n    } catch (error) {\n      console.error('读取目录失败:', error)\n      return []\n    }\n  }\n\n  // 转换为 Ant Design Tree 需要的格式\n  const convertToTreeData = (entries: FileEntry[], parentKey: string = ''): DataNode[] => {\n    return entries.map((entry, index) => {\n      const key = parentKey ? `${parentKey}-${index}` : `${index}`\n      \n      if (entry.isDirectory && entry.children) {\n        return {\n          title: entry.name,\n          key,\n          icon: <FolderOutlined />,\n          children: convertToTreeData(entry.children, key),\n          isLeaf: false\n        }\n      } else {\n        return {\n          title: entry.name,\n          key: entry.path,\n          icon: <FileOutlined />,\n          isLeaf: true\n        }\n      }\n    })\n  }\n\n  // 加载大纲\n  useEffect(() => {\n    const loadOutline = async () => {\n      if (!projectRoot) return\n      \n      setLoading(true)\n      try {\n        const plotsDir = path.join(projectRoot, 'plots')\n        // 检查 plots 目录是否存在\n        const exists = await window.electronAPI.exists(plotsDir)\n        if (!exists) {\n          // 创建 plots 目录\n          await window.electronAPI.mkdir(plotsDir)\n          setTreeData([])\n          return\n        }\n        \n        const entries = await loadDirectory(plotsDir)\n        const data = convertToTreeData(entries)\n        setTreeData(data)\n        \n        // 默认展开所有节点\n        const getAllKeys = (nodes: DataNode[]): string[] => {\n          let keys: string[] = []\n          nodes.forEach(node => {\n            keys.push(node.key as string)\n            if (node.children) keys = keys.concat(getAllKeys(node.children))\n          })\n          return keys\n        }\n        setExpandedKeys(getAllKeys(data))\n      } catch (error) {\n        message.error('加载大纲失败')\n        console.error(error)\n      } finally {\n        setLoading(false)\n      }\n    }\n\n    loadOutline()\n  }, [projectRoot])\n\n  // 监听文件变化，自动刷新大纲\n  useEffect(() => {\n    if (!projectRoot) return\n    \n    const plotsDir = path.join(projectRoot, 'plots')\n    window.electronAPI.fsWatch(plotsDir)\n    \n    const removeListener = window.electronAPI.onFsChange(() => {\n      // 文件变化时重新加载大纲\n      loadDirectory(path.join(projectRoot, 'plots')).then(entries => {\n        const data = convertToTreeData(entries)\n        setTreeData(data)\n      })\n    })\n    \n    return () => {\n      removeListener()\n      window.electronAPI.fsUnwatch()\n    }\n  }, [projectRoot])\n\n  // 处理选择\n  const handleSelect = (selectedKeys: string[]) => {\n    if (selectedKeys.length === 0) return\n    const key = selectedKeys[0]\n    // 检查是否是文件\n    if (key.startsWith('/') || key.includes('.md')) {\n      onSelect(key)\n    }\n  }\n\n  if (loading) {\n    return (\n      <div style={{ padding: 20, textAlign: 'center' }}>\n        <Spin tip=\"加载中...\" />\n      </div>\n    )\n  }\n\n  if (treeData.length === 0) {\n    return (\n      <div style={{ padding: 20 }}>\n        <Empty\n          description=\"暂无章节\"\n          image={Empty.PRESENTED_IMAGE_SIMPLE}\n        />\n      </div>\n    )\n  }\n\n  return (\n    <div style={{ height: '100%', overflow: 'auto', padding: 10 }}>\n      <Tree\n        treeData={treeData}\n        expandedKeys={expandedKeys}\n        selectedKeys={activeChapter ? [activeChapter] : []}\n        onSelect={handleSelect}\n        onExpand={setExpandedKeys}\n        showIcon\n        defaultExpandAll\n      />\n    </div>\n  )\n}\n\nexport default OutlineTree\n"}],"isError":false,"timestamp":1776082468665}}
{"type":"message","id":"d39b8548","parentId":"f9665fec","timestamp":"2026-04-13T12:14:32.570Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Let me also check the database layer and the main electron side to understand the full picture.","thinkingSignature":"5eeac2dc2bd8ae1e4e9aec137ef21919507b417c756ceb86d7ed0957ce35f9b9"},{"type":"toolCall","id":"call_function_5g1zvpkqqvec_1","name":"read","arguments":{"path":"/mnt/d/aafuzhi/axs/src/renderer/src/db/index.ts"}},{"type":"toolCall","id":"call_function_5g1zvpkqqvec_2","name":"read","arguments":{"path":"/mnt/d/aafuzhi/axs/src/main/index.ts"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":17709,"output":92,"cacheRead":19262,"cacheWrite":0,"totalTokens":37063,"cost":{"input":0.0053127,"output":0.0001104,"cacheRead":0.0011557199999999998,"cacheWrite":0,"total":0.00657882}},"stopReason":"toolUse","timestamp":1776082468675,"responseId":"062c1124db97c66b6761a17c1a618b2f"}}
{"type":"message","id":"e603f698","parentId":"d39b8548","timestamp":"2026-04-13T12:14:32.647Z","message":{"role":"toolResult","toolCallId":"call_function_5g1zvpkqqvec_1","toolName":"read","content":[{"type":"text","text":"/**\n * SQLite 数据库集成\n * 用于存储事实台账和角色信息\n */\n\n// 数据库类型定义\nexport interface Fact {\n  id: string\n  type: 'power' | 'item' | 'relation' | 'foreshadow'\n  subject: string\n  object: string\n  content: string\n  chapterStart: number\n  chapterEnd: number\n  createdAt: number\n}\n\nexport interface Role {\n  id: string\n  name: string\n  tags: string[]\n  goldenFinger: string\n  createdAt: number\n}\n\n// 初始化数据库\nclass Database {\n  private db: any | null = null\n  private initialized: boolean = false\n\n  constructor() {\n    // 在 Electron 环境中使用 better-sqlite3\n    if (window.electronAPI) {\n      this.initializeElectronDB()\n    }\n  }\n\n  private async initializeElectronDB() {\n    try {\n      // 通过 IPC 获取项目根路径\n      const projectRoot = await window.electronAPI.getProjectRoot()\n      if (!projectRoot) return\n\n      // 数据库文件路径\n      const dbPath = `${projectRoot}/facts.db`\n\n      // 检查是否存在数据库\n      const exists = await window.electronAPI.exists(dbPath)\n      if (!exists) {\n        await this.createTables()\n      }\n\n      this.initialized = true\n    } catch (error) {\n      console.error('数据库初始化失败:', error)\n    }\n  }\n\n  // 创建数据库表\n  private async createTables() {\n    // 通过 IPC 执行 SQL 创建表\n    await window.electronAPI.writeFile(\n      `${projectRoot}/facts.db`,\n      `CREATE TABLE IF NOT EXISTS facts (\n        id TEXT PRIMARY KEY,\n        type TEXT NOT NULL,\n        subject TEXT NOT NULL,\n        object TEXT,\n        content TEXT NOT NULL,\n        chapter_start INTEGER NOT NULL,\n        chapter_end INTEGER NOT NULL,\n        created_at INTEGER NOT NULL\n      );\n\n      CREATE TABLE IF NOT EXISTS roles (\n        id TEXT PRIMARY KEY,\n        name TEXT NOT NULL,\n        tags TEXT,\n        golden_finger TEXT,\n        created_at INTEGER NOT NULL\n      );`\n    )\n  }\n\n  // ========== 事实表操作 ==========\n\n  // 添加事实\n  async addFact(fact: Omit<Fact, 'id' | 'createdAt'>): Promise<{ success: boolean; id?: string; error?: string }> {\n    try {\n      const id = crypto.randomUUID()\n      const createdAt = Date.now()\n      \n      // 执行插入操作\n      const insertSQL = `\n        INSERT INTO facts (id, type, subject, object, content, chapter_start, chapter_end, created_at)\n        VALUES ('${id}', '${fact.type}', '${fact.subject}', '${fact.object || ''}', '${fact.content.replace(/'/g, \"''\")}', ${fact.chapterStart}, ${fact.chapterEnd}, ${createdAt})\n      `\n      \n      // 通过 IPC 执行 SQL\n      await window.electronAPI.ai.call(insertSQL, { type: 'sql' })\n      \n      return { success: true, id }\n    } catch (error: any) {\n      return { success: false, error: error.message }\n    }\n  }\n\n  // 查询事实\n  async getFacts(filters?: { type?: string; subject?: string; chapter?: number }): Promise<Fact[]> {\n    try {\n      let sql = 'SELECT * FROM facts'\n      const conditions: string[] = []\n      \n      if (filters?.type) conditions.push(`type = '${filters.type}'`)\n      if (filters?.subject) conditions.push(`subject = '${filters.subject}' OR object = '${filters.subject}'`)\n      if (filters?.chapter) conditions.push(`chapter_start <= ${filters.chapter} AND (chapter_end >= ${filters.chapter} OR chapter_end IS NULL)`)\n      \n      if (conditions.length > 0) sql += ` WHERE ${conditions.join(' AND ')}`\n      sql += ' ORDER BY created_at DESC'\n      \n      const result = await window.electronAPI.ai.call(sql, { type: 'sql' })\n      if (result.success) {\n        return JSON.parse(result.content).map((row: any) => ({\n          id: row.id,\n          type: row.type,\n          subject: row.subject,\n          object: row.object,\n          content: row.content,\n          chapterStart: row.chapter_start,\n          chapterEnd: row.chapter_end,\n          createdAt: row.created_at\n        }))\n      }\n      return []\n    } catch (error) {\n      console.error('查询事实失败:', error)\n      return []\n    }\n  }\n\n  // 删除事实\n  async deleteFact(id: string): Promise<boolean> {\n    try {\n      const sql = `DELETE FROM facts WHERE id = '${id}'`\n      const result = await window.electronAPI.ai.call(sql, { type: 'sql' })\n      return result.success\n    } catch (error) {\n      console.error('删除事实失败:', error)\n      return false\n    }\n  }\n\n  // ========== 角色表操作 ==========\n\n  // 添加角色\n  async addRole(role: Omit<Role, 'id' | 'createdAt'>): Promise<{ success: boolean; id?: string; error?: string }> {\n    try {\n      const id = crypto.randomUUID()\n      const createdAt = Date.now()\n      const tags = JSON.stringify(role.tags)\n      \n      const sql = `\n        INSERT INTO roles (id, name, tags, golden_finger, created_at)\n        VALUES ('${id}', '${role.name}', '${tags}', '${role.goldenFinger.replace(/'/g, \"''\")}', ${createdAt})\n      `\n      \n      const result = await window.electronAPI.ai.call(sql, { type: 'sql' })\n      if (result.success) {\n        return { success: true, id }\n      }\n      return { success: false, error: result.error }\n    } catch (error: any) {\n      return { success: false, error: error.message }\n    }\n  }\n\n  // 查询角色\n  async getRoles(): Promise<Role[]> {\n    try {\n      const sql = 'SELECT * FROM roles ORDER BY name'\n      const result = await window.electronAPI.ai.call(sql, { type: 'sql' })\n      if (result.success) {\n        return JSON.parse(result.content).map((row: any) => ({\n          id: row.id,\n          name: row.name,\n          tags: JSON.parse(row.tags),\n          goldenFinger: row.golden_finger,\n          createdAt: row.created_at\n        }))\n      }\n      return []\n    } catch (error) {\n      console.error('查询角色失败:', error)\n      return []\n    }\n  }\n}\n\n// 单例导出\nconst db = new Database()\nexport default db\n"}],"isError":false,"timestamp":1776082472638}}
{"type":"message","id":"3b94d08c","parentId":"e603f698","timestamp":"2026-04-13T12:14:32.655Z","message":{"role":"toolResult","toolCallId":"call_function_5g1zvpkqqvec_2","toolName":"read","content":[{"type":"text","text":"/**\n * 番茄小说创作助手 - Electron 主进程入口\n * \n * 提供：\n * - 窗口管理\n * - IPC 处理器注册\n * - 文件系统 API\n * - SQLite 连接（待实现）\n */\n\nimport { app, BrowserWindow, ipcMain, dialog, shell, safeStorage } from 'electron'\nimport path from 'path'\nimport fs, { FSWatcher } from 'fs'\n\n// 重新导出 main.ts 的功能\n// 这是为了保持统一的导入路径：import { createWindow } from '../src/main/index'\n\n// 保持对窗口对象的全局引用，避免被垃圾回收\nlet mainWindow: BrowserWindow | null = null\n\n// 项目根目录 - 用于路径验证\nlet projectRootPath: string | null = null\n\n// 文件系统监视器\nlet fsWatcher: FSWatcher | null = null\n\n/**\n * 验证文件路径是否安全\n * 防止路径遍历攻击 (如 ../../../etc/passwd)\n * 只允许访问项目目录内的文件\n */\nfunction validatePath(requestedPath: string): { valid: boolean; resolvedPath?: string; error?: string } {\n  // 如果没有设置项目根路径，允许绝对路径但进行基本验证\n  if (!projectRootPath) {\n    // 解析并规范化路径\n    const resolved = path.resolve(requestedPath)\n    \n    // 检查是否尝试访问系统敏感目录\n    const sensitivePaths = [\n      '/etc',\n      '/proc',\n      '/sys',\n      'C:\\\\Windows',\n      'C:\\\\Program Files',\n      'C:\\\\Program Files (x86)',\n    ]\n    \n    for (const sensitive of sensitivePaths) {\n      if (resolved.toLowerCase().startsWith(sensitive.toLowerCase())) {\n        return {\n          valid: false,\n          error: `访问被拒绝：不允许访问系统目录`,\n        }\n      }\n    }\n    \n    return { valid: true, resolvedPath: resolved }\n  }\n  \n  // 解析并规范化请求的路径\n  const resolved = path.resolve(requestedPath)\n  const normalizedRequested = path.normalize(resolved)\n  const normalizedRoot = path.normalize(projectRootPath)\n  \n  // 确保请求的路径在项目根目录内\n  if (!normalizedRequested.startsWith(normalizedRoot)) {\n    return {\n      valid: false,\n      error: `访问被拒绝：路径必须在项目目录内 (${projectRootPath})`,\n    }\n  }\n  \n  return { valid: true, resolvedPath: resolved }\n}\n\n/**\n * 创建应用窗口\n */\nfunction createWindow(): BrowserWindow {\n  mainWindow = new BrowserWindow({\n    width: 1400,\n    height: 900,\n    minWidth: 1000,\n    minHeight: 700,\n    title: '🍅 番茄小说创作助手',\n    webPreferences: {\n      preload: path.join(__dirname, 'preload.js'),\n      contextIsolation: true,\n      nodeIntegration: false,\n      sandbox: false,\n    },\n    show: false,\n  })\n\n  // 窗口准备好后显示\n  mainWindow.once('ready-to-show', () => {\n    mainWindow?.show()\n  })\n\n  // 窗口关闭时清理\n  mainWindow.on('closed', () => {\n    mainWindow = null\n  })\n\n  return mainWindow\n}\n\n/**\n * 关闭应用窗口\n */\nfunction closeWindow(): void {\n  if (mainWindow) {\n    mainWindow.close()\n    mainWindow = null\n  }\n}\n\n/**\n * 设置项目根路径\n */\nfunction setProjectRoot(rootPath: string): void {\n  projectRootPath = path.resolve(rootPath)\n}\n\n/**\n * 设置 IPC 处理器\n * 所有主进程功能通过 IPC 暴露给渲染进程\n */\nfunction setupIpcHandlers(): void {\n  // ========== 对话框 ==========\n  ipcMain.handle('dialog:openDirectory', async () => {\n    const result = await dialog.showOpenDialog({\n      properties: ['openDirectory'],\n    })\n    \n    if (!result.canceled && result.filePaths.length > 0) {\n      const selectedPath = result.filePaths[0]\n      setProjectRoot(selectedPath)\n      return selectedPath\n    }\n    return undefined\n  })\n\n  // ========== 文件系统 - 读取操作 ==========\n  ipcMain.handle('fs:readFile', async (_event, filePath: string) => {\n    try {\n      const validation = validatePath(filePath)\n      if (!validation.valid) {\n        return { success: false, error: validation.error }\n      }\n      \n      const content = await fs.promises.readFile(validation.resolvedPath!, 'utf-8')\n      return { success: true, content }\n    } catch (error: any) {\n      return { success: false, error: error.message }\n    }\n  })\n\n  ipcMain.handle('fs:exists', async (_event, filePath: string) => {\n    try {\n      const validation = validatePath(filePath)\n      if (!validation.valid) {\n        return false\n      }\n      \n      await fs.promises.access(validation.resolvedPath!)\n      return true\n    } catch {\n      return false\n    }\n  })\n\n  ipcMain.handle('fs:readdir', async (_event, dirPath: string) => {\n    try {\n      const validation = validatePath(dirPath)\n      if (!validation.valid) {\n        return { success: false, error: validation.error }\n      }\n      \n      const entries = await fs.promises.readdir(validation.resolvedPath!, { withFileTypes: true })\n      const result = entries.map(entry => ({\n        name: entry.name,\n        isDirectory: entry.isDirectory(),\n        isFile: entry.isFile(),\n      }))\n      return result\n    } catch (error: any) {\n      return { success: false, error: error.message }\n    }\n  })\n\n  // ========== 文件系统 - 写入操作 ==========\n  ipcMain.handle('fs:writeFile', async (_event, filePath: string, content: string) => {\n    try {\n      const validation = validatePath(filePath)\n      if (!validation.valid) {\n        return { success: false, error: validation.error }\n      }\n      \n      // 确保父目录存在\n      const dir = path.dirname(validation.resolvedPath!)\n      await fs.promises.mkdir(dir, { recursive: true })\n      \n      await fs.promises.writeFile(validation.resolvedPath!, content, 'utf-8')\n      return { success: true }\n    } catch (error: any) {\n      return { success: false, error: error.message }\n    }\n  })\n\n  ipcMain.handle('fs:mkdir', async (_event, dirPath: string) => {\n    try {\n      const validation = validatePath(dirPath)\n      if (!validation.valid) {\n        return { success: false, error: validation.error }\n      }\n      \n      await fs.promises.mkdir(validation.resolvedPath!, { recursive: true })\n      return { success: true }\n    } catch (error: any) {\n      return { success: false, error: error.message }\n    }\n  })\n\n  // ========== 文件系统 - 删除操作 ==========\n  ipcMain.handle('fs:unlink', async (_event, filePath: string) => {\n    try {\n      const validation = validatePath(filePath)\n      if (!validation.valid) {\n        return { success: false, error: validation.error }\n      }\n      \n      await fs.promises.unlink(validation.resolvedPath!)\n      return { success: true }\n    } catch (error: any) {\n      return { success: false, error: error.message }\n    }\n  })\n\n  ipcMain.handle('fs:rmdir', async (_event, dirPath: string, options?: { recursive?: boolean }) => {\n    try {\n      const validation = validatePath(dirPath)\n      if (!validation.valid) {\n        return { success: false, error: validation.error }\n      }\n      \n      await fs.promises.rmdir(validation.resolvedPath!, { recursive: options?.recursive })\n      return { success: true }\n    } catch (error: any) {\n      return { success: false, error: error.message }\n    }\n  })\n\n  ipcMain.handle('fs:remove', async (_event, targetPath: string) => {\n    try {\n      const validation = validatePath(targetPath)\n      if (!validation.valid) {\n        return { success: false, error: validation.error }\n      }\n      \n      await fs.promises.rm(validation.resolvedPath!, { recursive: true })\n      return { success: true }\n    } catch (error: any) {\n      return { success: false, error: error.message }\n    }\n  })\n\n  ipcMain.handle('fs:rename', async (_event, oldPath: string, newPath: string) => {\n    try {\n      const oldValidation = validatePath(oldPath)\n      const newValidation = validatePath(newPath)\n      \n      if (!oldValidation.valid) {\n        return { success: false, error: oldValidation.error }\n      }\n      if (!newValidation.valid) {\n        return { success: false, error: newValidation.error }\n      }\n      \n      await fs.promises.rename(oldValidation.resolvedPath!, newValidation.resolvedPath!)\n      return { success: true }\n    } catch (error: any) {\n      return { success: false, error: error.message }\n    }\n  })\n\n  // ========== 系统 ==========\n  ipcMain.handle('shell:openPath', async (_event, path: string) => {\n    return shell.openPath(path)\n  })\n\n  // ========== 项目 ==========\n  ipcMain.handle('project:getRoot', () => {\n    return projectRootPath\n  })\n\n  // ========== 文件系统监听 ==========\n  ipcMain.handle('fs:watch', async (_event, dirPath?: string) => {\n    try {\n      // 停止之前的监视\n      if (fsWatcher) {\n        await fsWatcher.close()\n        fsWatcher = null\n      }\n\n      const watchPath = dirPath \n        ? validatePath(dirPath).resolvedPath \n        : projectRootPath\n\n      if (!watchPath) {\n        return { success: false, error: '没有可监视的路径' }\n      }\n\n      fsWatcher = fs.watch(watchPath, { recursive: true }, (eventType, filename) => {\n        if (filename && mainWindow) {\n          mainWindow.webContents.send('fs:change', {\n            type: eventType,\n            fileName: filename,\n            path: path.join(watchPath, filename),\n          })\n        }\n      })\n\n      return { success: true, path: watchPath }\n    } catch (error: any) {\n      return { success: false, error: error.message }\n    }\n  })\n\n  ipcMain.handle('fs:unwatch', async () => {\n    try {\n      if (fsWatcher) {\n        await fsWatcher.close()\n        fsWatcher = null\n      }\n      return { success: true }\n    } catch (error: any) {\n      return { success: false, error: error.message }\n    }\n  })\n\n  // ========== 安全存储 ==========\n  ipcMain.handle('safeStorage:encrypt', async (_event, plainText: string) => {\n    try {\n      if (!safeStorage.isEncryptionAvailable()) {\n        return { success: false, error: '加密不可用' }\n      }\n      const encrypted = safeStorage.encryptString(plainText)\n      return { success: true, data: encrypted }\n    } catch (error: any) {\n      return { success: false, error: error.message }\n    }\n  })\n\n  ipcMain.handle('safeStorage:decrypt', async (_event, encrypted: Buffer) => {\n    try {\n      if (!safeStorage.isEncryptionAvailable()) {\n        return { success: false, error: '加密不可用' }\n      }\n      const decrypted = safeStorage.decryptString(encrypted)\n      return { success: true, data: decrypted }\n    } catch (error: any) {\n      return { success: false, error: error.message }\n    }\n  })\n\n  ipcMain.handle('safeStorage:isAvailable', () => {\n    return { success: true, available: safeStorage.isEncryptionAvailable() }\n  })\n\n  // ========== AI 服务 ==========\n  // 导入 AI 服务\n  const { setupAiHandlers } = require('./aiService')\n  setupAiHandlers(ipcMain)\n\n  // ========== 备份服务 ==========\n  // 导入备份服务\n  const { setupBackupHandlers } = require('./backupService')\n  setupBackupHandlers(ipcMain)\n}\n\n/**\n * 启动应用\n */\nasync function startApp(): Promise<void> {\n  // 设置 IPC 处理器\n  setupIpcHandlers()\n\n  // 创建窗口\n  createWindow()\n\n  // 加载应用\n  if (process.env.NODE_ENV === 'development') {\n    await mainWindow?.loadURL('http://localhost:5173')\n    mainWindow?.webContents.openDevTools()\n  } else {\n    await mainWindow?.loadFile(path.join(__dirname, '../renderer/index.html'))\n  }\n}\n\n// 应用就绪\napp.whenReady().then(startApp)\n\n// 所有窗口关闭时退出\napp.on('window-all-closed', () => {\n  if (process.platform !== 'darwin') {\n    app.quit()\n  }\n})\n\napp.on('activate', () => {\n  if (BrowserWindow.getAllWindows().length === 0) {\n    createWindow()\n  }\n})\n\n// 导出供测试和主进程入口使用\nexport { \n  createWindow, \n  closeWindow, \n  setupIpcHandlers, \n  setProjectRoot,\n  startApp,\n  projectRootPath \n}"}],"isError":false,"timestamp":1776082472647}}
