{"type":"message","id":"9adb1042","parentId":"0794e605","timestamp":"2026-04-13T12:18:46.328Z","message":{"role":"toolResult","toolCallId":"call_function_nrd527xx6b0l_1","toolName":"exec","content":[{"type":"text","text":"\"use strict\";\nObject.defineProperty(exports, \"__esModule\", { value: true });\nconst electron_1 = require(\"electron\");\n// 暴露 API 给渲染进程\nelectron_1.contextBridge.exposeInMainWorld('electronAPI', {\n    // 文件系统\n    readFile: (filePath) => electron_1.ipcRenderer.invoke('fs:readFile', filePath),\n    writeFile: (filePath, content) => electron_1.ipcRenderer.invoke('fs:writeFile', filePath, content),\n    readDir: (dirPath) => electron_1.ipcRenderer.invoke('fs:readDir', dirPath),\n    // 对话框\n    openDirectory: () => electron_1.ipcRenderer.invoke('dialog:openDirectory'),\n    // AI 服务\n    callAI: (model, prompt) => electron_1.ipcRenderer.invoke('ai:call', model, prompt),\n});\nconsole.log('[Preload] API 已暴露');"}],"details":{"status":"completed","exitCode":0,"durationMs":59,"aggregated":"\"use strict\";\nObject.defineProperty(exports, \"__esModule\", { value: true });\nconst electron_1 = require(\"electron\");\n// 暴露 API 给渲染进程\nelectron_1.contextBridge.exposeInMainWorld('electronAPI', {\n    // 文件系统\n    readFile: (filePath) => electron_1.ipcRenderer.invoke('fs:readFile', filePath),\n    writeFile: (filePath, content) => electron_1.ipcRenderer.invoke('fs:writeFile', filePath, content),\n    readDir: (dirPath) => electron_1.ipcRenderer.invoke('fs:readDir', dirPath),\n    // 对话框\n    openDirectory: () => electron_1.ipcRenderer.invoke('dialog:openDirectory'),\n    // AI 服务\n    callAI: (model, prompt) => electron_1.ipcRenderer.invoke('ai:call', model, prompt),\n});\nconsole.log('[Preload] API 已暴露');","cwd":"/home/ai/.openclaw/workspace/main"},"isError":false,"timestamp":1776082726316}}
{"type":"message","id":"c3840e97","parentId":"9adb1042","timestamp":"2026-04-13T12:18:46.351Z","message":{"role":"toolResult","toolCallId":"call_function_nrd527xx6b0l_2","toolName":"exec","content":[{"type":"text","text":"173\n\n// 为 TypeScript 声明全局类型\nexport type ElectronAPI = {\n  openDirectory: () => Promise<string | undefined>\n  readFile: (filePath: string) => Promise<{success: boolean; content?: string; error?: string}>\n  exists: (filePath: string) => Promise<boolean>\n  readdir: (dirPath: string) => Promise<Array<{name: string; isDirectory: boolean; isFile: boolean}>>\n  writeFile: (filePath: string, content: string) => Promise<{success: boolean; error?: string}>\n  mkdir: (dirPath: string) => Promise<{success: boolean; error?: string}>\n  unlink: (filePath: string) => Promise<{success: boolean; error?: string}>\n  rmdir: (dirPath: string, options?: { recursive?: boolean }) => Promise<{success: boolean; error?: string}>\n  remove: (targetPath: string) => Promise<{success: boolean; error?: string}>\n  deleteFile: (filePath: string) => Promise<{success: boolean; error?: string}>\n  deleteDirectory: (dirPath: string) => Promise<{success: boolean; error?: string}>\n  renameFile: (oldPath: string, newPath: string) => Promise<{success: boolean; error?: string}>\n  openPath: (path: string) => Promise<string>\n  getProjectRoot: () => Promise<string | null>\n  fsWatch: (dirPath?: string) => Promise<{ success: boolean; path?: string; error?: string }>\n  fsUnwatch: () => Promise<{ success: boolean; error?: string }>\n  onFsChange: (callback: (data: { type: string; fileName: string; path: string }) => void) => () => void\n  safeStorage: {\n    encrypt: (plainText: string) => Promise<{success: boolean; data?: Buffer; error?: string}>\n    decrypt: (encrypted: Buffer) => Promise<{success: boolean; data?: string; error?: string}>\n    isAvailable: () => Promise<{success: boolean; available?: boolean; error?: string}>\n  }\n  ai: {\n    saveApiKey: (service: string, apiKey: string) => Promise<{success: boolean; error?: string}>\n    isConfigured: (service: string) => Promise<{success: boolean; configured?: boolean; error?: string}>\n    getConfiguredServices: () => Promise<{success: boolean; services?: string[]; error?: string}>\n    call: (prompt: string, options?: any) => Promise<{success: boolean; content?: string; error?: string}>\n    stream: (prompt: string, options?: any) => Promise<{success: boolean; error?: string}>\n    onStreamChunk: (callback: (chunk: { content: string; done: boolean; reasoning?: string }) => void) => () => void\n    onStreamError: (callback: (error: string) => void) => () => void\n    testConnection: (service: string) => Promise<{success: boolean; result?: boolean; error?: string}>\n    saveSetting: (key: string, value: any) => Promise<{success: boolean; error?: string}>\n    getSetting: (key: string, defaultValue?: any) => Promise<{success: boolean; value?: any; error?: string}>\n  }\n  backup: {\n    create: () => Promise<{success: boolean; backupPath?: string; error?: string}>\n    list: () => Promise<{success: boolean; backups?: Array<{name: string; path: string; date: string; size: number}>; error?: string}>\n    restore: (backupPath: string) => Promise<{success: boolean; error?: string}>\n    delete: (backupPath: string) => Promise<{success: boolean; error?: string}>\n  }\n}\n\ndeclare global {\n  interface Window {\n    electronAPI: ElectronAPI\n  }\n}"}],"details":{"status":"completed","exitCode":0,"durationMs":86,"aggregated":"173\n\n// 为 TypeScript 声明全局类型\nexport type ElectronAPI = {\n  openDirectory: () => Promise<string | undefined>\n  readFile: (filePath: string) => Promise<{success: boolean; content?: string; error?: string}>\n  exists: (filePath: string) => Promise<boolean>\n  readdir: (dirPath: string) => Promise<Array<{name: string; isDirectory: boolean; isFile: boolean}>>\n  writeFile: (filePath: string, content: string) => Promise<{success: boolean; error?: string}>\n  mkdir: (dirPath: string) => Promise<{success: boolean; error?: string}>\n  unlink: (filePath: string) => Promise<{success: boolean; error?: string}>\n  rmdir: (dirPath: string, options?: { recursive?: boolean }) => Promise<{success: boolean; error?: string}>\n  remove: (targetPath: string) => Promise<{success: boolean; error?: string}>\n  deleteFile: (filePath: string) => Promise<{success: boolean; error?: string}>\n  deleteDirectory: (dirPath: string) => Promise<{success: boolean; error?: string}>\n  renameFile: (oldPath: string, newPath: string) => Promise<{success: boolean; error?: string}>\n  openPath: (path: string) => Promise<string>\n  getProjectRoot: () => Promise<string | null>\n  fsWatch: (dirPath?: string) => Promise<{ success: boolean; path?: string; error?: string }>\n  fsUnwatch: () => Promise<{ success: boolean; error?: string }>\n  onFsChange: (callback: (data: { type: string; fileName: string; path: string }) => void) => () => void\n  safeStorage: {\n    encrypt: (plainText: string) => Promise<{success: boolean; data?: Buffer; error?: string}>\n    decrypt: (encrypted: Buffer) => Promise<{success: boolean; data?: string; error?: string}>\n    isAvailable: () => Promise<{success: boolean; available?: boolean; error?: string}>\n  }\n  ai: {\n    saveApiKey: (service: string, apiKey: string) => Promise<{success: boolean; error?: string}>\n    isConfigured: (service: string) => Promise<{success: boolean; configured?: boolean; error?: string}>\n    getConfiguredServices: () => Promise<{success: boolean; services?: string[]; error?: string}>\n    call: (prompt: string, options?: any) => Promise<{success: boolean; content?: string; error?: string}>\n    stream: (prompt: string, options?: any) => Promise<{success: boolean; error?: string}>\n    onStreamChunk: (callback: (chunk: { content: string; done: boolean; reasoning?: string }) => void) => () => void\n    onStreamError: (callback: (error: string) => void) => () => void\n    testConnection: (service: string) => Promise<{success: boolean; result?: boolean; error?: string}>\n    saveSetting: (key: string, value: any) => Promise<{success: boolean; error?: string}>\n    getSetting: (key: string, defaultValue?: any) => Promise<{success: boolean; value?: any; error?: string}>\n  }\n  backup: {\n    create: () => Promise<{success: boolean; backupPath?: string; error?: string}>\n    list: () => Promise<{success: boolean; backups?: Array<{name: string; path: string; date: string; size: number}>; error?: string}>\n    restore: (backupPath: string) => Promise<{success: boolean; error?: string}>\n    delete: (backupPath: string) => Promise<{success: boolean; error?: string}>\n  }\n}\n\ndeclare global {\n  interface Window {\n    electronAPI: ElectronAPI\n  }\n}","cwd":"/home/ai/.openclaw/workspace/main"},"isError":false,"timestamp":1776082726343}}
