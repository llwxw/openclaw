 => {\n    const result = await dialog.showOpenDialog({\n      properties: ['openDirectory'],\n    })\n    \n    if (!result.canceled && result.filePaths.length > 0) {\n      const selectedPath = result.filePaths[0]\n      setProjectRoot(selectedPath)\n      return selectedPath\n    }\n    return undefined\n  })\n\n  // ========== 文件系统 - 读取操作 ==========\n  ipcMain.handle('fs:readFile', async (_event, filePath: string) => {\n    try {\n      const validation = validatePath(filePath)\n      if (!validation.valid) {\n        return { success: false, error: validation.error }\n      }\n      \n      const content = await fs.promises.readFile(validation.resolvedPath!, 'utf-8')\n      return { success: true, content }\n    } catch (error: any) {\n      return { success: false, error: error.message }\n    }\n  })\n\n  ipcMain.handle('fs:exists', async (_event, filePath: string) => {\n    try {\n      const validation = validatePath(filePath)\n      if (!validation.valid) {\n        return false\n      }\n      \n      await fs.promises.access(validation.resolvedPath!)\n      return true\n    } catch {\n      return false\n    }\n  })\n\n  ipcMain.handle('fs:readdir', async (_event, dirPath: string) => {\n    try {\n      const validation = validatePath(dirPath)\n      if (!validation.valid) {\n        return { success: false, error: validation.error }\n      }\n      \n      const entries = await fs.promises.readdir(validation.resolvedPath!, { withFileTypes: true })\n      const result = entries.map(entry => ({\n        name: entry.name,\n        isDirectory: entry.isDirectory(),\n        isFile: entry.isFile(),\n      }))\n      return result\n    } catch (error: any) {\n      return { success: false, error: error.message }\n    }\n  })\n\n  // ========== 文件系统 - 写入操作 ==========\n  ipcMain.handle('fs:writeFile', async (_event, filePath: string, content: string) => {\n    try {\n      const validation = validatePath(filePath)\n      if (!validation.valid) {\n        return 