{"type":"message","id":"4315158d","parentId":"a9cb3ea8","timestamp":"2026-04-13T12:23:00.706Z","message":{"role":"toolResult","toolCallId":"call_function_cdtde9p3oxvz_2","toolName":"exec","content":[{"type":"text","text":"// AI 服务 - 用于渲染进程调用 AI API\r\n// 支持 DeepSeek、OpenAI、豆包、Kimi、Ollama 等兼容接口\r\n\r\nimport type { AIService, FunctionName, ModelMapping, AICallOptions, ModelOption } from '../types/ai';\r\nimport { joinPath } from '../utils/pathUtils';\r\n\r\nexport interface AIConfig {\r\n  model: string;\r\n  apiKey: string;\r\n  baseUrl: string;\r\n  maxTokens: number;\r\n  temperature: number;\r\n}\r\n\r\nexport interface StreamChunk {\r\n  content: string;\r\n  done: boolean;\r\n}\r\n\r\n// 默认配置\r\nconst DEFAULT_CONFIG: AIConfig = {\r\n  model: 'deepseek-chat',\r\n  apiKey: '',\r\n  baseUrl: 'https://api.deepseek.com/v1',\r\n  maxTokens: 2000,\r\n  temperature: 0.7,\r\n};\r\n\r\n// ==================== 超时配置 ====================\r\n\r\n/** 超时级别（毫秒） */\r\nexport const TIMEOUT_LEVELS = {\r\n  FAST: 30_000,       // 30秒 - 快速任务（摘要/分类）\r\n  NORMAL: 120_000,    // 120秒 - 普通任务（默认）- 网文AI生成通常需要较长时间\r\n  DEEP: 180_000,      // 180秒 - 深度推理（逻辑校验）\r\n  LONG: 300_000,      // 300秒 - 长文本任务（一致性检查/设定召回/章节生成）\r\n  STREAM: 300_000,    // 300秒 - 流式生成（5分钟）\r\n} as const;\r\n\r\n/** 快速任务列表（30秒超时） */\r\nconst FAST_FUNCTIONS = new Set([\r\n  'fast_summary',\r\n  'rhythm_check',\r\n  'title_optimize',\r\n  'quality_ai_trace_score',\r\n  'advanced_real_time_emotion_monitor',\r\n  'advanced_catharsis_type_statistics',\r\n  'advanced_fatal_point_warning',\r\n  'advanced_foreshadowing_payoff_prediction',\r\n]);\r\n\r\n/** 深度推理任务列表（120秒超时） */\r\nconst DEEP_FUNCTIONS = new Set([\r\n  'logic_check',\r\n  'outline_level_skip_validate',\r\n  'world_power_growth_curve_validate',\r\n  'world_tech_setting_validate',\r\n  'relation_conflict_prediction',\r\n  'fact_power_extraction',\r\n  'fact_item_extraction',\r\n  'fact_relation_extraction',\r\n  'fact_power_conflict_detection',\r\n  'fact_item_conflict_detection',\r\n  'fact_relation_conflict_detection',\r\n  'fact_timeline_conflict_detection',\r\n  'quality_contradiction_detection',\r\n  'quality_character_behavior_validate',\r\n  'quality_timeline_age_validate',\r\n  'quality_logic_chain_tracing',\r\n  'quality_remove_ai_trace',\r\n  'advanced_bestseller_catharsis_analysis',\r\n  'writing_plot_adjustment',\r\n]);\r\n\r\n/** 长文本任务列表（180秒超时） */\r\nconst LONG_FUNCTIONS = new Set([\r\n  'long_context',\r\n  'setting_recall',\r\n  'chapter_generation',\r\n  'climax_generation',"}],"details":{"status":"completed","exitCode":0,"durationMs":70,"aggregated":"// AI 服务 - 用于渲染进程调用 AI API\r\n// 支持 DeepSeek、OpenAI、豆包、Kimi、Ollama 等兼容接口\r\n\r\nimport type { AIService, FunctionName, ModelMapping, AICallOptions, ModelOption } from '../types/ai';\r\nimport { joinPath } from '../utils/pathUtils';\r\n\r\nexport interface AIConfig {\r\n  model: string;\r\n  apiKey: string;\r\n  baseUrl: string;\r\n  maxTokens: number;\r\n  temperature: number;\r\n}\r\n\r\nexport interface StreamChunk {\r\n  content: string;\r\n  done: boolean;\r\n}\r\n\r\n// 默认配置\r\nconst DEFAULT_CONFIG: AIConfig = {\r\n  model: 'deepseek-chat',\r\n  apiKey: '',\r\n  baseUrl: 'https://api.deepseek.com/v1',\r\n  maxTokens: 2000,\r\n  temperature: 0.7,\r\n};\r\n\r\n// ==================== 超时配置 ====================\r\n\r\n/** 超时级别（毫秒） */\r\nexport const TIMEOUT_LEVELS = {\r\n  FAST: 30_000,       // 30秒 - 快速任务（摘要/分类）\r\n  NORMAL: 120_000,    // 120秒 - 普通任务（默认）- 网文AI生成通常需要较长时间\r\n  DEEP: 180_000,      // 180秒 - 深度推理（逻辑校验）\r\n  LONG: 300_000,      // 300秒 - 长文本任务（一致性检查/设定召回/章节生成）\r\n  STREAM: 300_000,    // 300秒 - 流式生成（5分钟）\r\n} as const;\r\n\r\n/** 快速任务列表（30秒超时） */\r\nconst FAST_FUNCTIONS = new Set([\r\n  'fast_summary',\r\n  'rhythm_check',\r\n  'title_optimize',\r\n  'quality_ai_trace_score',\r\n  'advanced_real_time_emotion_monitor',\r\n  'advanced_catharsis_type_statistics',\r\n  'advanced_fatal_point_warning',\r\n  'advanced_foreshadowing_payoff_prediction',\r\n]);\r\n\r\n/** 深度推理任务列表（120秒超时） */\r\nconst DEEP_FUNCTIONS = new Set([\r\n  'logic_check',\r\n  'outline_level_skip_validate',\r\n  'world_power_growth_curve_validate',\r\n  'world_tech_setting_validate',\r\n  'relation_conflict_prediction',\r\n  'fact_power_extraction',\r\n  'fact_item_extraction',\r\n  'fact_relation_extraction',\r\n  'fact_power_conflict_detection',\r\n  'fact_item_conflict_detection',\r\n  'fact_relation_conflict_detection',\r\n  'fact_timeline_conflict_detection',\r\n  'quality_contradiction_detection',\r\n  'quality_character_behavior_validate',\r\n  'quality_timeline_age_validate',\r\n  'quality_logic_chain_tracing',\r\n  'quality_remove_ai_trace',\r\n  'advanced_bestseller_catharsis_analysis',\r\n  'writing_plot_adjustment',\r\n]);\r\n\r\n/** 长文本任务列表（180秒超时） */\r\nconst LONG_FUNCTIONS = new Set([\r\n  'long_context',\r\n  'setting_recall',\r\n  'chapter_generation',\r\n  'climax_generation',","cwd":"/home/ai/.openclaw/workspace/main"},"isError":false,"timestamp":1776082980697}}
