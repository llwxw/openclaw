{"type":"message","id":"68b59c70","parentId":"e44c6cab","timestamp":"2026-04-13T12:29:13.677Z","message":{"role":"toolResult","toolCallId":"call_function_s8dfsenvlmit_1","toolName":"exec","content":[{"type":"text","text":"// ==================== 跨设备同步 ====================\r\n\r\n  const loadSyncStatus = () => {\r\n    try {\r\n      const stored = localStorage.getItem(STORAGE_KEYS.syncStatus);\r\n      if (stored) {\r\n        setSyncStatus(JSON.parse(stored));\r\n      }\r\n    } catch (e) {\r\n      console.error('加载同步状态失败:', e);\r\n    }\r\n  };\r\n\r\n  const handleSync = async () => {\r\n    setSyncStatus(prev => ({ ...prev, status: 'syncing' }));\r\n    // 模拟同步过程\r\n    setTimeout(() => {\r\n      const newStatus: SyncStatus = {\r\n        lastSync: new Date().toISOString(),\r\n        status: 'synced',\r\n        devices: [\r\n          { name: '当前设备', lastSeen: new Date().toISOString(), platform: 'Windows' },\r\n          { name: '笔记本电脑', lastSeen: new Date(Date.now() - 86400000).toISOString(), platform: 'macOS' },\r\n        ],\r\n      };\r\n      setSyncStatus(newStatus);\r\n      localStorage.setItem(STORAGE_KEYS.syncStatus, JSON.stringify(newStatus));\r\n      message.success('同步完成');\r\n    }, 2000);\r\n  };\r\n\r\n  const handleExportSync = () => {\r\n    const syncData: Record<string, any> = {};\r\n    for (let i = 0; i < localStorage.length; i++) {\r\n      const key = localStorage.key(i);\r\n      if (key?.startsWith('novel_')) {\r\n        syncData[key] = localStorage.getItem(key);\r\n      }\r\n    }\r\n    const blob = new Blob([JSON.stringify(syncData, null, 2)], { type: 'application/json' });\r\n    const url = URL.createObjectURL(blob);\r\n    const a = document.createElement('a');\r\n    a.href = url;\r\n    a.download = `novel_sync_${new Date().toISOString().split('T')[0]}.json`;\r\n    a.click();\r\n    URL.revokeObjectURL(url);\r\n    message.success('同步数据已导出');\r\n  };\r\n\r\n  const handleImportSync = () => {\r\n    const input = document.createElement('input');\r\n    input.type = 'file';\r\n    input.accept = '.json';\r\n    input.onchange = (e: any) => {\r\n      const file = e.target.files?.[0];\r\n      if (!file) return;\r\n      const reader = new FileReader();\r\n      reader.onload = (ev) => {\r\n        try {\r\n          const data = JSON.parse(ev.target?.result as string);\r\n          Object.entries(data).forEach(([key, value]) => {\r\n            if (key.startsWith('novel_')) {\r\n              localStorage.setItem(key, value as string);\r\n            }\r\n          });\r\n          message.success('同步数据已导入，请刷新页面');\r\n          loadProjects();\r\n          loadVersions();\r\n          loadBookmarks();"}],"details":{"status":"completed","exitCode":0,"durationMs":58,"aggregated":"// ==================== 跨设备同步 ====================\r\n\r\n  const loadSyncStatus = () => {\r\n    try {\r\n      const stored = localStorage.getItem(STORAGE_KEYS.syncStatus);\r\n      if (stored) {\r\n        setSyncStatus(JSON.parse(stored));\r\n      }\r\n    } catch (e) {\r\n      console.error('加载同步状态失败:', e);\r\n    }\r\n  };\r\n\r\n  const handleSync = async () => {\r\n    setSyncStatus(prev => ({ ...prev, status: 'syncing' }));\r\n    // 模拟同步过程\r\n    setTimeout(() => {\r\n      const newStatus: SyncStatus = {\r\n        lastSync: new Date().toISOString(),\r\n        status: 'synced',\r\n        devices: [\r\n          { name: '当前设备', lastSeen: new Date().toISOString(), platform: 'Windows' },\r\n          { name: '笔记本电脑', lastSeen: new Date(Date.now() - 86400000).toISOString(), platform: 'macOS' },\r\n        ],\r\n      };\r\n      setSyncStatus(newStatus);\r\n      localStorage.setItem(STORAGE_KEYS.syncStatus, JSON.stringify(newStatus));\r\n      message.success('同步完成');\r\n    }, 2000);\r\n  };\r\n\r\n  const handleExportSync = () => {\r\n    const syncData: Record<string, any> = {};\r\n    for (let i = 0; i < localStorage.length; i++) {\r\n      const key = localStorage.key(i);\r\n      if (key?.startsWith('novel_')) {\r\n        syncData[key] = localStorage.getItem(key);\r\n      }\r\n    }\r\n    const blob = new Blob([JSON.stringify(syncData, null, 2)], { type: 'application/json' });\r\n    const url = URL.createObjectURL(blob);\r\n    const a = document.createElement('a');\r\n    a.href = url;\r\n    a.download = `novel_sync_${new Date().toISOString().split('T')[0]}.json`;\r\n    a.click();\r\n    URL.revokeObjectURL(url);\r\n    message.success('同步数据已导出');\r\n  };\r\n\r\n  const handleImportSync = () => {\r\n    const input = document.createElement('input');\r\n    input.type = 'file';\r\n    input.accept = '.json';\r\n    input.onchange = (e: any) => {\r\n      const file = e.target.files?.[0];\r\n      if (!file) return;\r\n      const reader = new FileReader();\r\n      reader.onload = (ev) => {\r\n        try {\r\n          const data = JSON.parse(ev.target?.result as string);\r\n          Object.entries(data).forEach(([key, value]) => {\r\n            if (key.startsWith('novel_')) {\r\n              localStorage.setItem(key, value as string);\r\n            }\r\n          });\r\n          message.success('同步数据已导入，请刷新页面');\r\n          loadProjects();\r\n          loadVersions();\r\n          loadBookmarks();","cwd":"/home/ai/.openclaw/workspace/main"},"isError":false,"timestamp":1776083353666}}
