{"type":"message","id":"61b350e2","parentId":"3dce8772","timestamp":"2026-04-13T12:23:04.800Z","message":{"role":"toolResult","toolCallId":"call_function_r03hmrc425ab_2","toolName":"exec","content":[{"type":"text","text":"import { useState, useCallback } from 'react'\r\nimport { message } from 'antd'\r\n\r\n/**\r\n * 文件系统操作 Hook\r\n * 封装所有文件相关的 Electron API 调用\r\n */\r\nexport function useFileSystem() {\r\n  const [loading, setLoading] = useState(false)\r\n  const [error, setError] = useState<string | null>(null)\r\n\r\n  /**\r\n   * 读取文件内容\r\n   */\r\n  const readFile = useCallback(async (filePath: string): Promise<string | null> => {\r\n    setLoading(true)\r\n    setError(null)\r\n    try {\r\n      const result = await window.electronAPI.readFile(filePath)\r\n      if (result.success) {\r\n        return result.content || null\r\n      } else {\r\n        setError(result.error || '读取文件失败')\r\n        return null\r\n      }\r\n    } catch (err: any) {\r\n      setError(err.message)\r\n      return null\r\n    } finally {\r\n      setLoading(false)\r\n    }\r\n  }, [])\r\n\r\n  /**\r\n   * 写入文件内容\r\n   */\r\n  const writeFile = useCallback(async (filePath: string, content: string): Promise<boolean> => {\r\n    setLoading(true)\r\n    setError(null)\r\n    try {\r\n      const result = await window.electronAPI.writeFile(filePath, content)\r\n      if (result.success) {\r\n        return true\r\n      } else {\r\n        setError(result.error || '写入文件失败')\r\n        return false\r\n      }\r\n    } catch (err: any) {\r\n      setError(err.message)\r\n      return false"}],"details":{"status":"completed","exitCode":0,"durationMs":57,"aggregated":"import { useState, useCallback } from 'react'\r\nimport { message } from 'antd'\r\n\r\n/**\r\n * 文件系统操作 Hook\r\n * 封装所有文件相关的 Electron API 调用\r\n */\r\nexport function useFileSystem() {\r\n  const [loading, setLoading] = useState(false)\r\n  const [error, setError] = useState<string | null>(null)\r\n\r\n  /**\r\n   * 读取文件内容\r