{"type":"message","id":"03ca887f","parentId":"8c90cad9","timestamp":"2026-04-12T17:39:19.706Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me write the handler.ts.","thinkingSignature":"1742ea7156db57d8f4eccedb3277f84a6b98fcc1353e03aa15f2f20e48a83225"},{"type":"toolCall","id":"call_function_5idy24662l1u_1","name":"write","arguments":{"path":"/home/ai/.openclaw/hooks/auto-score-classify/handler.ts","content":"import * as fs from \"fs\";\nimport * as path from \"path\";\nimport * as https from \"https\";\nimport * as http from \"http\";\n\ninterface ClassificationResult {\n  label: string | null;\n  confidence: number;\n  meta: string;\n  top_candidates: [string, number][];\n  intercepted: boolean;\n}\n\ninterface ScoringResult {\n  score: number;\n  factors: Record<string, number>;\n  recommendedStrategy: string;\n  timeout: number;\n  _raw?: { total: number; max: number };\n}\n\nasync function fetchJSON<T>(url: string, body: Record<string, unknown>, timeoutMs = 3000): Promise<T | null> {\n  return new Promise((resolve) => {\n    const postData = JSON.stringify(body);\n    const parsedUrl = new URL(url);\n    const isHttps = parsedUrl.protocol === \"https:\";\n    const lib = isHttps ? https : http;\n\n    const req = lib.request(\n      url,\n      { method: \"POST\", headers: { \"Content-Type\": \"application/json\", \"Content-Length\": Buffer.byteLength(postData) } },\n      (res) => {\n        let data = \"\";\n        res.on(\"data\", (chunk) => (data += chunk));\n        res.on(\"end\", () => {\n          try { resolve(JSON.parse(data) as T); }\n          catch { resolve(null); }\n        });\n      }\n    );\n\n    req.on(\"error\", () => resolve(null));\n    req.on(\"timeout\", () => { req.destroy(); resolve(null); });\n    req.write(postData);\n    req.end();\n\n    setTimeout(() => { req.destroy(); resolve(null); }, timeoutMs);\n  });\n}\n\nasync function runClassification(text: string): Promise<ClassificationResult | null> {\n  return fetchJSON<ClassificationResult>(\"http://127.0.0.1:3104/classify\", { text }, 3000);\n}\n\nasync function runScoring(prompt: string): Promise<ScoringResult | null> {\n  return fetchJSON<ScoringResult>(\"http://127.0.0.1:3103/api/score\", { prompt }, 3000);\n}\n\nfunction getSessionDir(sessionKey: string): string {\n  const base = path.join(process.env.HOME || \"/home/ai\", \".openclaw/sessions\", sessionKey);\n  return base;\n}\n\nfunction ensureDir(dir: string): void {\n  if (!fs.existsSync(dir)) {\n    fs.mkdirSync(dir, { recursive: true });\n  }\n}\n\nexport default async function handler(event: {\n  type: string;\n  action: string;\n  sessionKey: string;\n  context: { bodyForAgent?: string; from?: string; channelId?: string };\n  messages: unknown[];\n}): Promise<void> {\n  // Only handle preprocessed messages\n  if (event.type !== \"message\" || event.action !== \"preprocessed\") {\n    return;\n  }\n\n  const text = event.context.bodyForAgent || \"\";\n  if (!text || text.trim().length === 0) return;\n\n  const sessionDir = getSessionDir(event.sessionKey);\n  ensureDir(sessionDir);\n\n  // Run both API calls concurrently\n  const [classification, scoring] = await Promise.allSettled([\n    runClassification(text),\n    runScoring(text),\n  ]);\n\n  const result = {\n    classification: classification.status === \"fulfilled\" ? classification.value : null,\n    scoring: scoring.status === \"fulfilled\" ? scoring.value : null,\n    timestamp: new Date().toISOString(),\n    messagePreview: text.slice(0, 100),\n  };\n\n  const outPath = path.join(sessionDir, \"context.json\");\n  try {\n    fs.writeFileSync(outPath, JSON.stringify(result, null, 2), \"utf-8\");\n  } catch {\n    // ignore write errors\n  }\n}\n"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":29666,"output":856,"cacheRead":17719,"cacheWrite":0,"totalTokens":48241,"cost":{"input":0.0088998,"output":0.0010272,"cacheRead":0.00106314,"cacheWrite"