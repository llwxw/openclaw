{"type":"message","id":"5cc48af9","parentId":"9e7f953c","timestamp":"2026-04-12T18:26:32.525Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Let me check for specific issues in the code more carefully.","thinkingSignature":"85fcb0c0a9c862996dc311dac0aebbb4aeb8251510ebfa3006e91d6910e05fd4"},{"type":"toolCall","id":"call_function_p9pnryprey4k_1","name":"exec","arguments":{"command":"cat /home/ai/.openclaw/hooks/session-summary/handler.js","timeout":5}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":90035,"output":63,"cacheRead":17776,"cacheWrite":0,"totalTokens":107874,"cost":{"input":0.0270105,"output":0.0000756,"cacheRead":0.0010665599999999998,"cacheWrite":0,"total":0.02815266}},"stopReason":"toolUse","timestamp":1776018389448,"responseId":"062b16d5b1f8670919900bd86e4eff4f"}}
{"type":"message","id":"18e1cec8","parentId":"5cc48af9","timestamp":"2026-04-12T18:26:32.629Z","message":{"role":"toolResult","toolCallId":"call_function_p9pnryprey4k_1","toolName":"exec","content":[{"type":"text","text":"/**\n * session-summary hook\n *\n * 触发时机: /new 或 /reset\n * 行为: 读取上一个 session 的内容，调 LLM 生成结构化摘要，写入 memory/\n * 降级: LLM 失败时写规则摘要，不报错\n */\n\nimport fs from \"node:fs\";\nimport path from \"node:path\";\nimport os from \"node:os\";\nimport http from \"node:http\";\n\n// ─── Constants ────────────────────────────────────────────────────────────────\n\nconst WORKSPACE_DIR = process.env.OPENCLAW_WORKSPACE_DIR ||\n  path.join(os.homedir(), \".openclaw\", \"workspace\");\n\nconst MEMORY_DIR = path.join(WORKSPACE_DIR, \"memory\");\n\n/** LLM 超时 (ms) */\nconst LLM_TIMEOUT_MS = 20_000;\n\n// ─── Types (JSDoc) ───────────────────────────────────────────────────────────\n\n/**\n * @typedef {Object} SessionEntry\n * @property {string} [sessionFile]\n * @property {string} [sessionId]\n */\n\n/**\n * @typedef {Object} HookContext\n * @property {SessionEntry} [previousSessionEntry]\n * @property {SessionEntry} [sessionEntry]\n */\n\n// ─── Session File Lookup ──────────────────────────────────────────────────────\n\n/**\n * 解析 sessionKey 格式: agent:{agentId}:{requestKey}\n * 尝试在 sessionsDir 下找匹配的 .jsonl 文件\n * @param {string} sessionsDir\n * @param {string} sessionKey\n * @returns {string|null}\n */\nfunction resolveSessionFile(sessionsDir, sessionKey) {\n  const parts = sessionKey.split(\":\");\n  if (parts.length < 3) return null;\n  const requestKey = parts[2];\n  if (!requestKey) return null;\n\n  try {\n    const files = fs.readdirSync(sessionsDir);\n    // 精确匹配 requestKey.jsonl\n    const exact = files.find((f) => f === `${requestKey}.jsonl`);\n    if (exact) return path.join(sessionsDir, exact);\n    // topic 变体\n    const topic = files.find(\n      (f) => f.startsWith(`${requestKey}-topic-`) && f.endsWith(\".jsonl\")\n    );\n    if (topic) return path.join(sessionsDir, topic);\n    // .reset. 备份文件\n    const reset = files\n      .filter((f) => f.startsWith(requestKey) && f.includes(\".reset.\") && f.endsWith(\".jsonl\"))\n      .sort()\n      .pop();\n    if (reset) return path.join(sessionsDir, reset);\n    return null;\n  } catch {\n    return null;\n  }\n}\n\n/**\n * 从 context 中提取 sessionFile 路径。\n * 优先用 previousSessionEntry（旧 session），降级用 sessionEntry（新 session）。\n * @param {HookContext} context\n * @param {string} workspaceDir\n * @param {string} sessionKey\n * @returns {string|null}\n */\nfunction getSessionFile(context, workspaceDir, sessionKey) {\n  const prev = context?.previousSessionEntry;\n  if (prev?.sessionFile) return prev.sessionFile;\n\n  const curr = context?.sessionEntry;\n  if (curr?.sessionFile) return curr.sessionFile;\n\n  // 兜底: 在 sessionsDir 下搜索\n  const sessionsDir = path.join(workspaceDir, \"sessions\");\n  if (fs.existsSync(sessionsDir)) {\n    return resolveSessionFile(sessionsDir, sessionKey);\n  }\n  return null;\n}\n\n// ─── Message Extraction ──────────────────────────────────────────────────────\n\n/**\n * 从 .jsonl 中提取最新 N 条 user/assistant 消息。\n * @param {string} filePath\n * @param {number} [messageCount=40]\n * @returns {Promise<string>} 空字符串表示读取失败\n */\nasync function extractMessages(filePath, messageCount = 40) {\n  try {\n    const content = await fs.promises.readFile(filePath, \"utf-8\");\n    const lines = content.trim().split(\"\\n\").slice(-messageCount * 2);\n    /** @type {string[]} */\n    const messages = [];\n\n    for (const line of lines) {\n      try {\n        /** @type {{ type: string, message?: { role: string, content: unknown } }} */\n        const entry = JSON.parse(line);\n        if (entry.type !== \"message\") continue;\n        const msg = entry.message;\n        if (!msg?.role || !msg?.content) continue;\n        if (msg.role !== \"user\" && msg.role !== \"assistant\") continue;\n\n        const text =\n          typeof msg.content === \"string\"\n            ? msg.content\n            : extractTextFromBlocks(msg.content);\n\n        if (!text || text.startsWith(\"/\")) continue;\n        messages.push(`${msg.role}: ${text}`);\n      } catch {\n        // skip malformed lines\n      }\n    }\n    return messages.slice(-messageCount).join(\"\\n\");\n  } catch {\n    return \"\";\n  }\n}\n\n/**\n * 从 content blocks 中提取 text。\n * @param {unknown} content\n * @returns {string}\n */\nfunction extractTextFromBlocks(content) {\n  if (Array.isArray(content)) {\n    for (const block of content) {\n      if (\n        block &&\n        typeof block === \"object\" &&\n        block.type === \"text\" &&\n        typeof block.text === \"string\"\n      ) {\n        return block.text;\n      }\n    }\n  }\n  return \"\";\n}\n\n// ─── LLM Summary Generation ───────────────────────────────────────────────────\n\n/**\n * 调用 v8 Router LLM 接口生成摘要。\n * @param {string} sessionContent\n * @returns {Promise<string>} 空字符串表示失败\n */\nasync function generateSummary(sessionContent) {\n  return new Promise((resolve) => {\n    const prompt = buildSummaryPrompt(sessionContent);\n    const postData = JSON.stringify({\n      model: \"minimax/MiniMax-M2.7\",\n      messages: [{ role: \"user\", content: prompt }],\n      temperature: 0.3,\n      max_tokens: 600,\n    });\n\n    const req = http.request(\n      \"http://127.0.0.1:3102/v1/chat/completions\",\n      {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          \"Content-Length\": Buffer.byteLength(postData),\n        },\n      },\n      (res) => {\n        let data = \"\";\n        res.on(\"data\", (c) => (data += c));\n        res.on(\"end\", () => {\n          try {\n            const parsed = JSON.parse(data);\n            const text = parsed.choices?.[0]?.message?.content;\n            resolve(text?.trim() ?? \"\");\n          } catch {\n            resolve(\"\");\n          }\n        });\n      }\n    );\n\n    req.on(\"error\", () => resolve(\"\"));\n    req.on(\"timeout\", () => {\n      req.destroy();\n      resolve(\"\");\n    });\n\n    req.write(postData);\n    req.end();\n\n    setTimeout(() => {\n      try { req.destroy(); } catch { /* ignore */ }\n      resolve(\"\");\n    }, LLM_TIMEOUT_MS);\n  });\n}\n\n/**\n * @param {string} sessionContent\n * @returns {string}\n */\nfunction buildSummaryPrompt(sessionContent) {\n  return `你是一个会话摘要生成器。\n给定以下对话记录，生成一个结构化摘要。\n\n要求：\n- 主题：一句话概括本次对话主题（少于20字）\n- 关键决策：列出做出的所有决策，如果没有则写\"无明确决策\"\n- 重要发现：列出任何重要信息或结论，如果没有则写\"无\"\n- 待跟进：列出任何未完成或需要后续处理的事项，如果没有则写\"无\"\n\n格式（严格按此格式，只输出内容，不输出说明）：\n## 主题\n{主题}\n\n## 关键决策\n{决策列表}\n\n## 重要发现\n{发现列表}\n\n## 待跟进\n{待办列表}\n\n对话记录：\n${sessionContent}`;\n}\n\n// ─── Fallback Summary ────────────────────────────────────────────────────────\n\n/**\n * @param {string} content\n * @param {string} date\n * @param {string} time\n * @returns {string}\n */\nfunction buildFallbackSummary(content, date, time) {\n  const firstLine = content.split(\"\\n\")[0] ?? \"\";\n  const preview = firstLine.slice(0, 60).replace(/[#*]/g, \"\").trim() || \"会话摘要\";\n  return `# Session: ${date} ${time}\n\n## 主题\n${preview}\n\n## 关键决策\n无\n\n## 重要发现\n无\n\n## 待跟进\n见原始对话记录\n`;\n}\n\n// ─── File Writing ────────────────────────────────────────────────────────────\n\n/**\n * 从摘要文本中提取 slug。\n * @param {string} summary\n * @param {string} time\n * @returns {string}\n */\nfunction extractSlug(summary, time) {\n  const match = summary.match(/^## 主题$\\s*([^\\n]+)/m);\n  if (!match) return time.replace(/:/g, \"\");\n\n  return match[1]\n    .toLowerCase()\n    .replace(/[^a-z0-9\\u4e00-\\u9fff]+/g, \"-\")\n    .replace(/^-+|-+$/g, \"\")\n    .slice(0, 40) || time.replace(/:/g, \"\");\n}\n\n/**\n * 写摘要到 memory/ 目录。\n * @param {string} summary\n * @param {string} date\n * @param {string} time\n * @param {string} sessionKey\n */\nasync function writeSummaryFile(summary, date, time, sessionKey) {\n  const slug = extractSlug(summary, time);\n  const filename = `${date}-${slug}.md`;\n  const filePath = path.join(MEMORY_DIR, filename);\n\n  await fs.promises.mkdir(MEMORY_DIR, { recursive: true });\n\n  const fullContent = [\n    `# Session: ${date} ${time}`,\n    \"\",\n    \"<!-- summary-only -->\",\n    summary,\n    \"\",\n    `<!-- source: ${sessionKey} -->`,\n  ].join(\"\\n\");\n\n  await fs.promises.writeFile(filePath, fullContent, \"utf-8\");\n  console.log(`[session-summary] Written: ${filename}`);\n}\n\n// ─── Core ────────────────────────────────────────────────────────────────────\n\n/**\n * @param {{ type: string, action: string, sessionKey: string, context: HookContext, messages: unknown[] }} event\n */\nasync function run(event) {\n  const isResetCommand = event.type === \"command\" && (event.action === \"new\" || event.action === \"reset\");\n  if (!isResetCommand) return;\n\n  const now = new Date();\n  const date = now.toISOString().split(\"T\")[0];\n  const time = now.toISOString().split(\"T\")[1].split(\".\")[0].slice(0, 5);\n\n  // 1. 找 session 文件\n  const workspaceDir =\n    event.context?.sessionEntry?.sessionFile\n      ? path.dirname(event.context.sessionEntry.sessionFile)\n      : WORKSPACE_DIR;\n\n  const sessionFile = getSessionFile(event.context || {}, workspaceDir, event.sessionKey);\n\n  // 2. 读内容\n  const content = sessionFile\n    ? await extractMessages(sessionFile)\n    : \"\";\n\n  // 3. 生摘要\n  let summary;\n  if (content && content.trim().length > 50) {\n    const llmText = await generateSummary(content);\n    summary = llmText || buildFallbackSummary(content, date, time);\n  } else {\n    summary = buildFallbackSummary(content || \"(无会话内容)\", date, time);\n  }\n\n  // 4. 写文件（后台，不等待）\n  writeSummaryFile(summary, date, time, event.sessionKey).catch((err) => {\n    console.error(\"[session-summary] Write error:\", err);\n  });\n}\n\n// ─── Entry Point ─────────────────────────────────────────────────────────────\n\n/** @type {{ default: (event: unknown) => Promise<void> }} */\nconst mod = {\n  default: (event) => {\n    // 不 await，fire-and-forget\n    run(/** @type {import(\"./types\").HookEvent} */ (event)).catch((err) => {\n      console.error(\"[session-summary] Uncaught error:\", err);\n    });\n  },\n};\n\nexport default mod.default;"}],"details":{"status":"completed","exitCode":0,"durationMs":57,"aggregated":"/**\n * session-summary hook\n *\n * 触发时机: /new 或 /reset\n * 行为: 读取上一个 session 的内容，调 LLM 生成结构化摘要，写入 memory/\n * 降级: LLM 失败时写规则摘要，不报错\n */\n\nimport fs from \"node:fs\";\nimport path from \"node:path\";\nimport os from \"node:os\";\nimport http from \"node:http\";\n\n// ─── Constants ────────────────────────────────────────────────────────────────\n\nconst WORKSPACE_DIR = process.env.OPENCLAW_WORKSPACE_DIR ||\n  path.join(os.homedir(), \".openclaw\", \"workspace\");\n\nconst MEMORY_DIR = path.join(WORKSPACE_DIR, \"memory\");\n\n/** LLM 超时 (ms) */\nconst LLM_TIMEOUT_MS = 20_000;\n\n// ─── Types (JSDoc) ───────────────────────────────────────────────────────────\n\n/**\n * @typedef {Object} SessionEntry\n * @property {string} [sessionFile]\n * @property {string} [sessionId]\n */\n\n/**\n * @typedef {Object} HookContext\n * @property {SessionEntry} [previousSessionEntry]\n * @property {SessionEntry} [sessionEntry]\n */\n\n// ─── Session File Lookup ──────────────────────────────────────────────────────\n\n/**\n * 解析 sessionKey 格式: agent:{agentId}:{requestKey}\n * 尝试在 sessionsDir 下找匹配的 .jsonl 文件\n * @param {string} sessionsDir\n * @param {string} sessionKey\n * @returns {string|null}\n */\nfunction resolveSessionFile(sessionsDir, sessionKey) {\n  const parts = sessionKey.split(\":\");\n  if (parts.length < 3) return null;\n  const requestKey = parts[2];\n  if (!requestKey) return null;\n\n  try {\n    const files = fs.readdirSync(sessionsDir);\n    // 精确匹配 requestKey.jsonl\n    const exact = files.find((f) => f === `${requestKey}.jsonl`);\n    if (exact) return path.join(sessionsDir, exact);\n    // topic 变体\n    const topic = files.find(\n      (f) => f.startsWith(`${requestKey}-topic-`) && f.endsWith(\".jsonl\")\n    );\n    if (topic) return path.join(sessionsDir, topic);\n    // .reset. 备份文件\n    const reset = files\n      .filter((f) => f.startsWith(requestKey) && f.includes(\".reset.\") && f.endsWith(\".jsonl\"))\n      .sort()\n      .pop();\n    if (reset) return path.join(sessionsDir, reset);\n    return null;\n  } catch {\n    return null;\n  }\n}\n\n/**\n * 从 context 中提取 sessionFile 路径。\n * 优先用 previousSessionEntry（旧 session），降级用 sessionEntry（新 session）。\n * @param {HookContext} context\n * @param {string} workspaceDir\n * @param {string} sessionKey\n * @returns {string|null}\n */\nfunction getSessionFile(context, workspaceDir, sessionKey) {\n  const prev = context?.previousSessionEntry;\n  if (prev?.sessionFile) return prev.sessionFile;\n\n  const curr = context?.sessionEntry;\n  if (curr?.sessionFile) return curr.sessionFile;\n\n  // 兜底: 在 sessionsDir 下搜索\n  const sessionsDir = path.join(workspaceDir, \"sessions\");\n  if (fs.existsSync(sessionsDir)) {\n    return resolveSessionFile(sessionsDir, sessionKey);\n  }\n  return null;\n}\n\n// ─── Message Extraction ──────────────────────────────────────────────────────\n\n/**\n * 从 .jsonl 中提取最新 N 条 user/assistant 消息。\n * @param {string} filePath\n * @param {number} [messageCount=40]\n * @returns {Promise<string>} 空字符串表示读取失败\n */\nasync function extractMessages(filePath, messageCount = 40) {\n  try {\n    const content = await fs.promises.readFile(filePath, \"utf-8\");\n    const lines = content.trim().split(\"\\n\").slice(-messageCount * 2);\n    /** @type {string[]} */\n    const messages = [];\n\n    for (const line of lines) {\n      try {\n        /** @type {{ type: string, message?: { role: string, content: unknown } }} */\n        const entry = JSON.parse(line);\n        if (entry.type !== \"message\") continue;\n        const msg = entry.message;\n        if (!msg?.role || !msg?.content) continue;\n        if (msg.role !== \"user\" && msg.role !== \"assistant\") continue;\n\n        const text =\n          typeof msg.content === \"string\"\n            ? msg.content\n            : extractTextFromBlocks(msg.content);\n\n        if (!text || text.startsWith(\"/\")) continue;\n        messages.push(`${msg.role}: ${text}`);\n      } catch {\n        // skip malformed lines\n      }\n    }\n    return messages.slice(-messageCount).join(\"\\n\");\n  } catch {\n    return \"\";\n  }\n}\n\n/**\n * 从 content blocks 中提取 text。\n * @param {unknown} content\n * @returns {string}\n */\nfunction extractTextFromBlocks(content) {\n  if (Array.isArray(content)) {\n    for (const block of content) {\n      if (\n        block &&\n        typeof block === \"object\" &&\n        block.type === \"text\" &&\n        typeof block.text === \"string\"\n      ) {\n        return block.text;\n      }\n    }\n  }\n  return \"\";\n}\n\n// ─── LLM Summary Generation ───────────────────────────────────────────────────\n\n/**\n * 调用 v8 Router LLM 接口生成摘要。\n * @param {string} sessionContent\n * @returns {Promise<string>} 空字符串表示失败\n */\nasync function generateSummary(sessionContent) {\n  return new Promise((resolve) => {\n    const prompt = buildSummaryPrompt(sessionContent);\n    const postData = JSON.stringify({\n      model: \"minimax/MiniMax-M2.7\",\n      messages: [{ role: \"user\", content: prompt }],\n      temperature: 0.3,\n      max_tokens: 600,\n    });\n\n    const req = http.request(\n      \"http://127.0.0.1:3102/v1/chat/completions\",\n      {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          \"Content-Length\": Buffer.byteLength(postData),\n        },\n      },\n      (res) => {\n        let data = \"\";\n        res.on(\"data\", (c) => (data += c));\n        res.on(\"end\", () => {\n          try {\n            const parsed = JSON.parse(data);\n            const text = parsed.choices?.[0]?.message?.content;\n            resolve(text?.trim() ?? \"\");\n          } catch {\n            resolve(\"\");\n          }\n        });\n      }\n    );\n\n    req.on(\"error\", () => resolve(\"\"));\n    req.on(\"timeout\", () => {\n      req.destroy();\n      resolve(\"\");\n    });\n\n    req.write(postData);\n    req.end();\n\n    setTimeout(() => {\n      try { req.destroy(); } catch { /* ignore */ }\n      resolve(\"\");\n    }, LLM_TIMEOUT_MS);\n  });\n}\n\n/**\n * @param {string} sessionContent\n * @returns {string}\n */\nfunction buildSummaryPrompt(sessionContent) {\n  return `你是一个会话摘要生成器。\n给定以下对话记录，生成一个结构化摘要。\n\n要求：\n- 主题：一句话概括本次对话主题（少于20字）\n- 关键决策：列出做出的所有决策，如果没有则写\"无明确决策\"\n- 重要发现：列出任何重要信息或结论，如果没有则写\"无\"\n- 待跟进：列出任何未完成或需要后续处理的事项，如果没有则写\"无\"\n\n格式（严格按此格式，只输出内容，不输出说明）：\n## 主题\n{主题}\n\n## 关键决策\n{决策列表}\n\n## 重要发现\n{发现列表}\n\n## 待跟进\n{待办列表}\n\n对话记录：\n${sessionContent}`;\n}\n\n// ─── Fallback Summary ────────────────────────────────────────────────────────\n\n/**\n * @param {string} content\n * @param {string} date\n * @param {string} time\n * @returns {string}\n */\nfunction buildFallbackSummary(content, date, time) {\n  const firstLine = content.split(\"\\n\")[0] ?? \"\";\n  const preview = firstLine.slice(0, 60).replace(/[#*]/g, \"\").trim() || \"会话摘要\";\n  return `# Session: ${date} ${time}\n\n## 主题\n${preview}\n\n## 关键决策\n无\n\n## 重要发现\n无\n\n## 待跟进\n见原始对话记录\n`;\n}\n\n// ─── File Writing ────────────────────────────────────────────────────────────\n\n/**\n * 从摘要文本中提取 slug。\n * @param {string} summary\n * @param {string} time\n * @returns {string}\n */\nfunction extractSlug(summary, time) {\n  const match = summary.match(/^## 主题$\\s*([^\\n]+)/m);\n  if (!match) return time.replace(/:/g, \"\");\n\n  return match[1]\n    .toLowerCase()\n    .replace(/[^a-z0-9\\u4e00-\\u9fff]+/g, \"-\")\n    .replace(/^-+|-+$/g, \"\")\n    .slice(0, 40) || time.replace(/:/g, \"\");\n}\n\n/**\n * 写摘要到 memory/ 目录。\n * @param {string} summary\n * @param {string} date\n * @param {string} time\n * @param {string} sessionKey\n */\nasync function writeSummaryFile(summary, date, time, sessionKey) {\n  const slug = extractSlug(summary, time);\n  const filename = `${date}-${slug}.md`;\n  const filePath = path.join(MEMORY_DIR, filename);\n\n  await fs.promises.mkdir(MEMORY_DIR, { recursive: true });\n\n  const fullContent = [\n    `# Session: ${date} ${time}`,\n    \"\",\n    \"<!-- summary-only -->\",\n    summary,\n    \"\",\n    `<!-- source: ${sessionKey} -->`,\n  ].join(\"\\n\");\n\n  await fs.promises.writeFile(filePath, fullContent, \"utf-8\");\n  console.log(`[session-summary] Written: ${filename}`);\n}\n\n// ─── Core ────────────────────────────────────────────────────────────────────\n\n/**\n * @param {{ type: string, action: string, sessionKey: string, context: HookContext, messages: unknown[] }} event\n */\nasync function run(event) {\n  const isResetCommand = event.type === \"command\" && (event.action === \"new\" || event.action === \"reset\");\n  if (!isResetCommand) return;\n\n  const now = new Date();\n  const date = now.toISOString().split(\"T\")[0];\n  const time = now.toISOString().split(\"T\")[1].split(\".\")[0].slice(0, 5);\n\n  // 1. 找 session 文件\n  const workspaceDir =\n    event.context?.sessionEntry?.sessionFile\n      ? path.dirname(event.context.sessionEntry.sessionFile)\n      : WORKSPACE_DIR;\n\n  const sessionFile = getSessionFile(event.context || {}, workspaceDir, event.sessionKey);\n\n  // 2. 读内容\n  const content = sessionFile\n    ? await extractMessages(sessionFile)\n    : \"\";\n\n  // 3. 生摘要\n  let summary;\n  if (content && content.trim().length > 50) {\n    const llmText = await generateSummary(content);\n    summary = llmText || buildFallbackSummary(content, date, time);\n  } else {\n    summary = buildFallbackSummary(content || \"(无会话内容)\", date, time);\n  }\n\n  // 4. 写文件（后台，不等待）\n  writeSummaryFile(summary, date, time, event.sessionKey).catch((err) => {\n    console.error(\"[session-summary] Write error:\", err);\n  });\n}\n\n// ─── Entry Point ─────────────────────────────────────────────────────────────\n\n/** @type {{ default: (event: unknown) => Promise<void> }} */\nconst mod = {\n  default: (event) => {\n    // 不 await，fire-and-forget\n    run(/** @type {import(\"./types\").HookEvent} */ (event)).catch((err) => {\n      console.error(\"[session-summary] Uncaught error:\", err);\n    });\n  },\n};\n\nexport default mod.default;","cwd":"/home/ai/.openclaw/workspace/main"},"isError":false,"timestamp":1776018392620}}
{"type":"message","id":"6a25f8be","parentId":"18e1cec8","timestamp":"2026-04-12T18:27:31.996Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me do a thorough review of this code:\n\n**Bug 1: Double timeout**\nIn `generateSummary`, there's a `req.on(\"timeout\")` handler AND a `setTimeout` that calls `req.destroy()` and `resolve(\"\")`. The `req.on(\"timeout\")` also calls `resolve(\"\")`. This means the timeout can resolve twice - once from the event handler and once from the setTimeout. This is a race condition.\n\n**Bug 2: workspaceDir computation is wrong**\n```javascript\nconst workspaceDir =\n  event.context?.sessionEntry?.sessionFile\n    ? path.dirname(event.context.sessionEntry.sessionFile)\n    : WORKSPACE_DIR;\n```\n\n\nIf `sessionFile` is `/foo/bar/agent:main:main/sessions/xyz.jsonl`, then `path.dirname` gives `/foo/bar/agent:main:main/sessions`, but the actual workspace directory should be `/foo/bar` without the `sessions` subdirectory. This is incorrect.\n\n**Bug 3: session-key format parsing is wrong**\nThe `sessionKey` format is `agent:main:main`, which means `parts = [\"agent\", \"main\", \"main\"]`, so `requestKey = \"main\"`. But I'm looking for a file named `main.jsonl`, which is too generic and will likely match the wrong file.\n\nLooking at how the actual session file is structured in `~/.openclaw/sessions/`, the directory names contain colons like `agent:main:main`, so I can't just split by `:` and take the third element as the request key.\n\n**Bug 4: The workspaceDir logic is flawed**\nThe session files are stored under `~/.openclaw/sessions/` as `agent:main:main/`, but the workspace directory is `~/.openclaw/workspace/`, and these don't align with the session key format.\n\n**Bug 5: Files might not exist where expected**\nI need to verify whether session files are actually stored at `~/.openclaw/sessions/` or somewhere else, since the gateway appears to pass session content directly in the event context rather than as file paths.\n\n**Bug 6: The `mod` wrapper is unnecessary**\nThe default export is already a function, so wrapping it in an object with a `default` property adds unnecessary complexity—I should just export the function directly.\n\n**Bug 7: `sessionEntry.sessionFile` is a file path, not a directory**\nWhen I call `path.dirname()` on a session file path like `/home/ai/.openclaw/sessions/agent:main:main/abc123.jsonl`, I get the session directory itself, not the workspace directory. But I'm using this result as a workspace directory, which is incorrect.\n\n**Bug 8: Missing error handling for writeSummaryFile in fire-and-forget**\nThe catch handler only handles errors from the initial call, but if `writeSummaryFile` throws after being invoked, that error disappears silently.\n\n**Bug 9: Ambiguous error handling in parse**\nWhen JSON parsing fails in the main loop, errors get silently swallowed with an empty catch block, making it harder to debug issues.\n\n**Bug 10: Inconsistent handling of `/reset` vs `/new`**\nBoth commands trigger the same `isResetCommand` check, but they're semantically different—one starts a fresh session while the other resets the current one.\n\nThe core issue is that `/new` creates a new session while `/reset` clears the current one, so using the current session's file for a `/reset` command is correct, but using the current session's file after `/new` would grab the wrong session.\n\nLooking at how `session-memory` handles this, it uses `context.previousSessionEntry.sessionFile` for both commands, which points to the session that just ended—the intended behavior. However, `previousSessionEntry` might not always be populated depending on the gateway implementation, so I need a fallback strategy to locate the correct session file when that context is missing.\n\nThe session key format `agent:{agentId}:{requestKey}` gives me a parts array where the request key is the third element, but this is problematic for main sessions since the request key is just \"main\"—I need to verify whether the session file actually matches this pattern or if there's a different identifier I'm missing.\n\nLooking at the directory listing, the session files don't seem to be stored as `.jsonl` files in the sessions directory, which means the gateway must be passing session content directly through the event context rather than relying on file-based session retrieval. This suggests the hook's event-driven approach is the primary mechanism for accessing session data, not file lookups.\n\nThere are several issues I need to address: the double timeout in `generateSummary`, the workspace directory being derived from a session file path that doesn't exist, the unnecessary object wrapper around the module export, and the mismatch between session content being passed directly versus stored as `.jsonl` files. I should fix these problems and potentially redesign the implementation to work with the actual event context approach the gateway uses.","thinkingSignature":"589dd2fbfbb1920dc107286bbfeab10ea21dfcb6443c14948bd94ea2fea3b3ed"},{"type":"text","text":"逐行严格评审，发现 4 个严重 Bug：\n\n---\n\n**Bug 1：双超时竞态（严重）**\n\n```javascript\nreq.on(\"timeout\", () => {\n  req.destroy();\n  resolve(\"\");   // ← 第一次 resolve\n});\n\nsetTimeout(() => {\n  try { req.destroy(); } catch {}\n  resolve(\"\");   // ← 第二次 resolve，如果 timeout 事件已触发\n}, LLM_TIMEOUT_MS);\n```\n\n两次 `resolve(\"\")`，概率性触发。\n\n---\n\n**Bug 2：workspaceDir 计算错误（严重）**\n\n```javascript\nconst workspaceDir =\n  event.context?.sessionEntry?.sessionFile\n    ? path.dirname(event.context.sessionEntry.sessionFile)  // ❌\n    : WORKSPACE_DIR;\n```\n\n`sessionEntry.sessionFile` 是 session 文件的路径（如 `.../sessions/agent:main:main/abc.jsonl`），取 dirname 得到的是 `sessions/` 目录，不是 workspace 目录。\n\n---\n\n**Bug 3：session-key 解析失效（严重）**\n\n```javascript\n// sessionKey = \"agent:main:main\"\n// parts = [\"agent\", \"main\", \"main\"]\n// requestKey = \"main\" ← 太模糊，根本找不到正确的 .jsonl\n```\n\n而实际上 `~/.openclaw/sessions/` 里没有 `.jsonl` 文件，只有目录。`session-memory` hook 用的是 `context.sessionEntry.sessionFile` 路径，不是自己解析 key。\n\n---\n\n**Bug 4：多余的 mod 包装（代码风格）**\n\n```javascript\nconst mod = {\n  default: (event) => { ... }\n};\nexport default mod.default;  // 直接 export 函数更干净\n```\n\n---\n\n**修复方案**：\n"},{"type":"toolCall","id":"call_function_3nw5rb4y6xxd_1","name":"write","arguments":{"path":"/home/ai/.openclaw/hooks/session-summary/handler.js","content":"/**\n * session-summary hook\n *\n * 触发时机: /new 或 /reset\n * 行为: 读取上一个 session 的内容，调 LLM 生成结构化摘要，写入 memory/\n * 降级: LLM 失败时写规则摘要，不报错\n */\n\nimport fs from \"node:fs\";\nimport path from \"node:path\";\nimport os from \"node:os\";\nimport http from \"node:http\";\n\n// ─── Constants ────────────────────────────────────────────────────────────────\n\nconst WORKSPACE_DIR =\n  process.env.OPENCLAW_WORKSPACE_DIR ||\n  path.join(os.homedir(), \".openclaw\", \"workspace\");\n\nconst MEMORY_DIR = path.join(WORKSPACE_DIR, \"memory\");\nconst LLM_TIMEOUT_MS = 20_000;\n\n// ─── Types (JSDoc) ─────────────────────────────────────────────────────────\n\n/**\n * @typedef {Object} SessionEntry\n * @property {string} [sessionFile]\n * @property {string} [sessionId]\n */\n\n/**\n * @typedef {Object} HookContext\n * @property {SessionEntry} [previousSessionEntry]\n * @property {SessionEntry} [sessionEntry]\n */\n\n// ─── Session File Resolution ──────────────────────────────────────────────────\n\n/**\n * 从 context 中提取 session 文件路径。\n * 优先使用 previousSessionEntry（旧 session，即刚结束的那个）。\n * @param {HookContext} context\n * @returns {string|null}\n */\nfunction resolveSessionFile(context) {\n  const prev = context?.previousSessionEntry;\n  if (prev?.sessionFile) return prev.sessionFile;\n\n  const curr = context?.sessionEntry;\n  if (curr?.sessionFile) return curr.sessionFile;\n\n  return null;\n}\n\n// ─── Message Extraction ──────────────────────────────────────────────────────\n\n/**\n * @param {unknown} content\n * @returns {string}\n */\nfunction extractTextFromBlocks(content) {\n  if (Array.isArray(content)) {\n    for (const block of content) {\n      if (\n        block &&\n        typeof block === \"object\" &&\n        block.type === \"text\" &&\n        typeof block.text === \"string\"\n      ) {\n        return block.text;\n      }\n    }\n  }\n  return \"\";\n}\n\n/**\n * 从 .jsonl 文件中提取最新 N 条 user/assistant 消息。\n * @param {string} filePath\n * @param {number} [messageCount=40]\n * @returns {Promise<string>}\n */\nasync function extractMessages(filePath, messageCount = 40) {\n  try {\n    const content = await fs.promises.readFile(filePath, \"utf-8\");\n    // 读取双倍行数以防 JSONL 格式行数波动\n    const lines = content.trim().split(\"\\n\").slice(-messageCount * 2);\n    /** @type {string[]} */\n    const messages = [];\n\n    for (const line of lines) {\n      if (!line.trim()) continue;\n      try {\n        /** @type {{ type: string, message?: { role: string, content: unknown } }} */\n        const entry = JSON.parse(line);\n        if (entry.type !== \"message\") continue;\n        const msg = entry.message;\n        if (!msg?.role || !msg?.content) continue;\n        if (msg.role !== \"user\" && msg.role !== \"assistant\") continue;\n\n        const text =\n          typeof msg.content === \"string\"\n            ? msg.content\n            : extractTextFromBlocks(msg.content);\n\n        if (!text || text.startsWith(\"/\")) continue;\n        messages.push(`${msg.role}: ${text}`);\n      } catch {\n        // skip malformed lines silently\n      }\n    }\n    return messages.slice(-messageCount).join(\"\\n\");\n  } catch {\n    return \"\";\n  }\n}\n\n// ─── LLM Generation ──────────────────────────────────────────────────────────\n\n/**\n * @param {string} sessionContent\n * @returns {string}\n */\nfunction buildSummaryPrompt(sessionContent) {\n  return `你是一个会话摘要生成器。\n给定以下对话记录，生成一个结构化摘要。\n\n要求：\n- 主题：一句话概括本次对话主题（少于20字）\n- 关键决策：列出做出的所有决策，如果没有则写\"无明确决策\"\n- 重要发现：列出任何重要信息或结论，如果没有则写\"无\"\n- 待跟进：列出任何未完成或需要后续处理的事项，如果没有则写\"无\"\n\n格式（严格按此格式，只输出内容，不输出说明）：\n## 主题\n{主题}\n\n## 关键决策\n{决策列表}\n\n## 重要发现\n{发现列表}\n\n## 待跟进\n{待办列表}\n\n对话记录：\n${sessionContent}`;\n}\n\n/**\n * 调用 v8 Router LLM 接口生成摘要。\n * 超时 20s 后自动销毁请求并降级。\n * @param {string} sessionContent\n * @returns {Promise<string>} 空字符串表示失败\n */\nasync function generateSummary(sessionContent) {\n  const prompt = buildSummaryPrompt(sessionContent);\n  const postData = JSON.stringify({\n    model: \"minimax/MiniMax-M2.7\",\n    messages: [{ role: \"user\", content: prompt }],\n    temperature: 0.3,\n    max_tokens: 600,\n  });\n\n  return new Promise((resolve) => {\n    let settled = false;\n    const doResolve = (v) => {\n      if (settled) return;\n      settled = true;\n      resolve(v);\n    };\n\n    const req = http.request(\n      \"http://127.0.0.1:3102/v1/chat/completions\",\n      {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          \"Content-Length\": Buffer.byteLength(postData),\n        },\n      },\n      (res) => {\n        let data = \"\";\n        res.on(\"data\", (c) => (data += c));\n        res.on(\"end\", () => {\n          try {\n            const parsed = JSON.parse(data);\n            const text = parsed.choices?.[0]?.message?.content;\n            doResolve(text?.trim() ?? \"\");\n          } catch {\n            doResolve(\"\");\n          }\n        });\n      }\n    );\n\n    req.on(\"error\", () => doResolve(\"\"));\n\n    // 20s 单边超时\n    const timer = setTimeout(() => {\n      try { req.destroy(); } catch { /* noop */ }\n      doResolve(\"\");\n    }, LLM_TIMEOUT_MS);\n\n    req.on(\"close\", () => clearTimeout(timer));\n\n    req.write(postData);\n    req.end();\n  });\n}\n\n// ─── Fallback ────────────────────────────────────────────────────────────────\n\n/**\n * @param {string} content\n * @param {string} date\n * @param {string} time\n * @returns {string}\n */\nfunction buildFallbackSummary(content, date, time) {\n  const firstLine = (content.split(\"\\n\")[0] ?? \"\").slice(0, 60).replace(/[#*]/g, \"\").trim();\n  const preview = firstLine || \"会话摘要\";\n  return `# Session: ${date} ${time}\n\n## 主题\n${preview}\n\n## 关键决策\n无\n\n## 重要发现\n无\n\n## 待跟进\n见原始对话记录\n`;\n}\n\n// ─── File Writing ─────────────────────────────────────────────────────────────\n\n/**\n * @param {string} summary\n * @param {string} time\n * @returns {string}\n */\nfunction slugFromSummary(summary, time) {\n  const match = summary.match(/^## 主题$\\s*([^\\n]+)/m);\n  if (!match) return time.replace(/:/g, \"\");\n\n  return match[1]\n    .toLowerCase()\n    .replace(/[^a-z0-9\\u4e00-\\u9fff]+/g, \"-\")\n    .replace(/^-+|-+$/g, \"\")\n    .slice(0, 40) || time.replace(/:/g, \"\");\n}\n\n/**\n * @param {string} summary\n * @param {string} date\n * @param {string} time\n * @param {string} sessionKey\n * @returns {Promise<void>}\n */\nasync function writeSummaryFile(summary, date, time, sessionKey) {\n  const slug = slugFromSummary(summary, time);\n  const filename = `${date}-${slug}.md`;\n  const filePath = path.join(MEMORY_DIR, filename);\n\n  await fs.promises.mkdir(MEMORY_DIR, { recursive: true });\n\n  const fullContent = [\n    `# Session: ${date} ${time}`,\n    \"\",\n    \"<!-- summary-only -->\",\n    summary,\n    \"\",\n    `<!-- source: ${sessionKey} -->`,\n  ].join(\"\\n\");\n\n  await fs.promises.writeFile(filePath, fullContent, \"utf-8\");\n  console.log(`[session-summary] Written: ${filename}`);\n}\n\n// ─── Core ───────────────────────────────────────────────────────────────────\n\n/**\n * @param {{ type: string, action: string, sessionKey: string, context: HookContext, messages: unknown[] }} event\n */\nasync function run(event) {\n  const isTarget = event.type === \"command\" && (event.action === \"new\" || event.action === \"reset\");\n  if (!isTarget) return;\n\n  const now = new Date();\n  const date = now.toISOString().split(\"T\")[0];\n  const time = now.toISOString().split(\"T\")[1].split(\".\")[0].slice(0, 5);\n\n  // 1. 解析 session 文件路径（优先 previousSessionEntry）\n  const sessionFile = resolveSessionFile(event.context || {});\n\n  // 2. 读取消息内容\n  const content = sessionFile ? await extractMessages(sessionFile) : \"\";\n\n  // 3. 生成摘要（失败则降级）\n  const summary =\n    content.trim().length > 50\n      ? await generateSummary(content).then((t) => t || buildFallbackSummary(content, date, time))\n      : buildFallbackSummary(content || \"(无会话内容)\", date, time);\n\n  // 4. 写入 memory/（后台，不等待）\n  writeSummaryFile(summary, date, time, event.sessionKey).catch((err) => {\n    console.error(\"[session-summary] Write error:\", err);\n  });\n}\n\n// ─── Entry Point ─────────────────────────────────────────────────────────────\n\nexport default function handler(event) {\n  run(event).catch((err) => {\n    console.error(\"[session-summary] Uncaught error:\", err);\n  });\n}\n"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":92699,"output":3573,"cacheRead":17776,"cacheWrite":0,"totalTokens":114048,"cost":{"input":0.0278097,"output":0.0042876,"cacheRead":0.0010665599999999998,"cacheWrite":0,"total":0.03316386}},"stopReason":"toolUse","timestamp":1776018392635,"responseId":"062b16d884022c00286e8b32e98f2652"}}
