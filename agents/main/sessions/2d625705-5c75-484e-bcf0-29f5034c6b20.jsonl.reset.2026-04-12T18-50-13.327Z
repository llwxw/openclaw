{"type":"message","id":"ee2efc48","parentId":"0ab29d39","timestamp":"2026-04-12T18:22:43.248Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me write the HOOK.md file.","thinkingSignature":"25fa371f74714214b2e187dc02d00e2604a54fb294675aa7522ac282cd587b21"},{"type":"toolCall","id":"call_function_kn3fkceki4q6_1","name":"write","arguments":{"path":"/home/ai/.openclaw/hooks/session-summary/HOOK.md","content":"---\nname: session-summary\ndescription: \"session 结束时（/new 或 /reset）生成结构化摘要，写入 memory/，供下次 bootstrap 读取。依赖 context.previousSessionEntry.sessionFile 读取刚结束的 session 内容。\"\nmetadata:\n  {\n    \"openclaw\": {\n      \"emoji\": \"📝\",\n      \"events\": [\"command:new\", \"command:reset\"],\n      \"requires\": {\n        \"bins\": [\"node\"],\n        \"config\": [\"workspace.dir\"]\n      },\n      \"always\": true\n    }\n  }\n---\n\n# session-summary\n\n每次 `/new` 或 `/reset` 触发时，异步生成刚结束 session 的结构化摘要。\n\n## 行为\n\n- **异步执行**：hook 立即返回，摘要生成在后台，不阻塞命令响应\n- **降级策略**：LLM 不可用或生成失败时，写入规则摘要，不报错不中断\n- **文件格式**：`memory/YYYY-MM-DD-{slug}.md`，带 `<!-- summary-only -->` 标记\n\n## 摘要格式\n\n```markdown\n# Session: {date} {time}\n\n## 主题\n{一句话概括}\n\n## 关键决策\n- {决策1}\n- {决策2}（无则省略）\n\n## 重要发现\n- {发现1}\n- {发现2}（无则省略）\n\n## 待跟进\n- {事项1}\n- {事项2}（无则省略）\n```\n\n## LLM 调用\n\n通过 v8 Router (3102) 调用 LLM 生成摘要，超时 20s。\n\n## Bootstrap 读取\n\nsession 启动时，扫描 `memory/` 下最新摘要文件（按修改时间），读入作为上下文。\n"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":88161,"output":409,"cacheRead":17776,"cacheWrite":0,"totalTokens":106346,"cost":{"input":0.026448299999999998,"output":0.0004908,"cacheRead":0.0010665599999999998,"cacheWrite":0,"total":0.028005659999999998}},"stopReason":"toolUse","timestamp":1776018153348,"responseId":"062b15e9b388410b40550a44b7537c99"}}
{"type":"message","id":"d2ef8c96","parentId":"ee2efc48","timestamp":"2026-04-12T18:22:43.337Z","message":{"role":"toolResult","toolCallId":"call_function_kn3fkceki4q6_1","toolName":"write","content":[{"type":"text","text":"Successfully wrote 895 bytes to /home/ai/.openclaw/hooks/session-summary/HOOK.md"}],"isError":false,"timestamp":1776018163327}}
{"type":"message","id":"3903b37f","parentId":"d2ef8c96","timestamp":"2026-04-12T18:23:22.545Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Good. Now let me write the handler.js. I'll use clean ESM JavaScript with JSDoc annotations.","thinkingSignature":"d327121242974f2569c1eb69441bc25436d91fcbc09ef6c36fe2b05a0e403a8f"},{"type":"text","text":"**Step 6：实现 handler.js**\n"},{"type":"toolCall","id":"call_function_yfyavod0qdc4_1","name":"write","arguments":{"path":"/home/ai/.openclaw/hooks/session-summary/handler.js","content":"/**\n * session-summary hook\n *\n * 触发时机: /new 或 /reset\n * 行为: 读取上一个 session 的内容，调 LLM 生成结构化摘要，写入 memory/\n * 降级: LLM 失败时写规则摘要，不报错\n */\n\nimport fs from \"node:fs\";\nimport path from \"node:path\";\nimport os from \"node:os\";\nimport http from \"node:http\";\n\n// ─── Constants ────────────────────────────────────────────────────────────────\n\nconst WORKSPACE_DIR = process.env.OPENCLAW_WORKSPACE_DIR ||\n  path.join(os.homedir(), \".openclaw\", \"workspace\");\n\nconst MEMORY_DIR = path.join(WORKSPACE_DIR, \"memory\");\n\n/** LLM 超时 (ms) */\nconst LLM_TIMEOUT_MS = 20_000;\n\n// ─── Types (JSDoc) ───────────────────────────────────────────────────────────\n\n/**\n * @typedef {Object} SessionEntry\n * @property {string} [sessionFile]\n * @property {string} [sessionId]\n */\n\n/**\n * @typedef {Object} HookContext\n * @property {SessionEntry} [previousSessionEntry]\n * @property {SessionEntry} [sessionEntry]\n */\n\n// ─── Session File Lookup ──────────────────────────────────────────────────────\n\n/**\n * 解析 sessionKey 格式: agent:{agentId}:{requestKey}\n * 尝试在 sessionsDir 下找匹配的 .jsonl 文件\n * @param {string} sessionsDir\n * @param {string} sessionKey\n * @returns {string|null}\n */\nfunction resolveSessionFile(sessionsDir, sessionKey) {\n  const parts = sessionKey.split(\":\");\n  if (parts.length < 3) return null;\n  const requestKey = parts[2];\n  if (!requestKey) return null;\n\n  try {\n    const files = fs.readdirSync(sessionsDir);\n    // 精确匹配 requestKey.jsonl\n    const exact = files.find((f) => f === `${requestKey}.jsonl`);\n    if (exact) return path.join(sessionsDir, exact);\n    // topic 变体\n    const topic = files.find(\n      (f) => f.startsWith(`${requestKey}-topic-`) && f.endsWith(\".jsonl\")\n    );\n    if (topic) return path.join(sessionsDir, topic);\n    // .reset. 备份文件\n    const reset = files\n      .filter((f) => f.startsWith(requestKey) && f.includes(\".reset.\") && f.endsWith(\".jsonl\"))\n      .sort()\n      .pop();\n    if (reset) return path.join(sessionsDir, reset);\n    return null;\n  } catch {\n    return null;\n  }\n}\n\n/**\n * 从 context 中提取 sessionFile 路径。\n * 优先用 previousSessionEntry（旧 session），降级用 sessionEntry（新 session）。\n * @param {HookContext} context\n * @param {string} workspaceDir\n * @param {string} sessionKey\n * @returns {string|null}\n */\nfunction getSessionFile(context, workspaceDir, sessionKey) {\n  const prev = context?.previousSessionEntry;\n  if (prev?.sessionFile) return prev.sessionFile;\n\n  const curr = context?.sessionEntry;\n  if (curr?.sessionFile) return curr.sessionFile;\n\n  // 兜底: 在 sessionsDir 下搜索\n  const sessionsDir = path.join(workspaceDir, \"sessions\");\n  if (fs.existsSync(sessionsDir)) {\n    return resolveSessionFile(sessionsDir, sessionKey);\n  }\n  return null;\n}\n\n// ─── Message Extraction ──────────────────────────────────────────────────────\n\n/**\n * 从 .jsonl 中提取最新 N 条 user/assistant 消息。\n * @param {string} filePath\n * @param {number} [messageCount=40]\n * @returns {Promise<string>} 空字符串表示读取失败\n */\nasync function extractMessages(filePath, messageCount = 40) {\n  try {\n    const content = await fs.promises.readFile(filePath, \"utf-8\");\n    const lines = content.trim().split(\"\\n\").slice(-messageCount * 2);\n    /** @type {string[]} */\n    const messages = [];\n\n    for (const line of lines) {\n      try {\n        /** @type {{ type: string, message?: { role: string, content: unknown } }} */\n        const entry = JSON.parse(line);\n        if (entry.type !== \"message\") continue;\n        const msg = entry.message;\n        if (!msg?.role || !msg?.content) continue;\n        if (msg.role !== \"user\" && msg.role !== \"assistant\") continue;\n\n        const text =\n          typeof msg.content === \"string\"\n            ? msg.content\n            : extractTextFromBlocks(msg.content);\n\n        if (!text || text.startsWith(\"/\")) continue;\n        messages.push(`${msg.role}: ${text}`);\n      } catch {\n        // skip malformed lines\n      }\n    }\n    return messages.slice(-messageCount).join(\"\\n\");\n  } catch {\n    return \"\";\n  }\n}\n\n/**\n * 从 content blocks 中提取 text。\n * @param {unknown} content\n * @returns {string}\n */\nfunction extractTextFromBlocks(content) {\n  if (Array.isArray(content)) {\n    for (const block of content) {\n      if (\n        block &&\n        typeof block === \"object\" &&\n        block.type === \"text\" &&\n        typeof block.text === \"string\"\n      ) {\n        return block.text;\n      }\n    }\n  }\n  return \"\";\n}\n\n// ─── LLM Summary Generation ───────────────────────────────────────────────────\n\n/**\n * 调用 v8 Router LLM 接口生成摘要。\n * @param {string} sessionContent\n * @returns {Promise<string>} 空字符串表示失败\n */\nasync function generateSummary(sessionContent) {\n  return new Promise((resolve) => {\n    const prompt = buildSummaryPrompt(sessionContent);\n    const postData = JSON.stringify({\n      model: \"minimax/MiniMax-M2.7\",\n      messages: [{ role: \"user\", content: prompt }],\n      temperature: 0.3,\n      max_tokens: 600,\n    });\n\n    const req = http.request(\n      \"http://127.0.0.1:3102/v1/chat/completions\",\n      {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          \"Content-Length\": Buffer.byteLength(postData),\n        },\n      },\n      (res) => {\n        let data = \"\";\n        res.on(\"data\", (c) => (data += c));\n        res.on(\"end\", () => {\n          try {\n            const parsed = JSON.parse(data);\n            const text = parsed.choices?.[0]?.message?.content;\n            resolve(text?.trim() ?? \"\");\n          } catch {\n            resolve(\"\");\n          }\n        });\n      }\n    );\n\n    req.on(\"error\", () => resolve(\"\"));\n    req.on(\"timeout\", () => {\n      req.destroy();\n      resolve(\"\");\n    });\n\n    req.write(postData);\n    req.end();\n\n    setTimeout(() => {\n      try { req.destroy(); } catch { /* ignore */ }\n      resolve(\"\");\n    }, LLM_TIMEOUT_MS);\n  });\n}\n\n/**\n * @param {string} sessionContent\n * @returns {string}\n */\nfunction buildSummaryPrompt(sessionContent) {\n  return `你是一个会话摘要生成器。\n给定以下对话记录，生成一个结构化摘要。\n\n要求：\n- 主题：一句话概括本次对话主题（少于20字）\n- 关键决策：列出做出的所有决策，如果没有则写\"无明确决策\"\n- 重要发现：列出任何重要信息或结论，如果没有则写\"无\"\n- 待跟进：列出任何未完成或需要后续处理的事项，如果没有则写\"无\"\n\n格式（严格按此格式，只输出内容，不输出说明）：\n## 主题\n{主题}\n\n## 关键决策\n{决策列表}\n\n## 重要发现\n{发现列表}\n\n## 待跟进\n{待办列表}\n\n对话记录：\n${sessionContent}`;\n}\n\n// ─── Fallback Summary ────────────────────────────────────────────────────────\n\n/**\n * @param {string} content\n * @param {string} date\n * @param {string} time\n * @returns {string}\n */\nfunction buildFallbackSummary(content, date, time) {\n  const firstLine = content.split(\"\\n\")[0] ?? \"\";\n  const preview = firstLine.slice(0, 60).replace(/[#*]/g, \"\").trim() || \"会话摘要\";\n  return `# Session: ${date} ${time}\n\n## 主题\n${preview}\n\n## 关键决策\n无\n\n## 重要发现\n无\n\n## 待跟进\n见原始对话记录\n`;\n}\n\n// ─── File Writing ────────────────────────────────────────────────────────────\n\n/**\n * 从摘要文本中提取 slug。\n * @param {string} summary\n * @param {string} time\n * @returns {string}\n */\nfunction extractSlug(summary, time) {\n  const match = summary.match(/^## 主题$\\s*([^\\n]+)/m);\n  if (!match) return time.replace(/:/g, \"\");\n\n  return match[1]\n    .toLowerCase()\n    .replace(/[^a-z0-9\\u4e00-\\u9fff]+/g, \"-\")\n    .replace(/^-+|-+$/g, \"\")\n    .slice(0, 40) || time.replace(/:/g, \"\");\n}\n\n/**\n * 写摘要到 memory/ 目录。\n * @param {string} summary\n * @param {string} date\n * @param {string} time\n * @param {string} sessionKey\n */\nasync function writeSummaryFile(summary, date, time, sessionKey) {\n  const slug = extractSlug(summary, time);\n  const filename = `${date}-${slug}.md`;\n  const filePath = path.join(MEMORY_DIR, filename);\n\n  await fs.promises.mkdir(MEMORY_DIR, { recursive: true });\n\n  const fullContent = [\n    `# Session: ${date} ${time}`,\n    \"\",\n    \"<!-- summary-only -->\",\n    summary,\n    \"\",\n    `<!-- source: ${sessionKey} -->`,\n  ].join(\"\\n\");\n\n  await fs.promises.writeFile(filePath, fullContent, \"utf-8\");\n  console.log(`[session-summary] Written: ${filename}`);\n}\n\n// ─── Core ────────────────────────────────────────────────────────────────────\n\n/**\n * @param {{ type: string, action: string, sessionKey: string, context: HookContext, messages: unknown[] }} event\n */\nasync function run(event) {\n  const isResetCommand = event.type === \"command\" && (event.action === \"new\" || event.action === \"reset\");\n  if (!isResetCommand) return;\n\n  const now = new Date();\n  const date = now.toISOString().split(\"T\")[0];\n  const time = now.toISOString().split(\"T\")[1].split(\".\")[0].slice(0, 5);\n\n  // 1. 找 session 文件\n  const workspaceDir =\n    event.context?.sessionEntry?.sessionFile\n      ? path.dirname(event.context.sessionEntry.sessionFile)\n      : WORKSPACE_DIR;\n\n  const sessionFile = getSessionFile(event.context || {}, workspaceDir, event.sessionKey);\n\n  // 2. 读内容\n  const content = sessionFile\n    ? await extractMessages(sessionFile)\n    : \"\";\n\n  // 3. 生摘要\n  let summary;\n  if (content && content.trim().length > 50) {\n    const llmText = await generateSummary(content);\n    summary = llmText || buildFallbackSummary(content, date, time);\n  } else {\n    summary = buildFallbackSummary(content || \"(无会话内容)\", date, time);\n  }\n\n  // 4. 写文件（后台，不等待）\n  writeSummaryFile(summary, date, time, event.sessionKey).catch((err) => {\n    console.error(\"[session-summary] Write error:\", err);\n  });\n}\n\n// ─── Entry Point ─────────────────────────────────────────────────────────────\n\n/** @type {{ default: (event: unknown) => Promise<void> }} */\nconst mod = {\n  default: (event) => {\n    // 不 await，fire-and-forget\n    run(/** @type {import(\"./types\").HookEvent} */ (event)).catch((err) => {\n      console.error(\"[session-summary] Uncaught error:\", err);\n    });\n  },\n};\n\nexport default mod.default;\n"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":88608,"output":2667,"cacheRead":17776,"cacheWrite":0,"totalTokens":109051,"cost":{"input":0.0265824,"output":0.0032004,"cacheRead":0.0010665599999999998,"cacheWrite":0,"total":0.03084936}},"stopReason":"toolUse","timestamp":1776018163341,"responseId":"062b15f3ebc7479db44adc2744aea7aa"}}
