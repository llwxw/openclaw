{"type":"message","id":"f0e4ec43","parentId":"501d74f0","timestamp":"2026-04-05T18:52:54.215Z","message":{"role":"toolResult","toolCallId":"019d5efcf9f6e2063231cb9ca9bb6fb0","toolName":"read","content":[{"type":"text","text":"const express = require('express');\nconst { createProxyMiddleware } = require('http-proxy-middleware');\nconst { computeFineScore, getExecutionPlan } = require('./scoring');\nconst { detectIntent } = require('./intentDetector');\n\nconst GATEWAY_URL = process.env.OPENCLAW_GATEWAY || 'http://127.0.0.1:18789';\nconst PORT = process.env.ROUTER_PORT || 3102;\n\nconst app = express();\napp.use(express.json());\n\napp.get('/health', (req, res) => res.json({ status: 'ok', service: 'task-orchestrator' }));\n\n// 获取评分\napp.get('/api/score', async (req, res) => {\n  const taskSpec = req.query.task || '';\n  const score = await computeFineScore(taskSpec);\n  const plan = getExecutionPlan(score.totalScore, score.factors?.scaleIndex || 1);\n  res.json({ score, plan });\n});\n\n// 任务拦截端点 - 评分后返回计划\napp.post('/api/task', async (req, res) => {\n  const taskSpec = req.body?.taskSpec || '';\n  if (taskSpec) {\n    const score = await computeFineScore(taskSpec);\n    const plan = getExecutionPlan(score.totalScore, score.factors?.scaleIndex || 1);\n    console.log(`[Router] Task scored: ${score.totalScore} → ${plan.mode}`);\n    res.json({ \n      taskSpec, \n      score: score.totalScore,\n      routing: plan,\n      message: 'Task scored, ready to execute'\n    });\n  } else {\n    res.status(400).json({ error: 'Missing taskSpec' });\n  }\n});\n\n// 意图判断端点\napp.post('/api/intent', async (req, res) => {\n  const { message, conversationId } = req.body;\n  const memoryStore = global.vectorMemory || null;\n  const result = await detectIntent(message, conversationId, memoryStore);\n  res.json(result);\n});\n\n// 对话路径拦截 - 意图判断 + 任务评分\napp.post('/api/chat/send', async (req, res, next) => {\n  const userMessage = req.body.message || req.body.text || req.body.content;\n  if (!userMessage) return next();\n  \n  const convId = req.body.conversationId || req.body.sessionId;\n  const memoryStore = global.vectorMemory || null;\n  \n  // 同步快速判断\n  const { isTask, confidence } = await detectIntent(userMessage, convId, memoryStore);\n  \n  if (isTask && confidence > 0.5) {\n    // 触发任务评分\n    const score = await computeFineScore(userMessage);\n    const plan = getExecutionPlan(score.totalScore, score.factors?.scaleIndex || 1);\n    console.log(`[Router] 检测到任务: \"${userMessage.slice(0,30)}...\" → 评分 ${score.totalScore} → ${plan.mode}`);\n    req.body.taskRouting = plan;\n  }\n  \n  next();\n});\n\n// 代理到 Gateway\napp.use('/', createProxyMiddleware({ \n  target: GATEWAY_URL, \n  changeOrigin: true,\n  onError: (err, req, res) => {\n    res.status(502).json({ error: 'Gateway unavailable', message: err.message });\n  }\n}));\n\napp.listen(PORT, () => console.log(`Router on ${PORT} → ${GATEWAY_URL}`));\nconsole.log('[Router] Task Orchestrator v3.0 ready - scoring enabled - intent detection enabled');"}],"isError":false,"timestamp":1775415174203}}
{"type":"message","id":"efa8dff8","parentId":"f0e4ec43","timestamp":"2026-04-05T18:53:08.166Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"问题是 `app.use('/', ...)` 会匹配所有路径，包括 `/api/score`, `/api/intent`, `/api/chat/send`。但实际上 Express 的路由匹配是按顺序的，所以 `/api/score` 等具体路由会先匹配，但 `/api/chat/send` 会被拦截并添加 `taskRouting`，然后转发。\n\n这个配置应该是正确的：\n1. `/api/score` - 本地处理\n2. `/api/intent` - 本地处理\n3. `/api/chat/send` - 拦截处理 + 转发到 Gateway4. 其他请求 - 直接转发到 Gateway现在中间件会：1. 接收对话请求2. 在 `/api/chat/send` 路径进行意图判断 + 评分3. 转发到 Gateway (18789)\n\n这正是用户想要的！只需要重启服务即可。\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n配置已完整！中间件会：\n1. 拦截 `/api/chat/send` → 意图判断 + 评分 → 转发 Gateway\n2. 其他路径直接转发\n\n**重启后生效：**\n\n```bash\nsudo systemctl restart openclaw-gateway\nsudo systemctl restart openclaw-router\n```\n\n重启后所有对话请求都会经过意图判断 + 评分。"}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":1081,"output":254,"cacheRead":103168,"cacheWrite":0,"totalTokens":104503,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"stop","timestamp":1775415174218,"responseId":"019d5efd017f5b0cde7e2d9ed8b27879"}}
