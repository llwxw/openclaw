{"type":"message","id":"1c5d303f","parentId":"bc33148f","timestamp":"2026-04-06T05:04:12.353Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"继续创建 logger.ts 和 queue.ts。\n\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"019d612c8011a239545c8edfc5f7dd6e","name":"exec","arguments":{"command":"# logger.ts\ncat > ~/openclaw-listener/src/logger.ts << 'EOF'\nimport pino from 'pino';\nimport { LoggingConfig } from './types';\n\nlet rootLogger: pino.Logger | null = null;\n\nexport function createLogger(config: LoggingConfig): pino.Logger {\n  if (rootLogger) return rootLogger;\n\n  const transport = config.file\n    ? pino.destination({ dest: config.file, sync: false, mkdir: true })\n    : undefined;\n\n  const logger = pino(\n    {\n      level: config.level,\n      formatters: {\n        level: (label) => ({ level: label }),\n      },\n      timestamp: pino.stdTimeFunctions.isoTime,\n    },\n    transport\n  );\n\n  if (config.file) {\n    const consoleStream = pino.destination(1);\n    logger.add(consoleStream);\n  }\n\n  rootLogger = logger;\n  return logger;\n}\n\nexport function getLogger(): pino.Logger {\n  if (!rootLogger) throw new Error('Logger not initialized. Call createLogger first.');\n  return rootLogger;\n}\nEOF\necho \"✅ logger.ts\""}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":7288,"output":258,"cacheRead":129152,"cacheWrite":0,"totalTokens":136698,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775451837188,"responseId":"019d612c7076d4ce329e9e98d0f834ff"}}
