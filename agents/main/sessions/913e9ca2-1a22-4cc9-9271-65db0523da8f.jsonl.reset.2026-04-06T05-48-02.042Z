{"type":"message","id":"896a470b","parentId":"34818a24","timestamp":"2026-04-05T18:43:38.572Z","message":{"role":"toolResult","toolCallId":"019d5ef51ee070eaa2fc91428f30d098","toolName":"read","content":[{"type":"text","text":"const express = require('express');\nconst { createProxyMiddleware } = require('http-proxy-middleware');\nconst { computeFineScore, getExecutionPlan } = require('./scoring');\n\nconst GATEWAY_URL = process.env.OPENCLAW_GATEWAY || 'http://localhost:3000';\nconst PORT = process.env.ROUTER_PORT || 3102;\n\nconst app = express();\napp.use(express.json());\n\napp.get('/health', (req, res) => res.json({ status: 'ok', service: 'task-orchestrator' }));\n\n// 获取评分\napp.get('/api/score', async (req, res) => {\n  const taskSpec = req.query.task || '';\n  const score = await computeFineScore(taskSpec);\n  const plan = getExecutionPlan(score.totalScore, score.factors?.scaleIndex || 1);\n  res.json({ score, plan });\n});\n\n// 任务拦截端点 - 评分后返回计划\napp.post('/api/task', async (req, res) => {\n  const taskSpec = req.body?.taskSpec || '';\n  if (taskSpec) {\n    const score = await computeFineScore(taskSpec);\n    const plan = getExecutionPlan(score.totalScore, score.factors?.scaleIndex || 1);\n    console.log(`[Router] Task scored: ${score.totalScore} → ${plan.mode}`);\n    res.json({ \n      taskSpec, \n      score: score.totalScore,\n      routing: plan,\n      message: 'Task scored, ready to execute'\n    });\n  } else {\n    res.status(400).json({ error: 'Missing taskSpec' });\n  }\n});\n\n// 代理到 Gateway\napp.use('/', createProxyMiddleware({ \n  target: GATEWAY_URL, \n  changeOrigin: true,\n  onError: (err, req, res) => {\n    res.status(502).json({ error: 'Gateway unavailable', message: err.message });\n  }\n}));\n\napp.listen(PORT, () => console.log(`Router on ${PORT} → ${GATEWAY_URL}`));\nconsole.log('[Router] Task Orchestrator v3.0 ready - scoring enabled');"}],"isError":false,"timestamp":1775414618566}}
{"type":"message","id":"a17b8697","parentId":"896a470b","timestamp":"2026-04-05T18:43:51.451Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在更新 router 来集成意图判断。我需要添加对 /api/chat/send 的拦截来检测意图。\n\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"call_7fcea7a35ab14b7faf9c4d47","name":"write","arguments":{"content":"const express = require('express');\nconst { createProxyMiddleware } = require('http-proxy-middleware');\nconst { computeFineScore, getExecutionPlan } = require('./scoring');\nconst { detectIntent } = require('./intentDetector');\n\nconst GATEWAY_URL = process.env.OPENCLAW_GATEWAY || 'http://127.0.0.1:18789';\nconst PORT = process.env.ROUTER_PORT || 3102;\n\nconst app = express();\napp.use(express.json());\n\napp.get('/health', (req, res) => res.json({ status: 'ok', service: 'task-orchestrator' }));\n\n// 获取评分\napp.get('/api/score', async (req, res) => {\n  const taskSpec = req.query.task || '';\n  const score = await computeFineScore(taskSpec);\n  const plan = getExecutionPlan(score.totalScore, score.factors?.scaleIndex || 1);\n  res.json({ score, plan });\n});\n\n// 任务拦截端点 - 评分后返回计划\napp.post('/api/task', async (req, res) => {\n  const taskSpec = req.body?.taskSpec || '';\n  if (taskSpec) {\n    const score = await computeFineScore(taskSpec);\n    const plan = getExecutionPlan(score.totalScore, score.factors?.scaleIndex || 1);\n    console.log(`[Router] Task scored: ${score.totalScore} → ${plan.mode}`);\n    res.json({ \n      taskSpec, \n      score: score.totalScore,\n      routing: plan,\n      message: 'Task scored, ready to execute'\n    });\n  } else {\n    res.status(400).json({ error: 'Missing taskSpec' });\n  }\n});\n\n// 意图判断端点\napp.post('/api/intent', async (req, res) => {\n  const { message, conversationId } = req.body;\n  const memoryStore = global.vectorMemory || null;\n  const result = await detectIntent(message, conversationId, memoryStore);\n  res.json(result);\n});\n\n// 对话路径拦截 - 意图判断 + 任务评分\napp.post('/api/chat/send', async (req, res, next) => {\n  const userMessage = req.body.message || req.body.text || req.body.content;\n  if (!userMessage) return next();\n  \n  const convId = req.body.conversationId || req.body.sessionId;\n  const memoryStore = global.vectorMemory || null;\n  \n  // 同步快速判断\n  const { isTask, confidence } = await detectIntent(userMessage, convId, memoryStore);\n  \n  if (isTask && confidence > 0.5) {\n    // 触发任务评分\n    const score = await computeFineScore(userMessage);\n    const plan = getExecutionPlan(score.totalScore, score.factors?.scaleIndex || 1);\n    console.log(`[Router] 检测到任务: \"${userMessage.slice(0,30)}...\" → 评分 ${score.totalScore} → ${plan.mode}`);\n    req.body.taskRouting = plan;\n  }\n  \n  next();\n});\n\n// 代理到 Gateway\napp.use('/', createProxyMiddleware({ \n  target: GATEWAY_URL, \n  changeOrigin: true,\n  onError: (err, req, res) => {\n    res.status(502).json({ error: 'Gateway unavailable', message: err.message });\n  }\n}));\n\napp.listen(PORT, () => console.log(`Router on ${PORT} → ${GATEWAY_URL}`));\nconsole.log('[Router] Task Orchestrator v3.0 ready - scoring enabled - intent detection enabled');","path":"/home/ai/openclaw-router/openclaw-router.js"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":95259,"output":814,"cacheRead":0,"cacheWrite":0,"totalTokens":96073,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775414618574,"responseId":"chatcmpl-75668224-a985-4e01-b85c-5737f68eadf1"}}
