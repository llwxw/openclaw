{"type":"message","id":"d94da9f3","parentId":"07a81fc3","timestamp":"2026-04-06T05:07:04.156Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在创建 main.ts。\n\n\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"call_646dd3a1825344258ba80de5","name":"exec","arguments":{"command":"# main.ts\ncat > ~/openclaw-listener/src/main.ts << 'EOF'\nimport { loadConfig } from './config';\nimport { createLogger } from './logger';\nimport { MessageQueue } from './queue';\nimport { ApiClient } from './apiClient';\nimport { GatewayClient } from './gatewayClient';\nimport { MessageHandler } from './messageHandler';\nimport { HealthServer } from './healthServer';\n\nasync function main() {\n  const config = loadConfig();\n  const logger = createLogger(config.logging);\n  logger.info({ version: '2.0.0' }, 'Starting OpenClaw Listener');\n\n  const queue = config.behavior.queueEnabled\n    ? new MessageQueue(config.behavior.queueDbPath, config.behavior.batchSize, config.behavior.batchIntervalMs)\n    : null;\n  const apiClient = new ApiClient(config.api);\n  const gatewayClient = new GatewayClient(config.gateway);\n  const messageHandler = new MessageHandler(apiClient, queue, config, gatewayClient);\n\n  let healthServer: HealthServer | null = null;\n  if (config.health.enabled) {\n    healthServer = new HealthServer(config.health.port, config.health.endpoint, () => ({\n      connected: gatewayClient.isConnected(),\n      queueSize: queue ? (queue as any).buffer?.length ?? 0 : 0,\n      reconnectAttempts: gatewayClient.getReconnectAttempts(),\n    }));\n    healthServer.start();\n  }\n\n  gatewayClient.on('open', async () => {\n    logger.info('Gateway connected, replaying queued messages');\n    if (queue) await messageHandler.replayQueuedMessages();\n  });\n\n  gatewayClient.on('message', async (data: Buffer) => {\n    try {\n      const parsed = JSON.parse(data.toString());\n      if (parsed.type === 'message') {\n        const msgData = parsed.data || parsed;\n        await messageHandler.handle(msgData);\n      } else {\n        logger.trace({ parsed }, 'Ignoring non-message type');\n      }\n    } catch (err) {\n      logger.error({ err, raw: data.toString().slice(0, 200) }, 'Failed to parse message');\n      if (queue) queue.enqueue(data.toString());\n    }\n  });\n\n  gatewayClient.on('error', (err) => {\n    logger.error({ err }, 'Gateway WebSocket error');\n  });\n\n  gatewayClient.on('close', (code, reason) => {\n    logger.warn({ code, reason: reason?.toString() }, 'Gateway connection closed');\n  });\n\n  gatewayClient.connect();\n\n  const shutdown = async () => {\n    logger.info('Shutting down...');\n    gatewayClient.close();\n    if (queue) await queue.close();\n    if (healthServer) await healthServer.stop();\n    process.exit(0);\n  };\n  process.on('SIGTERM', shutdown);\n  process.on('SIGINT', shutdown);\n}\n\nmain().catch((err) => {\n  console.error('Fatal error:', err);\n  process.exit(1);\n});\nEOF\necho \"✅ main.ts\""}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":140338,"output":652,"cacheRead":0,"cacheWrite":0,"totalTokens":140990,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775452011175,"responseId":"chatcmpl-ba70b0a0-b069-4c30-9f24-d133e056a06e"}}
