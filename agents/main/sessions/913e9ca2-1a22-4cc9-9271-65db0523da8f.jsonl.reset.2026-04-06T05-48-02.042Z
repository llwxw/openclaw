{"type":"message","id":"1bb9d089","parentId":"7920caa8","timestamp":"2026-04-05T15:19:31.377Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Actually the middleware approach won't work easily because scoreTask needs to be async. Let me rewrite the router more cleanly.\n\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"call_ddcebe56e62d4218b9253ae7","name":"write","arguments":{"content":"const express = require('express');\nconst { createProxyMiddleware } = require('http-proxy-middleware');\nconst { computeFineScore, getExecutionPlan } = require('./scoring');\n\nconst GATEWAY_URL = process.env.OPENCLAW_GATEWAY || 'http://localhost:3000';\nconst PORT = process.env.ROUTER_PORT || 3102;\n\nconst app = express();\napp.use(express.json());\n\napp.get('/health', (req, res) => res.json({ status: 'ok', service: 'task-orchestrator' }));\n\n// 获取评分\napp.get('/api/score', async (req, res) => {\n  const taskSpec = req.query.task || '';\n  const score = await computeFineScore(taskSpec);\n  const plan = getExecutionPlan(score.totalScore, score.factors?.scaleIndex || 1);\n  res.json({ score, plan });\n});\n\n// 任务拦截端点 - 评分后返回计划\napp.post('/api/task', async (req, res) => {\n  const taskSpec = req.body?.taskSpec || '';\n  if (taskSpec) {\n    const score = await computeFineScore(taskSpec);\n    const plan = getExecutionPlan(score.totalScore, score.factors?.scaleIndex || 1);\n    console.log(`[Router] Task scored: ${score.totalScore} → ${plan.mode}`);\n    res.json({ \n      taskSpec, \n      score: score.totalScore,\n      routing: plan,\n      message: 'Task scored, ready to execute'\n    });\n  } else {\n    res.status(400).json({ error: 'Missing taskSpec' });\n  }\n});\n\n// 代理到 Gateway\napp.use('/', createProxyMiddleware({ \n  target: GATEWAY_URL, \n  changeOrigin: true,\n  onError: (err, req, res) => {\n    res.status(502).json({ error: 'Gateway unavailable', message: err.message });\n  }\n}));\n\napp.listen(PORT, () => console.log(`Router on ${PORT} → ${GATEWAY_URL}`));\nconsole.log('[Router] Task Orchestrator v3.0 ready - scoring enabled');","path":"/home/ai/openclaw-router/openclaw-router.js"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":43618,"output":510,"cacheRead":0,"cacheWrite":0,"totalTokens":44128,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775402364000,"responseId":"chatcmpl-edc3212c-4a53-4507-860e-9850945a1938"}}
