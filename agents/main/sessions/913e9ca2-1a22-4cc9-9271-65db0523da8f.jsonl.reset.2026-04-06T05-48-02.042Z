echo \"【5. 前端连接】\"\necho \"━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\"\nss -tnp | grep 3103 | wc -l | xargs echo \"  3103 连接数:\"\n\necho \"\"\necho \"═══════════════════════════════════════════════════════\""}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":111856,"output":550,"cacheRead":0,"cacheWrite":0,"totalTokens":112406,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775449593025,"responseId":"chatcmpl-d2601674-429c-44b3-a817-e8592afad71f"}}
{"type":"message","id":"de158929","parentId":"6f09b3e2","timestamp":"2026-04-06T04:26:44.302Z","message":{"role":"toolResult","toolCallId":"call_6fa3a570189343589675b4ba","toolName":"exec","content":[{"type":"text","text":"╔══════════════════════════════════════════════════════╗\n║           当前系统完整状态检查                       ║\n╚══════════════════════════════════════════════════════╝\n\n【1. 端口监听状态】\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n  *:3101 → \n  *:3102 → \n  *:3104 → \n  127.0.0.1:3103 → \n  [::1]:3103 → \n\n【2. 进程状态】\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n  /home/ai/.nvm/versions/node/v22.22.1/bin/node PID=450 PORT=/home/ai/openclaw-router/context-api.js\n  /home/ai/.nvm/versions/node/v22.22.1/bin/node PID=452 PORT=/home/ai/openclaw-router/openclaw-router.js\n  openclaw-gateway PID=3881 PORT=openclaw-gateway\n  /home/ai/.nvm/versions/node/v22.22.1/bin/node PID=4338 PORT=/home/ai/openclaw-router/ws-proxy.js\n\n【3. 服务配置】\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nGateway 端口配置: \"port\":3103\nGateway 启动参数: port 3103\nWebSocket 代理: Environment=\"PROXY_WS_PORT=3103\"\n\n【4. API 测试】\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n  意图判断 (3102): error\n  评分 (3102): STEP_ARCHIVE\n  健康检查 (3104): ok\n\n【5. 前端连接】\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n  3103 连接数: 2\n\n═══════════════════════════════════════════════════════"}],"details":{"status":"completed","exitCode":0,"durationMs":108,"aggregated":"╔══════════════════════════════════════════════════════╗\n║           当前系统完整状态检查                       ║\n╚══════════════════════════════════════════════════════╝\n\n【1. 端口监听状态】\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n  *:3101 → \n  *:3102 → \n  *:3104 → \n  127.0.0.1:3103 → \n  [::1]:3103 → \n\n【2. 进程状态】\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n  /home/ai/.nvm/versions/node/v22.22.1/bin/node PID=450 PORT=/home/ai/openclaw-router/context-api.js\n  /home/ai/.nvm/versions/node/v22.2