{"type":"message","id":"0db51541","parentId":"ea594940","timestamp":"2026-04-05T14:58:57.409Z","message":{"role":"user","content":[{"type":"text","text":"Sender (untrusted metadata):\n```json\n{\n  \"label\": \"openclaw-control-ui\",\n  \"id\": \"openclaw-control-ui\"\n}\n```\n\n[Sun 2026-04-05 22:58 GMT+8] 学习、执行：好的，我理解您的情况：OpenClaw 重装了，之前我们共同设计的所有技能、中间件、配置文件都丢失了。现在需要**从零开始恢复**整个“全自动任务编排系统”。\n\n下面我将按照**模块**，把您需要重新创建的所有文件内容完整地列出来。请按顺序执行。\n\n---\n\n## 一、重建技能目录和核心技能\n\n### 1.1 创建技能目录\n```bash\nmkdir -p ~/.openclaw/skills\n```\n\n### 1.2 技能 `task_orchestrator`（核心编排技能）\n\n创建文件 `~/.openclaw/skills/task_orchestrator/skill.js`，内容如下：\n\n```javascript\n// task_orchestrator/skill.js\n// 整合：评分路由 + 上下文保护 + 子代理进度上报\n\nconst { computeFineScore, getExecutionPlan } = require('./scoring');\nconst { spawnWithProgress } = require('./progress_reporter');\nconst { executeMegaTask } = require('./mega_executor');\nconst contextProtector = require('./context_protector');\n\nmodule.exports = {\n name: 'task_orchestrator',\n version: '3.0.0',\n description: '全自动任务编排：评分路由 + 上下文保护 + 子代理进度',\n\n async init() {\n console.log('[TaskOrchestrator] Initialized');\n },\n\n hooks: {\n onUserMessage: async (message, userId, taskId) => {\n await contextProtector.addMessage('user', message, taskId);\n },\n onAssistantMessage: async (response) => {\n await contextProtector.addMessage('assistant', response);\n },\n beforeTask: async (taskSpec, context) => {\n const score = await computeFineScore(taskSpec);\n const plan = getExecutionPlan(score.totalScore, score.factors.scaleIndex);\n context.routing = plan;\n context.score = score;\n console.log(`[Router] Score=${score.totalScore} → ${plan.mode}`);\n return taskSpec;\n }\n },\n\n async executeTask(task, context, sendUserMessage) {\n const plan = context.routing;\n if (!plan) throw new Error('No routing plan');\n switch (plan.mode) {\n case 'DIRECT':\n return require('child_process').execSync(task.spec, { timeout: plan.timeoutSec * 1000 });\n case 'SPAWN_SUBAGENT':\n return spawnWithProgress(task.spec, [], plan.timeoutSec, plan.memLimitMB, sendUserMessage);\n case 'MEGA_TASK':\n return executeMegaTask(task.spec, plan, sendUserMessage);\n default:\n throw new Error(`Unsupported mode: ${plan.mode}`);\n }\n }\n};\n```\n\n### 1.3 配套模块文件（放在同一目录下）\n\n#### `scoring.js` – 评分因子与路由\n\n```javascript\n// scoring.js\nconst WEIGHTS = {\n instructionCount: 0.10, codeLines: 0.08, dependencyComplexity: 0.12,\n cpuIntensity: 0.10, ioIntensity: 0.08, networkIntensity: 0.12,\n estimatedDuration: 0.15, scaleIndex: 0.25\n};\n\nfunction computeComplexity(taskSpec) {\n const cnt = (taskSpec.match(/&&|;|\\n/g) || []).length + 1;\n if (cnt === 1) return 1;\n if (cnt <= 3) return 2;\n if (cnt <= 6) return 3;\n if (cnt <= 10) return 4;\n return 5;\n}\n\nasync function computeFineScore(taskSpec) {\n // 简化版，实际可扩展\n const factors = {\n instructionCount: computeComplexity(taskSpec),\n codeLines: 1,\n dependencyComplexity: /npm|pip|install/.test(taskSpec) ? 4 : 1,\n cpuIntensity: /make|compile|gzip/.test(taskSpec) ? 4 : 1,\n ioIntensity: /cp|mv|tar|dd/.test(taskSpec) ? 4 : 1,\n networkIntensity: /curl|wget|git clone/.test(taskSpec) ? 4 : 1,\n estimatedDuration: /sleep|compile|backup/.test(taskSpec) ? 4 : 1,\n scaleIndex: 1\n };\n let weighted = 0;\n for (const [k, v] of Object.entries(factors)) weighted += v * WEIGHTS[k];\n const totalScore = Math.min(100, Math.round(weighted * 20));\n return { totalScore, factors };\n}\n\nfunction getExecutionPlan(score, scaleIndex) {\n if (scaleIndex >= 4) return { mode: 'MEGA_TASK', timeoutSec: 7200, memLimitMB: 8192 };\n if (score <= 20) return { mode: 'DIRECT', timeoutSec: 30 };\n if (score <= 40) return { mode: 'STEP_ARCHIVE', stepTimeoutSec: 60, memLimitMB: 1024 };\n if (score <= 60) return { mode: 'SPAWN_SUBAGENT', timeoutSec: Math.max(60, score * 3), memLimitMB: 2048 };\n if (score <= 80) return { mode: 'PARALLEL_SHARDS', timeoutSec: Math.max(60, score * 2), memLimitMB: 2048 };\n return { mode: 'DISTRIBUTED', message: 'Too complex' };\n}\n\nmodule.exports = { computeFineScore, getExecutionPlan };\n```\n\n#### `progress_reporter.js` – 子代理进度上报\n\n```javascript\n// progress_reporter.js\nconst { spawn } = require('child_process');\n\nasync function spawnWithProgress(cmd, args, timeoutSec, memLimitMB, onProgress) {\n const limitCmd = `ulimit -v ${memLimitMB * 1024} && exec \"$@\"`;\n const proc = spawn('/bin/sh', ['-c', limitCmd, '--', cmd, ...args], { stdio: ['ignore', 'pipe', 'pipe'] });\n let lastOutput = Date.now();\n const interval = setInterval(() => {\n if (Date.now() - lastOutput > 30000 && !proc.killed) onProgress?.('仍在运行，30秒无输出');\n }, 30000);\n proc.stdout.on('data', (chunk) => {\n const text = chunk.toString();\n const match = text.match(/\\[PROGRESS\\]\\s*(.*)/);\n if (match) onProgress?.(match[1]);\n else process.stdout.write(text);\n lastOutput = Date.now();\n });\n const timeout = setTimeout(() => { if (!proc.killed) proc.kill('SIGKILL'); }, timeoutSec * 1000);\n const code = await new Promise(resolve => proc.on('close', resolve));\n clearInterval(interval); clearTimeout(timeout);\n if (code !== 0) throw new Error(`Exit ${code}`);\n}\n\nmodule.exports = { spawnWithProgress };\n```\n\n#### `mega_executor.js` – 超大任务执行器\n\n```javascript\n// mega_executor.js\nasync function executeMegaTask(taskSpec, plan, onProgress) {\n onProgress?.('启动超大任务执行器，自动分片并行');\n // 简化实现：直接调用子代理\n const { spawnWithProgress } = require('./progress_reporter');\n await spawnWithProgress(taskSpec, [], plan.timeoutSec, plan.memLimitMB, onProgress);\n}\n\nmodule.exports = { executeMegaTask };\n```\n\n#### `context_protector.js` – 上下文保护\n\n```javascript\n// context_protector.js\nconst fs = require('fs').promises;\nconst path = require('path');\nconst STORAGE = path.join(process.env.HOME, '.openclaw', 'context.json');\n\nclass ContextProtector {\n constructor() { this.messages = []; this.totalChars = 0; this.totalTokens = 0; this.lastSummarize = 0; this.load(); }\n async load() { try { const d = JSON.parse(await fs.readFile(STORAGE)); Object.assign(this, d); } catch(e) {} }\n async save() { await fs.writeFile(STORAGE, JSON.stringify({ messages: this.messages.slice(-200), totalChars: this.totalChars, totalTokens: this.totalTokens, lastSummarize: this.lastSummarize })); }\n estimateTokens(t) { const ch = (t.match(/[\\u4e00-\\u9fa5]/g)||[]).length; return Math.ceil(ch/1.5 + (t.length-ch)/4); }\n async addMessage(role, content, taskId) {\n const tokens = this.estimateTokens(content);\n this.messages.push({ role, content, timestamp: Date.now(), taskId, tokens });\n this.totalChars += content.length; this.totalTokens += tokens;\n if (this.messages.length > 50 && Date.now() - this.lastSummarize > 120000) await this.summarize();\n await this.save();\n }\n async summarize() {\n const old = this.messages.slice(0, -10);\n const summary = `[Auto] ${old.length} msgs: ${old.map(m=>m.content.slice(0,30)).join('; ')}`;\n this.messages = [{ role:'system', content:`Summarized at ${new Date().toISOString()}: ${summary}`, tokens:0 }, ...this.messages.slice(-10)];\n this.totalChars = this.messages.reduce((s,m)=>s+(m.content?.length||0),0);\n this.totalTokens = this.messages.reduce((s,m)=>s+(m.tokens||0),0);\n this.lastSummarize = Date.now();\n console.log('[Context] Summarized', old.length);\n }\n}\n\nmodule.exports = new ContextProtector();\n```\n\n---\n\n## 二、反向代理中间件（独立服务）\n\n创建目录并写入文件：\n\n```bash\nmkdir -p /opt/openclaw-router\ncd /opt/openclaw-router\nnpm init -y\nnpm install express http-proxy-middleware axios\n```\n\n### `openclaw-router.js`\n\n```javascript\nconst express = require('express');\nconst { createProxyMiddleware } = require('http-proxy-middleware');\nconst GATEWAY_URL = process.env.OPENCLAW_GATEWAY || 'http://localhost:3000';\nconst PORT = process.env.ROUTER_PORT || 3002;\n\nconst app = express();\napp.use(express.json());\n\napp.get('/health', (req, res) => res.json({ status: 'ok' }));\n\napp.post('/api/task', (req, res, next) => {\n console.log('[Router] Task intercepted:', req.body.taskSpec);\n // 可在此调用评分逻辑，注入 routing 字段\n next();\n});\n\napp.use('/', createProxyMiddleware({ target: GATEWAY_URL, changeOrigin: true }));\n\napp.listen(PORT, () => console.log(`Router on ${PORT} → ${GATEWAY_URL}`));\n```\n\n### `context-api.js`\n\n```javascript\nconst express = require('express');\nconst app = express();\napp.use(express.json());\n\nlet messages = [];\n\napp.post('/api/context', (req, res) => {\n const { role, content } = req.body;\n messages.push({ role, content, timestamp: Date.now() });\n res.json({ success: true });\n});\n\napp.get('/api/context/status', (req, res) => {\n res.json({ messages: messages.length, chars: messages.reduce((s,m)=>s+m.content.length,0) });\n});\n\napp.listen(3001, () => console.log('Context API on 3001'));\n```\n\n---\n\n## 三、systemd 服务文件（开机自启）\n\n创建 `/etc/systemd/system/openclaw-router.service`：\n\n```ini\n[Unit]\nDescription=OpenClaw Router\nAfter=network.target\n\n[Service]\nType=simple\nUser=ai\nWorkingDirectory=/opt/openclaw-router\nExecStart=/usr/bin/node /opt/openclaw-router/openclaw-router.js\nRestart=always\n\n[Install]\nWantedBy=multi-user.target\n```\n\n创建 `/etc/systemd/system/openclaw-context.service`：\n\n```ini\n[Unit]\nDescription=OpenClaw Context API\nAfter=network.target\n\n[Service]\nType=simple\nUser=ai\nWorkingDirectory=/opt/openclaw-router\nExecStart=/usr/bin/node /opt/openclaw-router/context-api.js\nRestart=always\n\n[Install]\nWantedBy=multi-user.target\n```\n\n然后启用并启动：\n\n```bash\nsudo systemctl daemon-reload\nsudo systemctl enable openclaw-router openclaw-context\nsudo systemctl start openclaw-router openclaw-context\n```\n\n---\n\n## 四、环境变量（写入 ~/.bashrc）\n\n```bash\necho 'export OPENCLAW_GATEWAY=http://localhost:3000' >> ~/.bashrc\necho 'export ROUTER_PORT=3002' >> ~/.bashrc\nsource ~/.bashrc\n```\n\n---\n\n## 五、测试验证\n\n```bash\n# 测试 context API\ncurl http://localhost:3001/api/context/status\n\n# 测试中间件\ncurl -X POST http://localhost:3002/api/task -H \"Content-Type: application/json\" -d '{\"taskSpec\":\"ls\"}'\n\n# 查看服务状态\nsudo systemctl status openclaw-router openclaw-context\n```"}],"timestamp":1775401137404}}
