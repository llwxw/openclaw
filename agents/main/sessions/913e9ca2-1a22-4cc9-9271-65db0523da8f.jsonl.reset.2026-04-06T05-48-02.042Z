{"type":"message","id":"7e3ff68e","parentId":"2c32f82e","timestamp":"2026-04-05T18:43:33.060Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"任务评分 27 分，应该用 STEP_ARCHIVE 模式执行（60s）。让我安装意图判断模块。\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"call_e284873c1bc14c89b7fe8feb","name":"write","arguments":{"content":"// intentDetector.js\n// 同步轻量级意图判断 + 异步增强\n\nconst axios = require('axios');\n\n// 规则配置\nconst RULE = {\n actionVerbs: /(写|做|执行|运行|处理|分析|检查|修复|重构|生成|编译|部署|创建|修改|删除|帮我|请|麻烦)/i,\n questionWords: /(吗|？|能不能|可不可以|是否|什么|为什么|怎么|如何)/i,\n confirmWords: /^(是|好|做|继续|可以|行|嗯|ok|yes)$/i,\n taskContinuation: /(再|又|也|还|继续|接着)/i\n};\n\n// 同步规则打分（快速，不依赖外部）\nfunction ruleBasedScore(message) {\n let score = 0;\n if (RULE.actionVerbs.test(message)) score += 2;\n if (RULE.confirmWords.test(message)) score += 1;\n if (RULE.taskContinuation.test(message)) score += 1;\n if (RULE.questionWords.test(message)) score -= 2;\n return score;\n}\n\n// 异步上下文增强（获取最近对话，调用 Context API）\nasync function contextEnhance(message, convId, timeoutMs = 500) {\n if (!convId) return 0;\n try {\n const controller = new AbortController();\n const timeout = setTimeout(() => controller.abort(), timeoutMs);\n const res = await axios.get(`http://localhost:3101/api/context/history`, {\n params: { convId, limit: 3 },\n signal: controller.signal\n });\n clearTimeout(timeout);\n const history = res.data.messages || [];\n let bonus = 0;\n const lastAssistant = history[history.length - 1]?.content || '';\n if (/要不要|是否|可以执行|需要我帮你/i.test(lastAssistant)) bonus += 1;\n if (RULE.confirmWords.test(message) && bonus > 0) bonus += 1;\n return bonus;\n } catch (err) {\n return 0;\n }\n}\n\n// 异步记忆增强（查询相似任务）\nasync function memoryEnhance(message, memoryStore, timeoutMs = 300) {\n if (!memoryStore || typeof memoryStore.query !== 'function') return 0;\n try {\n const controller = new AbortController();\n const timeout = setTimeout(() => controller.abort(), timeoutMs);\n const similar = await memoryStore.query(message, 1);\n clearTimeout(timeout);\n if (similar.length > 0 && similar[0].score > 0.7) return 2;\n return 0;\n } catch (err) {\n return 0;\n }\n}\n\n// 主判断函数\nasync function detectIntent(message, convId, memoryStore, options = {}) {\n // 截断超大消息\n const shortMsg = message?.slice(0, 200) || '';\n \n // 1. 同步规则打分\n let syncScore = ruleBasedScore(shortMsg);\n const isTaskQuick = syncScore >= 1;\n \n // 2. 异步增强（不等待）\n setImmediate(async () => {\n try {\n const contextBonus = await contextEnhance(shortMsg, convId);\n const memoryBonus = await memoryEnhance(shortMsg, memoryStore);\n const finalScore = syncScore + contextBonus + memoryBonus;\n const finalIsTask = finalScore >= 1.5;\n console.log(`[Intent] msg=\"${shortMsg.slice(0,50)}\" syncScore=${syncScore} contextBonus=${contextBonus} memoryBonus=${memoryBonus} finalScore=${finalScore} isTask=${finalIsTask}`);\n } catch (err) {}\n });\n \n return { isTask: isTaskQuick, confidence: Math.min(1, syncScore / 4) };\n}\n\nmodule.exports = { detectIntent };","path":"/home/ai/openclaw-router/intentDetector.js"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":93865,"output":844,"cacheRead":0,"cacheWrite":0,"totalTokens":94709,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775414600215,"responseId":"chatcmpl-be748c38-fc78-489b-aaab-b6b457326297"}}
