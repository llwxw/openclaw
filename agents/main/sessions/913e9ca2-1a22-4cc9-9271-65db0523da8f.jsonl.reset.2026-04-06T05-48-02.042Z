{"type":"message","id":"d764c125","parentId":"341d6814","timestamp":"2026-04-05T19:33:54.801Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Let me create the ws-proxy.js file now.\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"call_6ea48339b9384d91934de5dd","name":"write","arguments":{"content":"// ws-proxy.js\n// 高鲁棒 WebSocket 代理，集成意图判断与任务评分\n\nconst WebSocket = require('ws');\nconst crypto = require('crypto');\nconst { detectIntent } = require('./intentDetector');\nconst { computeFineScore, getExecutionPlan } = require('./scoring');\n\nconst CONFIG = {\n gatewayWsUrl: process.env.OPENCLAW_WS_URL || 'ws://localhost:18789',\n proxyPort: parseInt(process.env.PROXY_WS_PORT || '3103', 10),\n heartbeatIntervalMs: parseInt(process.env.HEARTBEAT_INTERVAL_MS || '30000', 10),\n connectionTimeoutMs: parseInt(process.env.CONNECTION_TIMEOUT_MS || '10000', 10),\n maxReconnectAttempts: parseInt(process.env.MAX_RECONNECT_ATTEMPTS || '5', 10),\n reconnectBaseDelayMs: parseInt(process.env.RECONNECT_BASE_DELAY_MS || '1000', 10),\n maxCachedMessages: parseInt(process.env.MAX_CACHED_MESSAGES || '100', 10),\n maxMessageSizeBytes: parseInt(process.env.MAX_MESSAGE_SIZE_BYTES || '1048576', 10),\n enableRateLimit: process.env.ENABLE_RATE_LIMIT === 'true',\n rateLimitPerSec: parseInt(process.env.RATE_LIMIT_PER_SEC || '10', 10),\n healthPort: parseInt(process.env.HEALTH_PORT || '3104', 10),\n};\n\nconst log = (level, msg, meta = {}) => {\n console[level](`[WSProxy] ${msg}`, JSON.stringify(meta));\n};\n\nconst messageExtractors = [\n (data) => { try { const p = JSON.parse(data); return p.content || p.message || p.text; } catch(e) {} },\n (data) => { try { const p = JSON.parse(data); return p.data?.message || p.data?.text; } catch(e) {} },\n];\n\nfunction extractUserMessage(data) {\n for (const extractor of messageExtractors) {\n const result = extractor(data);\n if (result && typeof result === 'string') return result;\n }\n return null;\n}\n\nclass RateLimiter {\n constructor(tokensPerSec) {\n this.tokens = tokensPerSec;\n this.maxTokens = tokensPerSec;\n this.lastRefill = Date.now();\n }\n allow() {\n const now = Date.now();\n const elapsed = (now - this.lastRefill) / 1000;\n this.tokens = Math.min(this.maxTokens, this.tokens + elapsed * this.maxTokens);\n this.lastRefill = now;\n if (this.tokens >= 1) {\n this.tokens -= 1;\n return true;\n }\n return false;\n }\n}\n\nclass WSProxyClient {\n constructor(clientSocket, req) {\n this.clientSocket = clientSocket;\n this.clientAddr = req.socket.remoteAddress;\n this.clientId = crypto.randomUUID().slice(0, 8);\n this.gatewaySocket = null;\n this.reconnectAttempts = 0;\n this.heartbeatTimer = null;\n this.pendingMessages = [];\n this.connected = false;\n this.rateLimiter = CONFIG.enableRateLimit ? new RateLimiter(CONFIG.rateLimitPerSec) : null;\n this.init();\n }\n\n init() {\n this.connectToGateway();\n this.setupClientHandlers();\n }\n\n connectToGateway() {\n log('info', `Client ${this.clientId} connecting to Gateway ${CONFIG.gatewayWsUrl} (attempt ${this.reconnectAttempts+1})`);\n this.gatewaySocket = new WebSocket(CONFIG.gatewayWsUrl, {\n maxPayload: CONFIG.maxMessageSizeBytes,\n });\n \n const timeout = setTimeout(() => {\n if (this.gatewaySocket.readyState !== WebSocket.OPEN) {\n log('error', `Client ${this.clientId} Gateway connection timeout`);\n this.gatewaySocket.terminate();\n this.scheduleReconnect();\n }\n }, CONFIG.connectionTimeoutMs);\n\n this.gatewaySocket.on('open', () => {\n clearTimeout(timeout);\n this.connected = true;\n this.reconnectAttempts = 0;\n log('info', `Client ${this.clientId} connected to Gateway`);\n while (this.pendingMessages.length) {\n const msg = this.pendingMessages.shift();\n this.gatewaySocket.send(msg);\n }\n this.startHeartbeat();\n });\n\n this.gatewaySocket.on('message', (data, isBinary) => {\n if (this.clientSocket.readyState === WebSocket.OPEN) {\n this.clientSocket.send(data, { binary: isBinary });\n }\n });\n\n this.gatewaySocket.on('error', (err) => {\n log('error', `Client ${this.clientId} Gateway error: ${err.message}`);\n });\n\n this.gatewaySocket.on('close', (code, reason) => {\n clearTimeout(timeout);\n this.connected = false;\n this.stopHeartbeat();\n log('warn', `Client ${this.clientId} Gateway closed: ${code}`);\n this.scheduleReconnect();\n });\n }\n\n scheduleReconnect() {\n if (this.reconnectAttempts >= CONFIG.maxReconnectAttempts) {\n log('error', `Client ${this.clientId} max reconnect attempts, closing`);\n this.clientSocket.close();\n return;\n }\n this.reconnectAttempts++;\n const delay = CONFIG.reconnectBaseDelayMs * Math.pow(1.5, this.reconnectAttempts - 1);\n log('info', `Client ${this.clientId} reconnect in ${delay}ms`);\n setTimeout(() => this.connectToGateway(), delay);\n }\n\n startHeartbeat() {\n this.stopHeartbeat();\n this.heartbeatTimer = setInterval(() => {\n if (this.gatewaySocket && this.gatewaySocket.readyState === WebSocket.OPEN) {\n this.gatewaySocket.ping();\n }\n }, CONFIG.heartbeatIntervalMs);\n }\n\n stopHeartbeat() {\n if (this.heartbeatTimer) {\n clearInterval(this.heartbeatTimer);\n this.heartbeatTimer = null;\n }\n }\n\n setupClientHandlers() {\n this.clientSocket.on('message', async (data, isBinary) => {\n if (this.rateLimiter && !this.rateLimiter.allow()) {\n log('warn', `Client ${this.clientId} rate limit exceeded`);\n return;\n }\n\n const userText = extractUserMessage(data);\n if (userText) {\n setImmediate(async () => {\n try {\n const { isTask, confidence } = await detectIntent(userText, null, null);\n if (isTask && confidence > 0.5) {\n const score = await computeFineScore(userText);\n const plan = getExecutionPlan(score.totalScore, score.factors?.scaleIndex || 1);\n log('info', `Task detected: \"${userText.slice(0,30)}\" score=${score.totalScore} mode=${plan.mode}`);\n if (this.clientSocket.readyState === WebSocket.OPEN) {\n const hint = JSON.stringify({ type: 'task_hint', plan: { mode: plan.mode, score: score.totalScore } });\n this.clientSocket.send(hint);\n }\n }\n } catch (err) {\n log('error', `Intent/score error: ${err.message}`);\n }\n });\n }\n\n if (this.connected && this.gatewaySocket.readyState === WebSocket.OPEN) {\n this.gatewaySocket.send(data, { binary: isBinary });\n } else {\n this.pendingMessages.push(data);\n if (this.pendingMessages.length > CONFIG.maxCachedMessages) {\n this.pendingMessages.shift();\n }\n }\n });\n\n this.clientSocket.on('close', () => {\n log('info', `Client ${this.clientId} disconnected`);\n this.stopHeartbeat();\n if (this.gatewaySocket && this.gatewaySocket.readyState === WebSocket.OPEN) {\n this.gatewaySocket.close();\n }\n });\n\n this.clientSocket.on('error', (err) => {\n log('error', `Client ${this.clientId} error: ${err.message}`);\n });\n }\n}\n\nconst wss = new WebSocket.Server({ \n port: CONFIG.proxyPort,\n maxPayload: CONFIG.maxMessageSizeBytes,\n});\n\nwss.on('connection', (clientSocket, req) => {\n log('info', `New client from ${req.socket.remoteAddress}`);\n new WSProxyClient(clientSocket, req);\n});\n\nwss.on('error', (err) => {\n log('error', `WebSocket server error: ${err.message}`);\n});\n\nlog('info', `WebSocket proxy listening on ${CONFIG.proxyPort} -> ${CONFIG.gatewayWsUrl}`);\n\nconst express = require('express');\nconst healthApp = express();\nhealthApp.get('/health', (req, res) => {\n res.json({\n status: 'ok',\n uptime: process.uptime(),\n connections: wss.clients.size,\n proxyPort: CONFIG.proxyPort,\n gatewayUrl: CONFIG.gatewayWsUrl,\n });\n});\nhealthApp.listen(CONFIG.healthPort, () => {\n log('info', `Health check on port ${CONFIG.healthPort}`);\n});","path":"/home/ai/openclaw-router/ws-proxy.js"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":78832,"output":1835,"cacheRead":0,"cacheWrite":0,"totalTokens":80667,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775417608364,"responseId":"chatcmpl-df51d061-523a-4ce4-8a67-90bbf7035954"}}
