{"type":"message","id":"779fc9e0","parentId":"c7ce26ef","timestamp":"2026-04-06T05:02:17.137Z","message":{"role":"user","content":[{"type":"text","text":"Sender (untrusted metadata):\n```json\n{\n  \"label\": \"openclaw-control-ui\",\n  \"id\": \"openclaw-control-ui\"\n}\n```\n\n[Mon 2026-04-06 13:02 GMT+8] 使用我给你的代码，只在需要修改以适配本地的地方进行修改：📦 完整项目结构\nCopy\nopenclaw-listener/\n├── .env.example\n├── .gitignore\n├── config.json\n├── package.json\n├── tsconfig.json\n├── jest.config.js\n├── README.md\n├── src/\n│ ├── types.ts\n│ ├── config.ts\n│ ├── logger.ts\n│ ├── queue.ts\n│ ├── apiClient.ts\n│ ├── gatewayClient.ts\n│ ├── messageHandler.ts\n│ ├── healthServer.ts\n│ └── main.ts\n├── tests/\n│ ├── config.test.ts\n│ ├── queue.test.ts\n│ ├── apiClient.test.ts\n│ └── messageHandler.test.ts\n└── scripts/\n └── start.sh\n￼\n1. 根目录配置文件\n.env.example\nenv\nCopy\n# Optional: override config.json path\nCONFIG_PATH=./config.json\nNODE_ENV=production\n.gitignore\nCopy\nnode_modules/\ndist/\n*.log\n*.db\n*.db-journal\n.env\nconfig.json (实际配置，请修改 token)\nJSON · 39 lines\npackage.json\nJSON · 44 lines\ntsconfig.json\nJSON · 20 lines\njest.config.js\njavascript\nCopy\nmodule.exports = {\n preset: 'ts-jest',\n testEnvironment: 'node',\n roots: ['<rootDir>/tests'],\n testMatch: ['**/*.test.ts'],\n collectCoverageFrom: ['src/**/*.ts', '!src/types.ts', '!src/main.ts'],\n coverageDirectory: 'coverage',\n coverageReporters: ['text', 'lcov'],\n};\n￼\n2. 源代码 (src/)\nsrc/types.ts\ntypescript\nCopy\n// Common types used across modules\n\nexport interface GatewayConfig {\n url: string;\n token: string;\n heartbeatInterval: number;\n reconnect: {\n initialDelay: number;\n maxDelay: number;\n factor: number;\n };\n}\n\nexport interface ApiConfig {\n intent: string;\n score: string;\n timeout: number;\n retries: number;\n retryDelay: number;\n}\n\nexport interface ReplyConfig {\n enabled: boolean;\n template?: string;\n}\n\nexport interface BehaviorConfig {\n messageField: string;\n queueEnabled: boolean;\n queueDbPath: string;\n batchSize: number;\n batchIntervalMs: number;\n}\n\nexport interface HealthConfig {\n enabled: boolean;\n port: number;\n endpoint: string;\n}\n\nexport interface LoggingConfig {\n level: 'trace' | 'debug' | 'info' | 'warn' | 'error';\n file?: string;\n}\n\nexport interface AppConfig {\n gateway: GatewayConfig;\n api: ApiConfig;\n reply: ReplyConfig;\n behavior: BehaviorConfig;\n health: HealthConfig;\n logging: LoggingConfig;\n}\n\nexport interface QueuedMessage {\n id: number;\n rawMessage: string;\n createdAt: number;\n}\n\nexport interface HealthStatus {\n status: 'ok' | 'degraded';\n connected: boolean;\n queueSize: number;\n reconnectAttempts: number;\n lastError: string | null;\n uptime: number;\n version: string;\n}\n\nexport interface GatewayMessage {\n type: string;\n data?: any;\n content?: string;\n [key: string]: unknown;\n}\nsrc/config.ts\ntypescript\nCopy\nimport fs from 'fs';\nimport path from 'path';\nimport { z } from 'zod';\nimport dotenv from 'dotenv';\nimport { AppConfig } from './types';\n\ndotenv.config();\n\nconst configSchema = z.object({\n gateway: z.object({\n url: z.string().url(),\n token: z.string().min(1),\n heartbeatInterval: z.number().int().positive().default(30000),\n reconnect: z.object({\n initialDelay: z.number().int().positive().default(1000),\n maxDelay: z.number().int().positive().default(60000),\n factor: z.number().positive().default(1.5),\n }),\n }),\n api: z.object({\n intent: z.string().url(),\n score: z.string().url(),\n timeout: z.number().int().positive().default(5000),\n retries: z.number().int().min(0).default(3),\n retryDelay: z.number().int().positive().default(1000),\n }),\n reply: z.object({\n enabled: z.boolean().default(false),\n template: z.string().optional(),\n }),\n behavior: z.object({\n messageField: z.string().default('content'),\n queueEnabled: z.boolean().default(true),\n queueDbPath: z.string().default('/tmp/openclaw-listener-queue.db'),\n batchSize: z.number().int().positive().default(10),\n batchIntervalMs: z.number().int().positive().default(100),\n }),\n health: z.object({\n enabled: z.boolean().default(true),\n port: z.number().int().min(1024).max(65535).default(3106),\n endpoint: z.string().default('/health'),\n }),\n logging: z.object({\n level: z.enum(['trace', 'debug', 'info', 'warn', 'error']).default('info'),\n file: z.string().optional(),\n }),\n});\n\nexport function loadConfig(): AppConfig {\n const configPath = process.env.CONFIG_PATH || path.join(process.cwd(), 'config.json');\n const raw = JSON.parse(fs.readFileSync(configPath, 'utf-8'));\n return configSchema.parse(raw);\n}\nsrc/logger.ts\ntypescript\nCopy\nimport pino from 'pino';\nimport { LoggingConfig } from './types';\n\nlet rootLogger: pino.Logger | null = null;\n\nexport function createLogger(config: LoggingConfig): pino.Logger {\n if (rootLogger) return rootLogger;\n\n const transport = config.file\n ? pino.destination({ dest: config.file, sync: false, mkdir: true })\n : undefined;\n\n const logger = pino(\n {\n level: config.level,\n formatters: {\n level: (label) => ({ level: label }),\n },\n timestamp: pino.stdTimeFunctions.isoTime,\n },\n transport\n );\n\n // Also log to console if file is used\n if (config.file) {\n const consoleStream = pino.destination(1);\n logger.add(consoleStream);\n }\n\n rootLogger = logger;\n return logger;\n}\n\nexport function getLogger(): pino.Logger {\n if (!rootLogger) throw new Error('Logger not initialized. Call createLogger first.');\n return rootLogger;\n}\nsrc/queue.ts\ntypescript\nCopy\nimport Database from 'better-sqlite3';\nimport { EventEmitter } from 'events';\nimport { QueuedMessage } from './types';\nimport { getLogger } from './logger';\n\nexport class MessageQueue extends EventEmitter {\n private db: Database.Database;\n private buffer: string[] = [];\n private flushTimer: NodeJS.Timeout | null = null;\n private readonly batchSize: number;\n private readonly flushIntervalMs: number;\n\n constructor(dbPath: string, batchSize: number, flushIntervalMs: number) {\n super();\n this.batchSize = batchSize;\n this.flushIntervalMs = flushIntervalMs;\n this.db = new Database(dbPath);\n this.db.pragma('journal_mode = WAL');\n this.db.exec(`\n CREATE TABLE IF NOT EXISTS message_queue (\n id INTEGER PRIMARY KEY AUTOINCREMENT,\n raw_message TEXT NOT NULL,\n created_at INTEGER NOT NULL\n )\n `);\n this.startFlushTimer();\n }\n\n private startFlushTimer(): void {\n this.flushTimer = setInterval(() => this.flush(), this.flushIntervalMs);\n }\n\n private flush(): void {\n if (this.buffer.length === 0) return;\n const batch = this.buffer.splice(0, this.batchSize);\n const insert = this.db.prepare('INSERT INTO message_queue (raw_message, created_at) VALUES (?, ?)');\n const insertMany = this.db.transaction((items: string[]) => {\n for (const raw of items) {\n insert.run(raw, Date.now());\n }\n });\n try {\n insertMany(batch);\n getLogger().debug({ count: batch.length }, 'Flushed messages to queue');\n this.emit('flushed', batch.length);\n } catch (err) {\n getLogger().error({ err }, 'Failed to flush queue');\n this.emit('error', err);\n // Re-add failed messages to buffer?\n this.buffer.unshift(...batch);\n }\n }\n\n public enqueue(rawMessage: string): void {\n this.buffer.push(rawMessage);\n if (this.buffer.length >= this.batchSize) {\n this.flush();\n }\n }\n\n public async dequeue(id: number): Promise<void> {\n this.db.prepare('DELETE FROM message_queue WHERE id = ?').run(id);\n }\n\n public async peek(limit = 20): Promise<QueuedMessage[]> {\n const rows = this.db\n .prepare('SELECT id, raw_message as rawMessage, created_at as createdAt FROM message_queue ORDER BY created_at LIMIT ?')\n .all(limit) as any[];\n return rows.map(r => ({ id: r.id, rawMessage: r.rawMessage, createdAt: r.createdAt }));\n }\n\n public async count(): Promise<number> {\n const row = this.db.prepare('SELECT COUNT(*) as count FROM message_queue').get() as { count: number };\n return row.count;\n }\n\n public async close(): Promise<void> {\n if (this.flushTimer) clearInterval(this.flushTimer);\n this.flush(); // final flush\n this.db.close();\n }\n}\nsrc/apiClient.ts\ntypescript\nCopy\nimport axios, { AxiosInstance, AxiosError } from 'axios';\nimport { getLogger } from './logger';\nimport { ApiConfig } from './types';\n\nclass CircuitBreaker {\n private failures = 0;\n private state: 'CLOSED' | 'OPEN' | 'HALF_OPEN' = 'CLOSED';\n private nextAttempt: number = 0;\n constructor(private readonly failureThreshold: number = 5, private readonly timeoutMs: number = 60000) {}\n\n async call<T>(fn: () => Promise<T>): Promise<T> {\n if (this.state === 'OPEN') {\n if (Date.now() < this.nextAttempt) {\n throw new Error('Circuit breaker is OPEN');\n }\n this.state = 'HALF_OPEN';\n getLogger().info('Circuit breaker half-open, attempting call');\n }\n try {\n const result = await fn();\n if (this.state === 'HALF_OPEN') {\n this.failures = 0;\n this.state = 'CLOSED';\n getLogger().info('Circuit breaker closed again');\n }\n return result;\n } catch (err) {\n this.failures++;\n if (this.failures >= this.failureThreshold) {\n this.state = 'OPEN';\n this.nextAttempt = Date.now() + this.timeoutMs;\n getLogger().warn({ failures: this.failures }, 'Circuit breaker opened');\n }\n throw err;\n }\n }\n\n reset(): void {\n this.failures = 0;\n this.state = 'CLOSED';\n this.nextAttempt = 0;\n }\n}\n\nexport class ApiClient {\n private http: AxiosInstance;\n private breaker: CircuitBreaker;\n private readonly retries: number;\n private readonly retryDelay: number;\n\n constructor(private config: ApiConfig) {\n this.http = axios.create({ timeout: config.timeout });\n this.retries = config.retries;\n this.retryDelay = config.retryDelay;\n this.breaker = new CircuitBreaker(5, 60000);\n }\n\n private async withRetry<T>(fn: () => Promise<T>, attempt = 0): Promise<T> {\n try {\n return await fn();\n } catch (err) {\n const axiosErr = err as AxiosError;\n const isRetryable = !axiosErr.response || axiosErr.response.status >= 500 || axiosErr.code === 'ECONNABORTED';\n if (attempt < this.retries && isRetryable) {\n const delay = this.retryDelay * Math.pow(2, attempt);\n getLogger().warn({ attempt, delay, error: axiosErr.message }, 'Retrying API call');\n await new Promise(re\n...(truncated)..."}],"timestamp":1775451737122}}
