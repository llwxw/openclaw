{"type":"message","id":"1435e458","parentId":"3ae1f642","timestamp":"2026-04-06T05:05:04.233Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"继续创建 queue.ts。\n\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"019d612d91476f9d8b324cf7b99c120d","name":"exec","arguments":{"command":"# queue.ts\ncat > ~/openclaw-listener/src/queue.ts << 'EOF'\nimport Database from 'better-sqlite3';\nimport { EventEmitter } from 'events';\nimport { QueuedMessage } from './types';\nimport { getLogger } from './logger';\n\nexport class MessageQueue extends EventEmitter {\n  private db: Database.Database;\n  private buffer: string[] = [];\n  private flushTimer: NodeJS.Timeout | null = null;\n  private readonly batchSize: number;\n  private readonly flushIntervalMs: number;\n\n  constructor(dbPath: string, batchSize: number, flushIntervalMs: number) {\n    super();\n    this.batchSize = batchSize;\n    this.flushIntervalMs = flushIntervalMs;\n    this.db = new Database(dbPath);\n    this.db.pragma('journal_mode = WAL');\n    this.db.exec(`\n      CREATE TABLE IF NOT EXISTS message_queue (\n        id INTEGER PRIMARY KEY AUTOINCREMENT,\n        raw_message TEXT NOT NULL,\n        created_at INTEGER NOT NULL\n      )\n    `);\n    this.startFlushTimer();\n  }\n\n  private startFlushTimer(): void {\n    this.flushTimer = setInterval(() => this.flush(), this.flushIntervalMs);\n  }\n\n  private flush(): void {\n    if (this.buffer.length === 0) return;\n    const batch = this.buffer.splice(0, this.batchSize);\n    const insert = this.db.prepare('INSERT INTO message_queue (raw_message, created_at) VALUES (?, ?)');\n    const insertMany = this.db.transaction((items: string[]) => {\n      for (const raw of items) {\n        insert.run(raw, Date.now());\n      }\n    });\n    try {\n      insertMany(batch);\n      getLogger().debug({ count: batch.length }, 'Flushed messages to queue');\n      this.emit('flushed', batch.length);\n    } catch (err) {\n      getLogger().error({ err }, 'Failed to flush queue');\n      this.emit('error', err);\n      this.buffer.unshift(...batch);\n    }\n  }\n\n  public enqueue(rawMessage: string): void {\n    this.buffer.push(rawMessage);\n    if (this.buffer.length >= this.batchSize) {\n      this.flush();\n    }\n  }\n\n  public async dequeue(id: number): Promise<void> {\n    this.db.prepare('DELETE FROM message_queue WHERE id = ?').run(id);\n  }\n\n  public async peek(limit = 20): Promise<QueuedMessage[]> {\n    const rows = this.db\n      .prepare('SELECT id, raw_message as rawMessage, created_at as createdAt FROM message_queue ORDER BY created_at LIMIT ?')\n      .all(limit) as any[];\n    return rows.map(r => ({ id: r.id, rawMessage: r.rawMessage, createdAt: r.createdAt }));\n  }\n\n  public async count(): Promise<number> {\n    const row = this.db.prepare('SELECT COUNT(*) as count FROM message_queue').get() as { count: number };\n    return row.count;\n  }\n\n  public async close(): Promise<void> {\n    if (this.flushTimer) clearInterval(this.flushTimer);\n    this.flush();\n    this.db.close();\n  }\n}\nEOF\necho \"✅ queue.ts\""}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":7183,"output":687,"cacheRead":129536,"cacheWrite":0,"totalTokens":137406,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775451852412,"responseId":"019d612d4b13d937da73ec9981b8a87d"}}
