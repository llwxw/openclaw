{"type":"message","id":"af98d386","parentId":"afb80abd","timestamp":"2026-04-06T16:35:20.998Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"效率优化模块完成，现在写部署运维模块。\n\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"call_d61032edccc94d39849c1b98","name":"write","arguments":{"content":"// deployment-ops.js - 部署与运维垂直拓展\n// 支持健康检查、Prometheus 指标、配置热重载、日志轮转\n\nconst fs = require('fs');\nconst { exec } = require('child_process');\n\n// 8.1 健康检查端点\nclass HealthChecker {\n  constructor() {\n    this.startTime = Date.now();\n    this.metrics = {\n      tasksTotal: 0,\n      tasksByMode: {},\n      scoresDistribution: [],\n      errors: [],\n      lastError: null\n    };\n  }\n\n  getHealth() {\n    return {\n      status: 'ok',\n      uptime: Math.floor((Date.now() - this.startTime) / 1000),\n      memory: process.memoryUsage(),\n      cpu: process.cpuUsage(),\n      activeRequests: this.getActiveRequestCount(),\n      timestamp: new Date().toISOString()\n    };\n  }\n\n  getReady() {\n    // 检查依赖服务\n    return {\n      ready: true,\n      checks: {\n        gateway: this.checkGateway(),\n        router: true\n      }\n    };\n  }\n\n  async checkGateway() {\n    return new Promise((resolve) => {\n      exec('curl -s -o /dev/null -w \"%{http_code}\" http://127.0.0.1:3108/health || echo \"failed\"', \n        (err, stdout) => {\n          resolve(stdout.trim() === '200');\n        }\n      );\n    });\n  }\n\n  getActiveRequestCount() {\n    // 简化实现\n    return 0;\n  }\n\n  // 记录任务\n  recordTask(mode, score) {\n    this.metrics.tasksTotal++;\n    this.metrics.tasksByMode[mode] = (this.metrics.tasksByMode[mode] || 0) + 1;\n    \n    // 分数分布（按桶统计）\n    const bucket = Math.floor(score / 10) * 10;\n    this.metrics.scoresDistribution[bucket] = (this.metrics.scoresDistribution[bucket] || 0) + 1;\n  }\n\n  // 记录错误\n  recordError(error) {\n    this.metrics.errors.push({\n      message: error.message,\n      timestamp: new Date().toISOString()\n    });\n    this.metrics.lastError = error.message;\n    \n    // 只保留最近 100 条\n    if (this.metrics.errors.length > 100) {\n      this.metrics.errors.shift();\n    }\n  }\n\n  getMetrics() {\n    return this.metrics;\n  }\n}\n\n// 8.2 Prometheus 指标\nclass PrometheusMetrics {\n  constructor() {\n    this.counters = new Map();\n    this.gauges = new Map();\n    this.histograms = new Map();\n  }\n\n  // Counter: 只增不减\n  counter(name, labels = {}) {\n    const key = `${name}:${JSON.stringify(labels)}`;\n    if (!this.counters.has(key)) {\n      this.counters.set(key, { name, labels, value: 0 });\n    }\n    return {\n      inc: (delta = 1) => {\n        const c = this.counters.get(key);\n        c.value += delta;\n      },\n      getValue: () => this.counters.get(key).value\n    };\n  }\n\n  // Gauge: 可增可减\n  gauge(name, labels = {}) {\n    const key = `${name}:${JSON.stringify(labels)}`;\n    if (!this.gauges.has(key)) {\n      this.gauges.set(key, { name, labels, value: 0 });\n    }\n    return {\n      set: (value) => { this.gauges.get(key).value = value; },\n      inc: () => { this.gauges.get(key).value++; },\n      dec: () => { this.gauges.get(key).value--; },\n      getValue: () => this.gauges.get(key).value\n    };\n  }\n\n  // 导出 Prometheus 格式\n  toPrometheus() {\n    let output = '';\n    \n    // Counters\n    for (const c of this.counters.values()) {\n      const labels = Object.entries(c.labels).map(([k, v]) => `${k}=\"${v}\"`).join(',');\n      const labelStr = labels ? `{${labels}}` : '';\n      output += `# TYPE ${c.name} counter\\n`;\n      output += `${c.name}${labelStr} ${c.value}\\n`;\n    }\n    \n    // Gauges\n    for (const g of this.gauges.values()) {\n      const labels = Object.entries(g.labels).map(([k, v]) => `${k}=\"${v}\"`).join(',');\n      const labelStr = labels ? `{${labels}}` : '';\n      output += `# TYPE ${g.name} gauge\\n`;\n      output += `${g.name}${labelStr} ${g.value}\\n`;\n    }\n    \n    return output;\n  }\n}\n\n// 8.3 配置热重载\nclass ConfigReloader {\n  constructor(configPath) {\n    this.configPath = configPath;\n    this.config = null;\n    this.lastMtime = null;\n    this.load();\n  }\n\n  load() {\n    try {\n      const stats = fs.statSync(this.configPath);\n      this.lastMtime = stats.mtimeMs;\n      this.config = JSON.parse(fs.readFileSync(this.configPath, 'utf8'));\n      console.log('[Config] Loaded:', this.configPath);\n    } catch (err) {\n      console.error('[Config] Load failed:', err.message);\n    }\n  }\n\n  check() {\n    try {\n      const stats = fs.statSync(this.configPath);\n      if (stats.mtimeMs > this.lastMtime) {\n        this.load();\n        return true;\n      }\n    } catch {}\n    return false;\n  }\n\n  get() {\n    return this.config;\n  }\n\n  // 监听 SIGHUP 重新加载\n  watch() {\n    process.on('SIGHUP', () => {\n      console.log('[Config] Received SIGHUP, reloading...');\n      this.load();\n    });\n  }\n}\n\n// 8.4 日志轮转\nclass LogRotator {\n  constructor(options = {}) {\n    this.logDir = options.logDir || './logs';\n    this.maxFiles = options.maxFiles || 30;\n    this.maxSize = options.maxSize || 10 * 1024 * 1024; // 10MB\n    this.currentSize = 0;\n    this.currentFile = null;\n    this.stream = null;\n    this.init();\n  }\n\n  init() {\n    // 确保目录存在\n    if (!fs.existsSync(this.logDir)) {\n      fs.mkdirSync(this.logDir, { recursive: true });\n    }\n    this.rotate();\n  }\n\n  getFilename() {\n    const date = new Date().toISOString().split('T')[0];\n    return `${this.logDir}/openclaw-${date}.log`;\n  }\n\n  rotate() {\n    if (this.stream) {\n      this.stream.end();\n    }\n    \n    this.currentFile = this.getFilename();\n    this.stream = fs.createWriteStream(this.currentFile, { flags: 'a' });\n    this.currentSize = 0;\n    \n    console.log('[LogRotator] Rotated to:', this.currentFile);\n  }\n\n  write(data) {\n    if (!this.stream) return;\n    \n    const chunk = typeof data === 'string' ? data : JSON.stringify(data);\n    this.stream.write(chunk + '\\n');\n    this.currentSize += chunk.length;\n    \n    // 超过最大 size 或跨天则轮转\n    if (this.currentSize >= this.maxSize || this.getFilename() !== this.currentFile) {\n      this.rotate();\n      this.cleanOld();\n    }\n  }\n\n  cleanOld() {\n    fs.readdir(this.logDir, (err, files) => {\n      if (err) return;\n      \n      const logFiles = files\n        .filter(f => f.startsWith('openclaw-') && f.endsWith('.log'))\n        .map(f => ({ name: f, time: fs.statSync(path.join(this.logDir, f)).mtime }))\n        .sort((a, b) => b.time - a.time);\n      \n      // 删除旧文件\n      for (let i = this.maxFiles; i < logFiles.length; i++) {\n        fs.unlink(path.join(this.logDir, logFiles[i].name), () => {});\n      }\n    });\n  }\n\n  end() {\n    if (this.stream) {\n      this.stream.end();\n    }\n  }\n}\n\nmodule.exports = { \n  HealthChecker, \n  PrometheusMetrics, \n  ConfigReloader, \n  LogRotator \n};","path":"/home/ai/openclaw-router/deployment-ops.js"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":84427,"output":1843,"cacheRead":0,"cacheWrite":0,"totalTokens":86270,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775493293783,"responseId":"chatcmpl-1e77ff91-210b-4445-8d2b-cfad38edbb23"}}
