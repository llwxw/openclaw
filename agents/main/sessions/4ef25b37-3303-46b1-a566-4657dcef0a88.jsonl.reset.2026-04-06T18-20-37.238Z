{"type":"message","id":"2630fa42","parentId":"29628ad2","timestamp":"2026-04-06T12:32:31.733Z","message":{"role":"user","content":[{"type":"text","text":"Sender (untrusted metadata):\n```json\n{\n  \"label\": \"openclaw-control-ui\",\n  \"id\": \"openclaw-control-ui\"\n}\n```\n\n[Mon 2026-04-06 20:32 GMT+8] 有这个功能吗？先回答我：// openclaw-router.js\nconst express = require('express');\nconst { computeFineScore, getExecutionPlan } = require('./scoring');\n\nconst app = express();\napp.use(express.json());\n\n// CORS 允许前端跨域访问\napp.use((req, res, next) => {\n res.header('Access-Control-Allow-Origin', '*');\n res.header('Access-Control-Allow-Methods', 'GET, POST');\n res.header('Access-Control-Allow-Headers', 'Content-Type');\n if (req.method === 'OPTIONS') return res.sendStatus(200);\n next();\n});\n\n// 评分接口（POST /api/task）\napp.post('/api/task', async (req, res) => {\n const taskSpec = req.body.taskSpec || req.body.command;\n if (!taskSpec) {\n return res.status(400).json({ error: 'Missing taskSpec' });\n }\n try {\n // 动态评分\n const scoreResult = await computeFineScore(taskSpec);\n const totalScore = scoreResult.totalScore;\n const factors = scoreResult.factors;\n const plan = getExecutionPlan(totalScore, factors.scaleIndex || 1);\n res.json({\n taskSpec,\n score: totalScore,\n routing: plan,\n factors\n });\n } catch (err) {\n console.error('Scoring error:', err);\n res.status(500).json({ error: err.message });\n }\n});\n\n// 健康检查\napp.get('/health', (req, res) => res.json({ status: 'ok' }));\n\nconst PORT = 3102;\napp.listen(PORT, () => {\n console.log(`Scoring API listening on port ${PORT}`);\n});"}],"timestamp":1775478751728}}
