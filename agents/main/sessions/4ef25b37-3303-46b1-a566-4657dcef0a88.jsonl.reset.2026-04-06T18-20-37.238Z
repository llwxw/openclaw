{"type":"message","id":"6b3236b1","parentId":"a40229fd","timestamp":"2026-04-06T15:43:03.158Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"继续创建上下文保护模块\n\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"call_5ccdb66b85fe415c8a9f6496","name":"write","arguments":{"content":"// context-protector.js - 上下文保护垂直拓展\n// 支持精确 token 计数、增量压缩、摘要生成\n\n// 需要安装: npm install tiktoken\nlet encoding = null;\ntry {\n  const { encoding_for_model } = require('tiktoken');\n  encoding = encoding_for_model('gpt-4');\n} catch {\n  console.log('[ContextProtector] tiktoken not available, using estimation');\n}\n\n// 估算 token 数（备用方案）\nfunction estimateTokens(text) {\n  return Math.ceil(text.length / 4);\n}\n\n/**\n * 精确计算 token 数\n */\nfunction countTokens(text) {\n  if (!encoding) return estimateTokens(text);\n  try {\n    return encoding.encode(text).length;\n  } catch {\n    return estimateTokens(text);\n  }\n}\n\n// ============== 4.1 增量 token 计数 ==============\n\nclass TokenCounter {\n  constructor(maxTokens = 80000) {\n    this.maxTokens = maxTokens;\n    this.messages = [];\n    this.totalTokens = 0;\n  }\n\n  addMessage(role, content) {\n    const tokens = countTokens(content);\n    this.messages.push({ role, content, tokens });\n    this.totalTokens += tokens;\n    return this.totalTokens;\n  }\n\n  removeOldest(count = 1) {\n    let removed = 0;\n    while (removed < count && this.messages.length > 0) {\n      const msg = this.messages.shift();\n      this.totalTokens -= msg.tokens;\n      removed++;\n    }\n    return removed;\n  }\n\n  shouldCompress() {\n    return this.totalTokens > this.maxTokens * 0.8;\n  }\n\n  getTokenCount() {\n    return this.totalTokens;\n  }\n}\n\n// ============== 4.2 压缩策略 ==============\n\nclass ContextCompressor {\n  constructor(options = {}) {\n    this.keepRecent = options.keepRecent || 10;\n    this.summaryModel = options.summaryModel || 'gpt-4';\n    this.storageDir = options.storageDir || './context-storage';\n    this.enableBackup = options.enableBackup !== false;\n  }\n\n  /**\n   * 压缩上下文\n   * @param {Array} messages - 消息历史\n   * @returns {Promise<{compressed: Array, summary: string}>}\n   */\n  async compress(messages) {\n    if (messages.length <= this.keepRecent) {\n      return { compressed: messages, summary: null };\n    }\n\n    // 备份原始消息\n    if (this.enableBackup) {\n      await this.backup(messages);\n    }\n\n    // 保留最近 N 条\n    const recent = messages.slice(-this.keepRecent);\n    \n    // 压缩旧消息\n    const old = messages.slice(0, -this.keepRecent);\n    const summary = await this.summarize(old);\n\n    // 合并\n    const compressed = [\n      { role: 'system', content: `[历史摘要] ${summary}` },\n      ...recent\n    ];\n\n    return { compressed, summary };\n  }\n\n  /**\n   * 生成摘要（调用 LLM 或使用规则）\n   */\n  async summarize(messages) {\n    if (messages.length === 0) return '无历史记录';\n\n    const text = messages.map(m => `${m.role}: ${m.content}`).join('\\n');\n    \n    // 尝试使用 LLM 摘要（需要 API key）\n    if (process.env.OPENAI_API_KEY) {\n      try {\n        return await this.llmSummary(text);\n      } catch (err) {\n        console.log('[ContextProtector] LLM summary failed, using keyword extraction');\n      }\n    }\n    \n    // 回退到关键词提取\n    return this.keywordSummary(text);\n  }\n\n  async llmSummary(text) {\n    const { default: fetch } = await import('node-fetch');\n    const response = await fetch('https://api.openai.com/v1/chat/completions', {\n      method: 'POST',\n      headers: {\n        'Content-Type': 'application/json',\n        'Authorization': `Bearer ${process.env.OPENAI_API_KEY}`\n      },\n      body: JSON.stringify({\n        model: this.summaryModel,\n        messages: [{\n          role: 'system',\n          content: '请用50字以内概括以下对话的核心内容'\n        }, {\n          role: 'user',\n          content: text.slice(0, 4000)\n        }],\n        max_tokens: 100\n      })\n    });\n    \n    const data = await response.json();\n    return data.choices?.[0]?.message?.content || '摘要生成失败';\n  }\n\n  /**\n   * 关键词提取摘要（规则方法）\n   */\n  keywordSummary(text) {\n    const keywords = [];\n    const keywordPatterns = [\n      /修复.*?(bug|问题|错误)/gi,\n      /实现.*?功能/gi,\n      /部署.*?项目/gi,\n      /创建.*?文件/gi,\n      /添加.*?支持/gi,\n      /更新.*?版本/gi,\n      /配置.*?环境/gi\n    ];\n\n    for (const pattern of keywordPatterns) {\n      const matches = text.match(pattern);\n      if (matches) keywords.push(...matches);\n    }\n\n    if (keywords.length === 0) {\n      // 提取名词短语\n      const nouns = text.match(/\\b[A-Z][a-z]+(?:\\s+[A-Z][a-z]+)*\\b/g) || [];\n      return `讨论话题: ${[...new Set(nouns)].slice(0, 5).join(', ')}`;\n    }\n\n    return `主要操作: ${keywords.slice(0, 5).join('; ')}`;\n  }\n\n  async backup(messages) {\n    const fs = require('fs').promises;\n    const filename = `${this.storageDir}/context_${Date.now()}.json`;\n    await fs.mkdir(this.storageDir, { recursive: true });\n    await fs.writeFile(filename, JSON.stringify(messages));\n  }\n\n  /**\n   * 回滚到备份\n   */\n  async rollback(timestamp) {\n    const fs = require('fs').promises;\n    const filename = `${this.storageDir}/context_${timestamp}.json`;\n    const data = await fs.readFile(filename, 'utf8');\n    return JSON.parse(data);\n  }\n}\n\n// ============== 4.3 用户命令支持 ==============\n\nclass ContextCommands {\n  constructor(compressor) {\n    this.compressor = compressor;\n    this.rollbackHistory = [];\n  }\n\n  /**\n   * 处理用户命令\n   */\n  async handleCommand(command, messages) {\n    const cmd = command.toLowerCase().trim();\n\n    if (cmd === '/summarize') {\n      return await this.compressor.compress(messages);\n    }\n\n    if (cmd.startsWith('/rollback')) {\n      const timestamp = parseInt(cmd.split(' ')[1]) || Date.now() - 3600000;\n      const rolledBack = await this.compressor.rollback(timestamp);\n      this.rollbackHistory.push({ timestamp: Date.now(), messages: rolledBack });\n      return { compressed: rolledBack, summary: '已回滚' };\n    }\n\n    if (cmd === '/tokens') {\n      const total = messages.reduce((sum, m) => sum + countTokens(m.content), 0);\n      return { compressed: messages, summary: `当前 token: ${total}` };\n    }\n\n    return null;\n  }\n}\n\nmodule.exports = { \n  TokenCounter, \n  ContextCompressor, \n  ContextCommands,\n  countTokens \n};","path":"/home/ai/openclaw-router/context-protector.js"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":77764,"output":1617,"cacheRead":0,"cacheWrite":0,"totalTokens":79381,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775490159038,"responseId":"chatcmpl-93a1b3f9-7c96-4ba9-b818-af6879e668e8"}}
