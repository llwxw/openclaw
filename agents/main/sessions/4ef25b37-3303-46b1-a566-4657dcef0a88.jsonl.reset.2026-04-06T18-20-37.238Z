{"type":"message","id":"f6e8d857","parentId":"656d51f9","timestamp":"2026-04-06T17:52:19.994Z","message":{"role":"toolResult","toolCallId":"call_6limwbwimfw64cuvbgdf2bgk","toolName":"read","content":[{"type":"text","text":"const express = require('express');\nconst { createProxyMiddleware } = require('http-proxy-middleware');\nconst { computeFineScore, getExecutionPlan, getCachedScore } = require('./scoring-v7');\nconst { detectIntent } = require('./intentDetector');\n\nconst GATEWAY_URL = 'http://127.0.0.1:3108';\nconst PORT = process.env.ROUTER_PORT || 3102;\n\nconst app = express();\napp.use(express.json());\n\n// CORS 支持\napp.use((req, res, next) => {\n  res.header('Access-Control-Allow-Origin', '*');\n  res.header('Access-Control-Allow-Methods', 'GET, POST, OPTIONS');\n  res.header('Access-Control-Allow-Headers', 'Content-Type, Authorization');\n  if (req.method === 'OPTIONS') {\n    return res.sendStatus(200);\n  }\n  next();\n});\n\napp.get('/health', (req, res) => res.json({ status: 'ok', service: 'task-orchestrator' }));\n\n// 获取评分\napp.get('/api/score', async (req, res) => {\n  const taskSpec = req.query.task || '';\n  const score = await computeFineScore(taskSpec);\n  const plan = getExecutionPlan(score.totalScore, score.factors?.scaleIndex || 1);\n  res.json({ score, plan });\n});\n\n// 任务拦截端点 - 评分后返回计划\napp.post('/api/task', async (req, res) => {\n  const taskSpec = req.body?.taskSpec || '';\n  if (taskSpec) {\n    const score = await computeFineScore(taskSpec);\n    const plan = getExecutionPlan(score.totalScore, score.factors?.scaleIndex || 1);\n    console.log(`[Router] Task scored: ${score.totalScore} → ${plan.mode}`);\n    res.json({ \n      taskSpec, \n      score: score.totalScore,\n      routing: plan,\n      factors: score.factors,\n      message: 'Task scored, ready to execute'\n    });\n  } else {\n    res.status(400).json({ error: 'Missing taskSpec' });\n  }\n});\n\n// 意图判断端点\napp.post('/api/intent', async (req, res) => {\n  const { message, conversationId } = req.body;\n  const memoryStore = global.vectorMemory || null;\n  const result = await detectIntent(message, conversationId, memoryStore);\n  res.json(result);\n});\n\n// 对话路径拦截 - 意图判断 + 任务评分\napp.post('/api/chat/send', async (req, res, next) => {\n  const userMessage = req.body.message || req.body.text || req.body.content;\n  if (!userMessage) return next();\n  \n  const convId = req.body.conversationId || req.body.sessionId;\n  const memoryStore = global.vectorMemory || null;\n  \n  // 同步快速判断\n  const { isTask, confidence } = await detectIntent(userMessage, convId, memoryStore);\n  \n  if (isTask && confidence > 0.5) {\n    // 触发任务评分\n    const score = await computeFineScore(userMessage);\n    const plan = getExecutionPlan(score.totalScore, score.factors?.scaleIndex || 1);\n    console.log(`[Router] 检测到任务: \"${userMessage.slice(0,30)}...\" → 评分 ${score.totalScore} → ${plan.mode}`);\n    req.body.taskRouting = plan;\n  }\n  \n  next();\n});\n\n// 代理到 Gateway（同时支持HTTP和WebSocket）\nconst proxy = createProxyMiddleware({\n  target: GATEWAY_URL,\n  changeOrigin: true,\n  ws: true, // 支持WebSocket\n  onError: (err, req, res) => {\n    res.status(502).json({ error: 'Gateway unavailable', message: err.message });\n  }\n});\n\napp.use('/', proxy);\n\n// WebSocket Upgrade处理\napp.on('upgrade', proxy.upgrade);\n\napp.listen(PORT, () => console.log(`Router on ${PORT} → ${GATEWAY_URL}`));\nconsole.log('[Router] Task Orchestrator v3.0 ready - scoring enabled - intent detection enabled');"}],"isError":false,"timestamp":1775497939970}}
{"type":"message","id":"475f60e5","parentId":"f6e8d857","timestamp":"2026-04-06T17:52:41.081Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"用户要求全部集成，我需要把所有模块都导入并集成进去。让我修改文件，把安全模块、健康检查等都集成进去。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_aqlinacgwgcmt8ca1lxowbc6","name":"edit","arguments":{"path":"/home/ai/openclaw-router/openclaw-router.js","edits":[{"oldText":"const express = require('express');\nconst { createProxyMiddleware } = require('http-proxy-middleware');\nconst { computeFineScore, getExecutionPlan, getCachedScore } = require('./scoring-v7');\nconst { detectIntent } = require('./intentDetector');\n\nconst GATEWAY_URL = 'http://127.0.0.1:3108';","newText":"const express = require('express');\nconst { createProxyMiddleware } = require('http-proxy-middleware');\nconst { computeFineScore, getExecutionPlan, getCachedScore } = require('./scoring-v7');\nconst { SecurityChecker } = require('./security-module');\nconst { HealthChecker, PrometheusMetrics } = require('./deployment-ops');\nconst { ScoreCache } = require('./efficiency-optimization');\nconst { detectIntent } = require('./intentDetector');\n\nconst GATEWAY_URL = 'http://127.0.0.1:3108';\n\n// 初始化 v7 模块\nconst healthChecker = new HealthChecker();\nconst metrics = new PrometheusMetrics();\nconst securityChecker = new SecurityChecker();"},{"oldText":"app.get('/health', (req, res) => res.json({ status: 'ok', service: 'task-orchestrator' }));","newText":"app.get('/health', (req, res) => {\n  const health = healthChecker.getHealth();\n  res.json(health);\n});\n\napp.get('/metrics', (req, res) => {\n  res.set('Content-Type', 'text/plain');\n  res.end(metrics.toPrometheus());\n});"}]}}],"api":"openai-completions","provider":"volcengine-plan","model":"doubao-seed-2.0-lite","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":177549793999