nTimeoutMs);\n\n this.gatewaySocket.on('open', () => {\n clearTimeout(timeout);\n this.connected = true;\n this.reconnectAttempts = 0;\n log('info', `[${this.clientId}] Connected to Gateway`);\n while (this.pendingMessages.length) {\n this.gatewaySocket.send(this.pendingMessages.shift());\n }\n this.startHeartbeat();\n });\n\n this.gatewaySocket.on('message', (data, isBinary) => {\n try {\n const msg = JSON.parse(data.toString());\n // 处理认证挑战\n if (msg.type === 'event' && msg.event === 'connect.challenge') {\n const nonce = msg.payload?.nonce;\n if (nonce) {\n // 生成响应\n\n[177 more lines in file. Use offset=150 to continue.]"}],"isError":false,"timestamp":1775479749983}}
