{"type":"message","id":"c878356b","parentId":"6c3663b9","timestamp":"2026-04-06T12:46:59.881Z","message":{"role":"toolResult","toolCallId":"019d62d4ecb222d285e8fb48f0adeebe","toolName":"read","content":[{"type":"text","text":"// ws-proxy.js\n// 高鲁棒 WebSocket 代理 + 自动任务评分 + 实时提示\n// 版本: 2.0.0\n\nconst WebSocket = require('ws');\nconst crypto = require('crypto');\nconst { detectIntent } = require('./intentDetector');\nconst { computeFineScore, getExecutionPlan } = require('./scoring');\n\n// ========== 配置（支持环境变量） ==========\nconst CONFIG = {\n gatewayWsUrl: process.env.OPENCLAW_WS_URL || 'ws://localhost:3108', // Gateway 端口\n proxyPort: parseInt(process.env.PROXY_WS_PORT || '3103', 10),\n heartbeatIntervalMs: parseInt(process.env.HEARTBEAT_INTERVAL_MS || '30000', 10),\n connectionTimeoutMs: parseInt(process.env.CONNECTION_TIMEOUT_MS || '10000', 10),\n maxReconnectAttempts: parseInt(process.env.MAX_RECONNECT_ATTEMPTS || '5', 10),\n reconnectBaseDelayMs: parseInt(process.env.RECONNECT_BASE_DELAY_MS || '1000', 10),\n maxCachedMessages: parseInt(process.env.MAX_CACHED_MESSAGES || '100', 10),\n maxMessageSizeBytes: parseInt(process.env.MAX_MESSAGE_SIZE_BYTES || '1048576', 10),\n enableRateLimit: process.env.ENABLE_RATE_LIMIT !== 'false', // 默认开启\n rateLimitPerSec: parseInt(process.env.RATE_LIMIT_PER_SEC || '10', 10),\n healthPort: parseInt(process.env.HEALTH_PORT || '3104', 10),\n // 评分相关配置\n enableScoring: process.env.ENABLE_SCORING !== 'false',\n scoringTimeoutMs: parseInt(process.env.SCORING_TIMEOUT_MS || '2000', 10),\n sendHint: process.env.SEND_HINT !== 'false',\n hintCooldownMs: parseInt(process.env.HINT_COOLDOWN_MS || '5000', 10),\n};\n\n// ========== 辅助函数 ==========\nconst log = (level, msg, meta = {}) => {\n console[level](`[WSProxy] ${msg}`, meta);\n};\n\n// 提取用户文本（支持多种格式）\nconst messageExtractors = [\n (data) => { try { const p = JSON.parse(data); return p.content || p.message || p.text; } catch(e) {} },\n (data) => { try { const p = JSON.parse(data); return p.data?.message || p.data?.text; } catch(e) {} },\n];\nfunction extractUserMessage(data) {\n for (const extractor of messageExtractors) {\n const result = extractor(data);\n if (result && typeof result === 'string') return result.trim();\n }\n return null;\n}\n\n// 简单速率限制（令牌桶）\nclass RateLimiter {\n constructor(tokensPerSec) {\n\n[276 more lines in file. Use offset=51 to continue.]"}],"isError":false,"timestamp":1775479619875}}
