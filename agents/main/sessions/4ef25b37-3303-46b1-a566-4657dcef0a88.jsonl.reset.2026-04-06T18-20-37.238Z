{"type":"message","id":"816b34d6","parentId":"e5dd3a2d","timestamp":"2026-04-06T15:42:38.993Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"好的，评分模块已创建。现在继续创建其他模块。\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"call_9ef02788bbcc457988c251c8","name":"write","arguments":{"content":"// mega-executor.js - 超大任务执行器垂直拓展\n// 支持自动分片、检查点恢复、结果聚合\n\nconst { promisify } = require('util');\nconst { exec, spawn } = require('child_process');\nconst fs = require('fs').promises;\nconst path = require('path');\n\nconst execAsync = promisify(exec);\n\n// ============== 3.1 自动分片策略 ==============\n\n/**\n * 按文件列表分片\n * @param {string} inputDir - 输入目录\n * @param {number} shardSize - 每个分片的最大文件数\n * @returns {Promise<string[][]>} 分片数组\n */\nasync function shardByFiles(inputDir, shardSize = 50) {\n  const files = await globFiles(inputDir);\n  const shards = [];\n  for (let i = 0; i < files.length; i += shardSize) {\n    shards.push(files.slice(i, i + shardSize));\n  }\n  return shards;\n}\n\n/**\n * 按数值范围分片\n * @param {number} start - 起始值\n * @param {number} end - 结束值\n * @param {number} shardCount - 分片数量\n * @returns {Array<{start: number, end: number}>}\n */\nfunction shardByRange(start, end, shardCount = 4) {\n  const step = Math.ceil((end - start + 1) / shardCount);\n  const shards = [];\n  for (let i = 0; i < shardCount; i++) {\n    shards.push({\n      start: start + i * step,\n      end: Math.min(start + (i + 1) * step - 1, end)\n    });\n  }\n  return shards;\n}\n\n/**\n * 按哈希分片\n * @param {string[]} items - 项目列表\n * @param {number} shardCount - 分片数量\n * @returns {string[][]}\n */\nfunction shardByHash(items, shardCount = 4) {\n  const shards = Array.from({ length: shardCount }, () => []);\n  for (const item of items) {\n    const hash = hashString(item);\n    const shardIndex = hash % shardCount;\n    shards[shardIndex].push(item);\n  }\n  return shards;\n}\n\nfunction hashString(str) {\n  let hash = 0;\n  for (let i = 0; i < str.length; i++) {\n    const char = str.charCodeAt(i);\n    hash = ((hash << 5) - hash) + char;\n    hash = hash & hash;\n  }\n  return Math.abs(hash);\n}\n\nasync function globFiles(dir, pattern = '**/*') {\n  const { stdout } = await execAsync(`find \"${dir}\" -type f -name \"${pattern}\" 2>/dev/null | head -1000`);\n  return stdout.trim().split('\\n').filter(Boolean);\n}\n\n// ============== 3.2 检查点与断点续传 ==============\n\nclass CheckpointManager {\n  constructor(dbPath = './mega-checkpoints.db') {\n    this.dbPath = dbPath;\n    this.checkpoints = new Map();\n    this.load();\n  }\n\n  async load() {\n    try {\n      const data = await fs.readFile(this.dbPath, 'utf8');\n      const parsed = JSON.parse(data);\n      for (const [taskId, steps] of Object.entries(parsed)) {\n        this.checkpoints.set(taskId, new Map(Object.entries(steps)));\n      }\n    } catch {\n      // 文件不存在，使用空检查点\n    }\n  }\n\n  async save() {\n    const data = {};\n    for (const [taskId, steps] of this.checkpoints) {\n      data[taskId] = Object.fromEntries(steps);\n    }\n    await fs.writeFile(this.dbPath, JSON.stringify(data, null, 2));\n  }\n\n  async saveStep(taskId, stepIndex, output) {\n    if (!this.checkpoints.has(taskId)) {\n      this.checkpoints.set(taskId, new Map());\n    }\n    this.checkpoints.get(taskId).set(stepIndex, {\n      output,\n      finishedAt: Date.now()\n    });\n    await this.save();\n  }\n\n  async getLastStep(taskId) {\n    const steps = this.checkpoints.get(taskId);\n    if (!steps || steps.size === 0) return -1;\n    return Math.max(...Array.from(steps.keys()));\n  }\n\n  async clear(taskId) {\n    this.checkpoints.delete(taskId);\n    await this.save();\n  }\n}\n\n// ============== 3.3 结果聚合 ==============\n\n/**\n * 聚合多个分片的结果\n * @param {Array<{stdout: string, stderr: string, code: number}>} shardResults\n * @param {string} strategy - 聚合策略: 'concat' | 'json_array' | 'fail_fast'\n * @returns {Promise<string|object>}\n */\nasync function aggregateResults(shardResults, strategy = 'concat') {\n  switch (strategy) {\n    case 'concat':\n      return shardResults.map(r => r.stdout).join('\\n');\n    \n    case 'json_array':\n      const allData = [];\n      for (const r of shardResults) {\n        try {\n          const data = JSON.parse(r.stdout);\n          if (Array.isArray(data)) {\n            allData.push(...data);\n          } else {\n            allData.push(data);\n          }\n        } catch {\n          // 非JSON，直接添加\n          allData.push(r.stdout);\n        }\n      }\n      return JSON.stringify(allData);\n    \n    case 'fail_fast':\n      const failed = shardResults.find(r => r.code !== 0);\n      if (failed) {\n        return { success: false, error: failed.stderr || 'Task failed', output: failed.stdout };\n      }\n      return { success: true, outputs: shardResults.map(r => r.stdout) };\n    \n    default:\n      return shardResults;\n  }\n}\n\n// ============== Mega Task 执行器 ==============\n\nclass MegaExecutor {\n  constructor(options = {}) {\n    this.checkpointManager = new CheckpointManager(options.checkpointPath);\n    this.maxConcurrent = options.maxConcurrent || 4;\n    this.shardStrategy = options.shardStrategy || 'files'; // files, range, hash\n  }\n\n  /**\n   * 执行超大任务\n   * @param {Object} task - 任务配置\n   * @param {string} task.command - 要执行的命令模板\n   * @param {Array|Object} task.input - 输入数据（文件列表或数值范围）\n   * @param {Function} task.shardFn - 自定义分片函数\n   */\n  async execute(task) {\n    const taskId = `mega_${Date.now()}`;\n    const lastStep = await this.checkpointManager.getLastStep(taskId);\n    \n    // 生成分片\n    let shards;\n    if (task.shardFn) {\n      shards = task.shardFn(task.input);\n    } else {\n      shards = await this.generateShards(task);\n    }\n    \n    console.log(`[MegaExecutor] Task ${taskId}: ${shards.length} shards, last completed: ${lastStep}`);\n    \n    const results = [];\n    \n    // 并行执行分片（受 maxConcurrent 限制）\n    for (let i = 0; i < shards.length; i++) {\n      if (i <= lastStep) {\n        console.log(`[MegaExecutor] Skipping shard ${i} (already completed)`);\n        continue;\n      }\n      \n      const shard = shards[i];\n      const shardInput = typeof shard === 'string' ? shard : JSON.stringify(shard);\n      const command = task.command.replace('{{shard}}', shardInput);\n      \n      console.log(`[MegaExecutor] Executing shard ${i}/${shards.length - 1}`);\n      \n      try {\n        const result = await this.executeShard(command, task.env);\n        results.push(result);\n        \n        // 保存检查点\n        await this.checkpointManager.saveStep(taskId, i, result.stdout);\n      } catch (err) {\n        console.error(`[MegaExecutor] Shard ${i} failed:`, err.message);\n        if (task.stopOnError) {\n          throw new Error(`Shard ${i} failed, stopping: ${err.message}`);\n        }\n      }\n    }\n    \n    // 聚合结果\n    const aggregated = await aggregateResults(results, task.aggregateStrategy || 'concat');\n    \n    // 清理检查点\n    await this.checkpointManager.clear(taskId);\n    \n    return {\n      taskId,\n      totalShards: shards.length,\n      successfulShards: results.filter(r => r.code === 0).length,\n      result: aggregated\n    };\n  }\n\n  async generateShards(task) {\n    switch (this.shardStrategy) {\n      case 'files':\n        return shardByFiles(task.input, task.shardSize || 50);\n      case 'range':\n        return shardByRange(task.input.start, task.input.end, task.shardCount || 4);\n      case 'hash':\n        return shardByHash(task.input, task.shardCount || 4);\n      default:\n        return [task.input];\n    }\n  }\n\n  async executeShard(command, env = {}) {\n    return new Promise((resolve, reject) => {\n      const child = spawn('bash', ['-c', command], { \n        env: { ...process.env, ...env },\n        stdio: ['ignore', 'pipe', 'pipe']\n      });\n      \n      let stdout = '', stderr = '';\n      child.stdout.on('data', d => stdout += d);\n      child.stderr.on('data', d => stderr += d);\n      \n      child.on('close', code => {\n        resolve({ stdout, stderr, code });\n      });\n      \n      child.on('error', reject);\n      \n      // 超时处理\n      setTimeout(() => {\n        child.kill();\n        reject(new Error('Shard execution timeout'));\n      }, 300000); // 5分钟超时\n    });\n  }\n}\n\nmodule.exports = { \n  MegaExecutor, \n  shardByFiles, \n  shardByRange, \n  shardByHash, \n  CheckpointManager,\n  aggregateResults \n};","path":"/home/ai/openclaw-router/mega-executor.js"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":75545,"output":2182,"cacheRead":0,"cacheWrite":0,"totalTokens":77727,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775490126677,"responseId":"chatcmpl-ccf4e100-3f2c-4a78-8111-9db727ca30b0"}}
