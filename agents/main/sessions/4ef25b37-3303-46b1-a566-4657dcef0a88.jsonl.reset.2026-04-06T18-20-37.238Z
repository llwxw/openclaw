{"type":"message","id":"7a29c15e","parentId":"c61217f2","timestamp":"2026-04-06T16:34:07.076Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"用户让我继续，继续实现安全模块。\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"call_8dc56ec384a24f38b107a844","name":"write","arguments":{"content":"// security-module.js - 安全模块垂直拓展\n// 支持命令白名单、路径沙箱、敏感信息脱敏\n\nconst fs = require('fs');\nconst path = require('path');\n\n// 6.1 命令白名单动态管理\nclass CommandWhitelist {\n  constructor(configPath = './command-whitelist.json') {\n    this.whitelist = new Set();\n    this.patterns = [];\n    this.configPath = configPath;\n    this.load();\n  }\n\n  load() {\n    try {\n      const data = fs.readFileSync(this.configPath, 'utf8');\n      const config = JSON.parse(data);\n      \n      for (const item of config.whitelist || []) {\n        if (item.startsWith('^')) {\n          this.patterns.push(new RegExp(item));\n        } else {\n          this.whitelist.add(item);\n        }\n      }\n      console.log(`[Security] Loaded ${this.whitelist.size} whitelist entries, ${this.patterns.length} patterns`);\n    } catch {\n      console.log('[Security] No whitelist config, using defaults');\n      this.setDefaults();\n    }\n  }\n\n  setDefaults() {\n    const defaults = [\n      '/usr/bin/ls', '/usr/bin/cat', '/usr/bin/grep', '/usr/bin/find',\n      '/usr/bin/mkdir', '/usr/bin/touch', '/usr/bin/chmod', '/usr/bin/chown',\n      '/bin/bash', '/bin/sh', '/usr/bin/git', '/usr/bin/curl', '/usr/bin/wget',\n      '/usr/bin/python3', '/usr/bin/node', '/usr/bin/npm', '/usr/bin/pip3'\n    ];\n    defaults.forEach(cmd => this.whitelist.add(cmd));\n  }\n\n  isAllowed(cmd) {\n    // 解析命令路径\n    const cmdPath = cmd.split(' ')[0];\n    \n    try {\n      const resolved = fs.realpathSync(cmdPath);\n      \n      // 检查精确匹配\n      if (this.whitelist.has(resolved)) return true;\n      \n      // 检查正则模式\n      for (const pattern of this.patterns) {\n        if (pattern.test(resolved)) return true;\n      }\n      \n      return false;\n    } catch {\n      return false;\n    }\n  }\n\n  add(cmd) {\n    this.whitelist.add(cmd);\n  }\n\n  remove(cmd) {\n    this.whitelist.delete(cmd);\n  }\n}\n\n// 6.2 路径沙箱\nclass PathSandbox {\n  constructor(baseDir) {\n    this.baseDir = path.resolve(baseDir);\n  }\n\n  safeResolve(userPath) {\n    // 防止路径遍历\n    if (userPath.includes('..')) {\n      throw new Error('Path traversal not allowed');\n    }\n    \n    const resolved = path.resolve(this.baseDir, userPath);\n    \n    // 确保解析后的路径在 baseDir 内\n    if (!resolved.startsWith(this.baseDir)) {\n      throw new Error('Path escape attempt detected');\n    }\n    \n    return resolved;\n  }\n\n  validateRead(filepath) {\n    const resolved = this.safeResolve(filepath);\n    return fs.existsSync(resolved);\n  }\n\n  validateWrite(filepath) {\n    const resolved = this.safeResolve(filepath);\n    const dir = path.dirname(resolved);\n    return fs.existsSync(dir) && fs.accessSync(dir, fs.constants.W_OK);\n  }\n}\n\n// 6.3 敏感信息脱敏\nclass SensitiveRedactor {\n  constructor(patterns = null) {\n    this.patterns = patterns || [\n      /password\\s*=\\s*[\"']?[^\"'\\s]+[\"']?/gi,\n      /token\\s*=\\s*[a-f0-9]{32,}/gi,\n      /api[_-]?key\\s*=\\s*[\"']?[^\"'\\s]+[\"']?/gi,\n      /secret\\s*=\\s*[\"']?[^\"'\\s]+[\"']?/gi,\n      /Authorization:\\s*Bearer\\s+[a-zA-Z0-9._-]+/gi,\n      /Bearer\\s+[a-zA-Z0-9._-]{20,}/gi,\n      /sk-[a-zA-Z0-9]{20,}/gi,  // OpenAI API key\n      /ghp_[a-zA-Z0-9]{36}/gi   // GitHub token\n    ];\n  }\n\n  redact(text) {\n    let redacted = text;\n    \n    for (const pattern of this.patterns) {\n      redacted = redacted.replace(pattern, (match) => {\n        // 保留键名，只替换值\n        return match.replace(/=.*$/, '=***').replace(/Bearer\\s+.+/, 'Bearer ***');\n      });\n    }\n    \n    return redacted;\n  }\n\n  redactObject(obj) {\n    const str = JSON.stringify(obj);\n    return JSON.parse(this.redact(str));\n  }\n}\n\n// 安全检查汇总\nclass SecurityChecker {\n  constructor(options = {}) {\n    this.whitelist = new CommandWhitelist(options.whitelistPath);\n    this.sandbox = new PathSandbox(options.baseDir || process.cwd());\n    this.redactor = new SensitiveRedactor();\n    this.dryRun = options.dryRun || false;\n  }\n\n  checkCommand(cmd) {\n    if (!this.whitelist.isAllowed(cmd)) {\n      throw new Error(`Command not allowed: ${cmd}`);\n    }\n    return true;\n  }\n\n  checkPath(filepath, mode = 'read') {\n    if (mode === 'write') {\n      if (!this.sandbox.validateWrite(filepath)) {\n        throw new Error(`Write not allowed: ${filepath}`);\n      }\n    } else {\n      if (!this.sandbox.validateRead(filepath)) {\n        throw new Error(`Read not allowed: ${filepath}`);\n      }\n    }\n    return true;\n  }\n\n  sanitizeOutput(output) {\n    return this.redactor.redact(output);\n  }\n\n  sanitizeInput(input) {\n    if (typeof input === 'string') {\n      // 检查危险命令\n      const dangerous = /rm\\s+-rf|dd\\s+|mkfs|>:?\\s*\\/dev\\/sd/i;\n      if (dangerous.test(input)) {\n        throw new Error('Dangerous command detected');\n      }\n    }\n    return input;\n  }\n}\n\nmodule.exports = { \n  CommandWhitelist, \n  PathSandbox, \n  SensitiveRedactor, \n  SecurityChecker \n};","path":"/home/ai/openclaw-router/security-module.js"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":81772,"output":1370,"cacheRead":0,"cacheWrite":0,"totalTokens":83142,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775493227626,"responseId":"chatcmpl-98ec1f60-8487-4b2f-87d1-fbadab452e15"}}
{"type":"message","id":"3b3ab611","parentId":"7a29c15e","timestamp":"2026-04-06T16:34:07.117Z","message":{"role":"toolResult","toolCallId":"call_8dc56ec384a24f38b107a844","toolName":"write","content":[{"type":"text","text":"Successfully wrote 4713 bytes to /home/ai/openclaw-router/security-module.js"}],"isError":false,"timestamp":1775493247103}}
{"type":"message","id":"973cd94a","parentId":"3b3ab611","timestamp":"2026-04-06T16:34:53.745Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"安全模块完成，继续写效率优化和部署运维。\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"019d63a4f59b9c49205df7ab7aadf624","name":"write","arguments":{"content":"// efficiency-optimization.js - 效率优化垂直拓展\n// 支持评分结果缓存、异步日志、连接池\n\nconst crypto = require('crypto');\n\n// 7.1 评分结果缓存（LRU）\nclass ScoreCache {\n  constructor(options = {}) {\n    this.cache = new Map();\n    this.maxSize = options.maxSize || 1000;\n    this.ttl = options.ttl || 3600000; // 1小时\n  }\n\n  _hash(key) {\n    return crypto.createHash('sha256').update(key).digest('hex');\n  }\n\n  get(key) {\n    const hash = this._hash(key);\n    const entry = this.cache.get(hash);\n    \n    if (!entry) return null;\n    \n    if (Date.now() - entry.timestamp > this.ttl) {\n      this.cache.delete(hash);\n      return null;\n    }\n    \n    // 移到末尾（LRU）\n    this.cache.delete(hash);\n    this.cache.set(hash, entry);\n    return entry.data;\n  }\n\n  set(key, data) {\n    const hash = this._hash(key);\n    \n    // 超过最大 size，删除最老的\n    if (this.cache.size >= this.maxSize) {\n      const firstKey = this.cache.keys().next().value;\n      this.cache.delete(firstKey);\n    }\n    \n    this.cache.set(hash, { data, timestamp: Date.now() });\n  }\n\n  clear() {\n    this.cache.clear();\n  }\n\n  size() {\n    return this.cache.size;\n  }\n\n  keys() {\n    return Array.from(this.cache.keys());\n  }\n}\n\n// 7.2 异步日志（简单实现）\nclass AsyncLogger {\n  constructor(options = {}) {\n    this.level = options.level || 'info';\n    this.output = options.output || process.stdout;\n    this.levels = { debug: 0, info: 1, warn: 2, error: 3 };\n    this.queue = [];\n    this.processing = false;\n  }\n\n  _log(level, msg, meta = {}) {\n    if (this.levels[level] < this.levels[this.level]) return;\n    \n    const entry = { level, msg, meta, time: new Date().toISOString() };\n    this.queue.push(entry);\n    this._process();\n  }\n\n  async _process() {\n    if (this.processing || this.queue.length === 0) return;\n    this.processing = true;\n    \n    while (this.queue.length > 0) {\n      const entry = this.queue.shift();\n      const line = JSON.stringify(entry) + '\\n';\n      this.output.write(line);\n      \n      // 异步模拟\n      await new Promise(r => setTimeout(r, 1));\n    }\n    \n    this.processing = false;\n  }\n\n  debug(msg, meta) { this._log('debug', msg, meta); }\n  info(msg, meta) { this._log('info', msg, meta); }\n  warn(msg, meta) { this._log('warn', msg, meta); }\n  error(msg, meta) { this._log('error', msg, meta); }\n}\n\n// 7.3 连接池（HTTP Keep-Alive）\nclass ConnectionPool {\n  constructor(options = {}) {\n    this.maxSockets = options.maxSockets || 50;\n    this.maxFreeSockets = options.maxFreeSockets || 10;\n    this.sockets = new Map();\n    this.freeSockets = new Set();\n  }\n\n  acquire(host) {\n    // 简化实现：返回 agent\n    const http = require('http');\n    return new http.Agent({\n      keepAlive: true,\n      maxSockets: this.maxSockets,\n      maxFreeSockets: this.maxFreeSockets\n    });\n  }\n\n  destroy() {\n    for (const agent of this.sockets.values()) {\n      agent.destroy();\n    }\n    this.sockets.clear();\n    this.freeSockets.clear();\n  }\n}\n\n// 批量操作优化\nclass BatchProcessor {\n  constructor(options = {}) {\n    this.batchSize = options.batchSize || 10;\n    this.delayMs = options.delayMs || 100;\n    this.queue = [];\n    this.timer = null;\n  }\n\n  add(task) {\n    return new Promise((resolve, reject) => {\n      this.queue.push({ task, resolve, reject });\n      this._schedule();\n    });\n  }\n\n  _schedule() {\n    if (this.timer) return;\n    \n    this.timer = setTimeout(async () => {\n      const batch = this.queue.splice(0, this.batchSize);\n      this.timer = null;\n      \n      for (const { task, resolve, reject } of batch) {\n        try {\n          const result = await task();\n          resolve(result);\n        } catch (err) {\n          reject(err);\n        }\n      }\n      \n      if (this.queue.length > 0) {\n        this._schedule();\n      }\n    }, this.delayMs);\n  }\n}\n\n// 防抖/节流\nfunction debounce(fn, delay) {\n  let timer = null;\n  return (...args) => {\n    clearTimeout(timer);\n    timer = setTimeout(() => fn(...args), delay);\n  };\n}\n\nfunction throttle(fn, limit) {\n  let lastCall = 0;\n  return (...args) => {\n    const now = Date.now();\n    if (now - lastCall >= limit) {\n      lastCall = now;\n      return fn(...args);\n    }\n  };\n}\n\nmodule.exports = { \n  ScoreCache, \n  AsyncLogger, \n  ConnectionPool, \n  BatchProcessor,\n  debounce,\n  throttle\n};","path":"/home/ai/openclaw-router/efficiency-optimization.js"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":3374,"output":1212,"cacheRead":79744,"cacheWrite":0,"totalTokens":84330,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775493247123,"responseId":"019d63a4ec2eb730c7e0c0e21e1cbc59"}}
