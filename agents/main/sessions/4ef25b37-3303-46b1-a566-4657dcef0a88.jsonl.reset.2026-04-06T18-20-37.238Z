{"type":"message","id":"bbb138ad","parentId":"7d81c91d","timestamp":"2026-04-06T16:27:28.995Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"用户发的是心跳检测的提示词，但我应该优先完成之前的任务（实现剩余模块）。让我继续实现。\n\n现在先按HEARTBEAT.md规则检查，但根据之前的情况我没有需要特别处理的。继续实现剩余模块。\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n继续实现剩余模块：\n"},{"type":"toolCall","id":"019d639d940df0ec31b14158c8c1457c","name":"write","arguments":{"content":"// progress-reporter.js - 子代理进度上报垂直拓展\n// 支持自适应心跳、容错解析、限流\n\nconst EventEmitter = require('events');\n\nclass ProgressReporter extends EventEmitter {\n  constructor(options = {}) {\n    super();\n    this.heartbeatMs = options.heartbeatMs || 30000;\n    this.minHeartbeat = options.minHeartbeat || 10000;\n    this.maxHeartbeat = options.maxHeartbeat || 60000;\n    this.progressMinInterval = options.progressMinInterval || 1000;\n    \n    this.lastProgressTime = Date.now();\n    this.lastReportTime = 0;\n    this.heartbeatTimer = null;\n    this.rateLimiter = new RateLimiter(2); // 每秒最多2条\n  }\n\n  // 5.1 自适应心跳间隔\n  adjustHeartbeat(hasProgress) {\n    if (hasProgress && Date.now() - this.lastProgressTime < this.heartbeatMs * 0.5) {\n      // 频繁有进度，延长心跳间隔\n      this.heartbeatMs = Math.min(this.maxHeartbeat, this.heartbeatMs * 1.2);\n    } else if (!hasProgress && Date.now() - this.lastProgressTime > this.heartbeatMs * 1.5) {\n      // 长时间无进度，缩短心跳间隔\n      this.heartbeatMs = Math.max(this.minHeartbeat, this.heartbeatMs * 0.8);\n    }\n    return this.heartbeatMs;\n  }\n\n  // 5.2 输出解析容错\n  parseProgress(output) {\n    const patterns = [\n      /\\[PROGRESS\\]\\s*(\\d+)%/i,           // [PROGRESS] 50%\n      /Progress:\\s*(\\d+)\\/(\\d+)/i,         // Progress: 2/5\n      /Step\\s+(\\d+)\\s+of\\s+(\\d+)/i,        // Step 2 of 5\n      /(\\d+)%\\s+complete/i,                // 50% complete\n      /\\[(\\d+)\\/(\\d+)\\]/                   // [2/5]\n    ];\n\n    for (const pattern of patterns) {\n      const match = output.match(pattern);\n      if (match) {\n        if (match.length === 2) {\n          // 百分比格式\n          return { percent: parseInt(match[1]), current: null, total: null };\n        } else if (match.length === 3) {\n          // 步骤格式\n          return { \n            percent: Math.round(parseInt(match[1]) / parseInt(match[2]) * 100),\n            current: parseInt(match[1]),\n            total: parseInt(match[2])\n          };\n        }\n      }\n    }\n    return null;\n  }\n\n  // 启动监控\n  start(proc) {\n    this.proc = proc;\n    this.startTime = Date.now();\n    \n    proc.stdout.on('data', (data) => {\n      const output = data.toString();\n      const progress = this.parseProgress(output);\n      \n      if (progress) {\n        this.lastProgressTime = Date.now();\n        this.adjustHeartbeat(true);\n        \n        // 限流\n        if (this.rateLimiter.allow()) {\n          this.emit('progress', progress);\n        }\n      }\n    });\n\n    proc.stderr.on('data', (data) => {\n      const output = data.toString();\n      if (output.includes('error') || output.includes('Error') || output.includes('failed')) {\n        this.emit('error', output);\n      }\n    });\n\n    // 心跳定时器\n    this.heartbeatTimer = setInterval(() => {\n      this.emit('heartbeat', {\n        uptime: Date.now() - this.startTime,\n        memory: process.memoryUsage()\n      });\n    }, this.heartbeatMs);\n  }\n\n  // 停止\n  stop() {\n    if (this.heartbeatTimer) {\n      clearInterval(this.heartbeatTimer);\n      this.heartbeatTimer = null;\n    }\n  }\n\n  // 手动上报进度\n  report(percent, current, total, description) {\n    const now = Date.now();\n    if (now - this.lastReportTime < this.progressMinInterval) {\n      return; // 限流\n    }\n    \n    this.lastReportTime = now;\n    this.lastProgressTime = now;\n    \n    this.emit('progress', { percent, current, total, description });\n  }\n}\n\n// 5.3 限流器（令牌桶）\nclass RateLimiter {\n  constructor(tokensPerSec = 2) {\n    this.tokens = tokensPerSec;\n    this.maxTokens = tokensPerSec;\n    this.lastRefill = Date.now();\n  }\n\n  allow() {\n    const now = Date.now();\n    const elapsed = (now - this.lastRefill) / 1000;\n    this.tokens = Math.min(this.maxTokens, this.tokens + elapsed * this.tokens);\n    this.lastRefill = now;\n    \n    if (this.tokens >= 1) {\n      this.tokens--;\n      return true;\n    }\n    return false;\n  }\n}\n\n// 进度格式化\nfunction formatProgress(data) {\n  let msg = '';\n  if (data.percent !== undefined) {\n    msg += `[PROGRESS] ${data.percent}%`;\n  }\n  if (data.current !== null && data.total !== null) {\n    msg += ` | ${data.current}/${data.total}`;\n  }\n  if (data.description) {\n    msg += ` | ${data.description}`;\n  }\n  return msg;\n}\n\nmodule.exports = { ProgressReporter, RateLimiter, formatProgress };","path":"/home/ai/openclaw-router/progress-reporter.js"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":77030,"output":1291,"cacheRead":128,"cacheWrite":0,"totalTokens":78449,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775492790492,"responseId":"019d639d6b49d4fa83bd8488dad22e84"}}
