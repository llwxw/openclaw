{"type":"message","id":"3864b799","parentId":"dfc290c0","timestamp":"2026-04-06T15:42:06.619Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"42分，MEGA_TASK模式。现在按照最高分数模式执行，创建文件实现v7.0的各个模块。\n\n这是一个大任务，需要创建多个文件。让我按照MEGA_TASK模式来做：\n1. 创建各个模块的代码文件\n2. 主入口文件\n3. 配置文件\n\n让我开始实现。\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"call_ca3ff48ec4bb4f6c8d14dc12","name":"write","arguments":{"content":"// scoring-v7.js - OpenClaw 任务编排系统 v7.0 评分模块\n// 评分因子垂直拓展\n\nconst fs = require('fs');\nconst path = require('path');\nconst crypto = require('crypto');\n\nconst DEFAULT_WEIGHTS = {\n instructionCount: 0.12,\n codeLines: 0.08,\n dependencyComplexity: 0.10,\n cpuIntensity: 0.10,\n ioIntensity: 0.08,\n networkIntensity: 0.12,\n estimatedDuration: 0.12,\n scaleIndex: 0.28\n};\n\nconst WEIGHTS_BY_TYPE = {\n build: { cpuIntensity: 0.25, estimatedDuration: 0.20, scaleIndex: 0.25 },\n test: { networkIntensity: 0.20, ioIntensity: 0.15, estimatedDuration: 0.20 },\n deploy: { networkIntensity: 0.30, dependencyComplexity: 0.20, estimatedDuration: 0.20 },\n generic: DEFAULT_WEIGHTS\n};\n\n// 预定义命令强度表\nconst CPU_COMMANDS = { make: 4, gcc: 4, g++: 4, clang: 4, gzip: 3, find: 3, grep: 2, sed: 2, awk: 2 };\nconst IO_COMMANDS = { dd: 5, tar: 4, cp: 3, rsync: 4, mv: 3, cat: 2, head: 2, tail: 2 };\n\n// ============== 1.1 多源输入适配 ==============\nasync function normalizeTaskSpec(input) {\n if (typeof input === 'string') {\n   // 检查是否是脚本文件路径\n   if (input.startsWith('/') && !input.includes(' ') && await fileExists(input)) {\n     const content = await fs.promises.readFile(input, 'utf8');\n     return { type: 'script', path: input, content };\n   }\n   return { type: 'command', command: input };\n }\n if (input && input.cmd) {\n   return { type: 'structured', cmd: input.cmd, args: input.args || [], env: input.env || {} };\n }\n throw new Error('Invalid task spec');\n}\n\nasync function fileExists(filepath) {\n try {\n   await fs.promises.access(filepath);\n   return true;\n } catch {\n   return false;\n }\n}\n\n// ============== 1.2 因子计算 ==============\nfunction computeInstructionCount(taskSpec) {\n const cnt = (taskSpec.match(/&&|;|\\n|\\|/g) || []).length + 1;\n if (cnt === 1) return 1;\n if (cnt <= 3) return 2;\n if (cnt <= 6) return 3;\n if (cnt <= 10) return 4;\n return 5;\n}\n\nfunction computeCodeLines(taskSpec) {\n const lines = (taskSpec.match(/\\n/g) || []).length + 1;\n if (lines <= 10) return 1;\n if (lines <= 50) return 2;\n if (lines <= 100) return 3;\n if (lines <= 500) return 4;\n return 5;\n}\n\nfunction computeDependencyComplexity(taskSpec) {\n const lower = taskSpec.toLowerCase();\n if (/\\b(npm install|pip install|apt install|yum install|brew install|composer install|go get)\\b/.test(lower)) return 5;\n if (/\\b(npm|pip|apt|yum|brew|composer|go)\\b/.test(lower)) return 3;\n if (/\\b(import|require|include|using)\\b/.test(lower)) return 3;\n if (/install|setup|init|依赖/.test(lower)) return 2;\n return 1;\n}\n\nfunction computeCpuIntensity(taskSpec) {\n const lower = taskSpec.toLowerCase();\n for (const [cmd, score] of Object.entries(CPU_COMMANDS)) {\n   if (new RegExp(`\\\\b${cmd}\\\\b`).test(lower)) return score;\n }\n if (/compile|build|处理|计算/.test(lower)) return 3;\n return 1;\n}\n\nfunction computeIoIntensity(taskSpec) {\n const lower = taskSpec.toLowerCase();\n for (const [cmd, score] of Object.entries(IO_COMMANDS)) {\n   if (new RegExp(`\\\\b${cmd}\\\\b`).test(lower)) return score;\n }\n if (/copy|move|backup|migration|复制|移动|备份/.test(lower)) return 3;\n return 1;\n}\n\nfunction computeNetworkIntensity(taskSpec) {\n const lower = taskSpec.toLowerCase();\n // 外部网络请求\n if (/\\b(curl|wget|http|https|fetch|api)\\b/.test(lower) && !/localhost|127\\.0\\.0\\.1/.test(lower)) return 4;\n if (/\\b(curl|wget|git clone|git pull)\\b/.test(lower)) return 3;\n if (/请求|获取|下载|爬取/.test(lower)) return 3;\n return 1;\n}\n\nfunction computeEstimatedDuration(taskSpec) {\n const lower = taskSpec.toLowerCase();\n if (/\\b(sleep|wait|timeout)\\b/.test(lower)) return 5;\n if (/\\b(compile|build|make|test|deploy)\\b/.test(lower)) return 4;\n if (/编译|构建|测试|部署|等待/.test(lower)) return 4;\n return 1;\n}\n\nfunction computeScaleIndex(taskSpec) {\n const lower = taskSpec.toLowerCase();\n let score = 0;\n \n const enPatterns = [\n   'docker', 'docker-compose', 'kubernetes', 'kubectl', 'helm',\n   'terraform', 'ansible', 'jenkins', 'gitlab', 'github actions', 'ci cd',\n   'git clone', 'npm install', 'pip install', 'yarn', 'make', 'build', 'compile', 'deploy',\n   'cluster', 'distributed', 'parallel', 'shard'\n ];\n \n const cnPatterns = [\n   'docker', '容器', 'k8s', '部署', '发布', '克隆', '安装依赖', '集群',\n   '编译', '构建', '打包', '测试', '迁移', '备份', '同步', '批量', '并行',\n   '学习', '执行', '实现', '开发', '设计', '系统', '模块', '功能',\n   '垂直', '拓展', '优化', '保护', '安全', '运维'\n ];\n \n for (const p of enPatterns) { if (lower.includes(p)) score += 1; }\n for (const p of cnPatterns) { if (taskSpec.includes(p)) score += 1; }\n \n return Math.min(5, Math.max(1, score));\n}\n\n// ============== 1.3 任务类型检测 ==============\nfunction detectTaskType(taskSpec) {\n const lower = taskSpec.toLowerCase();\n if (/test|spec|jest|pytest|mocha/.test(lower)) return 'test';\n if (/build|compile|make|gcc|g\\+\\+/.test(lower)) return 'build';\n if (/deploy|publish|push|release/.test(lower)) return 'deploy';\n return 'generic';\n}\n\nfunction getWeights(taskType) {\n return WEIGHTS_BY_TYPE[taskType] || DEFAULT_WEIGHTS;\n}\n\n// ============== 主评分函数 ==============\nasync function computeFineScore(taskSpec) {\n const normalized = await normalizeTaskSpec(taskSpec);\n const taskType = detectTaskType(taskSpec);\n const weights = getWeights(taskType);\n \n const factors = {\n   instructionCount: computeInstructionCount(normalized.content || normalized.command || ''),\n   codeLines: computeCodeLines(normalized.content || normalized.command || ''),\n   dependencyComplexity: computeDependencyComplexity(taskSpec),\n   cpuIntensity: computeCpuIntensity(taskSpec),\n   ioIntensity: computeIoIntensity(taskSpec),\n   networkIntensity: computeNetworkIntensity(taskSpec),\n   estimatedDuration: computeEstimatedDuration(taskSpec),\n   scaleIndex: computeScaleIndex(taskSpec)\n };\n \n let weighted = 0;\n for (const [k, v] of Object.entries(factors)) {\n   weighted += v * (weights[k] || 0);\n }\n \n const totalScore = Math.min(100, Math.round(weighted * 20));\n return { totalScore, factors, taskType, weights };\n}\n\n// ============== 2.3 路由规则配置化 ==============\nconst ROUTE_RULES = [\n { score_min: 0, score_max: 20, mode: 'DIRECT', timeout: 30, mem_mb: null },\n { score_min: 21, score_max: 40, mode: 'STEP_ARCHIVE', step_timeout: 60, mem_mb: 1024 },\n { score_min: 41, score_max: 60, mode: 'SPAWN_SUBAGENT', timeout_formula: 'max(60, score*3)', mem_mb: 2048 },\n { score_min: 61, score_max: 80, mode: 'PARALLEL_SHARDS', timeout_formula: 'max(60, score*2)', mem_mb: 2048 },\n { score_min: 81, score_max: 100, mode: 'MEGA_TASK', timeout: 7200, mem_mb: 8192 },\n { scale_index_min: 4, mode: 'MEGA_TASK', timeout: 7200, mem_mb: 8192 }\n];\n\nfunction getExecutionPlan(score, scaleIndex = 1) {\n // 先检查 scaleIndex\n if (scaleIndex >= 4) {\n   return { mode: 'MEGA_TASK', timeoutSec: 7200, memLimitMB: 8192 };\n }\n \n // 按分数段匹配\n for (const rule of ROUTE_RULES) {\n   if (score >= rule.score_min && score <= rule.score_max) {\n     const plan = { mode: rule.mode };\n     \n     if (rule.timeout) plan.timeoutSec = rule.timeout;\n     if (rule.step_timeout) plan.stepTimeoutSec = rule.step_timeout;\n     if (rule.timeout_formula) {\n       plan.timeoutSec = eval(rule.timeout_formula.replace('score', score));\n     }\n     if (rule.mem_mb !== undefined) plan.memLimitMB = rule.mem_mb;\n     \n     return plan;\n   }\n }\n \n return { mode: 'DIRECT', timeoutSec: 30 };\n}\n\n// ============== 评分缓存 (7.1 效率优化) ==============\nconst scoreCache = new Map();\nconst CACHE_TTL = 3600000; // 1小时\n\nasync function getCachedScore(taskSpec) {\n const key = crypto.createHash('sha256').update(taskSpec).digest('hex');\n const cached = scoreCache.get(key);\n if (cached && Date.now() - cached.timestamp < CACHE_TTL) {\n   return cached.data;\n }\n const score = await computeFineScore(taskSpec);\n scoreCache.set(key, { data: score, timestamp: Date.now() });\n // 限制缓存大小\n if (scoreCache.size > 1000) {\n   const firstKey = scoreCache.keys().next().value;\n   scoreCache.delete(firstKey);\n }\n return score;\n}\n\nmodule.exports = { \n computeFineScore, \n getExecutionPlan, \n getCachedScore,\n normalizeTaskSpec,\n detectTaskType,\n ROUTE_RULES\n};","path":"/home/ai/openclaw-router/scoring-v7.js"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":72988,"output":2521,"cacheRead":0,"cacheWrite":0,"totalTokens":75509,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775490092135,"responseId":"chatcmpl-c99b4fc6-8a61-43dd-9422-52a1846db5d0"}}
