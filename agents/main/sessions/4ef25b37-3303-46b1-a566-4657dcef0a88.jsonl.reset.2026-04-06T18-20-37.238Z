{"type":"message","id":"f084e41a","parentId":"0ed0ac05","timestamp":"2026-04-06T13:27:46.432Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"用户说之前写过精细的动态版。是的，之前我写过的精细版（8个因子）有中英文关键词匹配，那个更精细。让我把那个版本拿出来改进一下。\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"019d62f93ffaaa922bf918273c26fce6","name":"write","arguments":{"content":"// scoring.js - 动态评分 v2.0（精细版）\nfunction computeComplexity(taskSpec) {\n const cmdCount = (taskSpec.match(/&&|;|\\n/g) || []).length + 1;\n if (cmdCount === 1) return 1;\n if (cmdCount <= 3) return 3;\n if (cmdCount <= 6) return 4;\n return 5;\n}\n\nfunction computeNetworkIntensity(taskSpec) {\n const lower = taskSpec.toLowerCase();\n // 英文关键词\n if (/\\b(curl|wget|npm install|pip install|git clone|yarn|apt|yum|brew)\\b/.test(lower)) return 5;\n // 中文关键词\n if (/安装依赖|克隆|下载|请求|获取|pip|npm|yarn/.test(taskSpec)) return 5;\n return 1;\n}\n\nfunction computeEstimatedDuration(taskSpec) {\n const lower = taskSpec.toLowerCase();\n // 英文\n if (/\\b(sleep|make|compile|build|test|deploy|install)\\b/.test(lower)) return 4;\n // 中文\n if (/编译|构建|测试|部署|安装|等待|睡眠/.test(taskSpec)) return 4;\n return 1;\n}\n\nasync function computeFineScore(taskSpec) {\n const factors = {\n   instructionCount: computeComplexity(taskSpec),\n   networkIntensity: computeNetworkIntensity(taskSpec),\n   estimatedDuration: computeEstimatedDuration(taskSpec),\n };\n const total = (factors.instructionCount * 0.4 + factors.networkIntensity * 0.3 + factors.estimatedDuration * 0.3);\n const totalScore = Math.min(100, Math.max(0, Math.round(total / 5 * 100)));\n return { totalScore, factors };\n}\n\nfunction getExecutionPlan(score, scaleIndex = 1) {\n if (score <= 20) return { mode: 'DIRECT', timeoutSec: 30 };\n if (score <= 40) return { mode: 'STEP_ARCHIVE', stepTimeoutSec: 60, memLimitMB: 1024 };\n if (score <= 60) return { mode: 'SPAWN_SUBAGENT', timeoutSec: Math.max(60, score), memLimitMB: 2048 };\n return { mode: 'MEGA_TASK', timeoutSec: 7200, memLimitMB: 8192 };\n}\n\nmodule.exports = { computeFineScore, getExecutionPlan };","path":"/home/ai/openclaw-router/scoring.js"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":485,"output":587,"cacheRead":53760,"cacheWrite":0,"totalTokens":54832,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775482040508,"responseId":"019d62f932e73919d5a082377558045e"}}
