{"type":"message","id":"c5178eb7","parentId":"20a162c8","timestamp":"2026-04-06T15:36:00.303Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"用户要切换到精细版评分算法。\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"call_672329e3f3eb4daaa26ef4a2","name":"write","arguments":{"content":"// scoring.js - 精细评分 v2.0（8因子）\n\nconst WEIGHTS = {\n instructionCount: 0.12,\n codeLines: 0.08,\n dependencyComplexity: 0.10,\n cpuIntensity: 0.10,\n ioIntensity: 0.08,\n networkIntensity: 0.12,\n estimatedDuration: 0.12,\n scaleIndex: 0.28\n};\n\nfunction computeComplexity(taskSpec) {\n const cnt = (taskSpec.match(/&&|;|\\n/g) || []).length + 1;\n if (cnt === 1) return 1;\n if (cnt <= 3) return 2;\n if (cnt <= 6) return 3;\n if (cnt <= 10) return 4;\n return 5;\n}\n\nfunction computeCodeLines(taskSpec) {\n const lines = (taskSpec.match(/\\n/g) || []).length + 1;\n if (lines <= 10) return 1;\n if (lines <= 50) return 2;\n if (lines <= 100) return 3;\n if (lines <= 500) return 4;\n return 5;\n}\n\nfunction computeScaleIndex(taskSpec) {\n const lower = taskSpec.toLowerCase();\n let score = 0;\n \n const enPatterns = [\n   'docker', 'docker-compose', 'kubernetes', 'kubectl', 'helm',\n   'terraform', 'ansible', 'jenkins', 'gitlab', 'github actions',\n   'git clone', 'npm install', 'pip install', 'make', 'build', 'compile', 'deploy'\n ];\n \n const cnPatterns = [\n   'docker', '容器', 'k8s', '部署', '发布', '克隆', '安装依赖',\n   '编译', '构建', '打包', '测试', '迁移', '备份', '同步', '批量'\n ];\n \n for (const p of enPatterns) { if (lower.includes(p)) score += 1; }\n for (const p of cnPatterns) { if (taskSpec.includes(p)) score += 1; }\n \n return Math.min(5, Math.max(1, score));\n}\n\nasync function computeFineScore(taskSpec) {\n const factors = {\n   instructionCount: computeComplexity(taskSpec),\n   codeLines: computeCodeLines(taskSpec),\n   dependencyComplexity: /npm install|pip install|apt|yum|brew|安装依赖/i.test(taskSpec) ? 4 : \n                          /install|setup|init/i.test(taskSpec) ? 2 : 1,\n   cpuIntensity: /make|compile|gcc|g\\+\\+|clang|build|编译|构建|处理/i.test(taskSpec) ? 4 : 1,\n   ioIntensity: /cp|mv|tar|dd|rsync|backup|dump|复制|移动|备份|迁移/i.test(taskSpec) ? 4 : 1,\n   networkIntensity: /curl|wget|git clone|fetch|download|http|https|请求|获取/i.test(taskSpec) ? 4 : 1,\n   estimatedDuration: /sleep|wait|timeout|等待/i.test(taskSpec) ? 4 : \n                      /compile|build|install|test|编译|构建|测试|处理/i.test(taskSpec) ? 3 : 1,\n   scaleIndex: computeScaleIndex(taskSpec)\n };\n \n let weighted = 0;\n for (const [k, v] of Object.entries(factors)) {\n   weighted += v * WEIGHTS[k];\n }\n \n const totalScore = Math.min(100, Math.round(weighted * 20));\n return { totalScore, factors };\n}\n\nfunction getExecutionPlan(score, scaleIndex) {\n if (scaleIndex >= 4) return { mode: 'MEGA_TASK', timeoutSec: 7200, memLimitMB: 8192 };\n if (score <= 20) return { mode: 'DIRECT', timeoutSec: 30 };\n if (score <= 40) return { mode: 'STEP_ARCHIVE', stepTimeoutSec: 60, memLimitMB: 1024 };\n if (score <= 60) return { mode: 'SPAWN_SUBAGENT', timeoutSec: Math.max(60, score * 3), memLimitMB: 2048 };\n if (score <= 80) return { mode: 'PARALLEL_SHARDS', timeoutSec: Math.max(120, score * 2), memLimitMB: 2048 };\n return { mode: 'MEGA_TASK', timeoutSec: 7200, memLimitMB: 8192 };\n}\n\nmodule.exports = { computeFineScore, getExecutionPlan };","path":"/home/ai/openclaw-router/scoring.js"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":69828,"output":1014,"cacheRead":0,"cacheWrite":0,"totalTokens":70842,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775489746801,"responseId":"chatcmpl-5f098335-9727-4d17-8bd8-36ec5deba6f7"}}
