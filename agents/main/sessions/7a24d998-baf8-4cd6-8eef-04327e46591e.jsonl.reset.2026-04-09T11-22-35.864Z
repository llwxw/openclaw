{"type":"message","id":"30478e9f","parentId":"dfb9e933","timestamp":"2026-04-09T04:48:57.777Z","message":{"role":"toolResult","toolCallId":"call_6519ff9315f94c50b4958e9b","toolName":"read","content":[{"type":"text","text":"const express = require('express');\nconst { createProxyMiddleware } = require('http-proxy-middleware');\nconst { computeFineScore, getExecutionPlan, getCachedScore } = require('./scoring-v7');\nconst { SecurityChecker } = require('./security-module');\nconst { HealthChecker, PrometheusMetrics } = require('./deployment-ops');\nconst { ScoreCache } = require('./efficiency-optimization');\nconst { detectIntent } = require('./intentDetector');\n\nconst GATEWAY_URL = 'http://127.0.0.1:3108';\n\n// 初始化 v7 模块\nconst healthChecker = new HealthChecker();\nconst metrics = new PrometheusMetrics();\nconst securityChecker = new SecurityChecker();\nconst PORT = process.env.ROUTER_PORT || 3102;\n\nconst app = express();\napp.use(express.json());\n\n// CORS 支持\napp.use((req, res, next) => {\n  res.header('Access-Control-Allow-Origin', '*');\n  res.header('Access-Control-Allow-Methods', 'GET, POST, OPTIONS');\n  res.header('Access-Control-Allow-Headers', 'Content-Type, Authorization');\n  if (req.method === 'OPTIONS') {\n    return res.sendStatus(200);\n  }\n  next();\n});\n\napp.get('/health', (req, res) => {\n  const health = healthChecker.getHealth();\n  res.json(health);\n});\n\napp.get('/metrics', (req, res) => {\n  res.set('Content-Type', 'text/plain');\n  res.end(metrics.toPrometheus());\n});\n\n// 获取评分\napp.get('/api/score', async (req, res) => {\n  const taskSpec = req.query.task || '';\n  const score = await computeFineScore(taskSpec);\n  const plan = getExecutionPlan(score.totalScore, score.factors?.scaleIndex || 1);\n  res.json({ score, plan });\n});\n\n// 任务拦截端点 - 评分后返回计划\napp.post('/api/task', async (req, res) => {\n\n[121 more lines in file. Use offset=51 to continue.]"}],"isError":false,"timestamp":1775710137769}}
{"type":"message","id":"0e78fbc1","parentId":"30478e9f","timestamp":"2026-04-09T04:49:17.144Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"让我看一下更多代码，然后添加一个调用场景分类器的 API 端点。路由器是 Node.js，但场景分类器是 Python。比较简单的方案是在路由器中添加一个代理到 Python API (8080)，或者直接通过 HTTP 调用 Python 服务。\n\n让我添加一个 /api/classify 端点来代理到 Python 服务。\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"019d7092196ca3b7ca80fee6a25fb03e","name":"read","arguments":{"limit":50,"offset":70,"path":"/home/ai/openclaw-router/openclaw-router.js"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":74122,"output":120,"cacheRead":1152,"cacheWrite":0,"totalTokens":75394,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775710137781,"responseId":"019d7091d88f78365056280236997739"}}
{"type":"message","id":"1ec3fa17","parentId":"0e78fbc1","timestamp":"2026-04-09T04:49:17.197Z","message":{"role":"toolResult","toolCallId":"019d7092196ca3b7ca80fee6a25fb03e","toolName":"read","content":[{"type":"text","text":"});\n\n// 意图判断端点\napp.post('/api/intent', async (req, res) => {\n  const { message, conversationId } = req.body;\n  const memoryStore = global.vectorMemory || null;\n  const result = await detectIntent(message, conversationId, memoryStore);\n  res.json(result);\n});\n\n// 对话路径拦截 - 意图判断 + 任务评分\napp.post('/api/chat/send', async (req, res, next) => {\n  const userMessage = req.body.message || req.body.text || req.body.content;\n  if (!userMessage) return next();\n  \n  const convId = req.body.conversationId || req.body.sessionId;\n  const memoryStore = global.vectorMemory || null;\n  \n  // 同步快速判断\n  const { isTask, confidence } = await detectIntent(userMessage, convId, memoryStore);\n  \n  if (isTask && confidence > 0.5) {\n    // 触发任务评分\n    const score = await computeFineScore(userMessage);\n    const plan = getExecutionPlan(score.totalScore, score.factors?.scaleIndex || 1);\n    console.log(`[Router] 检测到任务: \"${userMessage.slice(0,30)}...\" → 评分 ${score.totalScore} → ${plan.mode}`);\n    // 记录指标\n    metrics.counter('openclaw_tasks_total').inc();\n    metrics.counter('openclaw_task_routes', { mode: plan.mode }).inc();\n    healthChecker.recordTask(plan.mode, score.totalScore);\n    req.body.taskRouting = plan;\n  }\n  \n  next();\n});\n\n// 代理到 Gateway（同时支持HTTP和WebSocket）\nconst proxy = createProxyMiddleware({\n  target: GATEWAY_URL,\n  changeOrigin: true,\n  ws: true, // 支持WebSocket\n  onError: (err, req, res) => {\n    res.status(502).json({ error: 'Gateway unavailable', message: err.message });\n  }\n});\n\napp.use('/', proxy);\n\n// WebSocket Upgrade处理 + 消息拦截\nconst server = require('http').createServer(app);\n\n[52 more lines in file. Use offset=120 to continue.]"}],"isError":false,"timestamp":1775710157188}}
