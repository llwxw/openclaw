{"type":"message","id":"93e1ee4b","parentId":"3ccebceb","timestamp":"2026-04-08T17:07:27.985Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me implement the classifier model based on embedding vectors.\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"call_18bb8f92388c45cfafa93a49","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\n场景分类器 - 基于嵌入向量的轻量级分类器\n使用 sentence-transformers + sklearn NearestNeighbors\n\"\"\"\n\nimport numpy as np\nimport os\nimport pickle\n\nclass SceneClassifier:\n    def __init__(self, model_name=\"paraphrase-multilingual-MiniLM-L12-v2\"):\n        self.model_name = model_name\n        self.encoder = None\n        self.labels = []\n        self.embeddings = None\n        self.knn = None\n        self.label_to_id = {}\n        \n    def _load_encoder(self):\n        \"\"\"延迟加载编码器\"\"\"\n        if self.encoder is None:\n            try:\n                from sentence_transformers import SentenceTransformer\n                self.encoder = SentenceTransformer(self.model_name)\n                print(f\"Loaded encoder: {self.model_name}\")\n            except ImportError:\n                raise ImportError(\"sentence-transformers not installed. Run: pip install sentence-transformers\")\n    \n    def fit(self, texts, labels):\n        \"\"\"训练：计算所有标注样本的嵌入向量，建立 KNN 索引\"\"\"\n        self._load_encoder()\n        \n        self.labels = list(set(labels))\n        self.label_to_id = {l: i for i, l in enumerate(self.labels)}\n        \n        print(f\"Encoding {len(texts)} samples...\")\n        self.embeddings = self.encoder.encode(texts, show_progress_bar=True)\n        \n        self.label_ids = [self.label_to_id[l] for l in labels]\n        \n        # 使用 KNN 做最近邻分类\n        from sklearn.neighbors import NearestNeighbors\n        self.knn = NearestNeighbors(n_neighbors=3, metric=\"cosine\")\n        self.knn.fit(self.embeddings)\n        \n        print(f\"Trained on {len(texts)} samples, {len(self.labels)} classes\")\n    \n    def predict(self, text, threshold=0.3):\n        \"\"\"预测场景标签，返回标签和置信度\"\"\"\n        if self.knn is None:\n            raise ValueError(\"Classifier not trained. Call fit() first.\")\n        \n        vec = self.encoder.encode([text])\n        distances, indices = self.knn.kneighbors(vec)\n        \n        # 取最近邻的标签，加权投票\n        weights = 1 - distances[0]  # cosine 距离转相似度\n        \n        if weights[0] < threshold:\n            return None, 0.0  # 低于阈值，拒绝分类，走默认 LLM\n        \n        label_votes = {}\n        for idx, w in zip(indices[0], weights):\n            lbl = self.labels[self.label_ids[idx]]\n            label_votes[lbl] = label_votes.get(lbl, 0) + w\n        \n        best_label = max(label_votes, key=label_votes.get)\n        confidence = label_votes[best_label] / sum(weights)\n        \n        return best_label, confidence\n    \n    def predict_batch(self, texts, threshold=0.3):\n        \"\"\"批量预测\"\"\"\n        return [self.predict(t, threshold) for t in texts]\n    \n    def save(self, path):\n        \"\"\"保存模型\"\"\"\n        os.makedirs(os.path.dirname(path), exist_ok=True)\n        with open(path, 'wb') as f:\n            pickle.dump({\n                'model_name': self.model_name,\n                'labels': self.labels,\n                'label_to_id': self.label_to_id,\n                'embeddings': self.embeddings,\n                'label_ids': self.label_ids,\n            }, f)\n        print(f\"Model saved to {path}\")\n    \n    @classmethod\n    def load(cls, path):\n        \"\"\"加载模型\"\"\"\n        with open(path, 'rb') as f:\n            data = pickle.load(f)\n        \n        obj = cls(model_name=data['model_name'])\n        obj._load_encoder()\n        \n        obj.labels = data['labels']\n        obj.label_to_id = data['label_to_id']\n        obj.embeddings = data['embeddings']\n        obj.label_ids = data['label_ids']\n        \n        from sklearn.neighbors import NearestNeighbors\n        obj.knn = NearestNeighbors(n_neighbors=3, metric=\"cosine\")\n        obj.knn.fit(obj.embeddings)\n        \n        print(f\"Model loaded from {path}\")\n        return obj\n\n\n# 测试\nif __name__ == \"__main__\":\n    from data.synthetic_training_data import generate_training_data\n    \n    # 生成训练数据\n    data = generate_training_data()\n    texts, labels = zip(*data)\n    \n    # 训练\n    clf = SceneClassifier()\n    clf.fit(list(texts), list(labels))\n    \n    # 测试预测\n    test_cases = [\n        \"帮我分析代码质量\",\n        \"服务器起不来了\",\n        \"nginx\",\n        \"我是新手\",\n        \"任务123完成了吗\",\n    ]\n    \n    print(\"\\n=== 预测测试 ===\")\n    for text in test_cases:\n        label, conf = clf.predict(text)\n        print(f\"Input: {text}\")\n        print(f\"  → {label} (confidence: {conf:.2f})\")\n    \n    # 保存模型\n    clf.save(\"models/scene_classifier.pkl\")","path":"~/.openclaw/workspace/skills/scene-classifier/classifier/scene_classifier.py"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":56355,"output":1128,"cacheRead":0,"cacheWrite":0,"totalTokens":57483,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775668027153,"responseId":"chatcmpl-89aa102d-9a91-4983-80ce-87a39a3adaf5"}}
