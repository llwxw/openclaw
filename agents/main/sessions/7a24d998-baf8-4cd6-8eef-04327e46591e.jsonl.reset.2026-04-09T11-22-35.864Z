{"type":"message","id":"1d78407c","parentId":"202221c5","timestamp":"2026-04-09T06:33:09.151Z","message":{"role":"toolResult","toolCallId":"019d70f1bf3bf1d7d34bae6543e27973","toolName":"read","content":[{"type":"text","text":"  \n  next();\n});\n\n// 代理到 Gateway（同时支持HTTP和WebSocket）\nconst proxy = createProxyMiddleware({\n  target: GATEWAY_URL,\n  changeOrigin: true,\n  ws: true, // 支持WebSocket\n  onError: (err, req, res) => {\n    res.status(502).json({ error: 'Gateway unavailable', message: err.message });\n  }\n});\n\napp.use('/', proxy);\n\n// WebSocket Upgrade处理 + 消息拦截\nconst server = require('http').createServer(app);\n\nserver.on('upgrade', (request, socket, head) => {\n  // 保存原始socket，添加监听器\n  const originalSocket = socket;\n  \n  // 包裹socket，捕获所有data事件\n  const originalEmit = socket.emit;\n  socket.emit = function(event, ...args) {\n    if (event === 'data') {\n      const data = args[0];\n      // 调试：打印原始数据前50字节\n      const raw = data.toString();\n\n[40 more lines in file. Use offset=155 to continue.]"}],"isError":false,"timestamp":1775716389141}}
{"type":"message","id":"c4df362d","parentId":"1d78407c","timestamp":"2026-04-09T06:33:29.936Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"我看到 `/api/chat/send` 在第 130 行调用 `next()` 之后会转发到 Gateway。我需要修改这里，让它在转发之前先进行自动评分和分类。\n\n让我修改 chat/send 的逻辑来添加自动评分和分类。\n\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"call_c929d5a1603743788bf701c7","name":"edit","arguments":{"edits":[{"newText":"// 对话路径拦截 - 意图判断 + 任务评分 + 场景分类\napp.post('/api/chat/send', async (req, res, next) => {\n  const userMessage = req.body.message || req.body.text || req.body.content;\n  if (!userMessage) return next();\n  \n  const convId = req.body.conversationId || req.body.sessionId;\n  const memoryStore = global.vectorMemory || null;\n  \n  // 0. 硬拦截检查\n  const blocked = criticalIntercept(userMessage);\n  if (blocked) {\n    console.log(`[Router] CRITICAL 拦截: \"${userMessage.slice(0,20)}...\"`);\n    return res.json({ reply: blocked, blocked: true, intent: null, score: null, scene: null });\n  }\n  \n  // 1. 意图判断 (必做)\n  const { isTask, confidence } = await detectIntent(userMessage, convId, memoryStore);\n  console.log(`[Router] 意图判断: isTask=${isTask}, confidence=${confidence}`);\n  \n  let scoreResult = null;\n  let sceneResult = null;\n  \n  // 2. 评分 + 分类联动 (根据意图结果触发)\n  if (isTask && confidence > 0.5) {\n    // 任务意图明确 → 评分 + 分类并行\n    console.log(`[Router] 任务意图明确，并行调用评分和分类...`);\n    \n    const [scoreData, classifyData] = await Promise.all([\n      computeFineScore(userMessage),\n      sceneClassify(userMessage).catch(e => ({ label: 'default', confidence: 0, meta: 'error', error: e.message }))\n    ]);\n    \n    scoreResult = {\n      totalScore: scoreData.totalScore,\n      plan: getExecutionPlan(scoreData.totalScore, scoreData.factors?.scaleIndex || 1),\n      factors: scoreData.factors\n    };\n    \n    sceneResult = classifyData;\n    \n    console.log(`[Router] 评分: ${scoreResult.totalScore} → ${scoreResult.plan.mode}, 场景: ${sceneResult.label} [${sceneResult.meta}]`);\n    \n    // 记录指标\n    metrics.counter('openclaw_tasks_total').inc();\n    metrics.counter('openclaw_task_routes', { mode: scoreResult.plan.mode }).inc();\n    healthChecker.recordTask(scoreResult.plan.mode, scoreResult.totalScore);\n    \n    req.body.taskRouting = scoreResult.plan;\n    req.body.scene = sceneResult.label;\n    req.body.sceneMeta = sceneResult.meta;\n    \n  } else if (confidence > 0.3) {\n    // 意图不确定但可能有任务 → 只分类\n    console.log(`[Router] 意图不确定，只调用分类...`);\n    sceneResult = await sceneClassify(userMessage).catch(e => ({ label: 'default', confidence: 0, meta: 'error' }));\n    console.log(`[Router] 场景: ${sceneResult.label} [${sceneResult.meta}]`);\n    req.body.scene = sceneResult.label;\n    req.body.sceneMeta = sceneResult.meta;\n  }\n  \n  // 3. 记录元判断日志\n  logMeta({\n    userMessage: userMessage.slice(0, 200),\n    intent: { isTask, confidence },\n    score: scoreResult,\n    scene: sceneResult\n  });\n  \n  // 返回初步结果 (不等待 LLM)\n  // 将结果存入 res.locals 供后续使用\n  res.locals.intentResult = { isTask, confidence };\n  res.locals.scoreResult = scoreResult;\n  res.locals.sceneResult = sceneResult;\n  \n  // 继续转发到 Gateway\n  next();\n});","oldText":"// 对话路径拦截 - 意图判断 + 任务评分\napp.post('/api/chat/send', async (req, res, next) => {\n  const userMessage = req.body.message || req.body.text || req.body.content;\n  if (!userMessage) return next();\n  \n  const convId = req.body.conversationId || req.body.sessionId;\n  const memoryStore = global.vectorMemory || null;\n  \n  // 同步快速判断\n  const { isTask, confidence } = await detectIntent(userMessage, convId, memoryStore);\n  \n  if (isTask && confidence > 0.5) {\n    // 触发任务评分\n    const score = await computeFineScore(userMessage);\n    const plan = getExecutionPlan(score.totalScore, score.factors?.scaleIndex || 1);\n    console.log(`[Router] 检测到任务: \"${userMessage.slice(0,30)}...\" → 评分 ${score.totalScore} → ${plan.mode}`);\n    // 记录指标\n    metrics.counter('openclaw_tasks_total').inc();\n    metrics.counter('openclaw_task_routes', { mode: plan.mode }).inc();\n    healthChecker.recordTask(plan.mode, score.totalScore);\n    req.body.taskRouting = plan;\n  }\n  \n  next();\n});"}],"path":"/home/ai/openclaw-router/openclaw-router.js"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":132776,"output":1282,"cacheRead":0,"cacheWrite":0,"totalTokens":134058,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775716389162,"responseId":"chatcmpl-3376f9e8-8928-4ac1-9cf6-4a1c84207055"}}
