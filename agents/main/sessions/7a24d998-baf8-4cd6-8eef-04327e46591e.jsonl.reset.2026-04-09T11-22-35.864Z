{"type":"message","id":"4156f51d","parentId":"2ee52d3e","timestamp":"2026-04-09T04:00:07.111Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在创建 API 服务文件。\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"call_d8daee7a53f24114ba6e9cbb","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\nScene Classifier API 服务\n启动: python api_server.py\n访问: http://localhost:8080\n\"\"\"\n\nimport os\nimport sys\nos.environ['HF_ENDPOINT'] = 'https://hf-mirror.com'\n\nfrom fastapi import FastAPI, HTTPException\nfrom pydantic import BaseModel\nfrom fastapi.middleware.cors import CORSMiddleware\nimport uvicorn\n\n# 添加路径\nsys.path.insert(0, '/home/ai/.openclaw/workspace/skills/scene-classifier')\n\nfrom pipeline import OpenClawPipeline\nfrom feedback.collector import FeedbackLoop\n\napp = FastAPI(title=\"Scene Classifier API\", version=\"1.0\")\n\n# CORS 支持\napp.add_middleware(\n    CORSMiddleware,\n    allow_origins=[\"*\"],\n    allow_credentials=True,\n    allow_methods=[\"*\"],\n    allow_headers=[\"*\"],\n)\n\n# 初始化\nMODEL_PATH = \"/home/ai/.openclaw/workspace/skills/scene-classifier/models/scene_classifier.pkl\"\n\ntry:\n    pipeline = OpenClawPipeline(MODEL_PATH)\n    feedback = FeedbackLoop()\n    print(f\"✅ Model loaded from {MODEL_PATH}\")\nexcept Exception as e:\n    pipeline = None\n    print(f\"⚠️ Model not loaded: {e}\")\n\n# 请求模型\nclass ClassifyRequest(BaseModel):\n    text: str\n    context: dict = {}\n\nclass FeedbackRequest(BaseModel):\n    text: str\n    predicted_label: str\n    feedback_type: str  # \"correct\", \"wrong_label\", \"not_satisfied\"\n    correct_label: str = None\n\n@app.get(\"/\")\ndef root():\n    \"\"\"主页\"\"\"\n    return {\n        \"name\": \"Scene Classifier API\",\n        \"version\": \"1.0\",\n        \"endpoints\": {\n            \"classify\": \"/classify (POST)\",\n            \"feedback\": \"/feedback (POST)\",\n            \"stats\": \"/stats (GET)\",\n            \"scenes\": \"/scenes (GET)\"\n        }\n    }\n\n@app.get(\"/health\")\ndef health():\n    \"\"\"健康检查\"\"\"\n    return {\"status\": \"ok\", \"model_loaded\": pipeline is not None}\n\n@app.get(\"/scenes\")\ndef list_scenes():\n    \"\"\"列出所有场景\"\"\"\n    from data.synthetic_training_data import SCENE_DEFINITIONS\n    return {\n        \"scenes\": list(SCENE_DEFINITIONS.keys()),\n        \"count\": len(SCENE_DEFINITIONS)\n    }\n\n@app.post(\"/classify\")\ndef classify(req: ClassifyRequest):\n    \"\"\"分类用户输入\"\"\"\n    if not pipeline:\n        raise HTTPException(status_code=500, detail=\"Model not loaded\")\n    \n    result = pipeline.process(req.text, req.context)\n    return result\n\n@app.post(\"/feedback\")\ndef submit_feedback(req: FeedbackRequest):\n    \"\"\"提交用户反馈\"\"\"\n    if not feedback:\n        raise HTTPException(status_code=500, detail=\"Feedback system not initialized\")\n    \n    feedback.record(\n        req.text,\n        req.predicted_label,\n        req.feedback_type,\n        req.correct_label\n    )\n    return {\"status\": \"recorded\", \"total_misclassifications\": len(feedback.misclassifications)}\n\n@app.get(\"/stats\")\ndef get_stats():\n    \"\"\"获取反馈统计\"\"\"\n    if not feedback:\n        return {\"error\": \"Feedback system not initialized\"}\n    return feedback.get_stats()\n\nif __name__ == \"__main__\":\n    print(\"\\n\" + \"=\"*50)\n    print(\"🎯 Scene Classifier API\")\n    print(\"=\"*50)\n    print(\"URL: http://localhost:8080\")\n    print(\"Docs: http://localhost:8080/docs\")\n    print(\"=\"*50 + \"\\n\")\n    \n    uvicorn.run(app, host=\"0.0.0.0\", port=8080)","path":"~/.openclaw/workspace/skills/scene-classifier/api_server.py"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":72895,"output":843,"cacheRead":0,"cacheWrite":0,"totalTokens":73738,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":17757