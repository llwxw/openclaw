{"type":"message","id":"e1cbaf79","parentId":"383ca484","timestamp":"2026-04-08T17:07:37.983Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me implement the templates and the pipeline integration.\n\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"call_9167c0ef70b54b3c81bc7efa","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\n模板注入层 - 场景对应的回复模板\n\"\"\"\n\nTEMPLATES = {\n    \"task_multi_step\": \"\"\"【任务提交模板】\n任务已提交（ID: {task_id}），预计 {duration} 完成。\n你可以透过 `/api/task/{{task_id}}` 查询状态，或直接问我'任务 {{task_id}} 怎么样了'。\n\n{context}\"\"\",\n\n    \"fault_recovery\": \"\"\"【故障恢复模板】\n先提供恢复步骤：\n1. {step1}\n2. {step2}\n3. {step3}\n\n提示：{lesson}\n\n{context}\"\"\",\n\n    \"vague_request\": \"\"\"【澄清模板】\n你的请求比较模糊，我列出 2-3 种可能意图：\n1. {option1}\n2. {option2}\n3. {option3}\n\n请告诉我你想选哪个，或者补充更多信息。\n\n{context}\"\"\",\n\n    \"expert_user\": \"\"\"【专家模式】\n{technical_content}\n\n{context}\"\"\",\n\n    \"novice_user\": \"\"\"【新手模式】\n{basic_explanation}\n\n简单说：{one_line_summary}\n\n{context}\"\"\",\n\n    \"insufficient_info\": \"\"\"【信息不足模板】\n要解决这个问题，我需要更多信息：\n- {missing_info_1}\n- {missing_info_2}\n- {missing_info_3}\n\n请提供以上信息后再问我。\n\n{context}\"\"\",\n\n    \"high_risk_automated\": \"\"\"[!WARNING] 此操作具有风险，请谨慎执行。\n\n操作：{operation}\n风险：{risk_description}\n缓解措施：{mitigation}\n\n{context}\"\"\",\n\n    \"task_status_query\": \"\"\"【状态查询】\n任务 {task_id} 当前状态：{status}\n进度：{progress}%\n{additional_info}\n\n{context}\"\"\",\n\n    \"cancel_task\": \"\"\"【取消任务】\n正在为你取消任务 {task_id}。\n当前状态：{cancel_status}\n\n{context}\"\"\",\n\n    \"default\": \"\"\"【通用回复】\n{user_input}\n\n让我帮你分析一下：\n{analysis}\n\n{context}\"\"\"\n}\n\ndef get_template(scene_label):\n    \"\"\"获取场景对应的模板\"\"\"\n    return TEMPLATES.get(scene_label, TEMPLATES[\"default\"])\n\ndef fill_template(scene_label, **kwargs):\n    \"\"\"填充模板\"\"\"\n    template = get_template(scene_label)\n    try:\n        return template.format(**kwargs)\n    except KeyError as e:\n        return template.format(user_input=kwargs.get(\"user_input\", \"\"), context=kwargs.get(\"context\", \"\"))\n\ndef list_templates():\n    \"\"\"列出所有模板\"\"\"\n    return list(TEMPLATES.keys())\n\n\nif __name__ == \"__main__\":\n    print(\"可用模板:\", list_templates())\n    \n    # 测试填充\n    print(\"\\n=== 模板测试 ===\")\n    print(fill_template(\"task_multi_step\", task_id=\"abc123\", duration=\"5分钟\", context=\"\"))\n    print(fill_template(\"high_risk_automated\", operation=\"删除文件\", risk_description=\"数据丢失\", mitigation=\"先备份\", context=\"\"))","path":"~/.openclaw/workspace/skills/scene-classifier/templates/template_map.py"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":57526,"output":679,"cacheRead":0,"cacheWrite":0,"totalTokens":58205,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775668048053,"responseId":"chatcmpl-bbde5394-603a-43c0-8ad4-5ff8b31fcd1e"}}
