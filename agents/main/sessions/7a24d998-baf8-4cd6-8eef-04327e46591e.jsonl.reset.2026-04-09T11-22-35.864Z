sh-light\"\n                  : \"dash\"\n                : mode === \"light\"\n                  ? \"light\"\n                  : \"dark\";\n          document.documentElement.setAttribute(\"data-theme\", resolved);\n          document.documentElement.setAttribute(\n            \"data-theme-mode\",\n            resolved.indexOf(\"light\") !== -1 ? \"light\" : \"dark\",\n          );\n        } catch (e) {}\n      })();\n    </script>\n    <script type=\"module\" crossorigin src=\"./assets/index-DWX0XMYb.js\"></script>\n    <link rel=\"modulepreload\" crossorigin href=\"./assets/i18n-CV7rUnW0.js\">\n    <link rel=\"modulepreload\" crossorigin href=\"./assets/directive-CUxOzvVj.js\">\n    <link rel=\"modulepreload\" crossorigin href=\"./assets/format-EHph2kGh.js\">\n    <link rel=\"stylesheet\" crossorigin href=\"./assets/index-D6qddEG9.css\">\n  </head>\n  <body>\n    <openclaw-app></openclaw-app>\n  </body>\n</html>"}],"details":{"status":"completed","exitCode":0,"durationMs":42,"aggregated":"=== 检查 OpenClaw 进程 ===\nai           639  0.0  0.4 11616280 73148 ?      Ssl  11:21   0:11 /home/ai/.nvm/versions/node/v22.22.1/bin/node /home/ai/openclaw-listener/dist/main.js\nai         30773  0.0  0.3 1014624 57272 ?       Ssl  14:45   0:00 /home/ai/.nvm/versions/node/v22.22.1/bin/node /home/ai/openclaw-router/context-api.js\nai         34778  5.5  3.2 22699396 532472 ?     Rsl  15:31   0:52 openclaw-gateway\nai         35600  0.0  0.0   8704  1684 ?        S    15:41   0:00 /bin/bash -c echo \"=== 启动 Python 分类服务 ===\" && \\ cd /home/ai/openclaw-classifier/python-service && \\ python3 app.py > /tmp/flask-service.log 2>&1 & sleep 3 echo \"=== 测试服务 ===\" && \\ curl -s http://localhost:5000/health && \\ echo \"\" && \\ echo \"=== 测试分类 ===\" && \\ curl -s -X POST http://localhost:3102/api/chat/send -H \"Content-Type: application/json\" -d '{\"message\": \"帮我分析代码\"}' | python3 -c \"import sys,json;d=json.load(sys.stdin);print('Scene:',d.get('scene',{}).get('source')ifd.get('sce