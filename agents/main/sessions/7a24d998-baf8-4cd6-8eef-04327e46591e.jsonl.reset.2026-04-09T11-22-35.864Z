{"type":"message","id":"e72347ce","parentId":"b675adaf","timestamp":"2026-04-08T17:08:50.932Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me implement the feedback loop for continuous improvement.\n\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"call_7864b0a352e8441f9b863bce","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\n迭代优化闭环 - 用户反馈收集与分类器重训练\n\"\"\"\n\nimport os\nimport json\nimport time\nfrom datetime import datetime\nfrom collections import defaultdict\n\n\nclass FeedbackLoop:\n    def __init__(self, feedback_file=\"logs/feedback.json\", model_path=\"models/scene_classifier.pkl\"):\n        self.feedback_file = feedback_file\n        self.model_path = model_path\n        self.misclassifications = []\n        self.feedback_history = []\n        \n        # 确保目录存在\n        os.makedirs(os.path.dirname(feedback_file), exist_ok=True)\n        os.makedirs(os.path.dirname(model_path), exist_ok=True)\n        \n        # 加载历史反馈\n        self._load_feedback()\n    \n    def _load_feedback(self):\n        \"\"\"加载历史反馈\"\"\"\n        if os.path.exists(self.feedback_file):\n            try:\n                with open(self.feedback_file, 'r') as f:\n                    data = json.load(f)\n                    self.feedback_history = data.get('feedback', [])\n                    print(f\"Loaded {len(self.feedback_history)} historical feedbacks\")\n            except Exception as e:\n                print(f\"Failed to load feedback: {e}\")\n    \n    def _save_feedback(self):\n        \"\"\"保存反馈到文件\"\"\"\n        try:\n            with open(self.feedback_file, 'w') as f:\n                json.dump({\n                    'feedback': self.feedback_history,\n                    'updated': datetime.now().isoformat()\n                }, f, indent=2, ensure_ascii=False)\n        except Exception as e:\n            print(f\"Failed to save feedback: {e}\")\n    \n    def record(self, user_input: str, predicted_label: str, user_feedback: str, correct_label: str = None):\n        \"\"\"\n        记录用户反馈\n        \n        Args:\n            user_input: 用户输入\n            predicted_label: 系统预测的标签\n            user_feedback: 用户反馈类型\n                - \"wrong_label\": 预测错误\n                - \"correct\": 预测正确\n                - \"not_satisfied\": 不满意但不是标签问题\n            correct_label: 正确的标签（当 user_feedback == \"wrong_label\" 时）\n        \"\"\"\n        entry = {\n            \"user_input\": user_input,\n            \"predicted_label\": predicted_label,\n            \"user_feedback\": user_feedback,\n            \"correct_label\": correct_label,\n            \"timestamp\": time.time(),\n            \"datetime\": datetime.now().isoformat()\n        }\n        \n        self.feedback_history.append(entry)\n        \n        # 记录误分类用于后续分析\n        if user_feedback == \"wrong_label\" and correct_label:\n            self.misclassifications.append({\n                \"text\": user_input,\n                \"predicted\": predicted_label,\n                \"correct\": correct_label,\n                \"timestamp\": time.time()\n            })\n        \n        self._save_feedback()\n        \n        # 检查是否触发重训练\n        if len(self.misclassifications) >= self.retrain_threshold:\n            self.retrain_trigger()\n    \n    def get_stats(self) -> dict:\n        \"\"\"获取反馈统计\"\"\"\n        stats = {\n            \"total_feedback\": len(self.feedback_history),\n            \"misclassifications\": len(self.misclassifications),\n            \"feedback_types\": defaultdict(int),\n            \"label_accuracy\": defaultdict(lambda: {\"correct\": 0, \"wrong\": 0})\n        }\n        \n        for fb in self.feedback_history:\n            stats[\"feedback_types\"][fb[\"user_feedback\"]] += 1\n            \n            if fb[\"user_feedback\"] == \"correct\":\n                stats[\"label_accuracy\"][fb[\"predicted_label\"]][\"correct\"] += 1\n            elif fb[\"user_feedback\"] == \"wrong_label\":\n                stats[\"label_accuracy\"][fb[\"predicted_label\"]][\"wrong\"] += 1\n        \n        return dict(stats)\n    \n    def retrain_trigger(self):\n        \"\"\"\n        触发重训练\n        当误分类累积超过阈值时调用\n        \"\"\"\n        threshold = getattr(self, 'retrain_threshold', 50)\n        \n        if len(self.misclassifications) < threshold:\n            print(f\"Not enough misclassifications ({len(self.misclassifications)}/{threshold})\")\n            return False\n        \n        print(f\"\\n=== 触发重训练 ===\")\n        print(f\"误分类数量: {len(self.misclassifications)}\")\n        \n        # 准备新数据\n        new_texts = []\n        new_labels = []\n        \n        for m in self.misclassifications:\n            new_texts.append(m[\"text\"])\n            new_labels.append(m[\"correct\"])\n        \n        # 这里应该加载现有模型，添加新数据，重新训练\n        # 简化版本只输出信息\n        print(f\"需要添加 {len(new_texts)} 条新训练数据\")\n        print(\"新数据示例:\")\n        for text, label in zip(new_texts[:5], new_labels[:5]):\n            print(f\"  [{label}] {text}\")\n        \n        # 清空误分类记录（实际应该重新训练后再清空）\n        # self.misclassifications = []\n        \n        return True\n    \n    def should_retrain(self) -> bool:\n        \"\"\"检查是否需要重训练\"\"\"\n        threshold = getattr(self, 'retrain_threshold', 50)\n        return len(self.misclassifications) >= threshold\n\n\n# 快捷函数\ndef record_feedback(user_input: str, predicted: str, feedback_type: str, correct: str = None):\n    \"\"\"快捷记录反馈\"\"\"\n    loop = FeedbackLoop()\n    loop.record(user_input, predicted, feedback_type, correct)\n\n\nif __name__ == \"__main__\":\n    # 测试\n    loop = FeedbackLoop()\n    \n    # 模拟一些反馈\n    test_feedbacks = [\n        (\"帮我分析代码质量\", \"task_multi_step\", \"correct\", None),\n        (\"nginx\", \"vague_request\", \"wrong_label\", \"vague_request\"),  # 实际应该是 vague_request\n        (\"服务器宕机了\", \"fault_recovery\", \"wrong_label\", \"fault_recovery\"),\n    ]\n    \n    print(\"=== 模拟反馈 ===\")\n    for user_input, predicted, fb_type, correct in test_feedbacks:\n        loop.record(user_input, predicted, fb_type, correct)\n    \n    print(\"\\n=== 统计 ===\")\n    stats = loop.get_stats()\n    print(json.dumps(stats, indent=2, ensure_ascii=False))\n    \n    print(f\"\\n是否需要重训练: {loop.should_retrain()}\")","path":"~/.openclaw/workspace/skills/scene-classifier/feedback/collector.py"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":60224,"output":1396,"cacheRead":0,"cacheWrite":0,"totalTokens":61620,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775668110548,"responseId":"chatcmpl-59f7ba77-9926-4c44-a083-ceba919501fe"}}
