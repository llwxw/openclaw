让我帮你做点什么？"}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":14918,"output":441,"cacheRead":0,"cacheWrite":0,"totalTokens":15359,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"stop","timestamp":1775646101698,"responseId":"chatcmpl-3b7d866c-2490-463b-a258-4e8e220d798d"}}
