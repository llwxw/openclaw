ain/sessions/08c2e407-a096-4d27-a71c-6ffcc5855fc3.jsonl\n-rw-rw-r-- 1 ai ai   18K Apr 16 00:11 /home/ai/.openclaw/agents/main/sessions/0b95f1f3-f99c-4964-ae27-5fe906ea2ed4.jsonl\n-rw-rw-r-- 1 ai ai  154K Apr 16 01:47 /home/ai/.openclaw/agents/main/sessions/0c98f6cc-a7ce-437b-be20-0c6a43beba38.jsonl\n-rw-rw-r-- 1 ai ai   25K Apr 16 01:20 /home/ai/.openclaw/agents/main/sessions/0ca73f0c-a3fd-4128-8ca2-7c80b0b611d7.jsonl\n-rw-rw-r-- 1 ai ai  102K Apr 16 02:26 /home/ai/.openclaw/agents/main/sessions/0ccb079f-f08d-4a09-9f5f-c89691bba31f.jsonl\n-rw-rw-r-- 1 ai ai  130K Apr 16 01:56 /home/ai/.openclaw/agents/main/sessions/0d5a6313-bd07-4560-995b-2f1f0e0ca4b3.jsonl\n-rw-rw-r-- 1 ai ai  1.4M Apr 10 10:07 /home/ai/.openclaw/agents/main/sessions/122589c7-91b3-43f3-93c5-2d5af138e58c.checkpoint.049986b9-3956-4999-9469-a45da0cd908a.jsonl","cwd":"/home/ai/.openclaw/workspace/main"},"isError":false,"timestamp":1776342200313}}
