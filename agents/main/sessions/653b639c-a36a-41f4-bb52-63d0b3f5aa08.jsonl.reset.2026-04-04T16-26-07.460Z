slashIdx + 1).trim() || \"claude-opus-4-6\";"}],"details":{"status":"completed","exitCode":0,"durationMs":187,"aggregated":"/home/ai/.nvm/versions/node/v22.22.1/lib/node_modules/openclaw/dist/auth-profiles-B5ypC5S-.js:\tif (compaction?.mode) return cfg;\n/home/ai/.nvm/versions/node/v22.22.1/lib/node_modules/openclaw/dist/auth-profiles-B5ypC5S-.js:\tconst mode = config?.agents?.defaults?.compaction?.postIndexSync;\n/home/ai/.nvm/versions/node/v22.22.1/lib/node_modules/openclaw/dist/auth-profiles-B5ypC5S-.js:* Default instructions injected into every safeguard-mode compaction summary.\n/home/ai/.nvm/versions/node/v22.22.1/lib/node_modules/openclaw/dist/auth-profiles-B5ypC5S-.js:\t\t\t\tlog$15.warn(\"[compaction-safeguard] Both ctx.model and runtime.model are undefined. Compaction summarization will not run. This indicates extensionRunner.initialize() was not called and model was not passed through runtime registry.\");\n/home/ai/.nvm/versions/node/v22.22.1/lib/node_modules/openclaw/dist/auth-profiles-B5ypC5S-.js:\treturn cfg?.agents?.defaults?.compaction?.mode === \"safeguard\" ? \"safeguard\" : \"default\";\n/home/ai/.nvm/versions/node/v22.22.1/lib/node_modules/openclaw/dist/auth-profiles-B5ypC5S-.js:\tconst compactionModelOverride = params.config?.agents?.defaults?.compaction?.model?.trim();\n/home/ai/.nvm/versions/node/v22.22.1/lib/node_modules/openclaw/dist/auth-profiles-B5ypC5S-.js:\tif (compactionModelOverride) {\n/home/ai/.nvm/versions/node/v22.22.1/lib/node_modules/openclaw/dist/auth-profiles-B5ypC5S-.js:\t\tconst slashIdx = compactionModelOverride.indexOf(\"/\");\n/home/ai/.nvm/versions/node/v22.22.1/lib/node_modules/openclaw/dist/auth-profiles-B5ypC5S-.js:\t\t\tprovider = compactionModelOverride.slice(0, slashIdx).trim();\n/home/ai/.nvm/versions/node/v22.22.1/lib/node_modules/openclaw/dist/auth-profiles-B5ypC5S-.js:\t\t\tmodelId = compactionModelOverride.slice(slashIdx + 1).trim() || \"claude-opus-4-6\";","cwd":"/home/ai/.openclaw/workspace"},"isError":false