nt);\n\t} catch (err) {\n\t\tconst message = formatErrorMessage(err);\n\t\tlog.error(`Hook error [${event.type}:${event.action}]: ${message}`);\n\t}","cwd":"/home/ai/.openclaw/workspace/main"},"isError":false,"timestamp":1776176990677}}
