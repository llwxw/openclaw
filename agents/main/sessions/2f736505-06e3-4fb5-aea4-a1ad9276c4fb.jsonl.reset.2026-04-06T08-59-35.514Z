{"type":"message","id":"54f697a7","parentId":"65e46a68","timestamp":"2026-04-06T05:49:57.866Z","message":{"role":"toolResult","toolCallId":"call_0eff4d8479d34497a4565210","toolName":"exec","content":[{"type":"text","text":"// intentDetector.js\n// 同步轻量级意图判断 + 异步增强\n\nconst axios = require('axios');\n\n// 规则配置\nconst RULE = {\n actionVerbs: /(写|做|执行|运行|处理|分析|检查|修复|重构|生成|编译|部署|创建|修改|删除|帮我|请|麻烦)/i,\n questionWords: /(吗|？|能不能|可不可以|是否|什么|为什么|怎么|如何)/i,\n confirmWords: /^(是|好|做|继续|可以|行|嗯|ok|yes)$/i,\n taskContinuation: /(再|又|也|还|继续|接着)/i\n};\n\n// 同步规则打分（快速，不依赖外部）\nfunction ruleBasedScore(message) {\n let score = 0;\n if (RULE.actionVerbs.test(message)) score += 2;\n if (RULE.confirmWords.test(message)) score += 1;\n if (RULE.taskContinuation.test(message)) score += 1;\n if (RULE.questionWords.test(message)) score -= 2;\n return score;\n}\n\n// 异步上下文增强（获取最近对话，调用 Context API）\nasync function contextEnhance(message, convId, timeoutMs = 500) {\n if (!convId) return 0;\n try {\n const controller = new AbortController();\n const timeout = setTimeout(() => controller.abort(), timeoutMs);\n const res = await axios.get(`http://localhost:3101/api/context/history`, {\n params: { convId, limit: 3 },\n signal: controller.signal\n });\n clearTimeout(timeout);\n const history = res.data.messages || [];\n let bonus = 0;\n const lastAssistant = history[history.length - 1]?.content || '';\n if (/要不要|是否|可以执行|需要我帮你/i.test(lastAssistant)) bonus += 1;\n if (RULE.confirmWords.test(message) && bonus > 0) bonus += 1;\n return bonus;\n } catch (err) {\n return 0;\n }\n}\n\n// 异步记忆增强（查询相似任务）\nasync function memoryEnhance(message, memoryStore, timeoutMs = 300) {\n if (!memoryStore || typeof memoryStore.query !== 'function') return 0;\n try {\n const controller = new AbortController();\n const timeout = setTimeout(() => controller.abort(), timeoutMs);\n const similar = await memoryStore.query(message, 1);\n clearTimeout(timeout);\n if (similar.length > 0 && similar[0].score > 0.7) return 2;\n return 0;\n } catch (err) {\n return 0;\n }\n}\n\n// 主判断函数\nasync function detectIntent(message, convId, memoryStore, options = {}) {\n // 截断超大消息\n const shortMsg = message?.slice(0, 200) || '';\n \n // 1. 同步规则打分\n let syncScore = ruleBasedScore(shortMsg);\n const isTaskQuick = syncScore >= 1;\n \n // 2. 异步增强（不等待）\n setImmediate(async () => {\n try {\n const contextBonus = await contextEnhance(shortMsg, convId);\n const memoryBonus = await memoryEnhance(shortMsg, memoryStore);\n const finalScore = syncScore + contextBonus + memoryBonus;\n const finalIsTask = finalScore >= 1.5;\n console.log(`[Intent] msg=\"${shortMsg.slice(0,50)}\" syncScore=${syncScore} contextBonus=${contextBonus} memoryBonus=${memoryBonus} finalScore=${finalScore} isTask=${finalIsTask}`);\n } catch (err) {}\n });\n \n return { isTask: isTaskQuick, confidence: Math.min(1, syncScore / 4) };\n}\n\nmodule.exports = { detectIntent };"}],"details":{"status":"completed","exitCode":0,"durationMs":20,"aggregated":"// intentDetector.js\n// 同步轻量级意图判断 + 异步增强\n\nconst axios = require('axios');\n\n// 规则配置\nconst RULE = {\n actionVerbs: /(写|做|执行|运行|处理|分析|检查|修复|重构|生成|编译|部署|创建|修改|删除|帮我|请|麻烦)/i,\n questionWords: /(吗|？|能不能|可不可以|是否|什么|为什么|怎么|如何)/i,\n confirmWords: /^(是|好|做|继续|可以|行|嗯|ok|yes)$/i,\n taskContinuation: /(再|又|也|还|继续|接着)/i\n};\n\n// 同步规则打分（快速，不依赖外部）\nfunction ruleBasedScore(message) {\n let score = 0;\n if (RULE.actionVerbs.test(message)) score += 2;\n if (RULE.confirmWords.test(message)) score += 1;\n if (RULE.taskContinuation.test(message)) score += 1;\n if (RULE.questionWords.test(message)) score -= 2;\n return score;\n}\n\n// 异步上下文增强（获取最近对话，调用 Context API）\nasync function contextEnhance(message, convId, timeoutMs = 500) {\n if (!convId) return 0;\n try {\n const controller = new AbortController();\n const timeout = setTimeout(() => controller.abort(), timeoutMs);\n const res = await axios.get(`http://localhost:3101/api/context/history`, {\n params: { convId, limit: 3 },\n signal: controller.signal\n });\n clearTimeout(timeout);\n const history = res.data.messages || [];\n let bonus = 0;\n const lastAssistant = history[history.length - 1]?.content || '';\n if (/要不要|是否|可以执行|需要我帮你/i.test(lastAssistant)) bonus += 1;\n if (RULE.confirmWords.test(message) && bonus > 0) bonus += 1;\n return bonus;\n } catch (err) {\n return 0;\n }\n}\n\n// 异步记忆增强（查询相似任务）\nasync function memoryEnhance(message, memoryStore, timeoutMs = 300) {\n if (!memoryStore || typeof memoryStore.query !== 'function') return 0;\n try {\n const controller = new AbortController();\n const timeout = setTimeout(() => controller.abort(), timeoutMs);\n const similar = await memoryStore.query(message, 1);\n clearTimeout(timeout);\n if (similar.length > 0 && similar[0].score > 0.7) return 2;\n return 0;\n } catch (err) {\n return 0;\n }\n}\n\n// 主判断函数\nasync function detectIntent(message, convId, memoryStore, options = {}) {\n // 截断超大消息\n const shortMsg = message?.slice(0, 200) || '';\n \n // 1. 同步规则打分\n let syncScore = ruleBasedScore(shortMsg);\n const isTaskQuick = syncScore >= 1;\n \n // 2. 异步增强（不等待）\n setImmediate(async () => {\n try {\n const contextBonus = await contextEnhance(shortMsg, convId);\n const memoryBonus = await memoryEnhance(shortMsg, memoryStore);\n const finalScore = syncScore + contextBonus + memoryBonus;\n const finalIsTask = finalScore >= 1.5;\n console.log(`[Intent] msg=\"${shortMsg.slice(0,50)}\" syncScore=${syncScore} contextBonus=${contextBonus} memoryBonus=${memoryBonus} finalScore=${finalScore} isTask=${finalIsTask}`);\n } catch (err) {}\n });\n \n return { isTask: isTaskQuick, confidence: Math.min(1, syncScore / 4) };\n}\n\nmodule.exports = { detectIntent };","cwd":"/home/ai/.openclaw/workspace"},"isError":false,"timestamp":1775454597862}}
{"type":"message","id":"468305ef","parentId":"54f697a7","timestamp":"2026-04-06T05:49:57.887Z","message":{"role":"toolResult","toolCallId":"call_10f517a33914432e847fa528","toolName":"exec","content":[{"type":"text","text":"// scoring.js - Task Orchestrator v3.0\n// 评分因子与路由 - 调整后支持 0-100 分完整覆盖\n\nconst WEIGHTS = {\n instructionCount: 0.12,\n codeLines: 0.08,\n dependencyComplexity: 0.10,\n cpuIntensity: 0.10,\n ioIntensity: 0.08,\n networkIntensity: 0.12,\n estimatedDuration: 0.12,\n scaleIndex: 0.28\n};\n\nfunction computeComplexity(taskSpec) {\n const cnt = (taskSpec.match(/&&|;|\\n/g) || []).length + 1;\n if (cnt === 1) return 1;\n if (cnt <= 3) return 2;\n if (cnt <= 6) return 3;\n if (cnt <= 10) return 4;\n return 5;\n}\n\nfunction computeCodeLines(taskSpec) {\n const lines = (taskSpec.match(/\\n/g) || []).length + 1;\n if (lines <= 10) return 1;\n if (lines <= 50) return 2;\n if (lines <= 100) return 3;\n if (lines <= 500) return 4;\n return 5;\n}\n\nfunction computeScaleIndex(taskSpec) {\n const lower = taskSpec.toLowerCase();\n let score = 0;\n \n const patterns = [\n   'docker', 'docker-compose', 'kubernetes', 'kubectl', 'helm',\n   'terraform', 'ansible', 'packer', 'vault',\n   'jenkins', 'gitlab', 'github actions', 'ci cd',\n   'git clone', 'npm install', 'pip install',\n   'make all', 'make test', 'build', 'compile'\n ];\n \n for (const p of patterns) {\n   if (lower.includes(p)) score += 1;\n }\n \n // 基础分1，最多加到5\n return Math.min(5, Math.max(1, score));\n}\n\nasync function computeFineScore(taskSpec) {\n const factors = {\n   instructionCount: computeComplexity(taskSpec),\n   codeLines: computeCodeLines(taskSpec),\n   dependencyComplexity: /npm install|pip install|apt install|yum install|brew install/i.test(taskSpec) ? 4 : \n                          /install|setup|init/i.test(taskSpec) ? 2 : 1,\n   cpuIntensity: /make|compile|gcc|g\\+\\+|clang|build|npm run build/i.test(taskSpec) ? 4 : \n                 /python.*\\.py|node.*\\.js/i.test(taskSpec) ? 2 : 1,\n   ioIntensity: /cp|mv|tar|dd|rsync|backup|dump/i.test(taskSpec) ? 4 : 1,\n   networkIntensity: /curl|wget|git clone|fetch|download|http|https/i.test(taskSpec) ? 4 : \n                     /ssh|scp|rsync/i.test(taskSpec) ? 2 : 1,\n   estimatedDuration: /sleep|wait|timeout/i.test(taskSpec) ? 4 : \n                      /compile|build|install|test/i.test(taskSpec) ? 3 : 1,\n   scaleIndex: computeScaleIndex(taskSpec)\n };\n \n let weighted = 0;\n for (const [k, v] of Object.entries(factors)) {\n   weighted += v * WEIGHTS[k];\n }\n \n const totalScore = Math.min(100, Math.round(weighted * 20));\n return { totalScore, factors };\n}\n\nfunction getExecutionPlan(score, scaleIndex) {\n if (scaleIndex >= 4) return { mode: 'MEGA_TASK', timeoutSec: 7200, memLimitMB: 8192 };\n if (score <= 20) return { mode: 'DIRECT', timeoutSec: 30 };\n if (score <= 40) return { mode: 'STEP_ARCHIVE', stepTimeoutSec: 60, memLimitMB: 1024 };\n if (score <= 60) return { mode: 'SPAWN_SUBAGENT', timeoutSec: Math.max(60, Math.min(180, score * 3)), memLimitMB: 2048 };\n if (score <= 80) return { mode: 'PARALLEL_SHARDS', timeoutSec: Math.max(120, Math.min(160, score * 2)), memLimitMB: 2048 };\n return { mode: 'MEGA_TASK', timeoutSec: 7200, memLimitMB: 8192 };\n}\n\nmodule.exports = { computeFineScore, getExecutionPlan };"}],"details":{"status":"completed","exitCode":0,"durationMs":33,"aggregated":"// scoring.js - Task Orchestrator v3.0\n// 评分因子与路由 - 调整后支持 0-100 分完整覆盖\n\nconst WEIGHTS = {\n instructionCount: 0.12,\n codeLines: 0.08,\n dependencyComplexity: 0.10,\n cpuIntensity: 0.10,\n ioIntensity: 0.08,\n networkIntensity: 0.12,\n estimatedDuration: 0.12,\n scaleIndex: 0.28\n};\n\nfunction computeComplexity(taskSpec) {\n const cnt = (taskSpec.match(/&&|;|\\n/g) || []).length + 1;\n if (cnt === 1) return 1;\n if (cnt <= 3) return 2;\n if (cnt <= 6) return 3;\n if (cnt <= 10) return 4;\n return 5;\n}\n\nfunction computeCodeLines(taskSpec) {\n const lines = (taskSpec.match(/\\n/g) || []).length + 1;\n if (lines <= 10) return 1;\n if (lines <= 50) return 2;\n if (lines <= 100) return 3;\n if (lines <= 500) return 4;\n return 5;\n}\n\nfunction computeScaleIndex(taskSpec) {\n const lower = taskSpec.toLowerCase();\n let score = 0;\n \n const patterns = [\n   'docker', 'docker-compose', 'kubernetes', 'kubectl', 'helm',\n   'terraform', 'ansible', 'packer', 'vault',\n   'jenkins', 'gitlab', 'github actions', 'ci cd',\n   'git clone', 'npm install', 'pip install',\n   'make all', 'make test', 'build', 'compile'\n ];\n \n for (const p of patterns) {\n   if (lower.includes(p)) score += 1;\n }\n \n // 基础分1，最多加到5\n return Math.min(5, Math.max(1, score));\n}\n\nasync function computeFineScore(taskSpec) {\n const factors = {\n   instructionCount: computeComplexity(taskSpec),\n   codeLines: computeCodeLines(taskSpec),\n   dependencyComplexity: /npm install|pip install|apt install|yum install|brew install/i.test(taskSpec) ? 4 : \n                          /install|setup|init/i.test(taskSpec) ? 2 : 1,\n   cpuIntensity: /make|compile|gcc|g\\+\\+|clang|build|npm run build/i.test(taskSpec) ? 4 : \n                 /python.*\\.py|node.*\\.js/i.test(taskSpec) ? 2 : 1,\n   ioIntensity: /cp|mv|tar|dd|rsync|backup|dump/i.test(taskSpec) ? 4 : 1,\n   networkIntensity: /curl|wget|git clone|fetch|download|http|https/i.test(taskSpec) ? 4 : \n                     /ssh|scp|rsync/i.test(taskSpec) ? 2 : 1,\n   estimatedDuration: /sleep|wait|timeout/i.test(taskSpec) ? 4 : \n                      /compile|build|install|test/i.test(taskSpec) ? 3 : 1,\n   scaleIndex: computeScaleIndex(taskSpec)\n };\n \n let weighted = 0;\n for (const [k, v] of Object.entries(factors)) {\n   weighted += v * WEIGHTS[k];\n }\n \n const totalScore = Math.min(100, Math.round(weighted * 20));\n return { totalScore, factors };\n}\n\nfunction getExecutionPlan(score, scaleIndex) {\n if (scaleIndex >= 4) return { mode: 'MEGA_TASK', timeoutSec: 7200, memLimitMB: 8192 };\n if (score <= 20) return { mode: 'DIRECT', timeoutSec: 30 };\n if (score <= 40) return { mode: 'STEP_ARCHIVE', stepTimeoutSec: 60, memLimitMB: 1024 };\n if (score <= 60) return { mode: 'SPAWN_SUBAGENT', timeoutSec: Math.max(60, Math.min(180, score * 3)), memLimitMB: 2048 };\n if (score <= 80) return { mode: 'PARALLEL_SHARDS', timeoutSec: Math.max(120, Math.min(160, score * 2)), memLimitMB: 2048 };\n return { mode: 'MEGA_TASK', timeoutSec: 7200, memLimitMB: 8192 };\n}\n\nmodule.exports = { computeFineScore, getExecutionPlan };","cwd":"/home/ai/.openclaw/workspace"},"isError":false,"timestamp":1775454597875}}
{"type":"message","id":"cbd391e1","parentId":"468305ef","timestamp":"2026-04-06T05:50:30.524Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在我已经看到了两个模块的接口。让我对比一下新代码中调用的方式是否兼容：\n\n**intentDetector.js**:\n- 导出: `{ detectIntent }`\n- 函数签名: `detectIntent(message, convId, memoryStore, options = {})`\n- 返回: `{ isTask: boolean, confidence: number }`\n\n新代码中调用方式：\n```javascript\nconst { isTask, confidence } = await detectIntent(userText, null, null);\n```\n\n✅ **兼容** - 传 null 给 convId 和 memoryStore 即可。\n\n---\n\n**scoring.js**:\n- 导出: `{ computeFineScore, getExecutionPlan }`\n- `computeFineScore(taskSpec)` 返回: `{ totalScore, factors }`\n- `getExecutionPlan(score, scaleIndex)` 返回执行计划对象\n\n新代码中调用方式：\n```javascript\nconst { totalScore, factors } = await computeFineScore(userText);\nconst plan = getExecutionPlan(totalScore, factors.scaleIndex);\n```\n\n✅ **完全兼容**。\n\n现在我来给用户一个清晰的分析报告。\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n完美，依赖模块都存在且接口兼容！让我总结分析：\n\n---\n\n## 📋 分析报告\n\n### 一、代码兼容性 ✅\n\n| 依赖模块 | 路径 | 接口 | 兼容状态 |\n|----------|------|------|----------|\n| intentDetector.js | `~/openclaw-router/` | `detectIntent(msg, convId, memoryStore)` | ✅ 传 null 即可 |\n| scoring.js | `~/openclaw-router/` | `computeFineScore()` + `getExecutionPlan()` | ✅ 完全兼容 |\n\n### 二、核心工作流程\n\n```\n客户端消息 \n    ↓\nextractUserMessage() 提取文本\n    ↓\nsetImmediate() → evaluateAndHint() 非阻塞执行\n    ↓\n① detectIntent(message, null, null) → 意图判断\n    ↓ (confidence > 0.5 才是任务)\n② computeFineScore() → 详细评分 (0-100)\n    ↓\n③ getExecutionPlan() → 获取执行建议\n    ↓\n④ 构造提示消息 → clientSocket.send() 推送到前端\n```\n\n### 三、需要本地适配的点\n\n| 项目 | 现状 | 需要修改 |\n|------|------|----------|\n| **require 路径** | `./intentDetector` | 如果 ws-proxy.js 在其他目录，需改相对路径 |\n| **Gateway 端口** | `ws://localhost:18789` | 检查 gateway 是否真的在这个端口 |\n| **npm 依赖** | ws, express | 确认已 `npm install` |\n| **systemd 服务** | 无 | 如需开机自启要创建 service 文件 |\n\n### 四、与原 ws-proxy.js 的区别\n\n| 特性 | 原版 | 增强版 |\n|------|------|--------|\n| 消息转发 | ✅ | ✅ |\n| Gateway 重连 | ✅ | ✅ |\n| 速率限制 | ✅ | ✅ |\n| **自动意图判断** | ❌ | ✅ |\n| **自动评分** | ❌ | ✅ |\n| **推送提示到前端** | ❌ | ✅ |\n\n### 五、提示消息示例\n\n当前端发送 \"帮我写个排序函数\" 时，你会在前端收到：\n```json\n{\n  \"type\": \"assistant\", \n  \"content\": \"[系统] 检测到任务，评分 28，建议使用 STEP_ARCHIVE 模式（超时 60 秒）。\",\n  \"metadata\": { \"source\": \"task-scoring\" }\n}\n```\n\n---\n\n**准备好要我执行部署了吗？还是你想先调整某些配置（比如端口、超时、是否发送提示等）？** 🦐"}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":6962,"output":748,"cacheRead":14080,"cacheWrite":0,"totalTokens":21790,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"stop","timestamp":1775454597888,"responseId":"019d61572929eec9a564d706fa33c33b"}}
