{"type":"message","id":"7ab70625","parentId":"e9a5c927","timestamp":"2026-04-06T08:08:56.227Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在只有一个 ws-proxy 进程了。让我总结一下问题：测试时评分提示能收到，但前端看不到。可能是：\n1. 前端 WebSocket 处理逻辑不同2. 评分提示发送时机问题\n3. 消息格式问题让我直接告诉用户问题在哪，并给出一个解决方案\n\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n原因找到了：\n\n**测试能收到是因为我用 node 脚本测试，前端可能有不同的 WebSocket 处理逻辑。**\n\n让我换个方式 — 不发单独的提示，而是在 Gateway 回复里带上评分信息：\n"},{"type":"toolCall","id":"call_9a2604308ae34953af96a8a6","name":"read","arguments":{"path":"/home/ai/openclaw-router/ws-proxy.js","limit":150}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":60841,"output":144,"cacheRead":0,"cacheWrite":0,"totalTokens":60985,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775462935199,"responseId":"chatcmpl-401ef5c2-c03e-42db-879e-ccf28c63ef08"}}
{"type":"message","id":"cc72d4f5","parentId":"7ab70625","timestamp":"2026-04-06T08:08:56.262Z","message":{"role":"toolResult","toolCallId":"call_9a2604308ae34953af96a8a6","toolName":"read","content":[{"type":"text","text":"// ws-proxy.js\n// 高鲁棒 WebSocket 代理 + 自动任务评分 + 实时提示\n// 版本: 2.0.0\n\nconst WebSocket = require('ws');\nconst crypto = require('crypto');\nconst { detectIntent } = require('./intentDetector');\nconst { computeFineScore, getExecutionPlan } = require('./scoring');\n\n// ========== 配置（支持环境变量） ==========\nconst CONFIG = {\n gatewayWsUrl: process.env.OPENCLAW_WS_URL || 'ws://localhost:3108', // Gateway 端口\n proxyPort: parseInt(process.env.PROXY_WS_PORT || '3103', 10),\n heartbeatIntervalMs: parseInt(process.env.HEARTBEAT_INTERVAL_MS || '30000', 10),\n connectionTimeoutMs: parseInt(process.env.CONNECTION_TIMEOUT_MS || '10000', 10),\n maxReconnectAttempts: parseInt(process.env.MAX_RECONNECT_ATTEMPTS || '5', 10),\n reconnectBaseDelayMs: parseInt(process.env.RECONNECT_BASE_DELAY_MS || '1000', 10),\n maxCachedMessages: parseInt(process.env.MAX_CACHED_MESSAGES || '100', 10),\n maxMessageSizeBytes: parseInt(process.env.MAX_MESSAGE_SIZE_BYTES || '1048576', 10),\n enableRateLimit: process.env.ENABLE_RATE_LIMIT !== 'false', // 默认开启\n rateLimitPerSec: parseInt(process.env.RATE_LIMIT_PER_SEC || '10', 10),\n healthPort: parseInt(process.env.HEALTH_PORT || '3104', 10),\n // 评分相关配置\n enableScoring: process.env.ENABLE_SCORING !== 'false',\n scoringTimeoutMs: parseInt(process.env.SCORING_TIMEOUT_MS || '2000', 10),\n sendHint: process.env.SEND_HINT !== 'false',\n hintCooldownMs: parseInt(process.env.HINT_COOLDOWN_MS || '5000', 10),\n};\n\n// ========== 辅助函数 ==========\nconst log = (level, msg, meta = {}) => {\n console[level](`[WSProxy] ${msg}`, meta);\n};\n\n// 提取用户文本（支持多种格式）\nconst messageExtractors = [\n (data) => { try { const p = JSON.parse(data); return p.content || p.message || p.text; } catch(e) {} },\n (data) => { try { const p = JSON.parse(data); return p.data?.message || p.data?.text; } catch(e) {} },\n];\nfunction extractUserMessage(data) {\n for (const extractor of messageExtractors) {\n const result = extractor(data);\n if (result && typeof result === 'string') return result.trim();\n }\n return null;\n}\n\n// 简单速率限制（令牌桶）\nclass RateLimiter {\n constructor(tokensPerSec) {\n this.tokens = tokensPerSec;\n this.maxTokens = tokensPerSec;\n this.lastRefill = Date.now();\n }\n allow() {\n const now = Date.now();\n const elapsed = (now - this.lastRefill) / 1000;\n this.tokens = Math.min(this.maxTokens, this.tokens + elapsed * this.maxTokens);\n this.lastRefill = now;\n if (this.tokens >= 1) {\n this.tokens -= 1;\n return true;\n }\n return false;\n }\n}\n\n// 去重缓存（简单 LRU）\nclass SimpleCache {\n constructor(maxSize = 100, ttlMs = 60000) {\n this.cache = new Map();\n this.maxSize = maxSize;\n this.ttl = ttlMs;\n }\n set(key, value) {\n if (this.cache.size >= this.maxSize) {\n const oldest = this.cache.keys().next().value;\n this.cache.delete(oldest);\n }\n this.cache.set(key, { value, expires: Date.now() + this.ttl });\n }\n get(key) {\n const entry = this.cache.get(key);\n if (!entry) return null;\n if (Date.now() > entry.expires) {\n this.cache.delete(key);\n return null;\n }\n return entry.value;\n }\n}\n\n// ========== WebSocket 代理客户端类 ==========\nclass WSProxyClient {\n constructor(clientSocket, req) {\n this.clientSocket = clientSocket;\n this.clientAddr = req.socket.remoteAddress;\n this.clientId = crypto.randomUUID();\n this.gatewaySocket = null;\n this.reconnectAttempts = 0;\n this.heartbeatTimer = null;\n this.pendingMessages = [];\n this.connected = false;\n this.rateLimiter = CONFIG.enableRateLimit ? new RateLimiter(CONFIG.rateLimitPerSec) : null;\n this.hintCache = new SimpleCache(200, CONFIG.hintCooldownMs);\n this.init();\n }\n\n init() {\n this.connectToGateway();\n this.setupClientHandlers();\n }\n\n connectToGateway() {\n log('info', `[${this.clientId}] Connecting to Gateway ${CONFIG.gatewayWsUrl} (attempt ${this.reconnectAttempts+1})`);\n this.gatewaySocket = new WebSocket(CONFIG.gatewayWsUrl, {\n maxPayload: CONFIG.maxMessageSizeBytes,\n });\n \n const timeout = setTimeout(() => {\n if (this.gatewaySocket.readyState !== WebSocket.OPEN) {\n log('error', `[${this.clientId}] Gateway connection timeout`);\n this.gatewaySocket.terminate();\n this.scheduleReconnect();\n }\n }, CONFIG.connectionTimeoutMs);\n\n this.gatewaySocket.on('open', () => {\n clearTimeout(timeout);\n this.connected = true;\n this.reconnectAttempts = 0;\n log('info', `[${this.clientId}] Connected to Gateway`);\n while (this.pendingMessages.length) {\n this.gatewaySocket.send(this.pendingMessages.shift());\n }\n this.startHeartbeat();\n });\n\n this.gatewaySocket.on('message', (data, isBinary) => {\n if (this.clientSocket.readyState === WebSocket.OPEN) {\n this.clientSocket.send(data, { binary: isBinary });\n }\n });\n\n this.gatewaySocket.on('error', (err) => {\n log('error', `[${this.clientId}] Gateway error: ${err.message}`);\n });\n\n this.gatewaySocket.on('close', (code, reason) => {\n clearTimeout(timeout);\n\n[149 more lines in file. Use offset=151 to continue.]"}],"isError":false,"timestamp":1775462936252}}
{"type":"message","id":"253bbb9a","parentId":"cc72d4f5","timestamp":"2026-04-06T08:09:01.173Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"让我继续看 evaluateAndHint 函数是怎么发送消息的\n\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"019d61d5bb3bbb533f5e6e4c1a4fcca9","name":"read","arguments":{"path":"/home/ai/openclaw-router/ws-proxy.js","offset":180,"limit":50}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":2168,"output":66,"cacheRead":60032,"cacheWrite":0,"totalTokens":62266,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775462936263,"responseId":"019d61d5b293b5d50fcad9e787703481"}}
{"type":"message","id":"5b22b3c2","parentId":"253bbb9a","timestamp":"2026-04-06T08:09:01.201Z","message":{"role":"toolResult","toolCallId":"019d61d5bb3bbb533f5e6e4c1a4fcca9","toolName":"read","content":[{"type":"text","text":" stopHeartbeat() {\n if (this.heartbeatTimer) {\n clearInterval(this.heartbeatTimer);\n this.heartbeatTimer = null;\n }\n }\n\n // 异步评分并发送提示\n async evaluateAndHint(userText) {\n if (!CONFIG.enableScoring) return;\n const cacheKey = `${this.clientId}:${userText.slice(0, 100)}`;\n if (this.hintCache.get(cacheKey)) return;\n\n try {\n // 1. 意图判断（快速过滤）\n const { isTask, confidence } = await detectIntent(userText, null, null);\n if (!isTask || confidence < 0.5) return;\n\n // 2. 详细评分（带超时保护）\n const scorePromise = computeFineScore(userText);\n const timeoutPromise = new Promise((_, reject) =>\n setTimeout(() => reject(new Error('Scoring timeout')), CONFIG.scoringTimeoutMs)\n );\n const { totalScore, factors } = await Promise.race([scorePromise, timeoutPromise]);\n const plan = getExecutionPlan(totalScore, factors.scaleIndex);\n\n // 3. 构造提示消息（改进: 使用 system 类型避免混淆）\n const hintText = `[系统] 检测到任务，评分 ${totalScore}，建议使用 ${plan.mode} 模式（超时 ${plan.timeoutSec || plan.stepTimeoutSec || '?'} 秒）。`;\n const hintMessage = JSON.stringify({\n type: 'assistant',\n content: hintText,\n metadata: { source: 'task-scoring', score: totalScore, plan: plan.mode }\n });\n\n // 4. 发送提示到前端\n if (CONFIG.sendHint && this.clientSocket.readyState === WebSocket.OPEN) {\n this.clientSocket.send(hintMessage);\n this.hintCache.set(cacheKey, true);\n log('info', `[${this.clientId}] Sent scoring hint: ${hintText.slice(0, 80)}...`);\n }\n } catch (err) {\n log('error', `[${this.clientId}] Scoring failed: ${err.message}`);\n }\n }\n\n setupClientHandlers() {\n this.clientSocket.on('message', async (data, isBinary) => {\n // 速率限制\n if (this.rateLimiter && !this.rateLimiter.allow()) {\n log('warn', `[${this.clientId}] Rate limit exceeded`);\n\n[70 more lines in file. Use offset=230 to continue.]"}],"isError":false,"timestamp":1775462941194}}
{"type":"message","id":"8d824315","parentId":"5b22b3c2","timestamp":"2026-04-06T08:09:49.672Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"代码看起来是对的。评分提示已经改成 `type: 'assistant'` 了。现在问题是前端看不到。可能的原因：\n\n1. 前端 WebSocket 处理逻辑可能只显示 Gateway 返回的消息，不显示我们发的\n2. 评分提示可能在 Gateway 响应之前发送了，导致顺序不对3. 可能需要等 Gateway 返回后再发送评分提示（这样前端才会显示）让我换个思路：不在消息到达时立即发送评分提示，而是等 Gateway 返回响应后，再把评分信息附加到响应消息上。这样前端应该会显示。但这样改动比较大...让我先确认问题是否真的是顺序问题。我可以用一个简单的测试：让评分提示延迟发送（比如等 1 秒），看看前端是否能收到。\n\n不过这样太复杂了。让我直接简化：把评分信息放在消息里，不单独发提示。实际上，问题可能是前端不显示从代理发出的消息，只显示从 Gateway 返回的消息。\n\n让我换个方式，把评分信息附加到 Gateway 返回的消息里（作为 metadata），但不单独发一条消息。\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"019d61d60d53f446f7258dd9a7dd394a","name":"edit","arguments":{"edits":[{"newText":" // 异步评分并发送提示\n async evaluateAndHint(userText) {\n if (!CONFIG.enableScoring) return;\n const cacheKey = `${this.clientId}:${userText.slice(0, 100)}`;\n if (this.hintCache.get(cacheKey)) return;\n\n try {\n // 1. 意图判断（快速过滤）\n const { isTask, confidence } = await detectIntent(userText, null, null);\n if (!isTask || confidence < 0.5) return;\n\n // 2. 详细评分（带超时保护）\n const scorePromise = computeFineScore(userText);\n const timeoutPromise = new Promise((_, reject) =>\n setTimeout(() => reject(new Error('Scoring timeout')), CONFIG.scoringTimeoutMs)\n );\n const { totalScore, factors } = await Promise.race([scorePromise, timeoutPromise]);\n this.lastScore = { totalScore, plan: getExecutionPlan(totalScore, factors.scaleIndex) };\n log('info', `[${this.clientId}] Scored: ${totalScore}, plan: ${this.lastScore.plan.mode}`);\n } catch (err) {\n log('error', `[${this.clientId}] Scoring failed: ${err.message}`);\n }\n }\n\n // 在发送 Gateway 响应时附加评分信息\n appendScoreHint(data) {\n if (!this.lastScore) return data;\n try {\n const msg = JSON.parse(data.toString());\n if (msg.type === 'assistant' && msg.content) {\n msg.metadata = msg.metadata || {};\n msg.metadata.taskScore = this.lastScore.totalScore;\n msg.metadata.taskPlan = this.lastScore.plan.mode;\n msg.content = `[📊 评分 ${this.lastScore.totalScore}] ${msg.content}`;\n this.lastScore = null; // 清除，只附加一次\n return JSON.stringify(msg);\n }\n } catch(e) {}\n return data;\n }","oldText":" // 异步评分并发送提示\n async evaluateAndHint(userText) {\n if (!CONFIG.enableScoring) return;\n const cacheKey = `${this.clientId}:${userText.slice(0, 100)}`;\n if (this.hintCache.get(cacheKey)) return;\n\n try {\n // 1. 意图判断（快速过滤）\n const { isTask, confidence } = await detectIntent(userText, null, null);\n if (!isTask || confidence < 0.5) return;\n\n // 2. 详细评分（带超时保护）\n const scorePromise = computeFineScore(userText);\n const timeoutPromise = new Promise((_, reject) =>\n setTimeout(() => reject(new Error('Scoring timeout')), CONFIG.scoringTimeoutMs)\n );\n const { totalScore, factors } = await Promise.race([scorePromise, timeoutPromise]);\n const plan = getExecutionPlan(totalScore, factors.scaleIndex);\n\n // 3. 构造提示消息（改进: 使用 system 类型避免混淆）\n const hintText = `[系统] 检测到任务，评分 ${totalScore}，建议使用 ${plan.mode} 模式（超时 ${plan.timeoutSec || plan.stepTimeoutSec || '?'} 秒）。`;\n const hintMessage = JSON.stringify({\n type: 'assistant',\n content: hintText,\n metadata: { source: 'task-scoring', score: totalScore, plan: plan.mode }\n });\n\n // 4. 发送提示到前端\n if (CONFIG.sendHint && this.clientSocket.readyState === WebSocket.OPEN) {\n this.clientSocket.send(hintMessage);\n this.hintCache.set(cacheKey, true);\n log('info', `[${this.clientId}] Sent scoring hint: ${hintText.slice(0, 80)}...`);\n }\n } catch (err) {\n log('error', `[${this.clientId}] Scoring failed: ${err.message}`);\n }\n }"}],"path":"/home/ai/openclaw-router/ws-proxy.js"}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":2995,"output":1104,"cacheRead":59776,"cacheWrite":0,"totalTokens":63875,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775462941202,"responseId":"019d61d5dd0651972