{"type":"message","id":"a8d57e7e","parentId":"446aa91a","timestamp":"2026-04-06T09:03:29.654Z","message":{"role":"toolResult","toolCallId":"019d620797840ef7f41480d9a70bdb58","toolName":"read","content":[{"type":"text","text":"/**\n * OpenClaw Router v7.1 - 反向代理 + 对话上下文自动记录\n * \n * 功能：\n * - 反向代理到 Gateway\n * - 拦截对话请求，记录用户消息\n * - 拦截 AI 回复，记录助手消息\n * - 任务评分与执行\n * \n * 启动: node openclaw-router.js\n * \n * 环境变量:\n * - OPENCLAW_GATEWAY: Gateway 地址 (默认 http://127.0.0.1:18789)\n * - ROUTER_PORT: 监听端口 (默认 3002)\n * - CONTEXT_API_URL: 上下文 API (默认 http://127.0.0.1:18790)\n * - CONTEXT_TIMEOUT_MS: 记录超时 (默认 2000)\n * - ENABLE_CONTEXT: 是否启用上下文记录 (默认 true)\n */\n\nimport http from 'http';\nimport { exec } from 'child_process';\nimport { URL } from 'url';\nimport scoring from './scoring.js';\nimport megaExecutor from './mega_executor.js';\nimport contextProtector from './context_protector.js';\nimport security from './security.js';\nimport optimizer from './optimizer.js';\n\n// ==================== 配置 ====================\nconst PORT = parseInt(process.env.ROUTER_PORT || '3002', 10);\nconst GATEWAY_URL = process.env.OPENCLAW_GATEWAY || 'http://127.0.0.1:18789';\nconst CONTEXT_API_URL = process.env.CONTEXT_API_URL || 'http://127.0.0.1:18790';\nconst CONTEXT_TIMEOUT_MS = parseInt(process.env.CONTEXT_TIMEOUT_MS || '2000', 10);\nconst ENABLE_CONTEXT = process.env.ENABLE_CONTEXT !== 'false';\n\n// 对话请求路径（支持多个）\nconst CONVERSATION_PATHS = [\n  '/agent',\n  '/chat',\n  '/api/chat/send',\n  '/api/message/send', \n  '/api/v1/chat',\n  '/webhook',\n  '/chat'\n];\n\n// 消息字段候选（按优先级）\nconst MESSAGE_FIELDS = ['message', 'text', 'content', 'prompt', 'input'];\n\n// ==================== 辅助函数 ====================\n\n// 从请求体提取用户消息\nfunction extractMessage(body) {\n  if (!body) return null;\n  \n  // 优先检查顶层字段\n  for (const field of MESSAGE_FIELDS) {\n    if (typeof body[field] === 'string' && body[field].trim()) {\n      return body[field].trim();\n    }\n  }\n  \n  // 处理 { messages: [{ role, content }] } 格式\n  if (body.messages && Array.isArray(body.messages)) {\n    const last = body.messages[body.messages.length - 1];\n    if (last && last.content) return last.content;\n  }\n  \n  return null;\n}\n\n// 异步记录到 Context API（非阻塞）\nasync function recordContext(role, content, conversationId = null) {\n  if (!ENABLE_CONTEXT || !content) return;\n  \n  try {\n    const controller = new AbortController();\n    const timeout = setTimeout(() => controller.abort(), CONTEXT_TIMEOUT_MS);\n    \n    await fetch(`${CONTEXT_API_URL}/api/context/add`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({\n        role,\n        content,\n        conversationId,\n        timestamp: Date.now()\n      }),\n      signal: controller.signal\n    });\n    \n    clearTimeout(timeout);\n  } catch (err) {\n    // 静默失败，仅打印日志\n    console.log(`[Context] 记录 ${role} 消息失败:`, err.message);\n  }\n}\n\n// 从响应体中提取 AI 回复\nfunction extractAssistantMessage(body, contentType) {\n\n[308 more lines in file. Use offset=101 to continue.]"}],"isError":false,"timestamp":1775466209648}}
