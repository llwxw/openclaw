require('./router/api');\nconst { setupGracefulShutdown } = require('./utils/gracefulShutdown');\n\n(async () => {\n  // 1. 加载配置\n  const config = loadConfig();\n  const logger = createLogger(config);\n  logger.info('OpenClaw v8.0 starting...');\n\n  // 2. 初始化组件\n  const taskStore = new TaskStore(config);\n  await taskStore.init();\n  taskStore.on('error', (err) => logger.error({ err }, 'TaskStore error'));\n  taskStore.on('recovered', (count) => logger.info({ recovered: count }, 'Stale tasks recovered'));\n\n  const security = new SecurityGateway(config);\n  const executor = new SandboxExecutor(config, logger);\n  const metrics = new MetricsCollector();\n  const healthChecker = new HealthChecker(config, taskStore);\n\n  const scheduler = new Scheduler(taskStore, executor, config, logger);\n---\n/home/ai/.openclaw/v8/src/security/SecurityGateway.js:module.exports = { SecurityGateway };\n/home/ai/.openclaw/v8/src/security/RateLimiter.js:module.exports = { RateLimiter };\n/home/ai/.openclaw/v8/src/router/api.js:module.exports = { createApiRouter };\n/home/ai/.openclaw/v8/src/skills/skillLoader.js:module.exports = { loadSkill, SKILLS };\n/home/ai/.openclaw/v8/src/context/ContextProtector.js:module.exports = { ContextProtector };\n/home/ai/.openclaw/v8/src/executor/ExecutionGuard.js:module.exports = { ExecutionGuard };\n/home/ai/.openclaw/v8/src/executor/SandboxExecutor.js:module.exports = { SandboxExecutor };\n/home/ai/.openclaw/v8/src/index.js:  const server = app.listen(config.server.port, config.server.host, () => {\n/home/ai/.openclaw/v8/src/index.js:    logger.info({ host: config.server.host, port: config.server.port }, 'OpenClaw v8.0 listening');\n/home/ai/.openclaw/v8/src/scoring/engine.js:module.exports = {\n/home/ai/.openclaw/v8/src/scoring/adapter.js:module.exports = { scoreTask };\n/home/ai/.openclaw/v8/src/scoring/adapter.js.bak:module.exports = { scoreTask };\n/home/ai/.openclaw/v8/src/scoring/rule-tuner.js:module.exports = { analyze };\n/home/ai/.openclaw