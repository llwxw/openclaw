{"type":"message","id":"26203c82","parentId":"f285613e","timestamp":"2026-04-17T16:20:03.577Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I need to create a context monitoring hook that will actually enforce these settings. Let me create a hook that:1. Checks context size on each message\n2. If over threshold, triggers compaction3. Uses the session's existing API to compactLet me also check what hooks are available and create a context-monitor hook.","thinkingSignature":"985c8b4e3b4046502d63f040ac1e2ebd268102b4840d91412c61d5a80876ea9b"},{"type":"text","text":"现在创建上下文监控 hook，实际执行压缩：\n"},{"type":"toolCall","id":"call_function_9d3iikybkz0l_1","name":"exec","arguments":{"command":"mkdir -p ~/.openclaw/hooks/context-monitor\ncat > ~/.openclaw/hooks/context-monitor/HOOK.md << 'EOF'\nname: context-monitor\ndescription: \"监控 session context 大小，超过阈值时触发自动压缩。依赖 context.maxContextTokens 和 summarizeThreshold 配置。\"\nmetadata:\n  {\n    \"openclaw\": {\n      \"emoji\": \"🧠\",\n      \"events\": [\"message:preprocessed\", \"agent:response\"],\n      \"requires\": {\"bins\": [\"node\"], \"config\": [\"context\"]},\n      \"always\": true\n    }\n  }\nEOF\n\ncat > ~/.openclaw/hooks/context-monitor/handler.js << 'JSEOF'\n#!/usr/bin/env node\n/**\n * Context Monitor Hook\n * 监控 session context 大小，超过阈值时触发自动压缩\n */\n\nconst fs = require('fs');\nconst path = require('path');\n\nconst CONFIG_PATH = '/home/ai/.openclaw/openclaw.json';\nconst SESSION_CONTEXT_PATH = process.env.OPENCLAW_SESSION_CONTEXT_PATH || \n  path.join(process.env.OPENCLAW_STATE_DIR || '/home/ai/.openclaw', 'sessions/agent:main:main/context.json');\n\nfunction loadConfig() {\n  try {\n    const config = JSON.parse(fs.readFileSync(CONFIG_PATH, 'utf8'));\n    const ctx = config.context || {};\n    return {\n      maxTokens: ctx.maxContextTokens || 160000,\n      threshold: ctx.summarizeThreshold || 0.75,\n      preserveRecent: ctx.preserveRecentTurns || 10,\n      enabled: ctx.monitoringEnabled !== false\n    };\n  } catch {\n    return null;\n  }\n}\n\nfunction countTokens(text) {\n  if (!text) return 0;\n  const chinese = (text.match(/[\\u4e00-\\u9fa5]/g) || []).length;\n  const other = text.length - chinese;\n  return Math.ceil(chinese / 1.5 + other / 4);\n}\n\nfunction countSessionTokens(messages) {\n  return messages.reduce((sum, m) => {\n    return sum + countTokens(m.content || '') + countTokens(m.name || '') + 20;\n  }, 0);\n}\n\nasync function compactSession(messages, config) {\n  const systemMsgs = messages.filter(m => m.role === 'system');\n  const recentMsgs = messages.slice(-config.preserveRecent);\n  const oldMsgs = messages.slice(0, -config.preserveRecent);\n  \n  // 生成摘要\n  const oldText = oldMsgs.map(m => `${m.role}: ${(m.content || '').slice(0, 200)}`).join('\\n');\n  const summary = oldText.length > 2000 ? oldText.slice(0, 2000) + '...' : oldText;\n  \n  const summaryMsg = {\n    role: 'system',\n    content: `[Previous conversation summary - ${oldMsgs.length} messages condensed]: ${summary}`\n  };\n  \n  return [...systemMsgs, summaryMsg, ...recentMsgs];\n}\n\nasync function main() {\n  const config = loadConfig();\n  if (!config || !config.enabled) {\n    console.log('[context-monitor] disabled or no config');\n    return;\n  }\n  \n  try {\n    const sessionData = JSON.parse(fs.readFileSync(SESSION_CONTEXT_PATH, 'utf8'));\n    const messages = sessionData.messages || [];\n    \n    const currentTokens = countSessionTokens(messages);\n    const limit = config.maxTokens * config.threshold;\n    \n    console.log(`[context-monitor] tokens=${currentTokens}/${limit} (${Math.round(currentTokens/limit*100)}%)`);\n    \n    if (currentTokens > limit) {\n      console.log(`[context-monitor] Threshold exceeded! Triggering compaction...`);\n      const compacted = await compactSession(messages, config);\n      sessionData.messages = compacted;\n      fs.writeFileSync(SESSION_CONTEXT_PATH, JSON.stringify(sessionData, null, 2));\n      console.log(`[context-monitor] Compaction done: ${messages.length} -> ${compacted.length} messages`);\n    }\n  } catch (err) {\n    console.error(`[context-monitor] Error: ${err.message}`);\n  }\n}\n\nmain();\nJSEOF\n\nchmod +x ~/.openclaw/hooks/context-monitor/handler.js\necho \"hook created\""}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":100046,"output":1008,"cacheRead":21638,"cacheWrite":0,"totalTokens":122692,"cost":{"input":0.0300138,"output":0.0012096,"cacheRead":0.00129828,"cacheWrite":0,"total":0.03252168}},"stopReason":"toolUse","timestamp":1776442785767,"responseId":"063190a1d8f2dfcbb0c125fae545745b"}}
