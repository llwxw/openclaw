ue;\n604:      const filePath = path.join(MEMORY_DIR, file);\n613:      console.log(`[session-summary] 清理旧摘要: ${pruned} 个`);\n646:  const { summary, entities } = (content.trim().length > 50 || hasEphemeral)\n651:    : { summary: buildFallbackSummary(\"(无会话内容)\", date, time), entities: [] };\n654:  writeSummaryFile(summary, date, time, event.sessionKey).catch((err) => {\n655:    console.error(\"[session-summary] Write error:\", err);\n662:        console.error(\"[session-summary] Entity write error:\", err);\n669:    console.error(\"[session-summary] Prune error:\", err);\n677:    console.error(\"[session-summary] Uncaught error:\", err);"}],"details":{"status":"completed","exitCode":0,"durationMs":-662,"aggregated":"2: * session-summary hook\n9: *   4. 写入 memory/YYYY-MM-DD-summary.md\n21:const MEMORY_DIR = path.join(\n26:const EPHEMERAL_DIR = path.join(MEMORY_DIR, \"ephemeral\");\n27:const ENTITIES_DIR = path.join(MEMORY_DIR, \"entities\");\n373: * @returns {Promise<{summary: string, entities: Array<{action:string,name:string,file:string,content:string}>}>}\n436: * @returns {{summary: string, entities: Array<{action:string,name:string,file:string,content:string}>}}\n460:  let summary = text.replace(/## entities\\n[\\s\\S]*?(?:---|$)/, '').trim();\n462:  summary = summary.replace(/^## 摘要\\s*/, '');\n464:  return { summary: summary.trim(), entities };\n469: * @returns {{summary: string, entities: Array}}\n473:  const summary = `# Session 摘要\n490:  return { summary, entities: [] };\n505:    await fs.promises.writeFile(filePath, header + content + '\\n', 'utf-8');\n506:    console.log(`[session-summary] Entity written: ${name}.md`);\n508:    console.error(`[session-summary] Entity write failed: ${name}`, e);\n545: * @param {string} summary\n551:async function writeSummaryFile(summary, date, time, sessionKey) {\n552:  const slug = slugFromSummary(summary, time);\n554:  const filePath = path.join(MEMORY_DIR, filename);\n556:  await fs.promises.mkdir(MEMORY_DIR, { recursive: true });\n561:    \"<!-- summary-only -->\",\n562:    summary,\n567:  await fs.promises.writeFile(filePath, fullContent, \"utf-8\");\n568:  console.log(`[session-summary] Written: ${filename}`);\n572: * @param {string} summary\n576:function slugFromSummary(summary, time) {\n577:  const match = summary.match(/^## 主题$\\s*([^\\n]+)/m);\n592: * 删除 30 天前的旧 session-summary 文件，防止累积。\n597:    const files = await fs.promises.readdir(MEMORY_DIR);\n603:      if (!file.endsWith('-session-summary.md')) continue;\n604:      const filePath = path.join(MEMORY_DIR, file);\n613:      console.log(`[session-summary] 清理旧摘要: ${pruned} 个`);\n646:  const { summary, entities } = (content.trim().length > 50 || hasEphemeral)\n651:    : { summary: buildFallbackSummary(\"(无会话内容)\", date, time), entities: [] };\n654:  writeSummaryFile(summary, date, time, event.sessionKey).catch((err) => {\n655:    console.error(\"[session-summary] Write error:\", err);\n662:        console.error(\"[session-summary] Entity write error:\", err);\n669:    console.error(\"[session-summary] Prune error:\", err);\n677:    console.error(\"[session-summary] Uncaught error:\", err);","cwd":"/home/ai/.openclaw/workspace/main"},"isError":false,"timestamp":1776173386755}}
{"type":"message","id":"c64f3c63","parentId":"1b79718b","timestamp":"2026-04-14T13:29:56.783Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I can see the session-summary hook writes to `MEMORY_DIR` which is `path.join(process.env.OPENCLAW_WORKSPACE_DIR || path.join(os.homedir(), \".openclaw\", \"workspace\"), \"memory\")`.\n\nFor the main agent, `OPENCLAW_WORKSPACE_DIR` is set to the workspace directory, which is `~/.openclaw/workspace/main`. So `MEMORY_DIR` would be `~/.openclaw/workspace/main/memory`.\n\nBut the summary file was found at `~/.openclaw/workspace/memory/2026-04-13-session-summary.md` (without `main`). This is confusing.\n\nWait, let me re-check. \n\nI need to figure out whether the session-summary hook is writing to `~/.openclaw/workspace/memory/` or `~/.openclaw/workspace/main/memory/`. Since the bootstrap hook reads from `memoryRoot = ${workspaceDir}/memory`, if `workspaceDir = ~/.openclaw/workspace/main`, then it should read from `~/.openclaw/workspace/main/memory/`. But the summary file seems to be in the parent directory instead, which suggests either the hook is writing to the wrong location or there's something else going on with how the paths are being resolved.\n\nActually, looking at this more carefully - there's only one session-summary file from April 13, but I ran `/new` today and it didn't create a new one. The hook is enabled in openclaw.json, so either it failed silently or it can't find the previous session's .jsonl file in webchat mode. Let me check the hook logs to see what actually happened.","thinkingSignature":"00883d8e96e466ce333bcd237c95f9ac185959693a0d1c2615787dbcfd29c346"},{"type":"toolCall","id":"call_function_v67tcsy8kf8d_1","name":"exec","arguments":{"command":"journalctl -u openclaw 2>/dev/null | tail -30; openclaw logs 2>/dev/null | tail -30"}},{"type":"toolCall","id":"call_function_v67tcsy8kf8d_2","name":"exec","arguments":{"command":"cat ~/.openclaw/workspace/memory/2026-04-13-session-summary.md 2>/dev/null"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":13084,"output":426,"cacheRead":19750,"cacheWrite":0,"totalTokens":33260,"cost":{"input":0.0039252,"output":0.0005112,"cacheRead":0.0011849999999999999,"cacheWrite":0,"total":0.0056214}},"stopReason":"toolUse","timestamp":1776173386767,"responseId":"062d744acc490ba1a48fe467ae6c56e1"}}
{"type":"message","id":"7c8280e3","parentId":"c64f3c63","timestamp":"2026-04-14T13:29:56.932Z","message":{"role":"toolResult","toolCallId":"call_function_v67tcsy8kf8d_1","toolName":"exec","content":[{"type":"text","text":"-- Logs begin at Tue 2026-04-14 16:52:18 CST, end at Tue 2026-04-14 21:29:51 CST. --\n-- No entries --"}],"details":{"status":"completed","exitCode":0,"durationMs":99,"aggregated":"-- Logs begin at Tue 2026-04-14 16:52:18 CST, end at Tue 2026-04-14 21:29:51 CST. --\n-- No entries --","cwd":"/home/ai/.openclaw/workspace/main"},"isError":false,"timestamp":1776173396919}}
{"type":"message","id":"812837bd","parentId":"7c8280e3","timestamp":"2026-04-14T13:29:56.948Z","message":{"role":"toolResult","toolCallId":"call_function_v67tcsy8kf8d_2","toolName":"exec","content":[{"type":"text","text":"# Session: 2026-04-13 17:00\n\n<!-- summary-only -->\n\n## 主题\n框架全面检查 + 记忆链路修复 + 知识库精简\n\n## 关键决策\n1. 修复 auto-score-classify hook：3108→3105（scene-classifier 端口）\n2. 修复 bootstrap hook：主动读 session-summary 注入新 session\n3. 修复 wiki-learn cron delivery：改 none 避免 channel 报错\n4. 建立 entity 稳定机制：blocklist 防重复摄入，稳定在 30 个\n5. 确认 session-summary 链路：ephemeral→摘要→bootstrap 已全线通\n\n## 重要发现\n1. bootstrap hook（handler.js）会在 /new 时主动读最新 session-summary 注入上下文\n2. auto-score-classify hook 在跑，每条消息更新 context.json\n3. ephemeral isMeaningful 过滤合理：高风险/拦截/显式记忆请求才入 ephemeral\n4. session-summary hook 每次 /new 时运行，从 ephemeral + session 内容提炼摘要\n5. entity 精简策略：TARGET=30，超量时删 auto-ingested 低行数模板\n\n## 待跟进\n- [ ] 下次 /new 验证 bootstrap 是否真正注入摘要\n- [ ] 清理 openclaw-router (pid 434)\n- [ ] 确认 entity 升格在 session-summary hook 中正常工作\n\n<!-- source: agent:main:main -->"}],"details":{"status":"completed","exitCode":0,"durationMs":83,"aggregated":"# Session: 2026-04-13 17:00\n\n<!-- summary-only -->\n\n## 主题\n框架全面检查 + 记忆链路修复 + 知识库精简\n\n## 关键决策\n1. 修复 auto-score-classify hook：3108→3105（scene-classifier 端口）\n2. 修复 bootstrap hook：主动读 session-summary 注入新 session\n3. 修复 wiki-learn cron delivery：改 none 避免 channel 报错\n4. 建立 entity 稳定机制：blocklist 防重复摄入，稳定在 30 个\n5. 确认 session-summary 链路：ephemeral→摘要→bootstrap 已全线通\n\n## 重要发现\n1. bootstrap hook（handler.js）会在 /new 时主动读最新 session-summary 注入上下文\n2. auto-score-classify hook 在跑，每条消息更新 context.json\n3. ephemeral isMeaningful 过滤合理：高风险/拦截/显式记忆请求才入 ephemeral\n4. session-summary hook 每次 /new 时运行，从 ephemeral + session 内容提炼摘要\n5. entity 精简策略：TARGET=30，超量时删 auto-ingested 低行数模板\n\n## 待跟进\n- [ ] 下次 /new 验证 bootstrap 是否真正注入摘要\n- [ ] 清理 openclaw-router (pid 434)\n- [ ] 确认 entity 升格在 session-summary hook 中正常工作\n\n<!-- source: agent:main:main -->","cwd":"/home/ai/.opencl