{"type":"message","id":"cf9bb44b","parentId":"ceedc5c7","timestamp":"2026-04-14T06:11:58.234Z","message":{"role":"toolResult","toolCallId":"call_function_7hf3cjk95eaw_1","toolName":"exec","content":[{"type":"text","text":"\"hooks\": {\n        \"internal\": {\n            \"enabled\": true,\n            \"entries\": {\n                \"session-memory\": {\n                    \"enabled\": true\n                },\n                \"command-logger\": {\n                    \"enabled\": true\n                },\n                \"self-improvement\": {\n                    \"enabled\": true\n                },\n                \"context_hook\": {\n                    \"enabled\": true\n                },\n                \"auto-score-classify\": {\n                    \"enabled\": true\n                },\n                \"session-summary\": {\n                    \"enabled\": true"}],"details":{"status":"completed","exitCode":0,"durationMs":81,"aggregated":"\"hooks\": {\n        \"internal\": {\n            \"enabled\": true,\n            \"entries\": {\n                \"session-memory\": {\n                    \"enabled\": true\n                },\n                \"command-logger\": {\n                    \"enabled\": true\n                },\n                \"self-improvement\": {\n                    \"enabled\": true\n                },\n                \"context_hook\": {\n                    \"enabled\": true\n                },\n                \"auto-score-classify\": {\n                    \"enabled\": true\n                },\n                \"session-summary\": {\n                    \"enabled\": true","cwd":"/home/ai/.openclaw/workspace/main"},"isError":false,"timestamp":1776147118223}}
