{"type":"message","id":"1e862a0d","parentId":"a9904a25","timestamp":"2026-04-14T07:41:51.290Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create the backupService.ts.","thinkingSignature":"1cdade3ff2fe5678a1a5807ebe70b72e1eada37a53a29d556ca665627f457e00"},{"type":"text","text":"---\n\n## 第 2 步：创建 `src/main/backupService.ts`\n\n**思考：** 备份服务需要实现：create / list / restore / delete。简单方案：用 JSON 记录备份元数据，备份内容用 zip 压缩（Node.js 内置 zlib，不用额外依赖）。\n"},{"type":"toolCall","id":"call_function_0ljr3hr9ggyx_1","name":"write","arguments":{"path":"/mnt/d/aafuzhi/axs/src/main/backupService.ts","content":"/**\n * 备份服务 - 主进程 IPC 处理器\n * 处理小说项目的备份/恢复\n */\n\nimport { IpcMain, app } from 'electron'\nimport fs from 'node:fs'\nimport path from 'node:path'\nimport zlib from 'node:zlib'\nimport { promisify } from 'node:util'\n\nconst gzip = promisify(zlib.gzip)\nconst gunzip = promisify(zlib.gunzip)\n\nconst BACKUP_DIR = path.join(app.getPath('userData'), 'backups')\nconst BACKUP_INDEX = path.join(BACKUP_DIR, 'index.json')\n\ninterface BackupEntry {\n  name: string\n  path: string\n  date: string\n  size: number\n  description?: string\n}\n\nfunction loadIndex(): BackupEntry[] {\n  if (!fs.existsSync(BACKUP_INDEX)) return []\n  try {\n    return JSON.parse(fs.readFileSync(BACKUP_INDEX, 'utf-8'))\n  } catch {\n    return []\n  }\n}\n\nfunction saveIndex(index: BackupEntry[]): void {\n  fs.mkdirSync(BACKUP_DIR, { recursive: true })\n  fs.writeFileSync(BACKUP_INDEX, JSON.stringify(index, null, 2), 'utf-8')\n}\n\n// 递归压缩目录为一个 gzip 文件\nasync function compressDir(dirPath: string, relativeRoot: string): Promise<Buffer> {\n  const entries: { path: string; relativePath: string; isDir: boolean }[] = []\n\n  function walk(dir: string): void {\n    const items = fs.readdirSync(dir)\n    for (const item of items) {\n      const full = path.join(dir, item)\n      const rel = path.relative(relativeRoot, full)\n      const stat = fs.statSync(full)\n      if (stat.isDirectory()) {\n        entries.push({ path: full, relativePath: rel + '/', isDir: true })\n        walk(full)\n      } else {\n        entries.push({ path: full, relativePath: rel, isDir: false })\n      }\n    }\n  }\n  walk(dirPath)\n\n  // 构建文件列表 JSON\n  const manifest = JSON.stringify(entries, null, 2)\n  const manifestBuf = Buffer.from(manifest, 'utf-8')\n\n  const parts: Buffer[] = []\n  // 格式：4字节manifest长度 + manifest JSON + 各文件内容\n  const manifestLenBuf = Buffer.alloc(4)\n  manifestLenBuf.writeUInt32BE(manifestBuf.length, 0)\n  parts.push(manifestLenBuf, manifestBuf)\n\n  for (const entry of entries) {\n    if (entry.isDir) continue\n    const content = fs.readFileSync(entry.path)\n    const nameBuf = Buffer.from(entry.relativePath, 'utf-8')\n    const nameLenBuf = Buffer.alloc(2)\n    nameLenBuf.writeUInt16BE(nameBuf.length, 0)\n    const sizeBuf = Buffer.alloc(4)\n    sizeBuf.writeUInt32BE(content.length, 0)\n    parts.push(nameLenBuf, nameBuf, sizeBuf, content)\n  }\n\n  const combined = Buffer.concat(parts)\n  return gzip(combined)\n}\n\nasync function decompressBackup(\n  archivePath: string,\n  targetDir: string\n): Promise<void> {\n  const raw = fs.readFileSync(archivePath)\n  const decompressed = await gunzip(raw)\n\n  let offset = 0\n\n  // 读取 manifest\n  const manifestLen = decompressed.readUInt32BE(offset)\n  offset += 4\n  const manifest = JSON.parse(decompressed.slice(offset, offset + manifestLen).toString('utf-8'))\n  offset += manifestLen\n\n  // 清空目标目录\n  if (fs.existsSync(targetDir)) {\n    fs.rmSync(targetDir, { recursive: true })\n  }\n  fs.mkdirSync(targetDir, { recursive: true })\n\n  // 恢复每个文件\n  for (const entry of manifest) {\n    if (entry.isDir) {\n      fs.mkdirSync(path.join(targetDir, entry.relativePath), { recursive: true })\n      continue\n    }\n\n    const nameLen = decompressed.readUInt16BE(offset)\n    offset += 2\n    // skip name (already have from manifest)\n    offset += nameLen\n    const size = decompressed.readUInt32BE(offset)\n    offset += 4\n    const content = decompressed.slice(offset, offset + size)\n    offset += size\n\n    const fullPath = path.join(targetDir, entry.relativePath)\n    fs.mkdirSync(path.dirname(fullPath), { recursive: true })\n    fs.writeFileSync(fullPath, content)\n  }\n}\n\nfunction getBackupSize(archivePath: string): number {\n  try {\n    return fs.statSync(archivePath).size\n  } catch {\n    return 0\n  }\n}\n\nexport function setupBackupHandlers(ipcMain: IpcMain): void {\n  // 创建备份\n  ipcMain.handle('backup:create', async (_event, projectPath?: string) => {\n    try {\n      if (!projectPath) {\n        return { success: false, error: '未提供项目路径' }\n      }\n      if (!fs.existsSync(projectPath)) {\n        return { success: false, error: '项目路径不存在' }\n      }\n\n      fs.mkdirSync(BACKUP_DIR, { recursive: true })\n\n      const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19)\n      const name = path.basename(projectPath) + '_' + timestamp\n      const archivePath = path.join(BACKUP_DIR, name + '.nbackup')\n\n      const archive = await compressDir(projectPath, projectPath)\n      fs.writeFileSync(archivePath, archive)\n\n      const entry: BackupEntry = {\n        name,\n        path: archivePath,\n        date: new Date().toISOString(),\n        size: archive.length,\n      }\n\n      const index = loadIndex()\n      index.unshift(entry)\n      saveIndex(index)\n\n      return { success: true, backupPath: archivePath }\n    } catch (e: any) {\n      return { success: false, error: e.message }\n    }\n  })\n\n  // 列出备份\n  ipcMain.handle('backup:list', async () => {\n    try {\n      const index = loadIndex()\n      // 清理不存在的备份记录\n      const valid = index.filter(e => fs.existsSync(e.path))\n      if (valid.length !== index.length) {\n        saveIndex(valid)\n      }\n      return {\n        success: true,\n        backups: valid.map(e => ({\n          name: e.name,\n          path: e.path,\n          date: e.date,\n          size: e.size,\n        })),\n      }\n    } catch (e: any) {\n      return { success: false, error: e.message }\n    }\n  })\n\n  // 恢复备份\n  ipcMain.handle('backup:restore', async (_event, backupPath: string, targetPath?: string) => {\n    try {\n      if (!fs.existsSync(backupPath)) {\n        return { success: false, error: '备份文件不存在' }\n      }\n      if (!targetPath) {\n        return { success: false, error: '未提供恢复目标路径' }\n      }\n\n      await decompressBackup(backupPath, targetPath)\n      return { success: true }\n    } catch (e: any) {\n      return { success: false, error: e.message }\n    }\n  })\n\n  // 删除备份\n  ipcMain.handle('backup:delete', async (_event, backupPath: string) => {\n    try {\n      if (fs.existsSync(backupPath)) {\n        fs.unlinkSync(backupPath)\n      }\n      const index = loadIndex()\n      saveIndex(index.filter(e => e.path !== backupPath))\n      return { success: true }\n    } catch (e: any) {\n      return { success: false, error: e.message }\n    }\n  })\n}\n"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":37547,"output":1792,"cacheRead":19262,"cacheWrite":0,"totalTokens":58601,"cost":{"input":0.011264099999999999,"output":0.0021504,"cacheRead":0.0011557199999999998,"cacheWrite":0,"total":0.014570219999999998}},"stopReason":"toolUse","timestamp":1776152474399,"responseId":"062d229a6bbc5df7fe256e4c9c349239"}}
