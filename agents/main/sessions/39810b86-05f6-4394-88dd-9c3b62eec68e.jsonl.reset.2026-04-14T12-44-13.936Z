{"type":"message","id":"ba42077a","parentId":"ede3cd2f","timestamp":"2026-04-14T08:11:48.576Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"There's no root `tsconfig.json`! This means Vite might be using its own config. Let me check if there's a `tsconfig.node.json` or similar for Vite.","thinkingSignature":"73d3c012a23e9a181baf66ba00fdb8241bcab1f4dc82a417c338d5e1701d21ab"},{"type":"toolCall","id":"call_function_2hqt7ljsgixp_1","name":"exec","arguments":{"command":"ls /mnt/d/aafuzhi/axs/tsconfig* 2>/dev/null\necho \"---\"\ncat /mnt/d/aafuzhi/axs/vite.config.ts | head -30"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":74113,"output":106,"cacheRead":19262,"cacheWrite":0,"totalTokens":93481,"cost":{"input":0.022233899999999997,"output":0.0001272,"cacheRead":0.0011557199999999998,"cacheWrite":0,"total":0.023516819999999997}},"stopReason":"toolUse","timestamp":1776154304371,"responseId":"062d29bf200c236fb84f87743a8fc303"}}
{"type":"message","id":"78917233","parentId":"ba42077a","timestamp":"2026-04-14T08:11:48.759Z","message":{"role":"toolResult","toolCallId":"call_function_2hqt7ljsgixp_1","toolName":"exec","content":[{"type":"text","text":"/mnt/d/aafuzhi/axs/tsconfig.main.json\n---\nimport { defineConfig } from 'vite';\nimport react from '@vitejs/plugin-react';\nimport { resolve } from 'path';\n\nexport default defineConfig({\n  plugins: [react()],\n  base: './',\n  root: resolve(__dirname, 'src/renderer'),\n  build: {\n    outDir: resolve(__dirname, 'dist/renderer'),\n    emptyOutDir: true,\n    rollupOptions: {\n      input: resolve(__dirname, 'src/renderer/index.html'),\n    },\n  },\n  resolve: {\n    alias: {\n      '@': resolve(__dirname, 'src/renderer/src'),\n    },\n  },\n  server: {\n    port: 5173,\n  },\n});"}],"details":{"status":"completed","exitCode":0,"durationMs":100,"aggregated":"/mnt/d/aafuzhi/axs/tsconfig.main.json\n---\nimport { defineConfig } from 'vite';\nimport react from '@vitejs/plugin-react';\nimport { resolve } from 'path';\n\nexport default defineConfig({\n  plugins: [react()],\n  base: './',\n  root: resolve(__dirname, 'src/renderer'),\n  build: {\n    outDir: resolve(__dirname, 'dist/renderer'),\n    emptyOutDir: true,\n    rollupOptions: {\n      input: resolve(__dirname, 'src/renderer/index.html'),\n    },\n  },\n  resolve: {\n    alias: {\n      '@': resolve(__dirname, 'src/renderer/src'),\n    },\n  },\n  server: {\n    port: 5173,\n  },\n});","cwd":"/home/ai/.openclaw/workspace/main"},"isError":false,"timestamp":1776154308735}}
{"type":"message","id":"2d22d95f","parentId":"78917233","timestamp":"2026-04-14T08:12:00.162Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"There's no `tsconfig.json` for the renderer (React/Vite) side. Vite uses esbuild for TypeScript transpilation without full type checking. This means the renderer TypeScript code isn't being type-checked by Vite - only compiled/bundled.\n\nThis is a common setup and not necessarily wrong. But let me check if there's a tsconfig for the renderer side.\n\nActually, this is a notable finding - there's no tsconfig.json for the renderer. The renderer TypeScript is transpiled by Vite/esbuild without full type checking. This means type errors in the renderer code would only be caught at runtime or when the editor provides warnings.\n\n\nI should look at the factExtractor to understand how it's integrating with the rest of the system.","thinkingSignature":"82ee015d5eddba9240930fbea18ab1d602d9fe15fdec4922a3ba9e7439294f72"},{"type":"text","text":"⚠️ **发现：renderer 端没有 tsconfig.json** — Vite 用 esbuild 直接编译 TypeScript，不做完整类型检查。renderer 类型错误只能靠编辑器警告，不会在构建时报出来。\n\n---\n\n## 第 6 步：审查 factExtractor 的 facts 保存链路\n"},{"type":"toolCall","id":"call_function_1xqkwawkxr1h_1","name":"exec","arguments":{"command":"cat /mnt/d/aafuzhi/axs/src/renderer/src/services/factExtractor.ts"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":74392,"output":258,"cacheRead":19262,"cacheWrite":0,"totalTokens":93912,"cost":{"input":0.0223176,"output":0.0003096,"cacheRead":0.0011557199999999998,"cacheWrite":0,"total":0.02378292}},"stopReason":"toolUse","timestamp":1776154308765,"responseId":"062d29c4cf642979df710564b0764a66"}}
{"type":"message","id":"12a8ef9a","parentId":"2d22d95f","timestamp":"2026-04-14T08:12:00.272Z","message":{"role":"toolResult","toolCallId":"call_function_1xqkwawkxr1h_1","toolName":"exec","content":[{"type":"text","text":"/**\n * 事实提取服务\n * 自动从章节内容中提取战力、物品、关系、伏笔等事实\n */\n\nimport aiModelService from './aiModels'\nimport factsStore, { Fact } from '../db'\n\n// 提取结果类型\nexport interface ExtractedFact extends Omit<Fact, 'id' | 'createdAt'> {\n  confidence: number // 置信度 0-1\n}\n\nclass FactExtractor {\n  /**\n   * 从章节内容提取事实\n   */\n  async extract(\n    chapterContent: string,\n    chapterNumber: number\n  ): Promise<ExtractedFact[]> {\n    try {\n      const systemPrompt = `\n你是小说事实提取专家。请从以下章节内容中提取关键事实信息，返回严格的JSON格式数组。\n\n提取规则：\n1. 战力信息(type=\"power\")：角色的等级、实力、功法等\n2. 物品信息(type=\"item\")：武器、丹药、宝物等\n3. 关系信息(type=\"relation\")：角色之间的关系（朋友、敌人、师徒、夫妻等）\n4. 伏笔信息(type=\"foreshadow\")：后续可能用到的线索、未解开的谜团\n\n每个事实必须包含：\n- type: 类型（power/item/relation/foreshadow）\n- subject: 主体（如\"林枫\"）\n- object: 客体（可选，如\"青云子\"）\n- content: 事实描述（如\"林枫修炼到炼气三层\"）\n- chapterStart: 章节号（传入的 ${chapterNumber}）\n- chapterEnd: 章节号（传入的 ${chapterNumber}）\n- confidence: 置信度 0-1\n\n返回格式示例：\n[\n  {\n    \"type\": \"power\",\n    \"subject\": \"林枫\",\n    \"object\": \"\",\n    \"content\": \"林枫突破到炼气三层，实力提升三倍\",\n    \"chapterStart\": ${chapterNumber},\n    \"chapterEnd\": ${chapterNumber},\n    \"confidence\": 0.95\n  }\n]\n\n只返回JSON，不要其他内容。\n`\n\n      const result = await aiModelService.call(\n        'extraction',\n        chapterContent,\n        { systemPrompt }\n      )\n\n      if (!result.success || !result.content) {\n        return []\n      }\n\n      // 解析提取结果\n      let extractedFacts: ExtractedFact[]\n      try {\n        extractedFacts = JSON.parse(result.content.trim())\n      } catch (parseError) {\n        console.error('解析提取结果失败:', parseError)\n        return []\n      }\n\n      return extractedFacts\n    } catch (error) {\n      console.error('事实提取失败:', error)\n      return []\n    }\n  }\n\n  /**\n   * 批量保存事实到数据库\n   */\n  async saveFacts(facts: Omit<Fact, 'id' | 'createdAt'>[]): Promise<string[]> {\n    const result = await factsStore.appendFacts(facts.map(f => ({\n      type: f.type,\n      subject: f.subject,\n      object: f.object,\n      content: f.content,\n      chapterStart: f.chapterStart,\n      chapterEnd: f.chapterEnd,\n      confidence: 1.0,\n    })))\n    return result.success ? ['ok'] : []\n  }\n\n  /**\n   * 自动提取并保存（用户确认后调用）\n   */\n  async extractAndSave(\n    chapterContent: string,\n    chapterNumber: number\n  ): Promise<string[]> {\n    const facts = await this.extract(chapterContent, chapterNumber)\n    // 过滤置信度低于0.7的结果\n    const highConfidenceFacts = facts.filter(f => f.confidence >= 0.7)\n    return this.saveFacts(highConfidenceFacts)\n  }\n\n  /**\n   * 验证事实一致性\n   */\n  async verifyConsistency(\n    newFacts: ExtractedFact[],\n    existingFacts: Fact[]\n  ): Promise<Array<{ fact: ExtractedFact; conflict?: Fact; message: string }>> {\n    const conflicts: Array<{ fact: ExtractedFact; conflict?: Fact; message: string }> = []\n\n    for (const newFact of newFacts) {\n      // 检查是否与现有事实冲突\n      const conflicting = existingFacts.find(f => {\n        if (f.subject !== newFact.subject) return false\n        \n        // 相同主体的战力信息冲突检查\n        if (f.type === 'power' && newFact.type === 'power') {\n          // 简单的冲突检测：如果新事实表明战力下降但没有合理解释\n          const oldLevel = this.extractPowerLevel(f.content)\n          const newLevel = this.extractPowerLevel(newFact.content)\n          return oldLevel !== null && newLevel !== null && newLevel < oldLevel\n        }\n        \n        // 关系信息冲突检查\n        if (f.type === 'relation' && newFact.type === 'relation') {\n          return f.object === newFact.object && f.content !== newFact.content\n        }\n        \n        return false\n      })\n\n      if (conflicting) {\n        conflicts.push({\n          fact: newFact,\n          conflict: conflicting,\n          message: `检测到事实冲突：现有记录 \"${conflicting.content}\" 与新提取的 \"${newFact.content}\" 不一致`\n        })\n      }\n    }\n\n    return conflicts\n  }\n\n  /**\n   * 辅助方法：提取战力等级\n   */\n  private extractPowerLevel(content: string): number | null {\n    const regex = /炼气(\\d+)/i\n    const match = content.match(regex)\n    if (match) return parseInt(match[1])\n    \n    const regex2 = /筑基(\\d+)/i\n    const match2 = content.match(regex2)\n    if (match2) return parseInt(match2[1]) + 10 // 筑基阶段+10\n    \n    return null\n  }\n}\n\n// 单例导出\nconst factExtractor = new FactExtractor()\nexport default factExtractor"}],"details":{"status":"completed","exitCode":0,"durationMs":62,"aggregated":"/**\n * 事实提取服务\n * 自动从章节内容中提取战力、物品、关系、伏笔等事实\n */\n\nimport aiModelService from './aiModels'\nimport factsStore, { Fact } from '../db'\n\n// 提取结果类型\nexport interface ExtractedFact extends Omit<Fact, 'id' | 'createdAt'> {\n  confidence: number // 置信度 0-1\n}\n\nclass FactExtractor {\n  /**\n   * 从章节内容提取事实\n   */\n  async extract(\n    chapterContent: string,\n    chapterNumber: number\n  ): Promise<ExtractedFact[]> {\n    try {\n      const systemPrompt = `\n你是小说事实提取专家。请从以下章节内容中提取关键事实信息，返回严格的JSON格式数组。\n\n提取规则：\n1. 战力信息(type=\"power\")：角色的等级、实力、功法等\n2. 物品信息(type=\"item\")：武器、丹药、宝物等\n3. 关系信息(type=\"relation\")：角色之间的关系（朋友、敌人、师徒、夫妻等）\n4. 伏笔信息(type=\"foreshadow\")：后续可能用到的线索、未解开的谜团\n\n每个事实必须包含：\n- type: 类型（power/item/relation/foreshadow）\n- subject: 主体（如\"林枫\"）\n- object: 客体（可选，如\"青云子\"）\n- content: 事实描述（如\"林枫修炼到炼气三层\"）\n- chapterStart: 章节号（传入的 ${chapterNumber}）\n- chapterEnd: 章节号（传入的 ${chapterNumber}）\n- confidence: 置信度 0-1\n\n返回格式示例：\n[\n  {\n    \"type\": \"power\",\n    \"subject\": \"林枫\",\n    \"object\": \"\",\n    \"content\": \"林枫突破到炼气三层，实力提升三倍\",\n    \"chapterStart\": ${chapterNumber},\n    \"chapterEnd\": ${chapterNumber},\n    \"confidence\": 0.95\n  }\n]\n\n只返回JSON，不要其他内容。\n`\n\n      const result = await aiModelService.call(\n        'extraction',\n        chapterContent,\n        { systemPrompt }\n      )\n\n      if (!result.success || !result.content) {\n        return []\n      }\n\n      // 解析提取结果\n      let extractedFacts: ExtractedFact[]\n      try {\n        extractedFacts = JSON.parse(result.content.trim())\n      } catch (parseError) {\n        console.error('解析提取结果失败:', parseError)\n        return []\n      }\n\n      return extractedFacts\n    } catch (error) {\n      console.error('事实提取失败:', error)\n      return []\n    }\n  }\n\n  /**\n   * 批量保存事实到数据库\n   */\n  async saveFacts(facts: Omit<Fact, 'id' | 'createdAt'>[]): Promise<string[]> {\n    const result = await factsStore.appendFacts(facts.map(f => ({\n      type: f.type,\n      subject: f.subject,\n      object: f.object,\n      content: f.content,\n      chapterStart: f.chapterStart,\n      chapterEnd: f.chapterEnd,\n      confidence: 1.0,\n    })))\n    return result.success ? ['ok'] : []\n  }\n\n  /**\n   * 自动提取并保存（用户确认后调用）\n   */\n  async extractAndSave(\n    chapterContent: string,\n    chapterNumber: number\n  ): Promise<string[]> {\n    const facts = await this.extract(chapterContent, chapterNumber)\n    // 过滤置信度低于0.7的结果\n    const highConfidenceFacts = facts.filter(f => f.confidence >= 0.7)\n    return this.saveFacts(highConfidenceFacts)\n  }\n\n  /**\n   * 验证事实一致性\n   */\n  async verifyConsistency(\n    newFacts: ExtractedFact[],\n    existingFacts: Fact[]\n  ): Promise<Array<{ fact: ExtractedFact; conflict?: Fact; message: string }>> {\n    const conflicts: Array<{ fact: ExtractedFact; conflict?: Fact; message: string }> = []\n\n    for (const newFact of newFacts) {\n      // 检查是否与现有事实冲突\n      const conflicting = existingFacts.find(f => {\n        if (f.subject !== newFact.subject) return false\n        \n        // 相同主体的战力信息冲突检查\n        if (f.type === 'power' && newFact.type === 'power') {\n          // 简单的冲突检测：如果新事实表明战力下降但没有合理解释\n          const oldLevel = this.extractPowerLevel(f.content)\n          const newLevel = this.extractPowerLevel(newFact.content)\n          return oldLevel !== null && newLevel !== null && newLevel < oldLevel\n        }\n        \n        // 关系信息冲突检查\n        if (f.type === 'relation' && newFact.type === 'relation') {\n          return f.object === newFact.object && f.content !== newFact.content\n        }\n        \n        return false\n      })\n\n      if (conflicting) {\n        conflicts.push({\n          fact: newFact,\n          conflict: conflicting,\n          message: `检测到事实冲突：现有记录 \"${conflicting.content}\" 与新提取的 \"${newFact.content}\" 不一致`\n        })\n      }\n    }\n\n    return conflicts\n  }\n\n  /**\n   * 辅助方法：提取战力等级\n   */\n  private extractPowerLevel(content: string): number | null {\n    const regex = /炼气(\\d+)/i\n    const match = content.match(regex)\n    if (match) return parseInt(match[1])\n    \n    const regex2 = /筑基(\\d+)/i\n    const match2 = content.match(regex2)\n    if (match2) return parseInt(match2[1]) + 10 // 筑基阶段+10\n    \n    return null\n  }\n}\n\n// 单例导出\nconst factExtractor = new FactExtractor()\nexport default factExtractor","cwd":"/home/ai/.openclaw/workspace/main"},"isError":false,"timestamp":1776154320261}}
{"type":"message","id":"df16cbe8","parentId":"12a8ef9a","timestamp":"2026-04-14T08:12:19.580Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"I see a critical issue! The `factExtractor.extract()` calls `aiModelService.call('extraction', ...)` with the task type `'extraction'`. Let me check if `aiModelService` actually supports a task type `'extraction'`.\n\nLooking at the aiModels.ts:\n```typescript\nconst ModelTaskMapping: Record<TaskType, AIModel> = {\n  creative: 'doubao-pro',\n  summary: 'doubao-lite',\n  classification: 'doubao-mini',\n  logic: 'deepseek-reasoner',\n  extraction: 'doubao-lite',\n}\n```\n\nIt does support 'extraction' and maps to 'doubao-lite'. Good.\n\n\nBut `aiModels.ts` is a renderer service, not a Node.js module—it calls through `window.electronAPI.ai.call()` which maps to `ai:call` in the main process. Since I implemented the `ai:call` handler in aiService.ts to forward to the DeepSeek API, this chain should work, though I need to verify the prompt formatting is actually correct.\n\nThe `factExtractor` doesn't have a `systemPrompt` field in its `CallOptions` type, so it would just use the default prompt. Looking at `aiModels.ts` more closely, the `call` method takes a `TaskType` and passes an `options` object containing `systemPrompt` to `window.electronAPI.ai.call(prompt, { model, ...config, systemPrompt: options?.systemPrompt })`, which should correctly forward everything to the main process. The prompt handling looks solid. I notice `factExtractor.extractAndSave` exists but AIToolsPanel never actually calls it—there's no save button after extraction, which is a separate bug. Now checking the `verifyConsistency` method's `extractPowerLevel` function: it correctly returns null when no power level is found, and the comparison logic properly returns false if either level is null, so conflicts only trigger when both are valid numbers.","thinkingSignature":"c396916b7bade6a39e9ac10814b3143a4b6a718640e608e1528db39b664daff2"},{"type":"text","text":"✅ factExtractor 逻辑正确，`extractPowerLevel` null 安全。\n\n---\n\n## 第 7 步：审查 aiModels.ts 的 AI 调用链路\n"},{"type":"toolCall","id":"call_function_dc0lucx6mic4_1","name":"exec","arguments":{"command":"cat /mnt/d/aafuzhi/axs/src/renderer/src/services/aiModels.ts"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":75888,"output":483,"cacheRead":19262,"cacheWrite":0,"totalTokens":95633,"cost":{"input":0.0227664,"output":0.0005796,"cacheRead":0.0011557199999999998,"cacheWrite":0,"total":0.024501719999999998}},"stopReason":"toolUse","timestamp":1776154320276,"responseId":"062d29d193b3143573b610614803f314"}}
{"type":"message","id":"3d2abee2","parentId":"df16cbe8","timestamp":"2026-04-14T08:12:19.707Z","message":{"role":"toolResult","toolCallId":"call_function_dc0lucx6mic4_1","toolName":"exec","content":[{"type":"text","text":"/**\n * AI 模型服务\n * 不同任务自动选择最合适的模型\n */\n\nexport type AIModel = 'doubao-pro' | 'doubao-lite' | 'doubao-mini' | 'deepseek-reasoner'\nexport type TaskType = 'creative' | 'summary' | 'classification' | 'logic' | 'extraction'\n\n// 模型能力映射\nconst ModelTaskMapping: Record<TaskType, AIModel> = {\n  creative: 'doubao-pro',         // 章节生成、创意续写\n  summary: 'doubao-lite',         // 摘要、结构化分析\n  classification: 'doubao-mini',  // 极速分类\n  logic: 'deepseek-reasoner',     // 逻辑校验、一致性检查\n  extraction: 'doubao-lite',      // 事实提取\n}\n\n// 模型配置\ninterface ModelConfig {\n  maxTokens: number\n  temperature: number\n  topP: number\n  presencePenalty: number\n  frequencyPenalty: number\n}\n\nconst ModelConfigs: Record<AIModel, ModelConfig> = {\n  'doubao-pro': {\n    maxTokens: 4096,\n    temperature: 0.8,\n    topP: 0.9,\n    presencePenalty: 0.1,\n    frequencyPenalty: 0.1,\n  },\n  'doubao-lite': {\n    maxTokens: 2048,\n    temperature: 0.3,\n    topP: 0.85,\n    presencePenalty: 0.0,\n    frequencyPenalty: 0.0,\n  },\n  'doubao-mini': {\n    maxTokens: 1024,\n    temperature: 0.1,\n    topP: 0.7,\n    presencePenalty: 0.0,\n    frequencyPenalty: 0.0,\n  },\n  'deepseek-reasoner': {\n    maxTokens: 8192,\n    temperature: 0.2,\n    topP: 0.95,\n    presencePenalty: 0.0,\n    frequencyPenalty: 0.0,\n  },\n}\n\nclass AIModelService {\n  /**\n   * 根据任务类型选择最优模型\n   */\n  selectModel(taskType: TaskType): AIModel {\n    return ModelTaskMapping[taskType] || 'doubao-pro'\n  }\n\n  /**\n   * 获取模型配置\n   */\n  getModelConfig(model: AIModel): ModelConfig {\n    return ModelConfigs[model] || ModelConfigs['doubao-pro']\n  }\n\n  /**\n   * 调用 AI 模型 (非流式)\n   */\n  async call(\n    taskType: TaskType,\n    prompt: string,\n    options?: Partial<ModelConfig> & { systemPrompt?: string }\n  ): Promise<{ success: boolean; content?: string; error?: string }> {\n    try {\n      const model = this.selectModel(taskType)\n      const config = { ...this.getModelConfig(model), ...options }\n\n      const result = await window.electronAPI.ai.call(prompt, {\n        model,\n        ...config,\n        systemPrompt: options?.systemPrompt,\n      })\n\n      return result\n    } catch (error: any) {\n      return { success: false, error: error.message }\n    }\n  }\n\n  /**\n   * 流式调用 AI 模型\n   */\n  async stream(\n    taskType: TaskType,\n    prompt: string,\n    onChunk: (chunk: string, done: boolean) => void,\n    onError?: (error: string) => void,\n    options?: Partial<ModelConfig> & { systemPrompt?: string }\n  ): Promise<void> {\n    try {\n      const model = this.selectModel(taskType)\n      const config = { ...this.getModelConfig(model), ...options }\n\n      // 监听流式输出\n      const removeChunkListener = window.electronAPI.ai.onStreamChunk((chunk) => {\n        if (chunk.done) {\n          onChunk('', true)\n          removeChunkListener()\n          removeErrorListener()\n        } else {\n          onChunk(chunk.content, false)\n        }\n      })\n\n      // 监听错误\n      const removeErrorListener = window.electronAPI.ai.onStreamError((error) => {\n        if (onError) onError(error)\n        removeChunkListener()\n        removeErrorListener()\n      })\n\n      // 发起流式请求\n      await window.electronAPI.ai.stream(prompt, {\n        model,\n        ...config,\n        systemPrompt: options?.systemPrompt,\n      })\n    } catch (error: any) {\n      if (onError) onError(error.message)\n    }\n  }\n\n  /**\n   * 测试模型连接\n   */\n  async testConnection(model: AIModel): Promise<boolean> {\n    try {\n      const result = await window.electronAPI.ai.testConnection(model)\n      return result.success && result.result\n    } catch {\n      return false\n    }\n  }\n}\n\n// 单例导出\nconst aiModelService = new AIModelService()\nexport default aiModelService"}],"details":{"status":"completed","exitCode":0,"durationMs":74,"aggregated":"/**\n * AI 模型服务\n * 不同任务自动选择最合适的模型\n */\n\nexport type AIModel = 'doubao-pro' | 'doubao-lite' | 'doubao-mini' | 'deepseek-reasoner'\nexport type TaskType = 'creative' | 'summary' | 'classification' | 'logic' | 'extraction'\n\n// 模型能力映射\nconst ModelTaskMapping: Record<TaskType, AIModel> = {\n  creative: 'doubao-pro',         // 章节生成、创意续写\n  summary: 'doubao-lite',         // 摘要、结构化分析\n  classification: 'doubao-mini',  // 极速分类\n  logic: 'deepseek-reasoner',     // 逻辑校验、一致性检查\n  extraction: 'doubao-lite',      // 事实提取\n}\n\n// 模型配置\ninterface ModelConfig {\n  maxTokens: number\n  temperature: number\n  topP: number\n  presencePenalty: number\n  frequencyPenalty: number\n}\n\nconst ModelConfigs: Record<AIModel, ModelConfig> = {\n  'doubao-pro': {\n    maxTokens: 4096,\n    temperature: 0.8,\n    topP: 0.9,\n    presencePenalty: 0.1,\n    frequencyPenalty: 0.1,\n  },\n  'doubao-lite': {\n    maxTokens: 2048,\n    temperature: 0.3,\n    topP: 0.85,\n    presencePenalty: 0.0,\n    frequencyPenalty: 0.0,\n  },\n  'doubao-mini': {\n    maxTokens: 1024,\n    temperature: 0.1,\n    topP: 0.7,\n    presencePenalty: 0.0,\n    frequencyPenalty: 0.0,\n  },\n  'deepseek-reasoner': {\n    maxTokens: 8192,\n    temperature: 0.2,\n    topP: 0.95,\n    presencePenalty: 0.0,\n    frequencyPenalty: 0.0,\n  },\n}\n\nclass AIModelService {\n  /**\n   * 根据任务类型选择最优模型\n   */\n  selectModel(taskType: TaskType): AIModel {\n    return ModelTaskMapping[taskType] || 'doubao-pro'\n  }\n\n  /**\n   * 获取模型配置\n   */\n  getModelConfig(model: AIModel): ModelConfig {\n    return ModelConfigs[model] || ModelConfigs['doubao-pro']\n  }\n\n  /**\n   * 调用 AI 模型 (非流式)\n   */\n  async call(\n    taskType: TaskType,\n    prompt: string,\n    options?: Partial<ModelConfig> & { systemPrompt?: string }\n  ): Promise<{ success: boolean; content?: string; error?: string }> {\n    try {\n      const model = this.selectModel(taskType)\n      const config = { ...this.getModelConfig(model), ...options }\n\n      const result = await window.electronAPI.ai.call(prompt, {\n        model,\n        ...config,\n        systemPrompt: options?.systemPrompt,\n      })\n\n      return result\n    } catch (error: any) {\n      return { success: false, error: error.message }\n    }\n  }\n\n  /**\n   * 流式调用 AI 模型\n   */\n  async stream(\n    taskType: TaskType,\n    prompt: string,\n    onChunk: (chunk: string, done: boolean) => void,\n    onError?: (error: string) => void,\n    options?: Partial<ModelConfig> & { systemPrompt?: string }\n  ): Promise<void> {\n    try {\n      const model = this.selectModel(taskType)\n      const config = { ...this.getModelConfig(model), ...options }\n\n      // 监听流式输出\n      const removeChunkListener = window.electronAPI.ai.onStreamChunk((chunk) => {\n        if (chunk.done) {\n          onChunk('', true)\n          removeChunkListener()\n          removeErrorListener()\n        } else {\n          onChunk(chunk.content, false)\n        }\n      })\n\n      // 监听错误\n      const removeErrorListener = window.electronAPI.ai.onStreamError((error) => {\n        if (onError) onError(error)\n        removeChunkListener()\n        removeErrorListener()\n      })\n\n      // 发起流式请求\n      await window.electronAPI.ai.stream(prompt, {\n        model,\n        ...config,\n        systemPrompt: options?.systemPrompt,\n      })\n    } catch (error: any) {\n      if (onError) onError(error.message)\n    }\n  }\n\n  /**\n   * 测试模型连接\n   */\n  async testConnection(model: AIModel): Promise<boolean> {\n    try {\n      const result = await window.electronAPI.ai.testConnection(model)\n      return result.success && result.result\n    } catch {\n      return false\n    }\n  }\n}\n\n// 单例导出\nconst aiModelService = new AIModelService()\nexport default aiModelService","cwd":"/home/ai/.openclaw/workspace/main"},"isError":false,"timestamp":1776154339695}}
