{"type":"message","id":"4b293e2f","parentId":"f0b449b1","timestamp":"2026-04-14T07:39:31.448Z","message":{"role":"toolResult","toolCallId":"call_function_edpkl5kdnx1t_1","toolName":"exec","content":[{"type":"text","text":"ipcMain.handle('safeStorage:isAvailable', () => {\n    return { success: true, available: safeStorage.isEncryptionAvailable() }\n  })\n\n  // ========== AI 服务 ==========\n  // 导入 AI 服务\n  const { setupAiHandlers } = require('./aiService')\n  setupAiHandlers(ipcMain)\n\n  // ========== 备份服务 ==========\n  // 导入备份服务\n  const { setupBackupHandlers } = require('./backupService')\n  setupBackupHandlers(ipcMain)\n}\n\n/**\n * 启动应用\n */\nasync function startApp(): Promise<void> {\n  // 设置 IPC 处理器\n  setupIpcHandlers()\n\n  // 创建窗口\n  createWindow()\n\n  // 加载应用\n  if (process.env.NODE_ENV === 'development') {\n    await mainWindow?.loadURL('http://localhost:5173')\n    mainWindow?.webContents.openDevTools()\n  } else {\n    await mainWindow?.loadFile(path.join(__dirname, '../renderer/index.html'))\n  }\n}\n\n// 应用就绪\napp.whenReady().then(startApp)\n\n// 所有窗口关闭时退出\napp.on('window-all-closed', () => {\n  if (process.platform !== 'darwin') {\n    app.quit()\n  }\n})\n\napp.on('activate', () => {\n  if (BrowserWindow.getAllWindows().length === 0) {\n    createWindow()\n  }\n})\n\n// 导出供测试和主进程入口使用\nexport { \n  createWindow, \n  closeWindow, \n  setupIpcHandlers, \n  setProjectRoot,\n  startApp,\n  projectRootPath \n}"}],"details":{"status":"completed","exitCode":0,"durationMs":93,"aggregated":"ipcMain.handle('safeStorage:isAvailable', () => {\n    return { success: true, available: safeStorage.isEncryptionAvailable() }\n  })\n\n  // ========== AI 服务 ==========\n  // 导入 AI 服务\n  const { setupAiHandlers } = require('./aiService')\n  setupAiHandlers(ipcMain)\n\n  // ========== 备份服务 ==========\n  // 导入备份服务\n  const { setupBackupHandlers } = require('./backupService')\n  setupBackupHandlers(ipcMain)\n}\n\n/**\n * 启动应用\n */\nasync function startApp(): Promise<void> {\n  // 设置 IPC 处理器\n  setupIpcHandlers()\n\n  // 创建窗口\n  createWindow()\n\n  // 加载应用\n  if (process.env.NODE_ENV === 'development') {\n    await mainWindow?.loadURL('http://localhost:5173')\n    mainWindow?.webContents.openDevTools()\n  } else {\n    await mainWindow?.loadFile(path.join(__dirname, '../renderer/index.html'))\n  }\n}\n\n// 应用就绪\napp.whenReady().then(startApp)\n\n// 所有窗口关闭时退出\napp.on('window-all-closed', () => {\n  if (process.platform !== 'darwin') {\n    app.quit()\n  }\n})\n\napp.on('activate', () => {\n  if (BrowserWindow.getAllWindows().length === 0) {\n    createWindow()\n  }\n})\n\n// 导出供测试和主进程入口使用\nexport { \n  createWindow, \n  closeWindow, \n  setupIpcHandlers, \n  setProjectRoot,\n  startApp,\n  projectRootPath \n}","cwd":"/home/ai/.openclaw/workspace/main"},"isError":false,"timestamp":1776152371430}}
