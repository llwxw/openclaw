{"type":"message","id":"95013aa6","parentId":"0759f257","timestamp":"2026-04-14T12:28:49.287Z","message":{"role":"toolResult","toolCallId":"call_function_qw4wd0zkzzoj_1","toolName":"exec","content":[{"type":"text","text":"/**\n * AI 模型服务\n * 不同任务自动选择最合适的模型\n */\n\nexport type AIModel = 'doubao-pro' | 'doubao-lite' | 'doubao-mini' | 'deepseek-reasoner'\nexport type TaskType = 'creative' | 'summary' | 'classification' | 'logic' | 'extraction'\n\n// 模型能力映射\nconst ModelTaskMapping: Record<TaskType, AIModel> = {\n  creative: 'doubao-pro',         // 章节生成、创意续写\n  summary: 'doubao-lite',         // 摘要、结构化分析\n  classification: 'doubao-mini',  // 极速分类\n  logic: 'deepseek-reasoner',     // 逻辑校验、一致性检查\n  extraction: 'doubao-lite',      // 事实提取\n}\n\n// 模型配置\ninterface ModelConfig {\n  maxTokens: number\n  temperature: number\n  topP: number\n  presencePenalty: number\n  frequencyPenalty: number\n}\n\nconst ModelConfigs: Record<AIModel, ModelConfig> = {\n  'doubao-pro': {\n    maxTokens: 4096,\n    temperature: 0.8,\n    topP: 0.9,\n    presencePenalty: 0.1,\n    frequencyPenalty: 0.1,\n  },\n  'doubao-lite': {\n    maxTokens: 2048,\n    temperature: 0.3,\n    topP: 0.85,\n    presencePenalty: 0.0,\n    frequencyPenalty: 0.0,"}],"details":{"status":"completed","exitCode":0,"durationMs":55,"aggregated":"/**\n * AI 模型服务\n * 不同任务自动选择最合适的模型\n */\n\nexport type AIModel = 'doubao-pro' | 'doubao-lite' | 'doubao-mini' | 'deepseek-reasoner'\nexport type TaskType = 'creative' | 'summary' | 'classification' | 'logic' | 'extraction'\n\n// 模型能力映射\nconst ModelTaskMapping: Record<TaskType, AIModel> = {\n  creative: 'doubao-pro',         // 章节生成、创意续写\n  summary: 'doubao-lite',         // 摘要、结构化分析\n  classification: 'doubao-mini',  // 极速分类\n  logic: 'deepseek-reasoner',     // 逻辑校验、一致性检查\n  extraction: 'doubao-lite',      // 事实提取\n}\n\n// 模型配置\ninterface ModelConfig {\n  maxTokens: number\n  temperature: number\n  topP: number\n  presencePenalty: number\n  frequencyPenalty: number\n}\n\nconst ModelConfigs: Record<AIModel, ModelConfig> = {\n  'doubao-pro': {\n    maxTokens: 4096,\n    temperature: 0.8,\n    topP: 0.9,\n    presencePenalty: 0.1,\n    frequencyPenalty: 0.1,\n  },\n  'doubao-lite': {\n    maxTokens: 2048,\n    temperature: 0.3,\n    topP: 0.85,\n    presencePenalty: 0.0,\n    frequencyPenalty: 0.0,","cwd":"/home/ai/.openclaw/workspace/main"},"isError":false,"timestamp":1776169729277}}
