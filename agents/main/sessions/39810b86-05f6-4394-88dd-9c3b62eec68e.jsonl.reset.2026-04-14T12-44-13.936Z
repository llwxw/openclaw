);\r\n      if (chapterContent) {\r\n        recent.push(chapterContent);\r\n      }\r\n    }\r\n    return recent;\r\n  }\r\n\r\n  // 根据章节号查找章节文件（简化版）\r\n  findChapterByNumber(chapterNum) {\r\n    const plotsDir = path.join(this.projectPath, 'plots');\r\n    if (!fs.existsSync(plotsDir)) {\r\n      return null;\r\n    }\r\n    \r\n    // 递归查找所有章节文件\r\n    function findInDir(dir) {\r\n      const entries = fs.readdirSync(dir, { withFileTypes: true });\r\n      for (const entry of entries) {\r\n        const fullPath = path.join(dir, entry.name);\r\n        if (entry.isDirectory()) {\r\n          const found = findInDir(fullPath);\r\n          if (found) return found;\r\n        } else if (entry.isFile() && entry.name.endsWith('.md')) {\r\n          // 检查文件名是否以章节号开头\r\n          const match = entry.name.match(/^(\\d+)_/);\r\n          if (match && parseInt(match[1]) === chapterNum) {\r\n            return fullPath;\r\n          }\r\n        }\r\n      }\r\n      return null;\r\n    }\r\n    \r\n    const foundPath = findInDir(plotsDir);\r\n    if (foundPath) {\r\n      return fs.readFileSync(foundPath, 'utf8');\r\n    }\r\n    return null;\r\n  }\r\n\r\n  // 读取关系文件\r\n  readRelationships() {\r\n    const relPath = path.join(this.projectPath, 'relationships.yaml');\r\n    if (!fs.existsSync(relPath)) {\r\n      return { relationships: [] };\r\n    }\r\n    const content = fs.readFileSync(relPath, 'utf8');\r\n    return yaml.load(content);\r\n  }\r\n\r\n  // 读取设定文件\r\n  readSettings() {\r\n    const settingsDir = path.join(this.projectPath, 'settings');\r\n    if (!fs.existsSync(settingsDir)) {\r\n      return [];\r\n    }\r\n    const files = fs.readdirSync(settingsDir).filter(f => f.endsWith('.md'));\r\n    const settings = [];\r\n    files.forEach(file => {\r\n      const filePath = path.join(settingsDir, file);\r\n      const content = fs.readFileSync(filePath, 'utf8');\r\n      settings.push({\r\n        name: file.replace('.md', ''),\r\n        content: content\r