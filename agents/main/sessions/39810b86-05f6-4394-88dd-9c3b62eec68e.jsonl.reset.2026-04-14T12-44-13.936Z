{"type":"message","id":"f41e9e40","parentId":"f0615594","timestamp":"2026-04-14T12:28:57.636Z","message":{"role":"toolResult","toolCallId":"call_function_2xh9l083zyl4_1","toolName":"exec","content":[{"type":"text","text":"return ModelConfigs[model] || ModelConfigs['doubao-pro']\n  }\n\n  /**\n   * 调用 AI 模型 (非流式)\n   */\n  async call(\n    taskType: TaskType,\n    prompt: string,\n    options?: Partial<ModelConfig> & { systemPrompt?: string }\n  ): Promise<{ success: boolean; content?: string; error?: string }> {\n    try {\n      const model = this.selectModel(taskType)\n      const config = { ...this.getModelConfig(model), ...options }\n\n      const result = await window.electronAPI.ai.call(prompt, {\n        model,\n        ...config,\n        systemPrompt: options?.systemPrompt,\n      })\n\n      return result\n    } catch (error: any) {\n      return { success: false, error: error.message }\n    }\n  }\n\n  /**\n   * 流式调用 AI 模型\n   */\n  async stream(\n    taskType: TaskType,\n    prompt: string,\n    onChunk: (chunk: string, done: boolean) => void,\n    onError?: (error: string) => void,\n    options?: Partial<ModelConfig> & { systemPrompt?: string }\n  ): Promise<void> {\n    try {\n      const model = this.selectModel(taskType)\n      const config = { ...this.getModelConfig(model), ...options }\n\n      // 监听流式输出\n      const removeChunkListener = window.electronAPI.ai.onStreamChunk((chunk) => {\n        if (chunk.done) {\n          onChunk('', true)\n          removeChunkListener()\n          removeErrorListener()\n        } else {\n          onChunk(chunk.content, false)\n        }\n      })\n\n      // 监听错误\n      const removeErrorListener = window.electronAPI.ai.onStreamError((error) => {\n        if (onError) onError(error)\n        removeChunkListener()\n        removeErrorListener()\n      })\n\n      // 发起流式请求\n      await window.electronAPI.ai.stream(prompt, {\n        model,\n        ...config,\n        systemPrompt: options?.systemPrompt,\n      })\n    } catch (error: any) {\n      if (onError) onError(error.message)\n    }\n  }\n\n  /**\n   * 测试模型连接\n   */\n  async testConnection(model: AIModel): Promise<boolean> {\n    try {\n      const result = await window.electronAPI.ai.testConnection(model)\n      return !!(result.success && result.result)\n    } catch {\n      return false\n    }\n  }\n}\n\n// 单例导出\nconst aiModelService = new AIModelService()\nexport default aiModelService"}],"details":{"status":"completed","exitCode":0,"durationMs":58,"aggregated":"return ModelConfigs[model] || ModelConfigs['doubao-pro']\n  }\n\n  /**\n   * 调用 AI 模型 (非流式)\n   */\n  async call(\n    taskType: TaskType,\n    prompt: string,\n    options?: Partial<ModelConfig> & { systemPrompt?: string }\n  ): Promise<{ success: boolean; content?: string; error?: string }> {\n    try {\n      const model = this.selectModel(taskType)\n      const config = { ...this.getModelConfig(model), ...options }\n\n      const result = await window.electronAPI.ai.call(prompt, {\n        model,\n        ...config,\n        systemPrompt: options?.systemPrompt,\n      })\n\n      return result\n    } catch (error: any) {\n      return { success: false, error: error.message }\n    }\n  }\n\n  /**\n   * 流式调用 AI 模型\n   */\n  async stream(\n    taskType: TaskType,\n    prompt: string,\n    onChunk: (chunk: string, done: boolean) => void,\n    onError?: (error: string) => void,\n    options?: Partial<ModelConfig> & { systemPrompt?: string }\n  ): Promise<void> {\n    try {\n      const model = this.selectModel(taskType)\n      const config = { ...this.getModelConfig(model), ...options }\n\n      // 监听流式输出\n      const removeChunkListener = window.electronAPI.ai.onStreamChunk((chunk) => {\n        if (chunk.done) {\n          onChunk('', true)\n          removeChunkListener()\n          removeErrorListener()\n        } else {\n          onChunk(chunk.content, false)\n        }\n      })\n\n      // 监听错误\n      const removeErrorListener = window.electronAPI.ai.onStreamError((error) => {\n        if (onError) onError(error)\n        removeChunkListener()\n        removeErrorListener()\n      })\n\n      // 发起流式请求\n      await window.electronAPI.ai.stream(prompt, {\n        model,\n        ...config,\n        systemPrompt: options?.systemPrompt,\n      })\n    } catch (error: any) {\n      if (onError) onError(error.message)\n    }\n  }\n\n  /**\n   * 测试模型连接\n   */\n  async testConnection(model: AIModel): Promise<boolean> {\n    try {\n      const result = await window.electronAPI.ai.testConnection(model)\n      return !!(result.success && result.result)\n    } catch {\n      return false\n    }\n  }\n}\n\n// 单例导出\nconst aiModelService = new AIModelService()\nexport default aiModelService","cwd":"/home/ai/.openclaw/workspace/main"},"isError":false,"timestamp":1776169737624}}
