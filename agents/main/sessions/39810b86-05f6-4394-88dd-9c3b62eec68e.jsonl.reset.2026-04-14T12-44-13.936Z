{"type":"message","id":"9f050fad","parentId":"933e3eea","timestamp":"2026-04-14T06:43:23.283Z","message":{"role":"toolResult","toolCallId":"call_function_sct30s7zs3fg_1","toolName":"exec","content":[{"type":"text","text":"=== package.json ===\n{\n  \"name\": \"tomato-novel-assistant\",\n  \"version\": \"1.0.0\",\n  \"description\": \"番茄小说创作助手\",\n  \"main\": \"dist/main/index.js\",\n  \"scripts\": {\n    \"dev\": \"concurrently \\\"npm run dev:renderer\\\" \\\"npm run dev:electron\\\"\",\n    \"dev:renderer\": \"vite\",\n    \"dev:electron\": \"tsc -p tsconfig.main.json && electron .\",\n    \"build\": \"npm run build:renderer && npm run build:electron\",\n    \"build:renderer\": \"vite build\",\n    \"build:electron\": \"tsc -p tsconfig.main.json\",\n    \"pack\": \"npm run build && electron-builder --dir\",\n    \"dist\": \"npm run build && electron-builder\"\n  },\n  \"dependencies\": {\n    \"@electron-toolkit/utils\": \"^4.0.0\",\n    \"@xenova/transformers\": \"^2.17.2\",\n    \"antd\": \"^6.3.4\",\n    \"axios\": \"^1.14.0\",\n    \"echarts\": \"^6.0.0\",\n    \"echarts-for-react\": \"^3.0.6\",\n    \"electron-store\": \"^11.0.2\",\n    \"graphology\": \"^0.26.0\",\n    \"graphology-metrics\": \"^2.4.0\",\n    \"js-yaml\": \"^4.1.1\",\n    \"monaco-editor\": \"^0.55.1\",\n    \"react\": \"^19.2.4\",\n    \"react-dom\": \"^19.2.4\",\n    \"vectra\": \"^0.12.3\",\n    \"zustand\": \"^5.0.12\"\n  },\n  \"devDependencies\": {\n    \"@ant-design/icons\": \"^6.1.1\",\n    \"@testing-library/jest-dom\": \"^6.9.1\",\n    \"@testing-library/react\": \"^16.3.2\",\n    \"@types/js-yaml\": \"^4.0.9\",\n    \"@types/node\": \"^25.5.0\",\n    \"@types/react\": \"^19.2.14\",\n    \"@types/react-dom\": \"^19.2.3\",\n    \"@vitejs/plugin-react\": \"^4.0.4\",\n    \"@vitest/ui\": \"^4.1.2\",\n    \"concurrently\": \"^8.2.2\",\n    \"electron\": \"^41.1.1\",\n    \"electron-builder\": \"^26.8.1\",\n    \"esbuild\": \"^0.24.2\",\n    \"jsdom\": \"^29.0.1\",\n    \"nodemon\": \"^3.1.14\",\n    \"npm-run-all\": \"^4.1.5\",\n    \"typescript\": \"^6.0.2\",\n    \"vite\": \"^4.3.9\",\n    \"vitest\": \"^4.1.2\"\n  },\n  \"build\": {\n    \"appId\": \"com.tomato.novel-assistant\",\n    \"productName\": \"番茄创作工作台\",\n    \"directories\": {\n      \"output\": \"release\"\n    },\n    \"files\": [\n      \"dist/**/*\"\n    ],\n    \"win\": {\n      \"target\": \"nsis\",\n      \"icon\": \"build/icon.ico\"\n    },\n    \"mac\": {\n      \"target\": \"dmg\",\n      \"icon\": \"build/icon.icns\"\n    }\n  }\n}\n\n=== 根目录 md 文件 ===\n/mnt/d/aafuzhi/axs/AI_NOVEL_ASSISTANT_SUMMARY.md\n/mnt/d/aafuzhi/axs/USER_GUIDE.md\n\n=== src 目录结构 ===\n/mnt/d/aafuzhi/axs/src/main/index.ts\n/mnt/d/aafuzhi/axs/src/preload/index.js\n/mnt/d/aafuzhi/axs/src/preload/index.ts\n/mnt/d/aafuzhi/axs/src/renderer/src/App.tsx\n/mnt/d/aafuzhi/axs/src/renderer/src/components/AIToolsPanel.tsx\n/mnt/d/aafuzhi/axs/src/renderer/src/components/Editor.tsx\n/mnt/d/aafuzhi/axs/src/renderer/src/components/FactsPanel.tsx\n/mnt/d/aafuzhi/axs/src/renderer/src/components/OutlineTree.tsx\n/mnt/d/aafuzhi/axs/src/renderer/src/components/Workbench.tsx\n/mnt/d/aafuzhi/axs/src/renderer/src/db/index.ts\n/mnt/d/aafuzhi/axs/src/renderer/src/main.tsx\n/mnt/d/aafuzhi/axs/src/renderer/src/services/aiModels.ts\n/mnt/d/aafuzhi/axs/src/renderer/src/services/factExtractor.ts\n/mnt/d/aafuzhi/axs/src/renderer/src/stores/index.ts"}],"details":{"status":"completed","exitCode":0,"durationMs":85,"aggregated":"=== package.json ===\n{\n  \"name\": \"tomato-novel-assistant\",\n  \"version\": \"1.0.0\",\n  \"description\": \"番茄小说创作助手\",\n  \"main\": \"dist/main/index.js\",\n  \"scripts\": {\n    \"dev\": \"concurrently \\\"npm run dev:renderer\\\" \\\"npm run dev:electron\\\"\",\n    \"dev:renderer\": \"vite\",\n    \"dev:electron\": \"tsc -p tsconfig.main.json && electron .\",\n    \"build\": \"npm run build:renderer && npm run build:electron\",\n    \"build:renderer\": \"vite build\",\n    \"build:electron\": \"tsc -p tsconfig.main.json\",\n    \"pack\": \"npm run build && electron-builder --dir\",\n    \"dist\": \"npm run build && electron-builder\"\n  },\n  \"dependencies\": {\n    \"@electron-toolkit/utils\": \"^4.0.0\",\n    \"@xenova/transformers\": \"^2.17.2\",\n    \"antd\": \"^6.3.4\",\n    \"axios\": \"^1.14.0\",\n    \"echarts\": \"^6.0.0\",\n    \"echarts-for-react\": \"^3.0.6\",\n    \"electron-store\": \"^11.0.2\",\n    \"graphology\": \"^0.26.0\",\n    \"graphology-metrics\": \"^2.4.0\",\n    \"js-yaml\": \"^4.1.1\",\n    \"monaco-editor\": \"^0.55.1\",\n    \"react\": \"^19.2.4\",\n    \"react-dom\": \"^19.2.4\",\n    \"vectra\": \"^0.12.3\",\n    \"zustand\": \"^5.0.12\"\n  },\n  \"devDependencies\": {\n    \"@ant-design/icons\": \"^6.1.1\",\n    \"@testing-library/jest-dom\": \"^6.9.1\",\n    \"@testing-library/react\": \"^16.3.2\",\n    \"@types/js-yaml\": \"^4.0.9\",\n    \"@types/node\": \"^25.5.0\",\n    \"@types/react\": \"^19.2.14\",\n    \"@types/react-dom\": \"^19.2.3\",\n    \"@vitejs/plugin-react\": \"^4.0.4\",\n    \"@vitest/ui\": \"^4.1.2\",\n    \"concurrently\": \"^8.2.2\",\n    \"electron\": \"^41.1.1\",\n    \"electron-builder\": \"^26.8.1\",\n    \"esbuild\": \"^0.24.2\",\n    \"jsdom\": \"^29.0.1\",\n    \"nodemon\": \"^3.1.14\",\n    \"npm-run-all\": \"^4.1.5\",\n    \"typescript\": \"^6.0.2\",\n    \"vite\": \"^4.3.9\",\n    \"vitest\": \"^4.1.2\"\n  },\n  \"build\": {\n    \"appId\": \"com.tomato.novel-assistant\",\n    \"productName\": \"番茄创作工作台\",\n    \"directories\": {\n      \"output\": \"release\"\n    },\n    \"files\": [\n      \"dist/**/*\"\n    ],\n    \"win\": {\n      \"target\": \"nsis\",\n      \"icon\": \"build/icon.ico\"\n    },\n    \"mac\": {\n      \"target\": \"dmg\",\n      \"icon\": \"build/icon.icns\"\n    }\n  }\n}\n\n=== 根目录 md 文件 ===\n/mnt/d/aafuzhi/axs/AI_NOVEL_ASSISTANT_SUMMARY.md\n/mnt/d/aafuzhi/axs/USER_GUIDE.md\n\n=== src 目录结构 ===\n/mnt/d/aafuzhi/axs/src/main/index.ts\n/mnt/d/aafuzhi/axs/src/preload/index.js\n/mnt/d/aafuzhi/axs/src/preload/index.ts\n/mnt/d/aafuzhi/axs/src/renderer/src/App.tsx\n/mnt/d/aafuzhi/axs/src/renderer/src/components/AIToolsPanel.tsx\n/mnt/d/aafuzhi/axs/src/renderer/src/components/Editor.tsx\n/mnt/d/aafuzhi/axs/src/renderer/src/components/FactsPanel.tsx\n/mnt/d/aafuzhi/axs/src/renderer/src/components/OutlineTree.tsx\n/mnt/d/aafuzhi/axs/src/renderer/src/components/Workbench.tsx\n/mnt/d/aafuzhi/axs/src/renderer/src/db/index.ts\n/mnt/d/aafuzhi/axs/src/renderer/src/main.tsx\n/mnt/d/aafuzhi/axs/src/renderer/src/services/aiModels.ts\n/mnt/d/aafuzhi/axs/src/renderer/src/services/factExtractor.ts\n/mnt/d/aafuzhi/axs/src/renderer/src/stores/index.ts","cwd":"/home/ai/.openclaw/workspace/main"},"isError":false,"timestamp":1776149003270}}
{"type":"message","id":"a579152f","parentId":"9f050fad","timestamp":"2026-04-14T06:43:23.294Z","message":{"role":"toolResult","toolCallId":"call_function_sct30s7zs3fg_2","toolName":"exec","content":[{"type":"text","text":"=== USER_GUIDE.md ===\n# AI小说创作助手 - 用户指南\r\n\r\n## 一、快速开始\r\n\r\n### 1.1 环境要求\r\n- Node.js 16+（已在系统检测到）\r\n- npm 或 yarn（已在系统检测到）\r\n\r\n### 1.2 项目结构\r\n```\r\nd:/axs/                          # 项目根目录\r\n├── my-novel-tools/              # 工具目录（已创建）\r\n│   ├── bin/                     # 10个命令行工具\r\n│   ├── lib/                     # 核心模块\r\n│   └── package.json            # 依赖配置\r\n├── my-novel/                    # 示例小说项目\r\n└── USER_GUIDE.md               # 本使用指南\r\n```\r\n\r\n### 1.3 验证安装\r\n```bash\r\n# 进入工具目录\r\ncd my-novel-tools\r\n\r\n# 验证工具可用\r\nnode bin/personality.js INTJ\r\n```\r\n\r\n如果看到INTJ人格描述输出，说明工具安装成功。\r\n\r\n## 二、工具详解\r\n\r\n### 2.1 10个核心工具列表\r\n\r\n| 工具名 | 命令格式 | 功能描述 | 示例 |\r\n|--------|----------|----------|------|\r\n| `personality` | `personality <MBTI>` | 生成MBTI人格提示词 | `personality INTJ` |\r\n| `fear` | `fear <认知功能>` | 根据劣势功能生成恐惧情节 | `fear Se` |\r\n| `structure` | `structure <章节数> [选项]` | 生成小说结构规划 | `structure 150 --type five-volume` |\r\n| `world-seed` | `world-seed <题材> <恐惧>` | 生成世界观种子 | `world-seed fantasy Ni` |\r\n| `complement` | `complement <MBTI>` | 推荐补盲配角 | `complement INTJ` |\r\n| `catharsis` | `catharsis <章节数>` | 生成爽点规划表 | `catharsis 150` |\r\n| `emotion` | `emotion <章节数> [选项]` | 生成情绪曲线 | `emotion 150 --style balanced` |\r\n| `template` | `template <类型>` | 输出章节模板 | `template climax` |\r\n| `dialogue` | `dialogue <MBTI>` | 对话风格指南 | `dialogue INTJ` |\r\n| `generate-chapter` | `generate-chapter [选项]` | 生成章节草稿 | `generate-chapter -p ./my-novel -c 1` |\r\n\r\n### 2.2 详细参数说明\r\n\r\n#### personality - 人格生成\r\n```bash\r\n# 基本用法\r\nnode bin/personality.js INTJ\r\n\r\n# 输出到文件\r\nnode bin/personality.js INFP -o characters/林小雨.yaml\r\n\r\n# 查看帮助\r\nnode bin/personality.js --help\r\n```\r\n\r\n#### structure - 结构规划\r\n```bash\r\n# 五卷式结构（默认）\r\nnode bin/structure.js 100\r\n\r\n# 三幕式结构\r\nnode bin/structure.js 80 --type three-act\r\n\r\n# 七点式结构\r\nnode bin/structure.js 50 --type seven-point\r\n\r\n# 输出到文件\r\nnode bin/structure.js 120 -o plots/小说结构.txt\r\n```\r\n\r\n#### generate-chapter - 章节生成\r\n```bash\r\n# 基本用法（使用模拟数据）\r\nnode bin/generate-chapter.js -p ./my-novel -c 1\r\n\r\n# 指定大纲\r\nnode bin/generate-chapter.js -p ./my-novel -c 2 --outline \"主角遇到第一个挑战\"\r\n\r\n# 指定输出文件\r\nnode bin/generate-chapter.js -p ./my-novel -c 1 --output plots/第一卷/01_重生归来.md\r\n\r\n# 使用真实API（需设置API密钥）\r\nset DEEPSEEK_API_KEY=your_api_key_here\r\nnode bin/generate-chapter.js -p ./my-novel -c 1 --api-key %DEEPSEEK_API_KEY%\r\n```\r\n\r\n### 2.3 查看工具帮助\r\n每个工具都支持 `--help` 参数查看详细帮助：\r\n```bash\r\nnode bin/structure.js --help\r\nnode bin/generate-chapter.js --help\r\n```\r\n\r\n## 三、完整工作流\r\n\r\n### 3.1 第一阶段：项目初始化\r\n\r\n#### 步骤1：创建新项目\r\n```bash\r\n# 在 d:/axs 目录下\r\nmkdir 我的小说\r\ncd 我的小说\r\n\r\n# 创建项目文件夹结构\r\nmkdir characters plots settings notes .ai-context\r\n```\r\n\r\n#### 步骤2：创建项目元数据\r\n创建 `project.yaml` 文件：\r\n```yaml\r\ntitle: 我的第一部小说\r\nauthor: 你的名字\r\ngenre: 玄幻\r\ntarget_words: 100000\r\nstatus: planning\r\ncreated: 2026-03-30\r\nlast_modified: 2026-03-30\r\nai_model: deepseek\r\napi_key_env: DEEPSEEK_API_KEY\r\n```\r\n\r\n#### 步骤3：生成主角设定\r\n```bash\r\n# 回到工具目录\r\ncd ../my-novel-tools\r\n\r\n# 生成INTJ主角人格\r\nnode bin/personality.js INTJ > ../我的小说/characters/主角.yaml\r\n\r\n# 编辑角色文件，补充更多细节\r\n# 使用文本编辑器打开 ../我的小说/characters/主角.yaml\r\n```\r\n\r\n### 3.2 第二阶段：故事规划\r\n\r\n#### 步骤4：生成世界观\r\n```bash\r\nnode bin/world-seed.js fantasy Ni > ../我的小说/settings/世界观.md\r\n```\r\n\r\n#### 步骤5：规划故事结构\r\n```bash\r\n# 生成100章的结构规划\r\nnode bin/structure.js 100 > ../我的小说/plots/故事结构.txt\r\n\r\n# 生成爽点规划\r\nnode bin/catharsis.js 100 > ../我的小说/plots/爽点规划.txt\r\n\r\n# 生成情绪曲线\r\nnode bin/emotion.js 100 --style balanced > ../我的小说/plots/情绪曲线.txt\r\n```\r\n\r\n#### 步骤6：创建卷文件夹\r\n```bash\r\ncd ../我的小说/plots\r\nmkdir \"第一卷_启程\" \"第二卷_成长\" \"第三卷_试炼\" \"第四卷_黑暗\" \"第五卷_终章\"\r\n```\r\n\r\n### 3.3 第三阶段：章节创作\r\n\r\n#### 步骤7：生成第一章\r\n```bash\r\n# 回到工具目录\r\ncd ../../../my-novel-tools\r\n\r\n# 生成第一章草稿\r\nnode bin/generate-chapter.js -p \"../我的小说\" -c 1 \\\r\n  --outline \"主角重生回到少年时代，决心改变命运\" \\\r\n  --output \"../我的小说/plots/第一卷_启程/01_重生归来.md\"\r\n```\r\n\r\n#### 步骤8：编辑和润色\r\n使用文本编辑器打开生成的章节文件，进行：\r\n1. 修正AI生成的不准确内容\r\n2. 优化文笔和对话\r\n3. 调整节奏和情绪\r\n4. 确保与角色设定一致\r\n\r\n#### 步骤9：生成后续章节\r\n```bash\r\n# 生成第二章\r\nnode bin/generate-chapter.js -p \"../我的小说\" -c 2 \\\r\n  --outline \"主角参加青云宗入门测试，展现惊人天赋\" \\\r\n  --output \"../我的小说/plots/第一卷_启程/02_入门测试.md\"\r\n\r\n# 依此类推...\r\n```\r\n\r\n### 3.4 第四阶段：项目管理\r\n\r\n#### 步骤10：创建关系文件\r\n创建 `relationships.yaml` 文件：\r\n```yaml\r\nrelationships:\r\n  - from: 主角\r\n    to: 导师\r\n    type: mentor\r\n    strength: 0.7\r\n  - from: 主角\r\n    to: 反派\r\n    type: rival\r\n    strength: 0.9\r\n```\r\n\r\n#### 步骤11：添加更多设定\r\n```bash\r\n# 生成更多世界观元素\r\nnode bin/world-seed.js fantasy Si > ../我的小说/settings/魔法系统.md\r\nnode bin/world-seed.js fantasy Fe > ../我的小说/settings/社会结构.md\r\n```\r\n\r\n## 四、高级用法\r\n\r\n### 4.1 使用真实AI API\r\n\r\n#### 配置API密钥\r\n```bash\r\n# Windows（CMD）\r\nset DEEPSEEK_API_KEY=sk-your-api-key-here\r\n\r\n# Windows（PowerShell）\r\n$env:DEEPSEEK_API_KEY=\"sk-your-api-key-here\"\r\n\r\n# 永久配置（添加到环境变量）\r\n# 1. 右键\"此电脑\" -> 属性 -> 高级系统设置\r\n# 2. 环境变量 -> 新建用户变量\r\n# 3. 变量名: DEEPSEEK_API_KEY\r\n# 4. 变量值: 你的API密钥\r\n```\r\n\r\n#### 使用真实API生成\r\n```bash\r\n# 方法1：通过环境变量\r\nset DEEPSEEK_API_KEY=your_key\r\nnode bin/generate-chapter.js -p ./my-novel -c 1\r\n\r\n# 方法2：通过命令行参数\r\nnode bin/generate-chapter.js -p ./my-novel -c 1 --api-key your_key\r\n\r\n# 方法3：使用其他模型\r\nnode bin/generate-chapter.js -p ./my-novel -c 1 --model openai\r\n```\r\n\r\n### 4.2 批量生成章节\r\n\r\n创建批量生成脚本 `generate_batch.bat`：\r\n```batch\r\n@echo off\r\nset PROJECT_PATH=../我的小说\r\n\r\nfor /l %%i in (1,1,10) do (\r\n  echo 正在生成第%%i章...\r\n  node bin/generate-chapter.js -p \"%PROJECT_PATH%\" -c %%i --output \"%PROJECT_PATH%/plots/第一卷_启程/%%i_章节.md\"\r\n)\r\necho 批量生成完成！\r\n```\r\n\r\n### 4.3 自定义数据模板\r\n\r\n#### 添加新的MBTI描述\r\n编辑 `my-novel-tools/lib/data/mbti.json`，添加或修改MBTI类型描述。\r\n\r\n#### 创建自定义章节模板\r\n编辑 `my-novel-tools/lib/data/templates.json`，添加新的章节模板：\r\n```json\r\n\"custom\": {\r\n  \"name\": \"自定义模板\",\r\n  \"description\": \"你的描述\",\r\n  \"structure\": [\"开场\", \"发展\", \"高潮\", \"结尾\"],\r\n  \"word_count_suggestion\": \"1500-2000字\",\r\n  \"focus\": \"自定义重点\"\r\n}\r\n```\r\n\r\n## 五、常见问题\r\n\r\n### 5.1 工具运行报错\"模块未找到\"\r\n```bash\r\n# 错误：Cannot find module 'commander'\r\n# 解决方法：安装依赖\r\ncd my-novel-tools\r\nnpm install\r\n```\r\n\r\n### 5.2 API调用失败\r\n```bash\r\n# 错误：AI调用失败\r\n# 原因1：API密钥未设置\r\n# 解决：设置环境变量或使用--api-key参数\r\n\r\n# 原因2：网络问题\r\n# 解决：检查网络连接，或使用模拟模式（不提供API密钥）\r\n```\r\n\r\n### 5.3 生成内容质量不佳\r\n1. **提供更详细的大纲**：`--outline` 参数越详细，生成质量越好\r\n2. **完善项目数据**：确保角色、设定文件内容完整\r\n3. **手动编辑优化**：AI生成的是草稿，需要人工润色\r\n4. **调整参数**：尝试不同的AI模型或温度参数\r\n\r\n### 5.4 文件路径问题\r\n```bash\r\n# 正确：使用相对路径\r\nnode bin/generate-chapter.js -p ../我的小说 -c 1\r\n\r\n# 正确：使用绝对路径\r\nnode bin/generate-chapter.js -p \"d:/axs/我的小说\" -c 1\r\n\r\n# 错误：路径包含空格未加引号\r\nnode bin/generate-chapter.js -p ../我的小说 -c 1  # 可能出错\r\n```\r\n\r\n## 六、最佳实践\r\n\r\n### 6.1 创作建议\r\n1. **先规划后创作**：使用工具规划好结构再开始写\r\n2. **角色驱动**：完善角色设定，让角色推动情节\r\n3. **保持一致性**：定期检查设定是否矛盾\r\n4. **迭代优化**：AI生成→人工编辑→AI润色的循环\r\n5. **备份重要版本**：重要章节手动备份\r\n\r\n### 6.2 文件管理\r\n1. **命名规范**：\r\n   - 角色文件：`角色名.yaml`\r\n   - 章节文件：`01_章节标题.md`\r\n   - 设定文件：`设定名称.md`\r\n2. **版本控制**：使用Git管理项目版本\r\n3. **定期备份**：备份整个项目文件夹\r\n4. **目录整洁**：及时清理.ai-context缓存\r\n\r\n### 6.3 效率技巧\r\n1. **批量操作**：创建脚本批量生成章节\r\n2. **模板复用**：保存成功的章节结构作为模板\r\n3. **快捷命令**：创建批处理文件快捷方式\r\n4. **协作工具**：配合VS Code、Cursor等编辑器使用\r\n\r\n## 七、下一步建议\r\n\r\n### 7.1 新手入门路径\r\n1. **第一天**：创建项目，生成主角和世界观\r\n2. **第二天**：规划故事结构，生成前3章\r\n3. **第一周**：完成第一卷（10-15章）\r\n4. **第一个月**：完成前50章，形成写作习惯\r\n\r\n### 7.2 进阶学习\r\n1. **学习MBTI理论**：深入理解角色人格设计\r\n2. **研究故事结构**：学习三幕剧、英雄之旅等结构\r\n3. **分析优秀作品**：用工具分析你喜欢的小说结构\r\n4. **参与社区**：分享经验，学习他人创作方法\r\n\r\n### 7.3 寻求帮助\r\n1. **查看总结文件**：`AI_NOVEL_ASSISTANT_SUMMARY.md`\r\n2. **工具帮助**：每个工具都有 `--help` 参数\r\n3. **问题反馈**：记录遇到的问题，便于优化工具\r\n\r\n---\r\n\r\n**最后更新**：2026年3月30日  \r\n**适用版本**：AI小说创作助手 v1.0  \r\n**作者建议**：工具只是辅助，真正的创作核心是你的想象力和坚持。开始写吧，完成比完美更重要！\r\n\r\n> 提示：本指南文件位于 `d:/axs/USER_GUIDE.md`，可随时查阅。\r\n\n=== AI_NOVEL_ASSISTANT_SUMMARY.md ===\n# AI小说创作助手 - 方案与实现总结\r\n\r\n## 一、方案概述\r\n\r\n### 1.1 核心架构理念\r\n- **极简存储**：所有数据用文件夹和纯文本文件（Markdown + YAML）保存，无需数据库。\r\n- **工具即脚本**：AI生成、情节规划、人格分析等封装为独立命令行工具，按需调用。\r\n- **记忆靠目录**：文件夹层级自然形成情节结构，文件名和元数据提供索引。\r\n- **幻觉靠上下文**：工具运行时自动读取相关文件，构建完整上下文传递给AI。\r\n- **个人使用**：不涉及协作、权限、实时同步，所有数据本地存储，工具离线可用。\r\n\r\n### 1.2 文件组织规范\r\n```\r\nmy-novel/                       # 小说项目根目录\r\n├── project.yaml                # 项目元数据\r\n├── characters/                 # 人物文件夹\r\n├── plots/                      # 情节文件夹\r\n├── settings/                   # 世界观设定文件夹\r\n├── relationships.yaml          # 人物关系索引\r\n├── notes/                      # 个人笔记（可选）\r\n└── .ai-context/                # AI上下文缓存（自动生成）\r\n```\r\n\r\n### 1.3 技术栈\r\n- **运行时**：Node.js\r\n- **命令行框架**：Commander.js\r\n- **文件解析**：js-yaml, marked\r\n- **AI集成**：Axios (支持DeepSeek、OpenAI等)\r\n- **数据格式**：YAML (配置), JSON (静态数据), Markdown (章节内容)\r\n\r\n## 二、已完成功能\r\n\r\n### 2.1 项目结构创建\r\n✅ **小说项目结构** (`my-novel/`)\r\n- `project.yaml` - 项目元数据文件（已填充示例）\r\n- `characters/` - 角色文件夹（已创建）\r\n- `plots/` - 情节文件夹（已创建）\r\n- `settings/` - 世界观设定文件夹（已创建）\r\n- `notes/` - 个人笔记文件夹（已创建）\r\n- `.ai-context/` - AI上下文缓存文件夹（已创建）\r\n\r\n✅ **工具项目结构** (`my-novel-tools/`)\r\n- `bin/` - 10个命令行工具（全部实现）\r\n- `lib/` - 核心模块和静态数据（全部实现）\r\n- `package.json` - 项目配置和依赖（已配置）\r\n\r\n### 2.2 10个核心工具实现\r\n| 序号 | 工具名 | 命令示例 | 功能 | 状态 |\r\n|------|--------|----------|------|------|\r\n| 1 | `personality` | `personality INTJ` | 生成MBTI人格提示词 | ✅ |\r\n| 2 | `fear` | `fear Se` | 根据劣势功能生成恐惧→冲突点子 | ✅ |\r\n| 3 | `structure` | `structure 150 --type five-volume` | 生成小说卷结构表 | ✅ |\r\n| 4 | `world-seed` | `world-seed fantasy Ni` | 生成世界观种子 | ✅ |\r\n| 5 | `complement` | `complement INTJ` | 推荐补盲配角（基于MBTI互补） | ✅ |\r\n| 6 | `catharsis` | `catharsis 150` | 生成爽点规划表 | ✅ |\r\n| 7 | `emotion` | `emotion 150 --style balanced` | 生成情绪曲线建议 | ✅ |\r\n| 8 | `template` | `template climax` | 输出章节模板 | ✅ |\r\n| 9 | `dialogue` | `dialogue INTJ` | 对话风格指南 | ✅ |\r\n| 10 | `generate-chapter` | `generate-chapter --project ./my-novel --chapter 1` | 生成章节草稿 | ✅ |\r\n\r\n### 2.3 核心模块实现\r\n✅ **AI模块** (`lib/ai.js`)\r\n- 封装AI调用，支持DeepSeek、OpenAI等API\r\n- 内置模拟模式，无需API密钥即可测试\r\n- 错误处理：API失败时自动切换到模拟模式\r\n\r\n✅ **项目模块** (`lib/project.js`)\r\n- 读取和解析项目文件（YAML、Markdown）\r\n- 构建AI生成所需的上下文\r\n- 支持角色、设定、关系、章节等数据读取\r\n\r\n✅ **静态数据** (`lib/data/`)\r\n- `mbti.json` - 16种MBTI类型的详细描述\r\n- `fear.json` - 8种认知功能的恐惧和情节建议\r\n- `structure-templates.json` - 3种故事结构模板\r\n- `world-seed-templates.json` - 3种题材×4种恐惧的世界观种子\r\n- `complement.json` - MBTI互补配对推荐\r\n- `templates.json` - 5种章节模板\r\n- `dialogue.json` - 16种MBTI的对话风格指南\r\n\r\n### 2.4 工具验证测试\r\n已成功测试以下工具：\r\n1. `personality INTJ` - 输出INTJ人格描述（主导功能Ni、辅助功能Te等）\r\n2. `fear Se` - 输出外倾感觉的恐惧和4条情节建议\r\n3. `structure 150` - 生成五卷式结构表，每卷30章\r\n4. `world-seed fantasy Ni` - 生成奇幻题材+内倾直觉的世界观种子\r\n5. `generate-chapter` - 生成测试章节（使用模拟数据成功）\r\n\r\n### 2.5 工作流演示\r\n已完成基础工作流测试：\r\n1. 创建项目结构：`my-novel/` 目录及子文件夹\r\n2. 生成角色人格：`personality INTJ` 可用于创建角色文件\r\n3. 规划结构：`structure 150` 生成五卷式规划\r\n4. 生成章节：`generate-chapter` 生成第1章草稿\r\n\r\n## 三、待完成功能与扩展建议\r\n\r\n### 3.1 核心功能增强\r\n- [ ] **关系图可视化**：生成人物关系网络图（PNG/SVG）\r\n- [ ] **一致性检查工具**：扫描项目文件，检测设定矛盾\r\n- [ ] **版本控制集成**：自动生成章节版本，支持回滚\r\n- [ ] **批量处理**：批量生成/润色多个章节\r\n- [ ] **导出功能**：支持导出为EPUB、PDF、Word格式\r\n\r\n### 3.2 AI功能扩展\r\n- [ ] **多模型支持**：增加Claude、GPT-4、本地Ollama模型支持\r\n- [ ] **风格迁移**：将章节内容转换为特定作家风格\r\n- [ ] **情节分析**：AI分析现有章节，提供优化建议\r\n- [ ] **对话生成**：基于角色性格生成特定场景对话\r\n- [ ] **伏笔管理**：标记和跟踪伏笔铺设与回收\r\n\r\n### 3.3 用户体验改进\r\n- [ ] **Web界面**：基于React的图形化操作界面\r\n- [ ] **实时预览**：Markdown实时渲染预览\r\n- [ ] **项目管理面板**：可视化项目进度统计\r\n- [ ] **快捷键支持**：快速调用常用功能\r\n- [ ] **主题定制**：深色/浅色主题切换\r\n\r\n### 3.4 数据管理优化\r\n- [ ] **数据导入/导出**：支持从其他写作软件导入数据\r\n- [ ] **云端同步**：可选云备份和跨设备同步\r\n- [ ] **模板市场**：用户可分享和下载创作模板\r\n- [ ] **数据分析**：创作习惯统计和分析报告\r\n- [ ] **智能推荐**：基于阅读偏好推荐情节走向\r\n\r\n### 3.5 技术优化\r\n- [ ] **性能优化**：缓存机制减少文件重复读取\r\n- [ ] **错误恢复**：更完善的错误处理和恢复机制\r\n- [ ] **测试覆盖**：增加单元测试和集成测试\r\n- [ ] **文档完善**：完整的API文档和用户指南\r\n- [ ] **多语言支持**：支持英文、日文等其他语言\r\n\r\n## 四、使用工作流建议\r\n\r\n### 4.1 初始化项目\r\n```bash\r\n# 1. 创建项目结构\r\nmkdir my-novel\r\ncd my-novel\r\nmkdir characters plots settings notes .ai-context\r\n\r\n# 2. 创建项目元数据\r\ncat > project.yaml << EOF\r\ntitle: 剑仙归来\r\nauthor: 你的名字\r\ngenre: 玄幻\r\ntarget_words: 200000\r\nstatus: writing\r\ncreated: 2025-03-30\r\nlast_modified: 2025-03-30\r\nai_model: deepseek\r\napi_key_env: DEEPSEEK_API_KEY\r\nEOF\r\n```\r\n\r\n### 4.2 设定核心元素\r\n```bash\r\n# 1. 生成主角人格描述\r\npersonality INTJ > characters/林枫.yaml\r\n\r\n# 2. 为角色生成恐惧情节\r\nfear Se >> characters/林枫.yaml\r\n\r\n# 3. 生成世界观\r\nworld-seed fantasy Ni > settings/世界观.md\r\n```\r\n\r\n### 4.3 规划结构\r\n```bash\r\n# 1. 生成150章结构规划\r\nstructure 150 > plots/_overview.md\r\n\r\n# 2. 生成爽点规划\r\ncatharsis 150 > plots/_catharsis.md\r\n\r\n# 3. 生成情绪曲线\r\nemotion 150 --style balanced > plots/_emotion.md\r\n```\r\n\r\n### 4.4 逐章创作\r\n```bash\r\n# 1. 生成章节草稿\r\ngenerate-chapter --project . --chapter 1 --outline \"林枫重生归来\" --output plots/第一卷/01_重生归来.md\r\n\r\n# 2. 手动润色编辑\r\n# 3. 重复生成后续章节\r\n```\r\n\r\n## 五、总结\r\n\r\n### 5.1 实现状态\r\n✅ **核心架构**：完全按照方案实现极简存储和工具化设计\r\n✅ **10个核心工具**：全部实现并通过基础测试\r\n✅ **项目结构**：完整的小说项目和工具项目结构\r\n✅ **数据模型**：全面的静态数据支持MBTI、恐惧、结构等\r\n✅ **AI集成**：支持真实API和模拟模式，具备完整上下文构建\r\n\r\n### 5.2 方案优势验证\r\n1. **极简性**：无需数据库，纯文件存储，人类可读\r\n2. **可控性**：所有工具独立，可单独升级或替换\r\n3. **灵活性**：支持手动修改文件，工具仅为辅助\r\n4. **低成本**：开发成本低，运行成本仅AI API费用\r\n5. **可扩展**：新工具只需添加脚本，不破坏现有结构\r\n\r\n### 5.3 后续建议\r\n1. **优先实现**：关系图可视化和一致性检查工具\r\n2. **用户反馈**：在实际创作中收集工具使用反馈\r\n3. **社区建设**：建立用户社区分享模板和最佳实践\r\n4. **持续优化**：根据使用情况迭代改进工具设计\r\n\r\n---\r\n\r\n**最后更新**：2026年3月30日  \r\n**项目状态**：核心功能已实现，可投入实际使用  \r\n**建议下一步**：开始使用工具创作第一个小说项目，根据实际需求提出改进建议"}],"details":{"status":"completed","exitCode":0,"durationMs":85,"aggregated":"=== USER_GUIDE.md ===\n# AI小说创作助手 - 用户指南\r\n\r\n## 一、快速开始\r\n\r\n### 1.1 环境要求\r\n- Node.js 16+（已在系统检测到）\r\n- npm 或 yarn（已在系统检测到）\r\n\r\n### 1.2 项目结构\r\n```\r\nd:/axs/                          # 项目根目录\r\n├── my-novel-tools/              # 工具目录（已创建）\r\n│   ├── bin/                     # 10个命令行工具\r\n│   ├── lib/                     # 核心模块\r\n│   └── package.json            # 依赖配置\r\n├── my-novel/                    # 示例小说项目\r\n└── USER_GUIDE.md               # 本使用指南\r\n```\r\n\r\n### 1.3 验证安装\r\n```bash\r\n# 进入工具目录\r\ncd my-novel-tools\r\n\r\n# 验证工具可用\r\nnode bin/personality.js INTJ\r\n```\r\n\r\n如果看到INTJ人格描述输出，说明工具安装成功。\r\n\r\n## 二、工具详解\r\n\r\n### 2.1 10个核心工具列表\r\n\r\n| 工具名 | 命令格式 | 功能描述 | 示例 |\r\n|--------|----------|----------|------|\r\n| `personality` | `personality <MBTI>` | 生成MBTI人格提示词 | `personality INTJ` |\r\n| `fear` | `fear <认知功能>` | 根据劣势功能生成恐惧情节 | `fear Se` |\r\n| `structure` | `structure <章节数> [选项]` | 生成小说结构规划 | `structure 150 --type five-volume` |\r\n| `world-seed` | `world-seed <题材> <恐惧>` | 生成世界观种子 | `world-seed fantasy Ni` |\r\n| `complement` | `complement <MBTI>` | 推荐补盲配角 | `complement INTJ` |\r\n| `catharsis` | `catharsis <章节数>` | 生成爽点规划表 | `catharsis 150` |\r\n| `emotion` | `emotion <章节数> [选项]` | 生成情绪曲线 | `emotion 150 --style balanced` |\r\n| `template` | `template <类型>` | 输出章节模板 | `template climax` |\r\n| `dialogue` | `dialogue <MBTI>` | 对话风格指南 | `dialogue INTJ` |\r\n| `generate-chapter` | `generate-chapter [选项]` | 生成章节草稿 | `generate-chapter -p ./my-novel -c 1` |\r\n\r\n### 2.2 详细参数说明\r\n\r\n#### personality - 人格生成\r\n```bash\r\n# 基本用法\r\nnode bin/personality.js INTJ\r\n\r\n# 输出到文件\r\nnode bin/personality.js INFP -o characters/林小雨.yaml\r\n\r\n# 查看帮助\r\nnode bin/personality.js --help\r\n```\r\n\r\n#### structure - 结构规划\r\n```bash\r\n# 五卷式结构（默认）\r\nnode bin/structure.js 100\r\n\r\n# 三幕式结构\r\nnode bin/structure.js 80 --type three-act\r\n\r\n# 七点式结构\r\nnode bin/structure.js 50 --type seven-point\r\n\r\n# 输出到文件\r\nnode bin/structure.js 120 -o plots/小说结构.txt\r\n```\r\n\r\n#### generate-chapter - 章节生成\r\n```bash\r\n# 基本用法（使用模拟数据）\r\nnode bin/generate-chapter.js -p ./my-novel -c 1\r\n\r\n# 指定大纲\r\nnode bin/generate-chapter.js -p ./my-novel -c 2 --outline \"主角遇到第一个挑战\"\r\n\r\n# 指定输出文件\r\nnode bin/generate-chapter.js -p ./my-novel -c 1 --output plots/第一卷/01_重生归来.md\r\n\r\n# 使用真实API（需设置API密钥）\r\nset DEEPSEEK_API_KEY=your_api_key_here\r\nnode bin/generate-chapter.js -p ./my-novel -c 1 --api-key %DEEPSEEK_API_KEY%\r\n```\r\n\r\n### 2.3 查看工具帮助\r\n每个工具都支持 `--help` 参数查看详细帮助：\r\n```bash\r\nnode bin/structure.js --help\r\nnode bin/generate-chapter.js --help\r\n```\r\n\r\n## 三、完整工作流\r\n\r\n### 3.1 第一阶段：项目初始化\r\n\r\n#### 步骤1：创建新项目\r\n```bash\r\n# 在 d:/axs 目录下\r\nmkdir 我的小说\r\ncd 我的小说\r\n\r\n# 创建项目文件夹结构\r\nmkdir characters plots settings notes .ai-context\r\n```\r\n\r\n#### 步骤2：创建项目元数据\r\n创建 `project.yaml` 文件：\r\n```yaml\r\ntitle: 我的第一部小说\r\nauthor: 你的名字\r\ngenre: 玄幻\r\ntarget_words: 100000\r\nstatus: planning\r\ncreated: 2026-03-30\r\nlast_modified: 2026-03-30\r\nai_model: deepseek\r\napi_key_env: DEEPSEEK_API_KEY\r\n```\r\n\r\n#### 步骤3：生成主角设定\r\n```bash\r\n# 回到工具目录\r\ncd ../my-novel-tools\r\n\r\n# 生成INTJ主角人格\r\nnode bin/personality.js INTJ > ../我的小说/characters/主角.yaml\r\n\r\n# 编辑角色文件，补充更多细节\r\n# 使用文本编辑器打开 ../我的小说/characters/主角.yaml\r\n```\r\n\r\n### 3.2 第二阶段：故事规划\r\n\r\n#### 步骤4：生成世界观\r\n```bash\r\nnode bin/world-seed.js fantasy Ni > ../我的小说/settings/世界观.md\r\n```\r\n\r\n#### 步骤5：规划故事结构\r\n```bash\r\n# 生成100章的结构规划\r\nnode bin/structure.js 100 > ../我的小说/plots/故事结构.txt\r\n\r\n# 生成爽点规划\r\nnode bin/catharsis.js 100 > ../我的小说/plots/爽点规划.txt\r\n\r\n# 生成情绪曲线\r\nnode bin/emotion.js 100 --style balanced > ../我的小说/plots/情绪曲线.txt\r\n```\r\n\r\n#### 步骤6：创建卷文件夹\r\n```bash\r\ncd ../我的小说/plots\r\nmkdir \"第一卷_启程\" \"第二卷_成长\" \"第三卷_试炼\" \"第四卷_黑暗\" \"第五卷_终章\"\r\n```\r\n\r\n### 3.3 第三阶段：章节创作\r\n\r\n#### 步骤7：生成第一章\r\n```bash\r\n# 回到工具目录\r\ncd ../../../my-novel-tools\r\n\r\n# 生成第一章草稿\r\nnode bin/generate-chapter.js -p \"../我的小说\" -c 1 \\\r\n  --outline \"主角重生回到少年时代，决心改变命运\" \\\r\n  --output \"../我的小说/plots/第一卷_启程/01_重生归来.md\"\r\n```\r\n\r\n#### 步骤8：编辑和润色\r\n使用文本编辑器打开生成的章节文件，进行：\r\n1. 修正AI生成的不准确内容\r\n2. 优化文笔和对话\r\n3. 调整节奏和情绪\r\n4. 确保与角色设定一致\r\n\r\n#### 步骤9：生成后续章节\r\n```bash\r\n# 生成第二章\r\nnode bin/generate-chapter.js -p \"../我的小说\" -c 2 \\\r\n  --outline \"主角参加青云宗入门测试，展现惊人天赋\" \\\r\n  --output \"../我的小说/plots/第一卷_启程/02_入门测试.md\"\r\n\r\n# 依此类推...\r\n```\r\n\r\n### 3.4 第四阶段：项目管理\r\n\r\n#### 步骤10：创建关系文件\r\n创建 `relationships.yaml` 文件：\r\n```yaml\r\nrelationships:\r\n  - from: 主角\r\n    to: 导师\r\n    type: mentor\r\n    strength: 0.7\r\n  - from: 主角\r\n    to: 反派\r\n    type: rival\r\n    strength: 0.9\r\n```\r\n\r\n#### 步骤11：添加更多设定\r\n```bash\r\n# 生成更多世界观元素\r\nnode bin/world-seed.js fantasy Si > ../我的小说/settings/魔法系统.md\r\nnode bin/world-seed.js fantasy Fe > ../我的小说/settings/社会结构.md\r\n```\r\n\r\n## 四、高级用法\r\n\r\n### 4.1 使用真实AI API\r\n\r\n#### 配置API密钥\r\n```bash\r\n# Windows（CMD）\r\nset DEEPSEEK_API_KEY=sk-your-api-key-here\r\n\r\n# Windows（PowerShell）\r\n$env:DEEPSEEK_API_KEY=\"sk-your-api-key-here\"\r\n\r\n# 永久配置（添加到环境变量）\r\n# 1. 右键\"此电脑\" -> 属性 -> 高级系统设置\r\n# 2. 环境变量 -> 新建用户变量\r\n# 3. 变量名: DEEPSEEK_API_KEY\r\n# 4. 变量值: 你的API密钥\r\n```\r\n\r\n#### 使用真实API生成\r\n```bash\r\n# 方法1：通过环境变量\r\nset DEEPSEEK_API_KEY=your_key\r\nnode bin/generate-chapter.js -p ./my-novel -c 1\r\n\r\n# 方法2：通过命令行参数\r\nnode bin/generate-chapter.js -p ./my-novel -c 1 --api-key your_key\r\n\r\n# 方法3：使用其他模型\r\nnode bin/generate-chapter.js -p ./my-novel -c 1 --model openai\r\n```\r\n\r\n### 4.2 批量生成章节\r\n\r\n创建批量生成脚本 `generate_batch.bat`：\r\n```batch\r\n@echo off\r\nset PROJECT_PATH=../我的小说\r\n\r\nfor /l %%i in (1,1,10) do (\r\n  echo 正在生成第%%i章...\r\n  node bin/generate-chapter.js -p \"%PROJECT_PATH%\" -c %%i --output \"%PROJECT_PATH%/plots/第一卷_启程/%%i_章节.md\"\r\n)\r\necho 批量生成完成！\r\n```\r\n\r\n### 4.3 自定义数据模板\r\n\r\n#### 添加新的MBTI描述\r\n编辑 `my-novel-tools/lib/data/mbti.json`，添加或修改MBTI类型描述。\r\n\r\n#### 创建自定义章节模板\r\n编辑 `my-novel-tools/lib/data/templates.json`，添加新的章节模板：\r\n```json\r\n\"custom\": {\r\n  \"name\": \"自定义模板\",\r\n  \"description\": \"你的描述\",\r\n  \"structure\": [\"开场\", \"发展\", \"高潮\", \"结尾\"],\r\n  \"word_count_suggestion\": \"1500-2000字\",\r\n  \"focus\": \"自定义重点\"\r\n}\r\n```\r\n\r\n## 五、常见问题\r\n\r\n### 5.1 工具运行报错\"模块未找到\"\r\n```bash\r\n# 错误：Cannot find module 'commander'\r\n# 解决方法：安装依赖\r\ncd my-novel-tools\r\nnpm install\r\n```\r\n\r\n### 5.2 API调用失败\r\n```bash\r\n# 错误：AI调用失败\r\n# 原因1：API密钥未设置\r\n# 解决：设置环境变量或使用--api-key参数\r\n\r\n# 原因2：网络问题\r\n# 解决：检查网络连接，或使用模拟模式（不提供API密钥）\r\n```\r\n\r\n### 5.3 生成内容质量不佳\r\n1. **提供更详细的大纲**：`--outline` 参数越详细，生成质量越好\r\n2. **完善项目数据**：确保角色、设定文件内容完整\r\n3. **手动编辑优化**：AI生成的是草稿，需要人工润色\r\n4. **调整参数**：尝试不同的AI模型或温度参数\r\n\r\n### 5.4 文件路径问题\r\n```bash\r\n# 正确：使用相对路径\r\nnode bin/generate-chapter.js -p ../我的小说 -c 1\r\n\r\n# 正确：使用绝对路径\r\nnode bin/generate-chapter.js -p \"d:/axs/我的小说\" -c 1\r\n\r\n# 错误：路径包含空格未加引号\r\nnode bin/generate-chapter.js -p ../我的小说 -c 1  # 可能出错\r\n```\r\n\r\n## 六、最佳实践\r\n\r\n### 6.1 创作建议\r\n1. **先规划后创作**：使用工具规划好结构再开始写\r\n2. **角色驱动**：完善角色设定，让角色推动情节\r\n3. **保持一致性**：定期检查设定是否矛盾\r\n4. **迭代优化**：AI生成→人工编辑→AI润色的循环\r\n5. **备份重要版本**：重要章节手动备份\r\n\r\n### 6.2 文件管理\r\n1. **命名规范**：\r\n   - 角色文件：`角色名.yaml`\r\n   - 章节文件：`01_章节标题.md`\r\n   - 设定文件：`设定名称.md`\r\n2. **版本控制**：使用Git管理项目版本\r\n3. **定期备份**：备份整个项目文件夹\r\n4. **目录整洁**：及时清理.ai-context缓存\r\n\r\n### 6.3 效率技巧\r\n1. **批量操作**：创建脚本批量生成章节\r\n2. **模板复用**：保存成功的章节结构作为模板\r\n3. **快捷命令**：创建批处理文件快捷方式\r\n4. **协作工具**：配合VS Code、Cursor等编辑器使用\r\n\r\n## 七、下一步建议\r\n\r\n### 7.1 新手入门路径\r\n1. **第一天**：创建项目，生成主角和世界观\r\n2. **第二天**：规划故事结构，生成前3章\r\n3. **第一周**：完成第一卷（10-15章）\r\n4. **第一个月**：完成前50章，形成写作习惯\r\n\r\n### 7.2 进阶学习\r\n1. **学习MBTI理论**：深入理解角色人格设计\r\n2. **研究故事结构**：学习三幕剧、英雄之旅等结构\r\n3. **分析优秀作品**：用工具分析你喜欢的小说结构\r\n4. **参与社区**：分享经验，学习他人创作方法\r\n\r\n### 7.3 寻求帮助\r\n1. **查看总结文件**：`AI_NOVEL_ASSISTANT_SUMMARY.md`\r\n2. **工具帮助**：每个工具都有 `--help` 参数\r\n3. **问题反馈**：记录遇到的问题，便于优化工具\r\n\r\n---\r\n\r\n**最后更新**：2026年3月30日  \r\n**适用版本**：AI小说创作助手 v1.0  \r\n**作者建议**：工具只是辅助，真正的创作核心是你的想象力和坚持。开始写吧，完成比完美更重要！\r\n\r\n> 提示：本指南文件位于 `d:/axs/USER_GUIDE.md`，可随时查阅。\r\n\n=== AI_NOVEL_ASSISTANT_SUMMARY.md ===\n# AI小说创作助手 - 方案与实现总结\r\n\r\n## 一、方案概述\r\n\r\n### 1.1 核心架构理念\r\n- **极简存储**：所有数据用文件夹和纯文本文件（Markdown + YAML）保存，无需数据库。\r\n- **工具即脚本**：AI生成、情节规划、人格分析等封装为独立命令行工具，按需调用。\r\n- **记忆靠目录**：文件夹层级自然形成情节结构，文件名和元数据提供索引。\r\n- **幻觉靠上下文**：工具运行时自动读取相关文件，构建完整上下文传递给AI。\r\n- **个人使用**：不涉及协作、权限、实时同步，所有数据本地存储，工具离线可用。\r\n\r\n### 1.2 文件组织规范\r\n```\r\nmy-novel/                       # 小说项目根目录\r\n├── project.yaml                # 项目元数据\r\n├── characters/                 # 人物文件夹\r\n├── plots/                      # 情节文件夹\r\n├── settings/                   # 世界观设定文件夹\r\n├── relationships.yaml          # 人物关系索引\r\n├── notes/                      # 个人笔记（可选）\r\n└── .ai-context/                # AI上下文缓存（自动生成）\r\n```\r\n\r\n### 1.3 技术栈\r\n- **运行时**：Node.js\r\n- **命令行框架**：Commander.js\r\n- **文件解析**：js-yaml, marked\r\n- **AI集成**：Axios (支持DeepSeek、OpenAI等)\r\n- **数据格式**：YAML (配置), JSON (静态数据), Markdown (章节内容)\r\n\r\n## 二、已完成功能\r\n\r\n### 2.1 项目结构创建\r\n✅ **小说项目结构** (`my-novel/`)\r\n- `project.yaml` - 项目元数据文件（已填充示例）\r\n- `characters/` - 角色文件夹（已创建）\r\n- `plots/` - 情节文件夹（已创建）\r\n- `settings/` - 世界观设定文件夹（已创建）\r\n- `notes/` - 个人笔记文件夹（已创建）\r\n- `.ai-context/` - AI上下文缓存文件夹（已创建）\r\n\r\n✅ **工具项目结构** (`my-novel-tools/`)\r\n- `bin/` - 10个命令行工具（全部实现）\r\n- `lib/` - 核心模块和静态数据（全部实现）\r\n- `package.json` - 项目配置和依赖（已配置）\r\n\r\n### 2.2 10个核心工具实现\r\n| 序号 | 工具名 | 命令示例 | 功能 | 状态 |\r\n|------|--------|----------|------|------|\r\n| 1 | `personality` | `personality INTJ` | 生成MBTI人格提示词 | ✅ |\r\n| 2 | `fear` | `fear Se` | 根据劣势功能生成恐惧→冲突点子 | ✅ |\r\n| 3 | `structure` | `structure 150 --type five-volume` | 生成小说卷结构表 | ✅ |\r\n| 4 | `world-seed` | `world-seed fantasy Ni` | 生成世界观种子 | ✅ |\r\n| 5 | `complement` | `complement INTJ` | 推荐补盲配角（基于MBTI互补） | ✅ |\r\n| 6 | `catharsis` | `catharsis 150` | 生成爽点规划表 | ✅ |\r\n| 7 | `emotion` | `emotion 150 --style balanced` | 生成情绪曲线建议 | ✅ |\r\n| 8 | `template` | `template climax` | 输出章节模板 | ✅ |\r\n| 9 | `dialogue` | `dialogue INTJ` | 对话风格指南 | ✅ |\r\n| 10 | `generate-chapter` | `generate-chapter --project ./my-novel --chapter 1` | 生成章节草稿 | ✅ |\r\n\r\n### 2.3 核心模块实现\r\n✅ **AI模块** (`lib/ai.js`)\r\n- 封装AI调用，支持DeepSeek、OpenAI等API\r\n- 内置模拟模式，无需API密钥即可测试\r\n- 错误处理：API失败时自动切换到模拟模式\r\n\r\n✅ **项目模块** (`lib/project.js`)\r\n- 读取和解析项目文件（YAML、Markdown）\r\n- 构建AI生成所需的上下文\r\n- 支持角色、设定、关系、章节等数据读取\r\n\r\n✅ **静态数据** (`lib/data/`)\r\n- `mbti.json` - 16种MBTI类型的详细描述\r\n- `fear.json` - 8种认知功能的恐惧和情节建议\r\n- `structure-templates.json` - 3种故事结构模板\r\n- `world-seed-templates.json` - 3种题材×4种恐惧的世界观种子\r\n- `complement.json` - MBTI互补配对推荐\r\n- `templates.json` - 5种章节模板\r\n- `dialogue.json` - 16种MBTI的对话风格指南\r\n\r\n### 2.4 工具验证测试\r\n已成功测试以下工具：\r\n1. `personality INTJ` - 输出INTJ人格描述（主导功能Ni、辅助功能Te等）\r\n2. `fear Se` - 输出外倾感觉的恐惧和4条情节建议\r\n3. `structure 150` - 生成五卷式结构表，每卷30章\r\n4. `world-seed fantasy Ni` - 生成奇幻题材+内倾直觉的世界观种子\r\n5. `generate-chapter` - 生成测试章节（使用模拟数据成功）\r\n\r\n### 2.5 工作流演示\r\n已完成基础工作流测试：\r\n1. 创建项目结构：`my-novel/` 目录及子文件夹\r\n2. 生成角色人格：`personality INTJ` 可用于创建角色文件\r\n3. 规划结构：`structure 150` 生成五卷式规划\r\n4. 生成章节：`generate-chapter` 生成第1章草稿\r\n\r\n## 三、待完成功能与扩展建议\r\n\r\n### 3.1 核心功能增强\r\n- [ ] **关系图可视化**：生成人物关系网络图（PNG/SVG）\r\n- [ ] **一致性检查工具**：扫描项目文件，检测设定矛盾\r\n- [ ] **版本控制集成**：自动生成章节版本，支持回滚\r\n- [ ] **批量处理**：批量生成/润色多个章节\r\n- [ ] **导出功能**：支持导出为EPUB、PDF、Word格式\r\n\r\n### 3.2 AI功能扩展\r\n- [ ] **多模型支持**：增加Claude、GPT-4、本地Ollama模型支持\r\n- [ ] **风格迁移**：将章节内容转换为特定作家风格\r\n- [ ] **情节分析**：AI分析现有章节，提供优化建议\r\n- [ ] **对话生成**：基于角色性格生成特定场景对话\r\n- [ ] **伏笔管理**：标记和跟踪伏笔铺设与回收\r\n\r\n### 3.3 用户体验改进\r\n- [ ] **Web界面**：基于React的图形化操作界面\r\n- [ ] **实时预览**：Markdown实时渲染预览\r\n- [ ] **项目管理面板**：可视化项目进度统计\r\n- [ ] **快捷键支持**：快速调用常用功能\r\n- [ ] **主题定制**：深色/浅色主题切换\r\n\r\n### 3.4 数据管理优化\r\n- [ ] **数据导入/导出**：支持从其他写作软件导入数据\r\n- [ ] **云端同步**：可选云备份和跨设备同步\r\n- [ ] **模板市场**：用户可分享和下载创作模板\r\n- [ ] **数据分析**：创作习惯统计和分析报告\r\n- [ ] **智能推荐**：基于阅读偏好推荐情节走向\r\n\r\n### 3.5 技术优化\r\n- [ ] **性能优化**：缓存机制减少文件重复读取\r\n- [ ] **错误恢复**：更完善的错误处理和恢复机制\r\n- [ ] **测试覆盖**：增加单元测试和集成测试\r\n- [ ] **文档完善**：完整的API文档和用户指南\r\n- [ ] **多语言支持**：支持英文、日文等其他语言\r\n\r\n## 四、使用工作流建议\r\n\r\n### 4.1 初始化项目\r\n```bash\r\n# 1. 创建项目结构\r\nmkdir my-novel\r\ncd my-novel\r\nmkdir characters plots settings notes .ai-context\r\n\r\n# 2. 创建项目元数据\r\ncat > project.yaml << EOF\r\ntitle: 剑仙归来\r\nauthor: 你的名字\r\ngenre: 玄幻\r\ntarget_words: 200000\r\nstatus: writing\r\ncreated: 2025-03-30\r\nlast_modified: 2025-03-30\r\nai_model: deepseek\r\napi_key_env: DEEPSEEK_API_KEY\r\nEOF\r\n```\r\n\r\n### 4.2 设定核心元素\r\n```bash\r\n# 1. 生成主角人格描述\r\npersonality INTJ > characters/林枫.yaml\r\n\r\n# 2. 为角色生成恐惧情节\r\nfear Se >> characters/林枫.yaml\r\n\r\n# 3. 生成世界观\r\nworld-seed fantasy Ni > settings/世界观.md\r\n```\r\n\r\n### 4.3 规划结构\r\n```bash\r\n# 1. 生成150章结构规划\r\nstructure 150 > plots/_overview.md\r\n\r\n# 2. 生成爽点规划\r\ncatharsis 150 > plots/_catharsis.md\r\n\r\n# 3. 生成情绪曲线\r\nemotion 150 --style balanced > plots/_emotion.md\r\n```\r\n\r\n### 4.4 逐章创作\r\n```bash\r\n# 1. 生成章节草稿\r\ngenerate-chapter --project . --chapter 1 --outline \"林枫重生归来\" --output plots/第一卷/01_重生归来.md\r\n\r\n# 2. 手动润色编辑\r\n# 3. 重复生成后续章节\r\n```\r\n\r\n## 五、总结\r\n\r\n### 5.1 实现状态\r\n✅ **核心架构**：完全按照方案实现极简存储和工具化设计\r\n✅ **10个核心工具**：全部实现并通过基础测试\r\n✅ **项目结构**：完整的小说项目和工具项目结构\r\n✅ **数据模型**：全面的静态数据支持MBTI、恐惧、结构等\r\n✅ **AI集成**：支持真实API和模拟模式，具备完整上下文构建\r\n\r\n### 5.2 方案优势验证\r\n1. **极简性**：无需数据库，纯文件存储，人类可读\r\n2. **可控性**：所有工具独立，可单独升级或替换\r\n3. **灵活性**：支持手动修改文件，工具仅为辅助\r\n4. **低成本**：开发成本低，运行成本仅AI API费用\r\n5. **可扩展**：新工具只需添加脚本，不破坏现有结构\r\n\r\n### 5.3 后续建议\r\n1. **优先实现**：关系图可视化和一致性检查工具\r\n2. **用户反馈**：在实际创作中收集工具使用反馈\r\n3. **社区建设**：建立用户社区分享模板和最佳实践\r\n4. **持续优化**：根据使用情况迭代改进工具设计\r\n\r\n---\r\n\r\n**最后更新**：2026年3月30日  \r\n**项目状态**：核心功能已实现，可投入实际使用  \r\n**建议下一步**：开始使用工具创作第一个小说项目，根据实际需求提出改进建议","cwd":"/home/ai/.openclaw/workspace/main"},"isError":false,"timestamp":1776149003283}}
{"type":"message","id":"5769d8ce","parentId":"a579152f","timestamp":"2026-04-14T06:43:35.326Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I have a very good picture of this project. Let me also check the novel-desktop-app directory and src directory for more details.","thinkingSignature":"a23be81a3b82cf1b4c72f9ab1201f7e0f313199a73f20b4dd91312f09b0a3820"},{"type":"toolCall","id":"call_function_8wde72sirn7y_1","name":"exec","arguments":{"command":"WORKDIR=\"/mnt/d/aafuzhi/axs\"\necho \"=== 详细需求文件（前80行）===\"\ncat \"$WORKDIR/详细需求和功能细化.txt\" | head -80\n\necho \"\"\necho \"=== src/main/index.ts ===\"\ncat \"$WORKDIR/src/main/index.ts\" 2>/dev/null | head -50\n\necho \"\"\necho \"=== novel-desktop-app 结构 ===\"\nfind \"$WORKDIR/novel-desktop-app\" -type f -name \"*.json\" -o -name \"*.md\" -o -name \"*.ts\" -o -name \"*.tsx\" 2>/dev/null | head -20"}},{"type":"toolCall","id":"call_function_8wde72sirn7y_2","name":"exec","arguments":{"command":"WORKDIR=\"/mnt/d/aafuzhi/axs\"\necho \"=== my-novel-tools/bin 目录 ===\"\nls \"$WORKDIR/my-novel-tools/bin/\" 2>/dev/null\n\necho \"\"\necho \"=== my-novel-tools/lib 目录 ===\"\nfind \"$WORKDIR/my-novel-tools/lib\" -type f 2>/dev/null | head -20\n\necho \"\"\necho \"=== memory-bank 目录 ===\"\nls \"$WORKDIR/memory-bank/\" 2>/dev/null"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":79014,"output":307,"cacheRead":19262,"cacheWrite":0,"totalTokens":98583,"cost":{"input":0.023704199999999998,"output":0.0003684,"cacheRead":0.0011557199999999998,"cacheWrite":0,"total":0.02522832}},"stopReason":"toolUse","timestamp":1776149003296,"responseId":"062d150bbbb3e423a1e5696a28c7cbef"}}
{"type":"message","id":"7734dbab","parentId":"5769d8ce","timestamp":"2026-04-14T06:43:35.468Z","message":{"role":"toolResult","toolCallId":"call_function_8wde72sirn7y_1","toolName":"exec","content":[{"type":"text","text":"=== 详细需求文件（前80行）===\n以下是AI小说创作工坊的详细需求和功能细化列表，按模块分类，包含具体功能点、实现细节、用户操作和技术要求：\r\n\r\n## 一、🤖 多模型支持系统\r\n\r\n### 1.1 云端模型集成\r\n\r\n| 功能点 | 详细描述 | 技术实现 | 用户操作 | 配置参数 | |--------|----------|----------|----------|----------| | DeepSeek Chat支持 | 集成DeepSeek API，支持流式生成 | Axios调用DeepSeek API，SSE流式响应 | 选择模型时自动启用 | API Key、Base URL、最大token数 | | GPT-4o支持 | 集成OpenAI GPT-4o模型 | OpenAI SDK调用 | 需要配置OpenAI API Key | API Key、温度、频率惩罚 | | Claude 3.5 Sonnet支持 | 集成Anthropic Claude模型 | Axios调用Claude API | 需要配置Claude API Key | API Key、最大token数 | | API密钥管理 | 加密存储和管理多个API密钥 | Crypto-JS加密，SQLite存储 | 在设置面板输入和更新密钥 | 加密算法、密钥轮换策略 |\r\n\r\n### 1.2 本地模型集成\r\n\r\n| 功能点 | 详细描述 | 技术实现 | 用户操作 | 配置参数 | |--------|----------|----------|----------|----------| | Ollama连接 | 连接本地Ollama服务 | Ollama SDK或Axios调用本地端口 | 启动Ollama服务 | Ollama Base URL (默认11434端口) | | 模型列表获取 | 动态获取本地可用模型列表 | GET请求到Ollama API | 自动刷新模型列表 | 轮询间隔、超时时间 | | qwen2.5支持 | 支持qwen2.5系列模型 | 标准聊天接口调用 | 下拉选择qwen2.5模型 | 模型版本、上下文长度 | | llama3支持 | 支持llama3系列模型 | 标准聊天接口调用 | 下拉选择llama3模型 | 模型版本、温度参数 |\r\n\r\n### 1.3 模型切换与参数配置\r\n\r\n| 功能点 | 详细描述 | 技术实现 | 用户操作 | 配置参数 | |--------|----------|----------|----------|----------| | 一键切换模型 | 快速在多个模型间切换 | 状态管理模型选择 | 顶部下拉菜单选择 | 当前模型状态 | | 温度参数调整 | 控制生成随机性(0-2) | 滑动条组件，实时调整 | 拖动滑动条调整温度 | 默认值0.7，步长0.1 | | 最大token数设置 | 控制单次生成的最大长度 | 数字输入框或滑动条 | 输入或拖动设置token数 | 范围500-8000，默认2000 | | 生成字数选择 | 预设置生成字数选项 | 下拉选择框 | 选择500/1000/2000/3000字 | 与token数的转换比率 |\r\n\r\n## 二、📖 智能创作功能模块\r\n\r\n### 2.1 AI续写功能\r\n\r\n| 功能点 | 详细描述 | 技术实现 | 用户操作 | 技术参数 | |--------|----------|----------|----------|----------| | 上下文提取 | 自动提取前文作为续写上下文 | 截取最后N个字符或段落 | 点击\"续写\"按钮自动执行 | 上下文长度(默认2000字符) | | 续写长度控制 | 按字数控制续写长度 | 将字数转换为token数 | 选择续写字数(500-3000) | 字数-token转换表 | | 流式生成显示 | 实时显示生成内容 | SSE流式响应，逐步显示 | 观看内容逐步生成 | 流式响应间隔 | | 续写中断 | 允许中途停止生成 | AbortController中断请求 | 点击\"停止\"按钮 | 请求中断处理 |\r\n\r\n### 2.2 AI重写功能\r\n\r\n| 功能点 | 详细描述 | 技术实现 | 用户操作 | 技术参数 | |--------|----------|----------|----------|----------| | 全章重写 | 重新生成整个章节 | 发送章节标题和概要 | 点击\"重写\"按钮确认 | 保持原结构参数 | | 段落重写 | 重写选中段落 | 获取选中文本，发送重写请求 | 选中文本后右键菜单选择 | 上下文保留范围 | | 重写模式选择 | 不同重写风格(精简/扩展/改进) | 不同提示词模板 | 下拉选择重写模式 | 模式对应的提示词 |\r\n\r\n### 2.3 AI润色功能\r\n\r\n| 功能点 | 详细描述 | 技术实现 | 用户操作 | 技术参数 | |--------|----------|----------|----------|----------| | 文笔优化 | 改进语言表达，保持原意 | 使用润色专用提示词 | 点击\"润色\"按钮 | 润色强度参数 | | 语法检查 | 检查并修正语法错误 | 集成语法检查逻辑 | 自动执行或手动触发 | 语法规则库 | | 风格统一 | 确保全文风格一致 | 分析现有风格并应用 | 点击\"统一风格\"按钮 | 风格特征提取算法 |\r\n\r\n### 2.4 风格迁移功能\r\n\r\n| 功能点 | 详细描述 | 技术实现 | 用户操作 | 技术参数 | |--------|----------|----------|----------|----------| | 作家风格模仿 | 模仿指定作家写作风格 | 预训练风格模型或提示词 | 选择作家名字(鲁迅、金庸等) | 风格特征库 | | 自定义风格 | 根据示例文本定义风格 | 提取示例文本风格特征 | 上传示例文本或输入描述 | 风格提取算法 | | 风格强度控制 | 控制风格迁移的程度 | 调整风格混合比例 | 滑动条调整强度 | 0-100%强度控制 |\r\n\r\n### 2.5 大纲生成功能\r\n\r\n| 功能点 | 详细描述 | 技术实现 | 用户操作 | 技术参数 | |--------|----------|----------|----------|----------| | 一键生成大纲 | 根据项目设定生成10-15章大纲 | 发送世界观、人物等上下文 | 点击\"生成大纲\"按钮 | 章节数范围、详细程度 | | 大纲结构调整 | 调整大纲章节顺序和结构 | 拖拽章节重新排序 | 拖拽章节调整顺序 | 树状结构数据模型 | | 章节细化 | 将大纲章节细化为具体内容 | 逐章扩展为详细描述 | 点击\"细化章节\"按钮 | 扩展深度参数 |\r\n\r\n## 三、👥 项目管理模块\r\n\r\n### 3.1 项目基础管理\r\n\r\n| 功能点 | 详细描述 | 技术实现 | 用户操作 | 数据模型 | |--------|----------|----------|----------|----------| | 创建新项目 | 初始化新小说项目 | SQLite插入项目记录 | 填写项目名称、简介 | 项目表结构 | | 项目列表展示 | 显示所有项目卡片 | 查询项目列表，卡片组件渲染 | 浏览项目列表 | 项目卡片组件 | | 项目选择与切换 | 切换当前编辑的项目 | Zustand状态管理当前项目ID | 点击项目卡片 | 全局状态管理 | | 项目删除 | 删除项目及关联数据 | 级联删除相关记录 | 点击删除按钮并确认 | 数据库级联删除 |\r\n\r\n### 3.2 章节管理\r\n\r\n| 功能点 | 详细描述 | 技术实现 | 用户操作 | 数据模型 | |--------|----------|----------|----------|----------| | 添加章节 | 创建新章节 | 插入章节记录，初始化内容 | 点击\"添加章节\"按钮 | 章节表结构 | | 章节编辑 | 编辑章节标题和内容 | 更新章节记录 | 双击标题或内容编辑 | 富文本编辑器集成 | | 章节排序 | 拖拽调整章节顺序 | Dnd Kit拖拽库，更新顺序字段 | 拖拽章节调整位置 | 排序索引字段 | | 章节删除 | 删除章节及关联数据 | 删除章节记录 | 点击删除按钮 | 关联数据清理 | | 章节导入 | 导入外部文本为章节 | 解析文本文件，创建章节 | 拖拽文件或选择文件 | 文件解析器 |\r\n\r\n### 3.3 数据导入导出\r\n\r\n| 功能点 | 详细描述 | 技术实现 | 用户操作 | 技术实现 | |--------|----------|----------|----------|----------| | Markdown导出 | 导出项目为Markdown文件 | 拼接章节内容为MD格式 | 选择\"导出为Markdown\" | 文件下载API | | EPUB导出 | 导出为EPUB电子书格式 | 使用EPUB生成库 | 选择\"导出为EPUB\" | EPUB库集成 | | 项目备份 | 完整项目数据备份 | SQLite数据库导出 | 选择\"备份项目\" | 数据库导出工具 | | 项目恢复 | 从备份恢复项目 | SQLite数据库导入 | 选择\"恢复项目\" | 数据库导入工具 |\r\n\r\n## 四、🎭 人物管理系统\r\n\r\n### 4.1 人物信息管理\r\n\r\n| 功能点 | 详细描述 | 技术实现 | 用户操作 | 数据模型 | |--------|----------|----------|----------|----------| | 人物卡创建 | 创建新人物记录 | 插入人物记录 | 填写人物表单 | 人物表结构 | | 详细信息编辑 | 编辑人物详细信息 | 更新人物记录 | 点击编辑按钮 | 表单字段验证 | | 人物分类 | 按角色类型分类(主角/配角) | 标签系统分类 | 选择角色类型 | 分类标签系统 | | 批量导入 | 批量导入人物设定 | 解析CSV/JSON文件 | 上传人物文件 | 文件解析器 |\r\n\r\n### 4.2 人物关系管理\r\n\r\n| 功能点 | 详细描述 | 技术实现 | 用户操作 | 技术实现 | |--------|----------|----------|----------|----------| | 关系定义 | 定义人物间关系类型 | 关系图数据模型 | 拖拽连接人物 | 图数据结构 | | 关系可视化 | 图形化展示人物关系 | D3.js或类似库绘制关系图 | 查看关系图 | 图布局算法 | | 关系强度设置 | 设置关系亲密程度 | 数值型关系强度字段 | 滑动条调整强度 | 强度映射算法 | | 关系时间线 | 展示关系随时间变化 | 时间线图表组件 | 查看关系演变 | 时间序列数据 |\r\n\r\n### 4.3 人物发展跟踪\r\n\r\n| 功能点 | 详细描述 | 技术实现 | 用户操作 | 技术实现 | |--------|----------|----------|----------|----------| | 性格变化记录 | 记录人物性格演变 | 时间戳性格快照 | 更新性格描述 | 快照系统 | | 成长弧线分析 | 分析人物成长轨迹 | 自然语言分析性格变化 | 查看成长分析报告 | NLP分析算法 | | 出场统计 | 统计人物出场次数 | 文本分析识别人物提及 | 查看出场统计 | 命名实体识别 | | 关联情节 | 关联人物与相关情节 | 情节-人物关联表 | 查看人物相关情节 | 多对多关系 |\r\n\r\n## 五、🌍 世界观管理系统\r\n\r\n### 5.1 世界观设定管理\r\n\r\n| 功能点 | 详细描述 | 技术实现 | 用户操作 | 数据模型 | |--------|----------|----------|----------|----------| | 世界观模板 | 提供预设世界观模板 | 模板库系统 | 选择模板应用 | 模板数据结构 | | 自定义设定 | 自定义世界观要素 | 结构化世界观编辑器 | 填写世界观表单 | 嵌套数据结构 | | 要素分类 | 分类管理世界观要素 | 标签分类系统 | 为要素添加标签 | 分类标签系统 | | 版本管理 | 世界观版本历史 | 版本控制系统 | 查看版本历史 | 版本差异对比 |\r\n\r\n### 5.2 一致性检查\r\n\r\n| 功能点 | 详细描述 | 技术实现 | 用户操作 | 技术实现 | |--------|----------|----------|----------|----------| | 矛盾检测 | 检测世界观内部矛盾 | 规则引擎检查逻辑矛盾 | 运行一致性检查 | 规则引擎 | | 冲突报告 | 生成矛盾详细报告 | 自然语言描述冲突 | 查看冲突报告 | 报告生成器 | | 自动修复建议 | 提供矛盾解决建议 | AI分析矛盾并提供方案 | 查看修复建议 | AI建议生成 | | 与情节一致性 | 检查情节是否符合世界观 | 情节-世界观匹配分析 | 运行情节检查 | 语义匹配算法 |\r\n\r\n## 六、🔍 事实库系统\r\n\r\n### 6.1 事实提取与管理\r\n\r\n\n=== src/main/index.ts ===\n/**\n * 番茄小说创作助手 - Electron 主进程入口\n * \n * 提供：\n * - 窗口管理\n * - IPC 处理器注册\n * - 文件系统 API\n * - SQLite 连接（待实现）\n */\n\nimport { app, BrowserWindow, ipcMain, dialog, shell, safeStorage } from 'electron'\nimport path from 'path'\nimport fs, { FSWatcher } from 'fs'\n\n// 重新导出 main.ts 的功能\n// 这是为了保持统一的导入路径：import { createWindow } from '../src/main/index'\n\n// 保持对窗口对象的全局引用，避免被垃圾回收\nlet mainWindow: BrowserWindow | null = null\n\n// 项目根目录 - 用于路径验证\nlet projectRootPath: string | null = null\n\n// 文件系统监视器\nlet fsWatcher: FSWatcher | null = null\n\n/**\n * 验证文件路径是否安全\n * 防止路径遍历攻击 (如 ../../../etc/passwd)\n * 只允许访问项目目录内的文件\n */\nfunction validatePath(requestedPath: string): { valid: boolean; resolvedPath?: string; error?: string } {\n  // 如果没有设置项目根路径，允许绝对路径但进行基本验证\n  if (!projectRootPath) {\n    // 解析并规范化路径\n    const resolved = path.resolve(requestedPath)\n    \n    // 检查是否尝试访问系统敏感目录\n    const sensitivePaths = [\n      '/etc',\n      '/proc',\n      '/sys',\n      'C:\\\\Windows',\n      'C:\\\\Program Files',\n      'C:\\\\Program Files (x86)',\n    ]\n    \n    for (const sensitive of sensitivePaths) {\n      if (resolved.toLowerCase().startsWith(sensitive.toLowerCase())) {\n        return {\n\n=== novel-desktop-app 结构 ===\n/mnt/d/aafuzhi/axs/novel-desktop-app/BUG_CHECK_PROGRESS.md\n/mnt/d/aafuzhi/axs/novel-desktop-app/BUG_FIX_LOG.md\n/mnt/d/aafuzhi/axs/novel-desktop-app/BUG_FIX_REPORT.md\n/mnt/d/aafuzhi/axs/novel-desktop-app/dist/main/src/main/aiService.d.ts\n/mnt/d/aafuzhi/axs/novel-desktop-app/dist/main/src/main/backupService.d.ts\n/mnt/d/aafuzhi/axs/novel-desktop-app/dist/main/src/main/index.d.ts\n/mnt/d/aafuzhi/axs/novel-desktop-app/dist/main/src/main/main.d.ts\n/mnt/d/aafuzhi/axs/novel-desktop-app/dist/main/src/main/preload.d.ts\n/mnt/d/aafuzhi/axs/novel-desktop-app/FEATURE_OPTIMIZATION_PLAN.md\n/mnt/d/aafuzhi/axs/novel-desktop-app/IMPLEMENTATION_PROGRESS.m