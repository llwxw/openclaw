{"type":"message","id":"95e541f8","parentId":"86d20fb0","timestamp":"2026-04-14T06:14:29.913Z","message":{"role":"toolResult","toolCallId":"call_function_si7rjvp5i2gr_2","toolName":"exec","content":[{"type":"text","text":"// auto-score-classify hook\n// Concurrent classification (3105) + scoring (3103) on every inbound message\n// + ephemeral memory capture for meaningful messages\n\nimport fs from \"node:fs\";\nimport path from \"node:path\";\nimport http from \"node:http\";\n\nasync function fetchJSON(url, body, timeoutMs = 3000) {\n  return new Promise((resolve) => {\n    const postData = JSON.stringify(body);\n    const req = http.request(\n      url,\n      {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\", \"Content-Length\": Buffer.byteLength(postData) },\n      },\n      (res) => {\n        let data = \"\";\n        res.on(\"data\", (chunk) => (data += chunk));\n        res.on(\"end\", () => {\n          try { resolve(JSON.parse(data)); }\n          catch { resolve(null); }\n        });\n      }\n    );\n    req.on(\"error\", () => resolve(null));\n    req.setTimeout(timeoutMs, () => { req.destroy(); resolve(null); });\n    req.write(postData);\n    req.end();\n    setTimeout(() => { try { req.destroy(); } catch {} }, timeoutMs);\n  });\n}\n\nasync function runClassification(text) {\n  return fetchJSON(\"http://127.0.0.1:3105/classify\", { text }, 3000);\n}\n\nasync function runScoring(prompt) {\n  return fetchJSON(\"http://127.0.0.1:3103/api/score\", { prompt }, 3000);\n}\n\nfunction ensureDir(dir) {\n  if (!fs.existsSync(dir)) {\n    fs.mkdirSync(dir, { recursive: true });\n  }\n}\n\n// ─── Meaningfulness filter ───────────────────────────────────────────────────\nconst MEANINGFUL_PATTERNS = [\n  /记住|以后都|决定用|别用|改用|这个要记|记下来/,\n];\n\nfunction isMeaningful(text, classification, scoring) {\n  const c = classification || {};\n  const s = scoring || {};\n\n  // 1. Explicit user intent (highest priority)\n  if (MEANINGFUL_PATTERNS.some(p => p.test(text))) return true;"}],"details":{"status":"completed","exitCode":0,"durationMs":119,"aggregated":"// auto-score-classify hook\n// Concurrent classification (3105) + scoring (3103) on every inbound message\n// + ephemeral memory capture for meaningful messages\n\nimport fs from \"node:fs\";\nimport path from \"node:path\";\nimport http from \"node:http\";\n\nasync function fetchJSON(url, body, timeoutMs = 3000) {\n  return new Promise((resolve) => {\n    const postData = JSON.stringify(body);\n    const req = http.request(\n      url,\n      {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\", \"Content-Length\": Buffer.byteLength(postData) },\n      },\n      (res) => {\n        let data = \"\";\n        res.on(\"data\", (chunk) => (data += chunk));\n        res.on(\"end\", () => {\n          try { resolve(JSON.parse(data)); }\n          catch { resolve(null); }\n        });\n      }\n    );\n    req.on(\"error\", () => resolve(null));\n    req.setTimeout(timeoutMs, () => { req.destroy(); resolve(null); });\n    req.write(postData);\n    req.end();\n    setTimeout(() => { try { req.destroy(); } catch {} }, timeoutMs);\n  });\n}\n\nasync function runClassification(text) {\n  return fetchJSON(\"http://127.0.0.1:3105/classify\", { text }, 3000);\n}\n\nasync function runScoring(prompt) {\n  return fetchJSON(\"http://127.0.0.1:3103/api/score\", { prompt }, 3000);\n}\n\nfunction ensureDir(dir) {\n  if (!fs.existsSync(dir)) {\n    fs.mkdirSync(dir, { recursive: true });\n  }\n}\n\n// ─── Meaningfulness filter ───────────────────────────────────────────────────\nconst MEANINGFUL_PATTERNS = [\n  /记住|以后都|决定用|别用|改用|这个要记|记下来/,\n];\n\nfunction isMeaningful(text, classification, scoring) {\n  const c = classification || {};\n  const s = scoring || {};\n\n  // 1. Explicit user intent (highest priority)\n  if (MEANINGFUL_PATTERNS.some(p => p.test(text))) return true;","cwd":"/home/ai/.openclaw/workspace/main"},"isError":f