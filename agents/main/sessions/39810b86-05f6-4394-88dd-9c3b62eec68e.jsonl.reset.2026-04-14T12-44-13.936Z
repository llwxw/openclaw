{"type":"message","id":"19a8dc4a","parentId":"7e86a653","timestamp":"2026-04-14T08:41:11.585Z","message":{"role":"toolResult","toolCallId":"call_function_yhm0noillllv_1","toolName":"exec","content":[{"type":"text","text":"/**\r\n * 轻量级向量索引服务\r\n * 使用 transformers.js 进行本地向量化，vectra 进行向量存储和检索\r\n */\r\n\r\nconst fs = require('fs');\r\nconst path = require('path');\r\nconst yaml = require('js-yaml');\r\n\r\n// 延迟加载 transformers，避免在不需要时下载模型\r\nlet pipeline = null;\r\nlet embedder = null;\r\n\r\n/**\r\n * 初始化嵌入模型\r\n */\r\nasync function initEmbedder() {\r\n  if (!embedder) {\r\n    const { pipeline: createPipeline } = require('@xenova/transformers');\r\n    pipeline = createPipeline;\r\n    embedder = await pipeline('feature-extraction', 'Xenova/bge-small-zh-v1.5');\r\n  }\r\n  return embedder;\r\n}\r\n\r\n/**\r\n * 生成文本的向量表示\r\n * @param {string} text - 输入文本\r\n * @returns {Promise<number[]>} - 向量数组\r\n */"}],"details":{"status":"completed","exitCode":0,"durationMs":112,"aggregated":"/**\r\n * 轻量级向量索引服务\r\n * 使用 transformers.js 进行本地向量化，vectra 进行向量存储和检索\r\n */\r\n\r\nconst fs = require('fs');\r\nconst path = require('path');\r\nconst yaml = require('js-yaml');\r\n\r\n// 延迟加载 transformers，避免在不需要时下载模型\r\nlet pipeline = null;\r\nlet embedder = null;\r\n\r\n/**\r\n * 初始化嵌入模型\r\n */\r\nasync function initEmbedder() {\r\n  if (!embedder) {\r\n    const { pipeline: createPipeline } = require('@xenova/transformers');\r\n    pipeline = createPipeline;\r\n    embedder = await pipeline('feature-extraction', 'Xenova/bge-small-zh-v1.5');\r\n  }\r\n  return embedder;\r\n}\r\n\r\n/**\r\n * 生成文本的向量表示\r\n * @param {string} text - 输入文本\r\n * @returns {Promise<number[]>} - 向量数组\r\n */","cwd":"/home/ai/.openclaw/workspace/main"},"isError":false,"timestamp":1776156071540}}
