{"type":"message","id":"bbbdde85","parentId":"92e306eb","timestamp":"2026-04-14T06:14:34.676Z","message":{"role":"toolResult","toolCallId":"call_function_6vtxkfhrm9qv_1","toolName":"exec","content":[{"type":"text","text":"// + ephemeral memory capture for meaningful messages\n\nimport fs from \"node:fs\";\nimport path from \"node:path\";\nimport http from \"node:http\";\n\nasync function fetchJSON(url, body, timeoutMs = 3000) {\n  return new Promise((resolve) => {\n    const postData = JSON.stringify(body);\n    const req = http.request(\n      url,\n      {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\", \"Content-Length\": Buffer.byteLength(postData) },\n      },\n      (res) => {\n        let data = \"\";\n        res.on(\"data\", (chunk) => (data += chunk));\n        res.on(\"end\", () => {\n          try { resolve(JSON.parse(data)); }\n          catch { resolve(null); }\n--\n  \"ephemeral\"\n);\n\nfunction writeEphemeral(entry) {\n  try {\n    ensureDir(EPHEMERAL_DIR);\n    // File per hour: YYYY-MM-DD-HH.jsonl\n    const now = new Date();\n    const hourStr = now.toISOString().slice(0, 13).replace('T', '-');\n    const filePath = path.join(EPHEMERAL_DIR, `${hourStr}.jsonl`);\n    const line = JSON.stringify(entry) + '\\n';\n    fs.appendFileSync(filePath, line, 'utf-8');\n  } catch (e) {\n    // Silently ignore write errors - ephemeral should not break main flow\n  }\n}\n\n// ─── Main handler ─────────────────────────────────────────────────────────────\nexport default async function handler(event) {\n  if (event.type !== \"message\" || event.action !== \"preprocessed\") {\n    return;\n  }\n\n  const text = event.context?.bodyForAgent || \"\";\n  if (!text || text.trim().length === 0) return;\n\n  const sessionKey = event.sessionKey || \"default\";\n  const sessionDir = path.join(process.env.HOME || \"/home/ai\", \".openclaw/sessions\", sessionKey);\n  ensureDir(sessionDir);\n\n  const [classificationResult, scoringResult] = await Promise.allSettled([\n    runClassification(text),\n    runScoring(text),\n  ]);\n--\n    fs.writeFileSync(outPath, JSON.stringify(result, null, 2), \"utf-8\");\n  } catch {\n    // ignore write errors silently\n  }\n\n  // ─── Ephemeral memory capture ─────────────────────────────────────────────\n  if (isMeaningful(text, classification, scoring)) {\n    writeEphemeral({\n      timestamp: new Date().toISOString(),\n      sessionKey,\n      text,\n      textPreview: text.length > 200 ? text.slice(0, 200) + '...' : text,\n      classification,\n      scoring,\n    });\n  }\n}"}],"details":{"status":"completed","exitCode":0,"durationMs":86,"aggregated":"// + ephemeral memory capture for meaningful messages\n\nimport fs from \"node:fs\";\nimport path from \"node:path\";\nimport http from \"node:http\";\n\nasync function fetchJSON(url, body, timeoutMs = 3000) {\n  return new Promise((resolve) => {\n    const postData = JSON.stringify(body);\n    const req = http.request(\n      url,\n      {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\", \"Content-Length\": Buffer.byteLength(postData) },\n      },\n      (res) => {\n        let data = \"\";\n        res.on(\"data\", (chunk) => (data += chunk));\n        res.on(\"end\", () => {\n          try { resolve(JSON.parse(data)); }\n          catch { resolve(null); }\n--\n  \"ephemeral\"\n);\n\nfunction writeEphemeral(entry) {\n  try {\n    ensureDir(EPHEMERAL_DIR);\n    // File per hour: YYYY-MM-DD-HH.jsonl\n    const now = new Date();\n    const hourStr = now.toISOString().slice(0, 13).replace('T', '-');\n    const filePath = path.join(EPHEMERAL_DIR, `${hourStr}.jsonl`);\n    const line = JSON.stringify(entry) + '\\n';\n    fs.appendFileSync(filePath, line, 'utf-8');\n  } catch (e) {\n    // Silently ignore write errors - ephemeral should not break main flow\n  }\n}\n\n// ─── Main handler ─────────────────────────────────────────────────────────────\nexport default async function handler(event) {\n  if (event.type !== \"message\" || event.action !== \"preprocessed\") {\n    return;\n  }\n\n  const text = event.context?.bodyForAgent || \"\";\n  if (!text || text.trim().length === 0) return;\n\n  const sessionKey = event.sessionKey || \"default\";\n  const sessionDir = path.join(process.env.HOME || \"/home/ai\", \".openclaw/sessions\", sessionKey);\n  ensureDir(sessionDir);\n\n  const [classificationResult, scoringResult] = await Promise.allSettled([\n    runClassification(text),\n    runScoring(text),\n  ]);\n--\n    fs.writeFileSync(outPath, JSON.stringify(result, null, 2), \"utf-8\");\n  } catch {\n    // ignore write errors silently\n  }\n\n  // ─── Ephemeral memory capture ─────────────────────────────────────────────\n  if (isMeaningful(text, classification, scoring)) {\n    writeEphemeral({\n      timestamp: new Date().toISOString(),\n      sessionKey,\n      text,\n      textPreview: text.length > 200 ? text.slice(0, 200) + '...' : text,\n      classification,\n      scoring,\n    });\n  }\n}","cwd":"/home/ai/.openclaw/workspace/main"},"isError":false,"timestamp":1776147274659}}
