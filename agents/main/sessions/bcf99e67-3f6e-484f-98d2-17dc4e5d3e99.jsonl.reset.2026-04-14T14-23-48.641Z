{"type":"message","id":"2b16c48b","parentId":"1230420c","timestamp":"2026-04-14T13:51:33.927Z","message":{"role":"toolResult","toolCallId":"call_function_xiy9o30roy93_1","toolName":"exec","content":[{"type":"text","text":"/home/ai/.nvm/versions/node/v22.22.1/lib/node_modules/openclaw/docs/vps.md\n/home/ai/.nvm/versions/node/v22.22.1/lib/node_modules/openclaw/docs/help/faq.md\n/home/ai/.nvm/versions/node/v22.22.1/lib/node_modules/openclaw/docs/help/index.md\n/home/ai/.nvm/versions/node/v22.22.1/lib/node_modules/openclaw/docs/help/debugging.md\n/home/ai/.nvm/versions/node/v22.22.1/lib/node_modules/openclaw/docs/help/environment.md\n/home/ai/.nvm/versions/node/v22.22.1/lib/node_modules/openclaw/docs/help/troubleshooting.md\n/home/ai/.nvm/versions/node/v22.22.1/lib/node_modules/openclaw/docs/help/testing.md\n/home/ai/.nvm/versions/node/v22.22.1/lib/node_modules/openclaw/docs/help/scripts.md\n/home/ai/.nvm/versions/node/v22.22.1/lib/node_modules/openclaw/docs/pi.md\n/home/ai/.nvm/versions/node/v22.22.1/lib/node_modules/openclaw/docs/security/formal-verification.md\nassets\nauth-credential-semantics.md\nautomation\nbrave-search.md\nchannels\nci.md\ncli\nconcepts\ndate-time.md\ndebug\ndiagnostics\ndocs.json\ngateway\nhelp\nimages\nindex.md\ninstall\nlogging.md\nnav-tabs-underline.js\nnetwork.md"}],"details":{"status":"completed","exitCode":0,"durationMs":69,"aggregated":"/home/ai/.nvm/versions/node/v22.22.1/lib/node_modules/openclaw/docs/vps.md\n/home/ai/.nvm/versions/node/v22.22.1/lib/node_modules/openclaw/docs/help/faq.md\n/home/ai/.nvm/versions/node/v22.22.1/lib/node_modules/openclaw/docs/help/index.md\n/home/ai/.nvm/versions/node/v22.22.1/lib/node_modules/openclaw/docs/help/debugging.md\n/home/ai/.nvm/versions/node/v22.22.1/lib/node_modules/openclaw/docs/help/environment.md\n/home/ai/.nvm/versions/node/v22.22.1/lib/node_modules/openclaw/docs/help/troubleshooting.md\n/home/ai/.nvm/versions/node/v22.22.1/lib/node_modules/openclaw/docs/help/testing.md\n/home/ai/.nvm/versions/node/v22.22.1/lib/node_modules/openclaw/docs/help/scripts.md\n/home/ai/.nvm/versions/node/v22.22.1/lib/node_modules/openclaw/docs/pi.md\n/home/ai/.nvm/versions/node/v22.22.1/lib/node_modules/openclaw/docs/security/formal-verification.md\nassets\nauth-credential-semantics.md\nautomation\nbrave-search.md\nchannels\nci.md\ncli\nconcepts\ndate-time.md\ndebug\ndiagnostics\ndocs.json\ngateway\nhelp\nimages\nindex.md\ninstall\nlogging.md\nnav-tabs-underline.js\nnetwork.md","cwd":"/home/ai/.openclaw/workspace/main"},"isError":false,"timestamp":1776174693917}}
