{"type":"message","id":"3da54a60","parentId":"d7a2570d","timestamp":"2026-04-14T12:49:08.326Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create a standalone cron script for pruning old session summaries (30 days), separate from the session-summary hook.","thinkingSignature":"6f0150daaf58ff947feed32f4ff21d018557f082b9c7404387e5e02d6b0d5bdf"},{"type":"text","text":"独立清理脚本（供 cron 调用）：\n"},{"type":"toolCall","id":"call_function_90w30xwubtg6_1","name":"write","arguments":{"path":"/home/ai/.openclaw/scripts/prune-old-summaries.js","content":"#!/usr/bin/env node\n/**\n * prune-old-summaries — 清理 30 天前的 session-summary 文件\n * 独立于 session-summary hook 运行，作为 cron 备份保障\n *\n * 建议 cron: 每周日凌晨 4:00 执行\n * 0 4 * * 0 node /home/ai/.openclaw/scripts/prune-old-summaries.js\n */\n\nimport fs from 'node:fs';\nimport path from 'node:path';\nimport os from 'node:os';\n\nconst MEMORY_DIR = path.join(\n  process.env.OPENCLAW_WORKSPACE_DIR ||\n    path.join(os.homedir(), '.openclaw', 'workspace'),\n  'memory'\n);\nconst MAX_AGE_DAYS = 30;\nconst DRY_RUN = process.argv.includes('--dry-run');\n\nasync function main() {\n  console.log(`[prune-old-summaries] 开始检查（${DRY_RUN ? 'DRY RUN' : 'LIVE'}）`);\n\n  let files;\n  try {\n    files = await fs.promises.readdir(MEMORY_DIR);\n  } catch (err) {\n    console.error(`[prune-old-summaries] 无法读取目录: ${MEMORY_DIR}`, err.message);\n    process.exit(1);\n  }\n\n  const now = Date.now();\n  const maxAge = MAX_AGE_DAYS * 24 * 60 * 60 * 1000;\n  let total = 0, pruned = 0, errors = 0;\n\n  for (const file of files) {\n    if (!file.endsWith('-session-summary.md')) continue;\n    total++;\n    const filePath = path.join(MEMORY_DIR, file);\n    try {\n      const stat = await fs.promises.stat(filePath);\n      const age = now - stat.mtimeMs;\n      if (age > maxAge) {\n        if (DRY_RUN) {\n          console.log(`  [dry-run] 将删除: ${file}（${Math.round(age / 86400000)} 天前）`);\n        } else {\n          await fs.promises.unlink(filePath);\n          console.log(`  删除: ${file}（${Math.round(age / 86400000)} 天前）`);\n        }\n        pruned++;\n      }\n    } catch (err) {\n      console.error(`  错误 ${file}: ${err.message}`);\n      errors++;\n    }\n  }\n\n  console.log(`[prune-old-summaries] 完成: 检查 ${total} 个摘要文件，删除 ${pruned} 个，错误 ${errors} 个`);\n}\n\nmain().catch(err => {\n  console.error('[prune-old-summaries] 致命错误:', err.message);\n  process.exit(1);\n});\n"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":15738,"output":649,"cacheRead":19262,"cacheWrite":0,"totalTokens":35649,"cost":{"input":0.0047214,"output":0.0007788,"cacheRead":0.0011557199999999998,"cacheWrite":0,"total":0.006655919999999999}},"stopReason":"toolUse","timestamp":1776170934518,"responseId":"062d6ab6022dd0b8a209df0dc32dfe75"}}
