{"type":"message","id":"952addac","parentId":"6cd50d37","timestamp":"2026-04-14T12:48:21.209Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now update `buildFallbackSummary` similarly.","thinkingSignature":"94e7808d9e5c81ee9e0fdd100cc2f59d4d517caa91f62c1f06d81bffa2e0bbd4"},{"type":"toolCall","id":"call_function_w966mkca09yt_1","name":"edit","arguments":{"path":"/home/ai/.openclaw/hooks/session-summary/handler.js","edits":[{"oldText":"function buildFallbackSummary(content, date, time) {\n  const firstLine = (content.split(\"\\n\")[0] ?? \"\").slice(0, 60).replace(/[#*]/g, \"\").trim();\n  const preview = firstLine || \"会话摘要\";\n  return `# Session: ${date} ${time}\n\n## 主题\n${preview}\n\n## 关键决策\n无\n\n## 重要发现\n无\n\n## 待跟进\n见原始对话记录\n`;\n}","newText":"function buildFallbackSummary(content, date, time) {\n  const firstLine = (content.split(\"\\n\")[0] ?? \"\").slice(0, 60).replace(/[#*]/g, \"\").trim();\n  const preview = firstLine || \"会话摘要\";\n  return `# Session: ${date} ${time}\n\n## 主题\n${preview}\n\n## AI 决策模式\n无决策数据（webchat 或 ephemeral 不可用）\n\n## 关键决策\n无\n\n## 重要发现\n无\n\n## 待跟进\n见原始对话记录\n`;\n}"}]}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":13637,"output":325,"cacheRead":19262,"cacheWrite":0,"totalTokens":33224,"cost":{"input":0.004091099999999999,"output":0.00039,"cacheRead":0.0011557199999999998,"cacheWrite":0,"total":0.005636819999999999}},"stopReason":"toolUse","timestamp":1776170894909,"responseId":"062d6a8e24161229c47cd039718d2251"}}
{"type":"message","id":"63fc865f","parentId":"952addac","timestamp":"2026-04-14T12:48:21.300Z","message":{"role":"toolResult","toolCallId":"call_function_w966mkca09yt_1","toolName":"edit","content":[{"type":"text","text":"Successfully replaced 1 block(s) in /home/ai/.openclaw/hooks/session-summary/handler.js."}],"details":{"diff":"     ...\n 492 \n 493 ## 主题\n 494 ${preview}\n 495 \n+496 ## AI 决策模式\n+497 无决策数据（webchat 或 ephemeral 不可用）\n+498 \n 496 ## 关键决策\n 497 无\n 498 \n 499 ## 重要发现\n     ...","firstChangedLine":496},"isError":false,"timestamp":1776170901288}}
{"type":"message","id":"8cbcebe2","parentId":"63fc865f","timestamp":"2026-04-14T12:48:54.421Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create the ephemeral analyzer script for decision data visualization.","thinkingSignature":"fe27496950f80a3555bc6bf89d2fa12dc8346fc3a8ebdf268f67a9bc9dd99e30"},{"type":"text","text":"现在写 ephemeral 可视化脚本：\n"},{"type":"toolCall","id":"call_function_hod278e2z20l_1","name":"write","arguments":{"path":"/home/ai/.openclaw/scripts/ephemeral-analyze.js","content":"#!/usr/bin/env node\n/**\n * ephemeral-analyze — AI 决策数据可视化\n * 分析 ~/.openclaw/ephemeral/*.jsonl 中的 scene/score/strategy 分布\n *\n * 用法: node ephemeral-analyze.js [--days 7] [--output text|json]\n */\n\nimport fs from 'node:fs';\nimport path from 'node:path';\nimport os from 'node:os';\n\nconst EPHEMERAL_DIR = path.join(os.homedir(), '.openclaw', 'ephemeral');\nconst DEFAULT_DAYS = 7;\nconst MAX_ENTRIES = 5000;\n\n// ─── CLI ───────────────────────────────────────────────────────────────────\n\nconst args = process.argv.slice(2);\nconst daysIdx = args.indexOf('--days');\nconst days = daysIdx >= 0 ? parseInt(args[daysIdx + 1]) || DEFAULT_DAYS : DEFAULT_DAYS;\nconst outputMode = args.includes('--json') ? 'json' : 'text';\n\n// ─── Core ─────────────────────────────────────────────────────────────────\n\nasync function main() {\n  const cutoff = Date.now() - days * 24 * 60 * 60 * 1000;\n  const allEntries = [];\n\n  let files;\n  try {\n    files = await fs.promises.readdir(EPHEMERAL_DIR);\n  } catch {\n    console.error(`[ephemeral-analyze] 无法读取目录: ${EPHEMERAL_DIR}`);\n    process.exit(1);\n  }\n\n  for (const file of files) {\n    if (!file.endsWith('.jsonl')) continue;\n    const filePath = path.join(EPHEMERAL_DIR, file);\n    let stat;\n    try {\n      stat = await fs.promises.stat(filePath);\n    } catch { continue; }\n    if (stat.mtimeMs < cutoff) continue;\n\n    try {\n      const content = await fs.promises.readFile(filePath, 'utf-8');\n      const lines = content.trim().split('\\n');\n      for (const line of lines) {\n        if (!line.trim()) continue;\n        try {\n          const entry = JSON.parse(line);\n          if (new Date(entry.timestamp).getTime() >= cutoff) {\n            allEntries.push(entry);\n          }\n        } catch { /* skip */ }\n      }\n    } catch { continue; }\n  }\n\n  // 去重（按 text slice）\n  const seen = new Set();\n  const entries = allEntries.filter(e => {\n    const key = `${e.sessionKey || ''}-${(e.text || '').slice(0, 80)}`;\n    if (seen.has(key)) return false;\n    seen.add(key);\n    return true;\n  }).slice(-MAX_ENTRIES);\n\n  if (entries.length === 0) {\n    const empty = { summary: '无数据', days, entries: 0, scenes: {}, scores: [], strategies: {}, avgScore: 0 };\n    console.log(outputMode === 'json' ? JSON.stringify(empty, null, 2) : formatText(empty));\n    return;\n  }\n\n  // ─── 统计 ───────────────────────────────────────────────────────────────\n\n  /** @type {Record<string, number>} */\n  const scenes = {};\n  /** @type {number[]} */\n  const scores = [];\n  /** @type {Record<string, number>} */\n  const strategies = {};\n  /** @type {Record<string, number>} */\n  const riskByScene = {};\n  let totalRisk = 0;\n\n  for (const e of entries) {\n    const scene = e.classification?.scene || 'unknown';\n    scenes[scene] = (scenes[scene] || 0) + 1;\n\n    const score = e.scoring?.score ?? 0;\n    scores.push(score);\n\n    const strategy = e.scoring?.recommendedStrategy || 'unknown';\n    strategies[strategy] = (strategies[strategy] || 0) + 1;\n\n    const risk = e.scoring?.factors?.risk || 0;\n    if (risk > 0) {\n      riskByScene[scene] = riskByScene[scene] || [];\n      riskByScene[scene].push(risk);\n      totalRisk += risk;\n    }\n  }\n\n  scores.sort((a, b) => a - b);\n  const avgScore = scores.length > 0 ? scores.reduce((s, v) => s + v, 0) / scores.length : 0;\n  const p50 = scores[Math.floor(scores.length * 0.5)] || 0;\n  const p90 = scores[Math.floor(scores.length * 0.9)] || 0;\n  const maxScore = scores[scores.length - 1] || 0;\n\n  const topScenes = Object.entries(scenes).sort((a, b) => b[1] - a[1]).slice(0, 5);\n  const topStrategies = Object.entries(strategies).sort((a, b) => b[1] - a[1]).slice(0, 5);\n\n  const sceneRiskAvg = {};\n  for (const [scene, vals] of Object.entries(riskByScene)) {\n    sceneRiskAvg[scene] = vals.reduce((s, v) => s + v, 0) / vals.length;\n  }\n  const highestRiskScene = Object.entries(sceneRiskAvg).sort((a, b) => b[1] - a[1])[0];\n\n  // ─── 输出 ───────────────────────────────────────────────────────────────\n\n  const result = {\n    summary: `${days} 天内共 ${entries.length} 条有效碎片`,\n    days,\n    entries: entries.length,\n    scenes: Object.fromEntries(topScenes),\n    strategies: Object.fromEntries(topStrategies),\n    score: {\n      avg: Math.round(avgScore * 10) / 10,\n      p50,\n      p90,\n      max: maxScore,\n    },\n    highestRiskScene: highestRiskScene\n      ? { scene: highestRiskScene[0], avgRisk: Math.round(highestRiskScene[1] * 10) / 10 }\n      : null,\n    sessionCount: new Set(entries.map(e => e.sessionKey)).size,\n  };\n\n  if (outputMode === 'json') {\n    console.log(JSON.stringify(result, null, 2));\n  } else {\n    console.log(formatText(result));\n  }\n}\n\nfunction formatText(r) {\n  const lines = [\n    `📊 ephemeral 决策数据（近 ${r.days} 天）`,\n    `─────────────────────────────────`,\n    `有效碎片: ${r.entries} 条`,\n    `涉及 session: ${r.sessionCount} 个`,\n    ``,\n    `🏷️  场景分布（Top5）:`,\n    ...Object.entries(r.scenes).map(([s, c]) => `   ${s}: ${c} (${Math.round(c / r.entries * 100)}%)`),\n    ``,\n    `🎯 推荐策略分布（Top5）:`,\n    ...Object.entries(r.strategies).map(([s, c]) => `   ${s}: ${c}`),\n    ``,\n    `📈 复杂度评分:`,\n    `   平均: ${r.score.avg}  |  P50: ${r.score.p50}  |  P90: ${r.score.p90}  |  MAX: ${r.score.max}`,\n    ``,\n    r.highestRiskScene\n      ? `⚠️  最高风险场景: ${r.highestRiskScene.scene}（均分 ${r.highestRiskScene.avgRisk}）`\n      : `⚠️  无风险数据`,\n  ];\n  return lines.join('\\n');\n}\n\nmain().catch(err => {\n  console.error('[ephemeral-analyze] 错误:', err.message);\n  process.exit(1);\n});\n"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":14001,"output":1699,"cacheRead":19262,"cacheWrite":0,"totalTokens":34962,"cost":{"input":0.0042003,"output":0.0020388,"cacheRead":0.0011557199999999998,"cacheWrite":0,"total":0.007394819999999999}},"stopReason":"toolUse","timestamp":1776170901300,"responseId":"062d6a9465a2d7656c1eaf61a99860d9"}}
