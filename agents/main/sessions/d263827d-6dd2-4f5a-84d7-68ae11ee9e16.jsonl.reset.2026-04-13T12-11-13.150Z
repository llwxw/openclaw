{"type":"message","id":"50312dc3","parentId":"4abeacaf","timestamp":"2026-04-13T09:05:20.406Z","message":{"role":"toolResult","toolCallId":"call_function_lwa5pwzi0sla_1","toolName":"exec","content":[{"type":"text","text":"=== 18790端口 ===\n\n=== 检查 ephemeral hook 注册 ===\n// auto-score-classify hook\n// Concurrent classification (3104) + scoring (3103) on every inbound message\n// + ephemeral memory capture for meaningful messages\n\nimport fs from \"node:fs\";\nimport path from \"node:path\";\nimport http from \"node:http\";\n\nasync function fetchJSON(url, body, timeoutMs = 3000) {\n  return new Promise((resolve) => {\n    const postData = JSON.stringify(body);\n    const req = http.request(\n      url,\n      {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\", \"Content-Length\": Buffer.byteLength(postData) },\n      },\n      (res) => {\n        let data = \"\";\n        res.on(\"data\", (chunk) => (data += chunk));\n        res.on(\"end\", () => {\n          try { resolve(JSON.parse(data)); }\n          catch { resolve(null); }\n        });\n      }\n    );\n    req.on(\"error\", () => resolve(null));\n    req.setTimeout(timeoutMs, () => { req.destroy(); resolve(null); });\n    req.write(postData);\n    req.end();\n    setTimeout(() => { try { req.destroy(); } catch {} }, timeoutMs);\n  });\n}\n\nasync function runClassification(text) {\n  return fetchJSON(\"http://127.0.0.1:3108/classify\", { text }, 3000);\n}\n\nasync function runScoring(prompt) {\n  return fetchJSON(\"http://127.0.0.1:3103/api/score\", { prompt }, 3000);\n\n=== ephemeral写入位置 ===\n/home/ai/.openclaw/hooks/auto-score-classify/handler.js:// + ephemeral memory capture for meaningful messages\n/home/ai/.openclaw/hooks/auto-score-classify/handler.js:// ─── Ephemeral memory writer ──────────────────────────────────────────────────\n/home/ai/.openclaw/hooks/auto-score-classify/handler.js:  \"ephemeral\"\n/home/ai/.openclaw/hooks/auto-score-classify/handler.js:funct