{"type":"message","id":"f3a63d1a","parentId":"b0150322","timestamp":"2026-04-13T07:18:33.779Z","message":{"role":"toolResult","toolCallId":"call_91086643e2614ded9524a5bb","toolName":"exec","content":[{"type":"text","text":"---\n/**\n * session-summary hook\n *\n * 触发时机: /new 或 /reset\n * 行为: \n *   1. 读取上一个 session 的内容\n *   2. 读取 ephemeral/ 中的记忆碎片\n *   3. 调 LLM 生成结构化摘要 + entity 升格决策\n *   4. 写入 memory/YYYY-MM-DD-summary.md\n *   5. 执行 entity 升格（创建/更新 memory/entities/*.md）\n * 降级: LLM 失败时写规则摘要，不报错\n */\n\nimport fs from \"node:fs\";\nimport path from \"node:path\";\nimport os from \"node:os\";\nimport http from \"node:http\";\n\n// ─── Constants ────────────────────────────────────────────────────────────────\n\nconst MEMORY_DIR = path.join(\n  process.env.OPENCLAW_WORKSPACE_DIR ||\n    path.join(os.homedir(), \".openclaw\", \"workspace\"),\n  \"memory\"\n);\nconst EPHEMERAL_DIR = path.join(MEMORY_DIR, \"ephemeral\");\nconst ENTITIES_DIR = path.join(MEMORY_DIR, \"entities\");\nconst LLM_TIMEOUT_MS = 20_000;\n\n// ─── Types (JSDoc) ─────────────────────────────────────────────────────────"}],"details":{"status":"completed","exitCode":0,"durationMs":54,"aggregated":"---\n/**\n * session-summary hook\n *\n * 触发时机: /new 或 /reset\n * 行为: \n *   1. 读取上一个 session 的内容\n *   2. 读取 ephemeral/ 中的记忆碎片\n *   3. 调 LLM 生成结构化摘要 + entity 升格决策\n *   4. 写入 memory/YYYY-MM-DD-summary.md\n *   5. 执行 entity 升格（创建/更新 memory/entities/*.md）\n * 降级: LLM 失败时写规则摘要，不报错\n */\n\nimport fs from \"node:fs\";\nimport path from \"node:path\";\nimport os from \"node:os\";\nimport http from \"node:http\";\n\n// ─── Constants ────────────────────────────────────────────────────────────────\n\nconst MEMORY_DIR = path.join(\n  process.env.OPENCLAW_WORKSPACE_DIR ||\n    path.join(os.homedir(), \".openclaw\", \"workspace\"),\n  \"memory\"\n);\nconst EPHEMERAL_DIR = path.join(MEMORY_DIR, \"ephemeral\");\nconst ENTITIES_DIR = path.join(MEMORY_DIR, \"entities\");\nconst LLM_TIMEOUT_MS = 20_000;\n\n// ─── Types (JSDoc) ─────────────────────────────────────────────────────────","cwd":"/home/ai/.openclaw/workspace/main"},"isError":false,"timestamp":1776064713769}}
