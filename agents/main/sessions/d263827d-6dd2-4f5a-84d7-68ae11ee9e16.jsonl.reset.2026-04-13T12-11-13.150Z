ifier\": {\n    \"url\": \"http://127.0.0.1:3105\",\n    \"enabled\": true\n  },"}]}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":61924,"output":498,"cacheRead":18601,"cacheWrite":0,"totalTokens":81023,"cost":{"input":0.0185772,"output":0.0005976,"cacheRead":0.0011160599999999999,"cacheWrite":0,"total":0.020290859999999997}},"stopReason":"toolUse","timestamp":1776065854925,"responseId":"062bd03e40adbfbc45f6c77d0f3d534e"}}
