n\nif [ -n \"$MESSAGE\" ]; then\n  # 发送到 Context API（openclaw-router）\n  curl -s -X POST \"${SERVER_URL}/api/context\" \\\n    -H \"Content-Type: application/json\" \\\n    -d \"{\\\"role\\\":\\\"user\\\",\\\"content\\\":\\\"$(echo \"$MESSAGE\" | jq -Rs .)\\\",\\\"user\\\":\\\"$USER\\\",\\\"channel\\\":\\\"$CHANNEL\\\"}\" \\\n    > /dev/null 2>&1 || true\nfi\nEOF\nchmod +x ~/.openclaw/hooks/on-message.sh\necho \"修复完成\"\necho \"\"\ncurl -s http://localhost:3101/api/context/status"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":28757,"output":579,"cacheRead":18887,"cacheWrite":0,"totalTokens":48223,"cost":{"input":0.0086271,"output":0.0006948,"cacheRead":0.0011332199999999999,"cacheWrite":0,"total":0.010455120000000002}},"stopReason":"toolUse","timestamp":1776071949989,"responseId":"062be80c9d0a1283ad93fbaef59ffd26"}}
