{"type":"message","id":"2459c258","parentId":"7679873f","timestamp":"2026-04-13T09:19:09.987Z","message":{"role":"toolResult","toolCallId":"call_function_67q2m3fsm68s_1","toolName":"exec","content":[{"type":"text","text":"=== on-message.sh ===\n#!/bin/bash\n# OpenClaw Context Hook - HTTP 版本\n# 将消息发送到保护层的 HTTP 服务\n\nMESSAGE=\"${OPENCLAW_MESSAGE:-}\"\nUSER=\"${OPENCLAW_SENDER:-unknown}\"\nCHANNEL=\"${OPENCLAW_CHANNEL:-unknown}\"\nSERVER_URL=\"http://127.0.0.1:18790\"\n\nif [ -n \"$MESSAGE\" ]; then\n  # 发送到 HTTP 服务\n  curl -s -X POST \"${SERVER_URL}/api/context/add\" \\\n    -H \"Content-Type: application/json\" \\\n    -d \"{\\\"role\\\":\\\"user\\\",\\\"content\\\":\\\"$(echo \"$MESSAGE\" | jq -Rs .)\\\",\\\"user\\\":\\\"$USER\\\",\\\"channel\\\":\\\"$CHANNEL\\\"}\" \\\n    > /dev/null 2>&1 || true\nfi\n=== context-api 状态(3101) ===\n{\"messages\":0,\"chars\":0}"}],"details":{"status":"completed","exitCode":0,"durationMs":50,"aggregated":"=== on-message.sh ===\n#!/bin/bash\n# OpenClaw Context Hook - HTTP 版本\n# 将消息发送到保护层的 HTTP 服务\n\nMESSAGE=\"${OPENCLAW_MESSAGE:-}\"\nUSER=\"${OPENCLAW_SENDER:-unknown}\"\nCHANNEL=\"${OPENCLAW_CHANNEL:-unknown}\"\nSERVER_URL=\"http://127.0.0.1:18790\"\n\nif [ -n \"$MESSAGE\" ]; then\n  # 发送到 HTTP 服务\n  curl -s -X POST \"${SERVER_URL}/api/context/add\" \\\n    -H \"Content-Type: application/json\" \\\n    -d \"{\\\"role\\\":\\\"user\\\",\\\"content\\\":\\\"$(echo \"$MESSAGE\" | jq -Rs .)\\\",\\\"user\\\":\\\"$USER\\\",\\\"channel\\\":\\\"$CHANNEL\\\"}\" \\\n    > /dev/null 2>&1 || true\nfi\n=== context-api 状态(3101) ===\n{\"messages\":0,\"chars\":0}","cwd":"/home/ai/.openclaw/workspace/main"},"isError":false,"timestamp":1776071949975}}
