ootstrap issues\n\n=== gateway配置 ===\n{\n    \"meta\": {\n        \"lastTouchedVersion\": \"2026.3.13\",\n        \"lastTouchedAt\": \"2026-03-22T13:00:54.791Z\"\n    },\n    \"logging\": {\n        \"level\": \"warn\"\n    },\n    \"v8\": {\n        \"url\": \"http://127.0.0.1:3103\",\n        \"enabled\": true\n    },\n    \"sceneClassifier\": {\n        \"url\": \"http://127.0.0.1:3104\",\n        \"enabled\": true\n    },\n    \"plugins\": {\n        \"openclaw-cc-bridge\": {\n            \"enabled\": true,\n            \"model\": \"minimax-m2.5\",\n            \"allowedTools\": [\n                \"Bash\",\n                \"Read\",\n                \"Edit\",\n                \"Write\",\n                \"Glob\",\n                \"Grep\",\n                \"WebFetch\",\n                \"WebSearch\",\n                \"Mildred\",\n                \"Task*\"\n            ],\n            \"env\": {\n                \"ANTHROPIC_BASE_URL\": \"https://zhenze-huhehaote.cmecloud.cn/api/coding/v1\",\n                \"ANTHROPIC_AUTH_TOKEN\": \"J99ouXWKXO8Zg5tLqv92YVsPNFhwuZc-z6z2ioeg7VE\",\n                \"ANTHROPIC_MODEL\": \"minimax-m2.5\"\n            }\n        }\n    },\n    \"models\": {\n        \"providers\": {\n            \"ollama\": {\n                \"baseUrl\": \"http://172.23.96.1:11434\",\n                \"models\": [\n                    {\n                        \"id\": \"qwen2.5:14b\",\n                        \"name\": \"\\u672c\\u5730-qwen2.5-14b\"\n                    }\n                ]\n            },"}],"details":{"status":"completed","exitCode":0,"durationMs":149,"aggregated":"=== scene-classifier 测试 ===\n{\n    \"response\": \"[LLM\\u54cd\\u5e94] \\u57fa\\u4e8e\\u4f60\\u7684\\u8f93\\u5165\\uff0c\\u5efa\\u8bae\\u64cd\\u4f5c\\u5982\\u4e0b\\uff1a...\",\n    \"intercepted\": false,\n    \"scene\": \"clarify\",\n    \"meta\": \"ambiguous\",\n    \"confidence\": 0.6941336393356323\n}\n\n=== scorer 测试 ===\n{\n    \"score\": 0,\n    \"factors\":