{"type":"message","id":"d35d1dd9","parentId":"2bab08c0","timestamp":"2026-04-13T11:53:03.984Z","message":{"role":"toolResult","toolCallId":"call_function_mfsl2o13rkd4_1","toolName":"exec","content":[{"type":"text","text":"async function writeEntityFile(name, content) {\n  try {\n    await fs.promises.mkdir(ENTITIES_DIR, { recursive: true });\n    const filePath = path.join(ENTITIES_DIR, `${name}.md`);\n    const header = `# Entity: ${name}\\n\\n`;\n    await fs.promises.writeFile(filePath, header + content + '\\n', 'utf-8');\n    console.log(`[session-summary] Entity written: ${name}.md`);\n  } catch (e) {\n    console.error(`[session-summary] Entity write failed: ${name}`, e);\n  }\n}\n\n// ─── Fallback ────────────────────────────────────────────────────────────────\n\n/**\n * @param {string} content\n * @param {string} date\n * @param {string} time\n * @returns {string}\n */\nfunction buildFallbackSummary(content, date, time) {\n  const firstLine = (content.split(\"\\n\")[0] ?? \"\").slice(0, 60).replace(/[#*]/g, \"\").trim();"}],"details":{"status":"completed","exitCode":0,"durationMs":47,"aggregated":"async function writeEntityFile(name, content) {\n  try {\n    await fs.promises.mkdir(ENTITIES_DIR, { recursive: true });\n    const filePath = path.join(ENTITIES_DIR, `${name}.md`);\n    const header = `# Entity: ${name}\\n\\n`;\n    await fs.promises.writeFile(filePath, header + content + '\\n', 'utf-8');\n    console.log(`[session-summary] Entity written: ${name}.md`);\n  } catch (e) {\n    console.error(`[session-summary] Entity write failed: ${name}`, e);\n  }\n}\n\n// ─── Fallback ────────────────────────────────────────────────────────────────\n\n/**\n * @param {string} content\n * @param {string} date\n * @param {string} time\n * @returns {string}\n */\nfunction buildFallbackSummary(content, date, time) {\n  const firstLine = (content.split(\"\\n\")[0] ?? \"\").slice(0, 60).replace(/[#*]/g, \"\").trim();","cwd":"/home/ai/.openclaw/workspace/main"},"isError