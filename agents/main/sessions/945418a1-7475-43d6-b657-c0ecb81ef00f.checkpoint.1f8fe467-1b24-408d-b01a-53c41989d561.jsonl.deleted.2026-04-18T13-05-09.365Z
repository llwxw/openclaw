a.toString());\n            if (parsed.type === 'message') {\n                const msgData = parsed.data || parsed;\n                await messageHandler.handle(msgData);\n            }\n            else {\n                logger.trace({ parsed }, 'Ignoring non-message type');\n            }\n        }\n        catch (err) {\n            logger.error({ err, raw: data.toString().slice(0, 200) }, 'Failed to parse message');\n            if (queue)\n                queue.enqueue(data.toString());\n        }\n    });\n    gatewayClient.on('error', (err) => {\n        logger.error({ err }, 'Gateway WebSocket error');\n    });\n    gatewayClient.on('close', (code, reason) => {\n        logger.warn({ code, reason: reason?.toString() }, 'Gateway connection closed');\n    });\n    gatewayClient.connect();\n    const shutdown = async () => {\n        logger.info('Shutting down...');\n        gatewayClient.close();\n        if (queue)\n            await queue.close();\n        if (healthServer)\n            await healthServer.stop();\n        process.exit(0);\n    };\n    process.on('SIGTERM', shutdown);\n    process.on('SIGINT', shutdown);\n}\nmain().catch((err) => {\n    console.error('Fatal error:', err);\n    process.exit(1);\n});\n//# sourceMappingURL=main.js.map"}],"details":{"status":"completed","exitCode":0,"durationMs":254,"aggregated":"\"use strict\";\nObject.defineProperty(exports, \"__esModule\", { value: true });\nconst config_1 = require(\"./config\");\nconst logger_1 = require(\"./logger\");\nconst queue_1 = require(\"./queue\");\nconst apiClient_1 = require(\"./apiClient\");\nconst gatewayClient_1 = require(\"./gatewayClient\");\nconst messageHandler_1 = require(\"./messageHandler\");\nconst healthServer_1 = require(\"./healthServer\");\nasync function main() {\n    const config = (0, config_1.loadConfig)();\n    const logger = (0, logger_1.createLogger)(config.logging);\n    logger.info({ version: '2.0.0' }, 'Starting OpenClaw Listener');\n    const queue = config.behavior.queueEnabled\n        ? new queue_1.MessageQueue(config.behavior.queueDbPath, config.behavior.batchSize, config.behavior.batchIntervalMs)\n        : null;\n    const apiClient = new apiClient_1.ApiClient(config.api);\n    const gatewayClient = new gatewayClient_1.GatewayClient(config.gateway);\n    const messageHandler = new messageHandler_1.MessageHandler(apiClient, queue, config, gatewayClient);\n    let healthServer = null;\n    if (config.health.enabled) {\n        healthServer = new healthServer_1.HealthServer(config.health.port, config.health.endpoint, () => ({\n            connected: gatewayClient.isConnected(),\n            queueSize: queue ? queue.buffer?.length ?? 0 : 0,\n            reconnectAttempts: gatewayClient.getReconnectAttempts(),\n        }));\n        healthServer.start();\n    }\n    gatewayClient.on('open', async () => {\n        logger.info('Gateway connected, replaying queued messages');\n        if (queue)\n            await messageHandler.replayQueuedMessages();\n    });\n    gatewayClient.on('message', async (data) => {\n        try {\n            const parsed = JSON.parse(data.toString());\n            if (parsed.type === 'message') {\n                const msgData = parsed.data || parsed;\n                await messageHandler.handle(msgData);\n            }\n            else {\n                logger.trace({ parsed }, 'Ignoring non-message type');\n            }\n        }\n        catch (err) {\n            logger.error({ err, raw: data.toString().slice(0, 200) }, 'Failed to parse message');\n            if (queue)\n                queue.enqueue(data.toString());\n        }\n    });\n    gatewayClient.on('error', (err) => {\n        logger.error({ err }, 'Gateway WebSocket error');\n    });\n    gatewayClient.on('close', (code, reason) => {\n        logger.warn({ code, reason: reason?.toString() }, 'Gateway connection closed');\n    });\n    gatewayClient.connect();\n    const shutdown = async () => {\n        logger.inf