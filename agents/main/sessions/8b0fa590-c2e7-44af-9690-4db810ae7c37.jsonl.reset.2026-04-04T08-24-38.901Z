{"type":"message","id":"70e24599","parentId":"934556d3","timestamp":"2026-04-03T16:15:19.942Z","message":{"role":"toolResult","toolCallId":"019d54201a1480e583cacb4dee330932","toolName":"read","content":[{"type":"text","text":"import { app, BrowserWindow, ipcMain, dialog, shell, safeStorage } from 'electron'\r\nimport path from 'path'\r\nimport fs, { FSWatcher } from 'fs'\r\nimport { WebContents } from 'electron'\r\n\r\n// 保持对窗口对象的全局引用，避免被垃圾回收\r\nlet mainWindow: BrowserWindow | null = null\r\n\r\n// 项目根目录 - 用于路径验证\r\nlet projectRootPath: string | null = null\r\n\r\n// 文件系统监视器\r\nlet fsWatcher: FSWatcher | null = null\r\n\r\n/**\r\n * 验证文件路径是否安全\r\n * 防止路径遍历攻击 (如 ../../../etc/passwd)\r\n * 只允许访问项目目录内的文件\r\n */\r\nfunction validatePath(requestedPath: string): { valid: boolean; resolvedPath?: string; error?: string } {\r\n  // 如果没有设置项目根路径，允许绝对路径但进行基本验证\r\n  if (!projectRootPath) {\r\n    // 解析并规范化路径\r\n    const resolved = path.resolve(requestedPath)\r\n    \r\n    // 检查是否尝试访问系统敏感目录\r\n    const sensitivePaths = [\r\n      '/etc',\r\n      '/proc',\r\n      '/sys',\r\n      'C:\\\\Windows',\r\n      'C:\\\\Program Files',\r\n      'C:\\\\Program Files (x86)',\r\n    ]\r\n    \r\n    for (const sensitive of sensitivePaths) {\r\n      if (resolved.toLowerCase().startsWith(sensitive.toLowerCase())) {\r\n        return {\r\n          valid: false,\r\n          error: `访问被拒绝：不允许访问系统目录`,\r\n        }\r\n      }\r\n    }\r\n    \r\n    return { valid: true, resolvedPath: resolved }\r\n  }\r\n  \r\n  // 解析并规范化请求的路径\r\n  const resolved = path.resolve(requestedPath)\r\n  const normalizedRequested = path.normalize(resolved)\r\n  const normalizedRoot = path.normalize(projectRootPath)\r\n  \r\n  // 检查路径是否在项目根目录内\r\n  // 使用 startsWith 检查，确保路径以项目根目录开头\r\n  const isWithinProject = \r\n    normalizedRequested === normalizedRoot ||\r\n    normalizedRequested.startsWith(normalizedRoot + path.sep) ||\r\n    normalizedRequested.startsWith(normalizedRoot + '/')\r\n  \r\n  if (!isWithinProject) {\r\n    return {\r\n      valid: false,\r\n      error: `访问被拒绝：只能访问项目目录内的文件。请求路径：${requestedPath}，项目根目录：${projectRootPath}`,\r\n    }\r\n  }\r\n  \r\n  return { valid: true, resolvedPath: resolved }\r\n}\r\n\r\n/**\r\n * 设置项目根路径\r\n * 在打开项目时调用\r\n */\r\nexport function setProjectRoot(rootPath: string): void {\r\n  projectRootPath = path.resolve(rootPath)\r\n}\r\n\r\n/**\r\n * 获取当前项目根路径\r\n */\r\nexport function getProjectRoot(): string | null {\r\n  return projectRootPath\r\n}\r\n\r\nfunction createWindow() {\r\n  mainWindow = new BrowserWindow({\r\n    width: 1200,\r\n    height: 800,\r\n    webPreferences: {\r\n      nodeIntegration: false,\r\n      contextIsolation: true,\r\n      preload: path.join(__dirname, 'preload.js')\r\n    },\r\n    show: false,\r\n    icon: path.join(__dirname, '../../assets/icon.ico')\r\n  })\r\n\r\n  // 加载应用\r\n  if (process.env.NODE_ENV === 'development') {\r\n    mainWindow.loadURL('http://localhost:3000')\r\n\n[497 more lines in file. Use offset=101 to continue.]"}],"isError":false,"timestamp":1775232919939}}
