{"type":"message","id":"31f73dad","parentId":"17aa00ec","timestamp":"2026-04-03T16:15:06.600Z","message":{"role":"toolResult","toolCallId":"019d541fd0bd0c5bc6341ee511049c67","toolName":"read","content":[{"type":"text","text":"// AI 服务 - 用于渲染进程调用 AI API\r\n// 支持 DeepSeek、OpenAI、豆包、Kimi、Ollama 等兼容接口\r\n\r\nimport type { AIService, FunctionName, ModelMapping, AICallOptions, ModelOption } from '../types/ai';\r\nimport { joinPath } from '../utils/pathUtils';\r\n\r\nexport interface AIConfig {\r\n  model: string;\r\n  apiKey: string;\r\n  baseUrl: string;\r\n  maxTokens: number;\r\n  temperature: number;\r\n}\r\n\r\nexport interface StreamChunk {\r\n  content: string;\r\n  done: boolean;\r\n}\r\n\r\n// 默认配置\r\nconst DEFAULT_CONFIG: AIConfig = {\r\n  model: 'deepseek-chat',\r\n  apiKey: '',\r\n  baseUrl: 'https://api.deepseek.com/v1',\r\n  maxTokens: 2000,\r\n  temperature: 0.7,\r\n};\r\n\r\n// ==================== 超时配置 ====================\r\n\r\n/** 超时级别（毫秒） */\r\nexport const TIMEOUT_LEVELS = {\r\n  FAST: 30_000,       // 30秒 - 快速任务（摘要/分类）\r\n  NORMAL: 120_000,    // 120秒 - 普通任务（默认）- 网文AI生成通常需要较长时间\r\n  DEEP: 180_000,      // 180秒 - 深度推理（逻辑校验）\r\n  LONG: 300_000,      // 300秒 - 长文本任务（一致性检查/设定召回/章节生成）\r\n  STREAM: 300_000,    // 300秒 - 流式生成（5分钟）\r\n} as const;\r\n\r\n/** 快速任务列表（30秒超时） */\r\nconst FAST_FUNCTIONS = new Set([\r\n  'fast_summary',\r\n  'rhythm_check',\r\n  'title_optimize',\r\n  'quality_ai_trace_score',\r\n  'advanced_real_time_emotion_monitor',\r\n  'advanced_catharsis_type_statistics',\r\n  'advanced_fatal_point_warning',\r\n  'advanced_foreshadowing_payoff_prediction',\r\n]);\r\n\r\n/** 深度推理任务列表（120秒超时） */\r\nconst DEEP_FUNCTIONS = new Set([\r\n  'logic_check',\r\n  'outline_level_skip_validate',\r\n  'world_power_growth_curve_validate',\r\n  'world_tech_setting_validate',\r\n  'relation_conflict_prediction',\r\n  'fact_power_extraction',\r\n  'fact_item_extraction',\r\n  'fact_relation_extraction',\r\n  'fact_power_conflict_detection',\r\n  'fact_item_conflict_detection',\r\n  'fact_relation_conflict_detection',\r\n  'fact_timeline_conflict_detection',\r\n  'quality_contradiction_detection',\r\n  'quality_character_behavior_validate',\r\n  'quality_timeline_age_validate',\r\n  'quality_logic_chain_tracing',\r\n  'quality_remove_ai_trace',\r\n  'advanced_bestseller_catharsis_analysis',\r\n  'writing_plot_adjustment',\r\n]);\r\n\r\n/** 长文本任务列表（180秒超时） */\r\nconst LONG_FUNCTIONS = new Set([\r\n  'long_context',\r\n  'setting_recall',\r\n  'chapter_generation',\r\n  'climax_generation',\r\n  'outline_planning',\r\n  'style_imitation',\r\n]);\r\n\r\n/**\r\n * 根据功能名获取推荐超时时间\r\n */\r\nexport function getTimeoutForFunction(funcName?: FunctionName): number {\r\n  if (!funcName) return TIMEOUT_LEVELS.NORMAL;\r\n  if (FAST_FUNCTIONS.has(funcName)) return TIMEOUT_LEVELS.FAST;\r\n  if (DEEP_FUNCTIONS.has(funcName)) return TIMEOUT_LEVELS.DEEP;\r\n  if (LONG_FUNCTIONS.has(funcName)) return TIMEOUT_LEVELS.LONG;\r\n  return TIMEOUT_LEVELS.NORMAL;\r\n}\r\n\r\n// 硬编码豆包API配置 - 作为回退机制\r\nconst HARCODED_DOUBAO_CONFIG = {\r\n  apiKey: 'bef1c53c-e4da-4067-abf0-182c4f0daa7c',\r\n  endpointIds: {\r\n    pro: 'ep-20260401204837-jklzh',      // 豆包 Seed-2.0 Pro\r\n    lite: 'ep-20260401210511-qhg9m',     // 豆包 Seed-2.0 Lite\r\n    mini: 'ep-20260401205747-4csq4',     // 豆包 Seed-2.0 Mini\r\n  },\r\n};\r\n\r\n// 环境变量支持 - 优先使用环境变量中的配置\r\nconst ENV_CONFIG = {\r\n  // 豆包API环境变量\r\n  ARK_API_KEY: '',\r\n  // 其他API环境变量（可选）\r\n  DEEPSEEK_API_KEY: '',\r\n  OPENAI_API_KEY: '',\r\n  KIMI_API_KEY: '',\r\n};\r\n\r\n// 存储键名\r\nconst STORAGE_KEYS = {\r\n  CONFIG: 'ai_config',\r\n  ENCRYPTED_API_KEY: 'ai_encrypted_api_key',\r\n  MODEL_MAPPING: 'ai_model_mapping',\r\n  DEFAULT_MODEL: 'ai_default_model',\r\n  DOUBAO_PRO_ENDPOINT: 'doubao_pro_endpoint',\r\n  DOUBAO_LITE_ENDPOINT: 'doubao_lite_endpoint',\r\n  DOUBAO_MINI_ENDPOINT: 'doubao_mini_endpoint',\r\n} as const;\r\n\r\n// 缓存\r\nlet cachedApiKey: string | null = null;\r\nlet cachedEncryptedKey: Buffer | null = null;\r\nlet apiKeyCache: Record<string, string> = {}; // 多 API Key 缓存\r\n\r\n/**\r\n * 检查 safeStorage 是否可用\r\n * 在 mock 环境下返回 false，避免使用损坏的加密数据\r\n */\r\nasync function isSafeStorageAvailable(): Promise<boolean> {\r\n  try {\r\n    if (typeof window !== 'undefined' && window.electronAPI?.safeStorage) {\r\n      // 检查是否是 mock 环境：mock 环境会注入 openDirectory 函数\r\n      // 真实 Electron 的 preload.ts 通常不会注入 openDirectory\r\n      const isMockEnvironment = typeof window.electronAPI.openDirectory === 'function';\r\n      if (isMockEnvironment) {\r\n        console.log('检测到 mock 环境，跳过 safeStorage');\r\n        return false;\r\n      }\r\n      \r\n      // 真实 Electron 环境：检查 safeStorage 是否真的可用\r\n      const result = await window.electronAPI.safeStorage.isAvailable();\r\n      return result;\r\n    }\r\n\n[1457 more lines in file. Use offset=151 to continue.]"}],"isError":false,"timestamp":1775232906599}}
