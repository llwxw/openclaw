 '青云宗现任宗主，修行千年，经历过正邪大战。看出林枫的潜力，收其为徒。',\r\n    notes: '可作为林枫的导师和引路人。',\r\n  },\r\n];\r\n\r\nconst CharacterManager: React.FC<ManagementComponentProps> = ({\r\n  currentPath,\r\n  onSelectFile,\r\n  onSave,\r\n  onDelete,\r\n  onRefresh,\r\n}) => {\r\n  const [characters, setCharacters] = useState<CharacterData[]>(MOCK_CHARACTERS);\r\n  const [selectedCharacter, setSelectedCharacter] = useState<CharacterData | null>(null);\r\n  const [searchQuery, setSearchQuery] = useState('');\r\n  const [loading, setLoading] = useState(false);\r\n  const [isModalVisible, setIsModalVisible] = useState(false);\r\n  const [editingCharacter, setEditingCharacter] = useState<CharacterData | null>(null);\r\n  const [directoryExists, setDirectoryExists] = useState<boolean>(true);\r\n  const [form] = Form.useForm();\r\n\r\n  // 加载角色数据（从文件系统读取）\r\n  useEffect(() => {\r\n    loadCharacters();\r\n  }, [currentPath]);\r\n\r\n\n[963 more lines in file. Use offset=101 to continue.]"}],"isError":false,"timestamp":1775232897743}}
