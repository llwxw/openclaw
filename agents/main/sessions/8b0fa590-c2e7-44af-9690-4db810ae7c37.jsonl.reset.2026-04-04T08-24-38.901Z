{"type":"message","id":"657da424","parentId":"149e01ea","timestamp":"2026-04-03T16:15:09.115Z","message":{"role":"toolResult","toolCallId":"call_fce15b291f5b4987920f238b","toolName":"read","content":[{"type":"text","text":"    }\r\n  } catch (e) {\r\n    console.warn('safeStorage 不可用，将使用 localStorage:', e);\r\n  }\r\n  return false;\r\n}\r\n\r\n/**\r\n * 加密 API Key\r\n */\r\nasync function encryptApiKey(apiKey: string): Promise<Buffer | null> {\r\n  try {\r\n    if (typeof window !== 'undefined' && window.electronAPI?.safeStorage) {\r\n      const result = await window.electronAPI.safeStorage.encrypt(apiKey);\r\n      if (result.success && result.data) {\r\n        return result.data;\r\n      }\r\n    }\r\n  } catch (e) {\r\n    console.error('加密 API Key 失败:', e);\r\n  }\r\n  return null;\r\n}\r\n\r\n/**\r\n * 解密 API Key\r\n */\r\nasync function decryptApiKey(encrypted: Buffer | string): Promise<string | null> {\r\n  try {\r\n    if (typeof window !== 'undefined' && window.electronAPI?.safeStorage) {\r\n      let buffer: Buffer;\r\n      if (typeof encrypted === 'string') {\r\n        buffer = Buffer.from(encrypted, 'base64');\r\n      } else {\r\n        buffer = encrypted;\r\n      }\r\n      \r\n      const result = await window.electronAPI.safeStorage.decrypt(buffer);\r\n      if (result.success && result.data) {\r\n        return result.data;\r\n      }\r\n    }\r\n  } catch (e) {\r\n    console.error('解密 API Key 失败:', e);\r\n  }\r\n  return null;\r\n}\r\n\r\n/**\r\n * 安全地存储 API Key\r\n */\r\nasync function storeApiKeySecurely(apiKey: string, service: string = 'default'): Promise<void> {\r\n  const safeStorageAvailable = await isSafeStorageAvailable();\r\n  \r\n  if (safeStorageAvailable) {\r\n    const encrypted = await encryptApiKey(apiKey);\r\n    if (encrypted) {\r\n      const encryptedBase64 = encrypted.toString('base64');\r\n      localStorage.setItem(`${STORAGE_KEYS.ENCRYPTED_API_KEY}_${service}`, encryptedBase64);\r\n      apiKeyCache[service] = apiKey;\r\n      return;\r\n    }\r\n  }\r\n  \r\n  console.warn('警告：safeStorage 不可用，API Key 将以明文存储在 localStorage 中');\r\n  localStorage.setItem(`${STORAGE_KEYS.CONFIG}_${service}`, JSON.stringify({ apiKey }));\r\n  apiKeyCache[service] = apiKey;\r\n}\r\n\r\n/**\r\n * 安全地获取 API Key\r\n */\r\nasync function getApiKeySecurely(service: string = 'default'): Promise<string> {\r\n  if (apiKeyCache[service]) {\r\n    return apiKeyCache[service];\r\n  }\r\n\r\n  let apiKey = '';\r\n  let source = '';\r\n\r\n  // 1. 优先检查环境变量\r\n  if (service === 'doubao' && ENV_CONFIG.ARK_API_KEY) {\r\n    apiKey = ENV_CONFIG.ARK_API_KEY;\r\n    source = '环境变量';\r\n  } else if (service === 'deepseek' && ENV_CONFIG.DEEPSEEK_API_KEY) {\r\n    apiKey = ENV_CONFIG.DEEPSEEK_API_KEY;\r\n    source = '环境变量';\r\n  } else if (service === 'openai' && ENV_CONFIG.OPENAI_API_KEY) {\r\n    apiKey = ENV_CONFIG.OPENAI_API_KEY;\r\n    source = '环境变量';\r\n  } else if (service === 'kimi' && ENV_CONFIG.KIMI_API_KEY) {\r\n    apiKey = ENV_CONFIG.KIMI_API_KEY;\r\n    source = '环境变量';\r\n  }\r\n  \r\n  // 2. 检查安全存储\r\n  if (!apiKey) {\r\n    const safeStorageAvailable = await isSafeStorageAvailable();\r\n    \r\n    if (safeStorageAvailable) {\r\n      const encryptedBase64 = localStorage.getItem(`${STORAGE_KEYS.ENCRYPTED_API_KEY}_${service}`);\r\n      if (encryptedBase64) {\r\n        const decrypted = await decryptApiKey(encryptedBase64);\r\n        if (decrypted) {\r\n          apiKey = decrypted;\r\n          source = '安全存储';\r\n        }\r\n      }\r\n    }\r\n  }\r\n  \r\n  // 3. 检查localStorage中的明文配置\r\n  if (!apiKey) {\r\n    const config = localStorage.getItem(`${STORAGE_KEYS.CONFIG}_${service}`);\r\n    if (config) {\r\n      try {\r\n        const parsed = JSON.parse(config);\r\n        if (parsed.apiKey) {\r\n          apiKey = parsed.apiKey;\r\n          source = 'localStorage明文';\r\n        }\r\n      } catch (e) {\r\n        console.error('解析配置失败:', e);\r\n      }\r\n    }\r\n  }\r\n  \r\n  // 4. 豆包API硬编码回退 - 如果其他方式都没有配置，使用硬编码的API Key\r\n  if (!apiKey && service === 'doubao') {\r\n    apiKey = HARCODED_DOUBAO_CONFIG.apiKey;\r\n    source = '硬编码回退';\r\n  }\r\n\r\n  // 清理API Key，去除空格和特殊字符\r\n  if (apiKey) {\r\n    apiKey = apiKey.trim().replace(/[\\r\\n\\t]/g, '');\r\n  }\r\n\r\n  // 豆包API Key格式验证\r\n  if (apiKey && service === 'doubao') {\r\n    // 豆包API Key是UUID格式，长度为36\r\n    const uuidRegex = /^[0-9a-fA-F-]{36}$/;\r\n    if (!uuidRegex.test(apiKey)) {\r\n      console.warn(`[豆包API Key] 警告：API Key格式不正确，长度: ${apiKey.length}，已自动忽略，将使用硬编码Key`);\r\n      apiKey = ''; // 清空错误的Key，让逻辑自动使用硬编码回退\r\n    }\r\n  }\r\n\r\n  // 如果经过前面的步骤API Key为空，且是豆包服务，强制使用硬编码Key\r\n  if (!apiKey && service === 'doubao') {\r\n\n[1308 more lines in file. Use offset=300 to continue.]"}],"isError":false,"timestamp":1775232909112}}
{"type":"message","id":"d6add9ac","parentId":"657da424","timestamp":"2026-04-03T16:15:11.349Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"发现了更多问题：1. **安全漏洞**: 硬编码的豆包 API Key (`HARCODED_DOUBAO_CONFIG`) - 这是严重的安全问题2. **逻辑 bug**: 在获取 API Key 时，如果格式验证失败，会自动清空并使用硬编码的 key，这可能导致用户配置被绕过让我继续检查更多代码。\n\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"\n\n\n"},{"type":"toolCall","id":"call_e08f648d3a4643a7a80c3d68","name":"read","arguments":{"file":"/mnt/d/axs/novel-desktop-app/src/renderer/src/services/aiService.ts","limit":100,"offset":300}}],"api":"openai-completions","provider":"codingplan","model":"minimax-m2.5","usage":{"input":39671,"output":134,"cacheRead":0,"cacheWrite":0,"totalTokens":39805,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775232909115,"responseId":"chatcmpl-42cfbf84-a087-4822-8fab-718978ad16f4"}}
{"type":"message","id":"3323a7b3","parentId":"d6add9ac","timestamp":"2026-04-03T16:15:11.371Z","message":{"role":"toolResult","toolCallId":"call_e08f648d3a4643a7a80c3d68","toolName":"read","content":[{"type":"text","text":"    apiKey = HARCODED_DOUBAO_CONFIG.apiKey;\r\n    source = '硬编码回退（前面的配置格式错误）';\r\n  }\r\n\r\n  // 打印调试信息，隐藏中间部分保护隐私\r\n  if (apiKey && service === 'doubao') {\r\n    const maskedKey = apiKey.length > 10 \r\n      ? `${apiKey.substring(0, 8)}...${apiKey.substring(apiKey.length - 6)}`\r\n      : apiKey;\r\n    console.log(`[豆包API Key] 来源: ${source}, Key: ${maskedKey}, 长度: ${apiKey.length}, 格式正确: ${/^[0-9a-fA-F-]{36}$/.test(apiKey)}`);\r\n  }\r\n  \r\n  apiKeyCache[service] = apiKey;\r\n  return apiKey;\r\n}\r\n\r\n// 获取当前 API Key（异步）\r\nexport async function getApiKeyAsync(service?: string): Promise<string> {\r\n  return getApiKeySecurely(service || 'default');\r\n}\r\n\r\n// 获取当前 API Key（同步版本，使用缓存）\r\nexport function getApiKey(service?: string): string {\r\n  const key = service || 'default';\r\n  if (apiKeyCache[key]) {\r\n    return apiKeyCache[key];\r\n  }\r\n  const config = localStorage.getItem(`${STORAGE_KEYS.CONFIG}_${key}`);\r\n  if (config) {\r\n    try {\r\n      const parsed = JSON.parse(config);\r\n      return parsed.apiKey || '';\r\n    } catch (e) {\r\n      return '';\r\n    }\r\n  }\r\n  return '';\r\n}\r\n\r\n// 保存 API Key（使用加密存储）\r\nexport async function saveApiKey(apiKey: string, service: string = 'default'): Promise<void> {\r\n  await storeApiKeySecurely(apiKey, service);\r\n}\r\n\r\n// 检查是否配置了 API Key（异步）\r\nexport async function isConfiguredAsync(service?: string): Promise<boolean> {\r\n  if (service) {\r\n    const apiKey = await getApiKeySecurely(service);\r\n    return !!apiKey;\r\n  }\r\n  \r\n  // 如果没有指定服务，检查所有已知服务商（除了 ollama）是否有至少一个配置了 API Key\r\n  const services = ['doubao', 'deepseek', 'kimi', 'openai'];\r\n  for (const svc of services) {\r\n    const apiKey = await getApiKeySecurely(svc);\r\n    if (apiKey) {\r\n      return true;\r\n    }\r\n  }\r\n  return false;\r\n}\r\n\r\n// 检查是否配置了 API Key（同步版本）\r\nexport function isConfigured(service?: string): boolean {\r\n  if (service) {\r\n    return !!getApiKey(service);\r\n  }\r\n  \r\n  // 如果没有指定服务，检查所有已知服务商（除了 ollama）是否有至少一个配置了 API Key\r\n  const services = ['doubao', 'deepseek', 'kimi', 'openai'];\r\n  for (const svc of services) {\r\n    if (getApiKey(svc)) {\r\n      return true;\r\n    }\r\n  }\r\n  return false;\r\n}\r\n\r\n// ==================== 模型映射管理 ====================\r\n\r\nconst DEFAULT_MODEL_MAPPING: ModelMapping = {\r\n  // 角色工坊\r\n  character_name_generation: 'doubao/doubao-seed-2.0-pro-32k',\r\n  character_title_generation: 'doubao/doubao-seed-2.0-pro-32k',\r\n  character_appearance_generation: 'doubao/doubao-seed-2.0-pro-32k',\r\n  character_catchphrase_generation: 'doubao/doubao-seed-2.0-pro-32k',\r\n  character_cheat_code_generation: 'doubao/doubao-seed-2.0-pro-32k',\r\n  character_golden_finger_generation: 'doubao/doubao-seed-2.0-pro-32k',\r\n  character_core_desire_generation: 'doubao/doubao-seed-2.0-pro-32k',\r\n  character_fear_conflict_generation: 'doubao/doubao-seed-2.0-pro-32k',\r\n  character_flaw_generation: 'doubao/doubao-seed-2.0-pro-32k',\r\n  character_relationship_recommendation: 'doubao/doubao-seed-2.0-pro-32k',\r\n  character_relationship_conflict_generation: 'doubao/doubao-seed-2.0-pro-32k',\r\n\r\n  // 大纲工坊\r\n  outline_golden_three_chapters_check: 'doubao/doubao-seed-2.0-pro-32k',\r\n  outline_catharsis_density_planning: 'doubao/doubao-seed-2.0-pro-32k',\r\n  outline_chapter_hook_generation: 'doubao/doubao-seed-2.0-pro-32k',\r\n  outline_emotion_curve_generation: 'doubao/doubao-seed-2.0-pro-32k',\r\n  outline_face_slapping_scene_generation: 'doubao/doubao-seed-2.0-pro-32k',\r\n\n[1208 more lines in file. Use offset=400 to continue.]"}],"isError":false,"timestamp":1775232911370}}
