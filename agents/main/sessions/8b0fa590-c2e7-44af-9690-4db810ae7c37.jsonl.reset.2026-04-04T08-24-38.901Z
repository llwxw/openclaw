{"type":"message","id":"83a96430","parentId":"c18d3756","timestamp":"2026-04-03T16:15:22.583Z","message":{"role":"toolResult","toolCallId":"call_e9b8524fcc9b466d82780674","toolName":"read","content":[{"type":"text","text":"import * as yaml from 'js-yaml';\r\nimport { CharacterData, RelationshipData, ChapterData, SettingData } from '../types/management';\r\n\r\n/**\r\n * YAML解析工具类\r\n * 提供统一的YAML解析和序列化方法，包含错误处理和类型转换\r\n */\r\nexport class YamlParser {\r\n  /**\r\n   * 解析YAML字符串为JavaScript对象\r\n   * @param content YAML字符串\r\n   * @returns 解析后的对象\r\n   * @throws 如果YAML格式无效\r\n   */\r\n  static parse(content: string): any {\r\n    try {\r\n      return yaml.load(content);\r\n    } catch (error: any) {\r\n      throw new Error(`YAML解析失败: ${error.message}`);\r\n    }\r\n  }\r\n\r\n  /**\r\n   * 将JavaScript对象序列化为YAML字符串\r\n   * @param obj JavaScript对象\r\n   * @param options 序列化选项\r\n   * @returns YAML字符串\r\n   */\r\n  static stringify(obj: any, options?: yaml.DumpOptions): string {\r\n    try {\r\n      return yaml.dump(obj, {\r\n        indent: 2,\r\n        lineWidth: -1, // 不限制行宽\r\n        ...options,\r\n      });\r\n    } catch (error: any) {\r\n      throw new Error(`YAML序列化失败: ${error.message}`);\r\n    }\r\n  }\r\n\r\n  /**\r\n   * 解析角色YAML文件\r\n   * @param content YAML文件内容\r\n   * @returns CharacterData对象\r\n   */\r\n  static parseCharacter(content: string): CharacterData {\r\n    try {\r\n      // 使用loadAll解析多文档YAML\r\n      const documents = yaml.loadAll(content);\r\n      \r\n      // 第一个文档是frontmatter，第二个文档是notes（如果有）\r\n      const frontmatter = documents[0] as any || {};\r\n      const notesDoc = documents[1];\r\n      \r\n      // 提取notes：如果第二个文档存在，将其转换为字符串；否则使用frontmatter中的notes字段\r\n      let notes = '';\r\n      if (notesDoc !== undefined) {\r\n        if (typeof notesDoc === 'string') {\r\n          notes = notesDoc;\r\n        } else {\r\n          notes = String(notesDoc);\r\n        }\r\n      } else {\r\n        notes = frontmatter.notes || '';\r\n      }\r\n      \r\n      // 构建CharacterData对象\r\n      const character: CharacterData = {\r\n        name: frontmatter.name || '',\r\n        mbti: frontmatter.mbti || '',\r\n        coreFear: frontmatter.core_fear || frontmatter.coreFear || '',\r\n        keyAttributes: {\r\n          appearance: frontmatter.key_attributes?.appearance || frontmatter.keyAttributes?.appearance || '',\r\n          ability: frontmatter.key_attributes?.ability || frontmatter.keyAttributes?.ability || '',\r\n          goal: frontmatter.key_attributes?.goal || frontmatter.keyAttributes?.goal || '',\r\n          flaw: frontmatter.key_attributes?.flaw || frontmatter.keyAttributes?.flaw || '',\r\n        },\r\n        background: frontmatter.background || '',\r\n        notes: notes,\r\n      };\r\n      \r\n      return character;\r\n    } catch (error: any) {\r\n      throw new Error(`角色YAML解析失败: ${error.message}`);\r\n    }\r\n  }\r\n\r\n  /**\r\n   * 将角色数据序列化为YAML字符串\r\n   * @param character 角色数据\r\n   * @returns YAML字符串\r\n   */\r\n  static stringifyCharacter(character: CharacterData): string {\r\n    try {\r\n      const yamlObj = {\r\n        name: character.name,\r\n        mbti: character.mbti || undefined,\r\n        core_fear: character.coreFear || undefined,\r\n        key_attributes: {\r\n          appearance: character.keyAttributes.appearance || undefined,\r\n          ability: character.keyAttributes.ability || undefined,\r\n          goal: character.keyAttributes.goal || undefined,\r\n          flaw: character.keyAttributes.flaw || undefined,\r\n        },\r\n        background: character.background || undefined,\r\n        notes: character.notes || undefined,\r\n      };\r\n      \r\n      // 清理undefined值\r\n      const cleanedObj = this.cleanUndefined(yamlObj);\r\n      \r\n      // 生成YAML字符串\r\n      const yamlStr = this.stringify(cleanedObj);\r\n      \r\n      // 如果notes存在且不为空，添加到YAML后面\r\n      let result = yamlStr;\r\n      if (character.notes && character.notes.trim()) {\r\n        result = `---\\n${yamlStr}\\n---\\n${character.notes}`;\r\n      } else {\r\n        result = `---\\n${yamlStr}\\n---\\n`;\r\n      }\r\n      \r\n      return result;\r\n    } catch (error: any) {\r\n      throw new Error(`角色YAML序列化失败: ${error.message}`);\r\n    }\r\n  }\r\n\r\n  /**\r\n   * 解析关系YAML文件\r\n   * @param content YAML文件内容\r\n   * @returns RelationshipData数组\r\n   */\r\n  static parseRelationships(content: string): RelationshipData[] {\r\n    try {\r\n      const parsed = this.parse(content);\r\n      \r\n      if (!parsed.relationships || !Array.isArray(parsed.relationships)) {\r\n        return [];\r\n      }\r\n      \r\n      return parsed.relationships.map((rel: any) => ({\r\n        from: rel.from || '',\r\n        to: rel.to || '',\r\n        type: rel.type || 'friend',\r\n        strength: typeof rel.strength === 'number' ? rel.strength : 0.5,\r\n        development: Array.isArray(rel.development) \r\n          ? rel.development.map((dev: any) => ({\r\n              chapter: dev.chapter || 0,\r\n              event: dev.event || '',\r\n              strength: typeof dev.strength === 'number' ? dev.strength : 0.5,\r\n            }))\r\n          : [],\r\n      }));\r\n    } catch (error: any) {\r\n      throw new Error(`关系YAML解析失败: ${error.message}`);\r\n    }\r\n  }\r\n\r\n  /**\r\n   * 将关系数据序列化为YAML字符串\r\n   * @param relationships 关系数据数组\r\n   * @returns YAML字符串\r\n   */\r\n  static stringifyRelationships(relationships: RelationshipData[]): string {\r\n    try {\r\n      const yamlObj = {\r\n        relationships: relationships.map(rel => ({\r\n          from: rel.from,\r\n          to: rel.to,\r\n          type: rel.type,\r\n          strength: rel.strength,\r\n          development: rel.development.map(dev => ({\r\n            chapter: dev.chapter,\r\n            event: dev.event,\r\n            strength: dev.strength,\r\n          })),\r\n        })),\r\n      };\r\n      \r\n      return this.stringify(yamlObj);\r\n    } catch (error: any) {\r\n      throw new Error(`关系YAML序列化失败: ${error.message}`);\r\n    }\r\n  }\r\n\r\n  /**\r\n   * 解析章节frontmatter\r\n   * @param content Markdown文件内容\r\n   * @returns 章节数据和内容\r\n   */\r\n  static parseChapter(content: string): { frontmatter: Partial<ChapterData>; content: string } {\r\n    try {\r\n      // 查找frontmatter（以---开头和结束）\r\n      const frontmatterMatch = content.match(/^---\\n([\\s\\S]*?)\\n---\\n([\\s\\S]*)$/);\r\n      \r\n      if (!frontmatterMatch) {\r\n        // 没有frontmatter，返回空对象和完整内容\r\n        return {\r\n          frontmatter: {},\r\n          content: content,\r\n        };\r\n      }\r\n      \r\n      const frontmatterStr = frontmatterMatch[1];\r\n      const chapterContent = frontmatterMatch[2];\r\n      \r\n      const parsed = this.parse(frontmatterStr);\r\n      \r\n      const frontmatter: Partial<ChapterData> = {\r\n        title: parsed.title || '',\r\n        chapter: typeof parsed.chapter === 'number' ? parsed.chapter : 0,\r\n        volume: typeof parsed.volume === 'number' ? parsed.volume : 1,\r\n        emotionType: ['爽', '虐', '燃', '暖'].includes(parsed.emotion_type) \r\n          ? parsed.emotion_type \r\n          : '爽',\r\n        catharsisLevel: [1, 2, 3, 4, 5].includes(parsed.catharsis_level) \r\n          ? parsed.catharsis_level \r\n          : 1,\r\n        stage: ['hero', 'parent', 'child', 'shadow', 'integration'].includes(parsed.stage)\r\n          ? parsed.stage\r\n          : 'hero',\r\n        characters: Array.isArray(parsed.characters) ? parsed.characters : [],\r\n        settings: Array.isArray(parsed.settings) ? parsed.settings : [],\r\n        summary: parsed.summary || '',\r\n      };\r\n      \r\n      return {\r\n        frontmatter,\r\n        content: chapterContent,\r\n      };\r\n    } catch (error: any) {\r\n      throw new Error(`章节YAML解析失败: ${error.message}`);\r\n    }\r\n  }\r\n\r\n  /**\r\n   * 将章节数据序列化为Markdown字符串\r\n   * @param chapterData 章节数据\r\n   * @param content 章节内容\r\n   * @returns Markdown字符串\r\n   */\r\n  static stringifyChapter(chapterData: Partial<ChapterData>, content: string): string {\r\n    try {\r\n      const frontmatterObj = {\r\n        title: chapterData.title || '',\r\n        chapter: chapterData.chapter || 0,\r\n        volume: chapterData.volume || 1,\r\n        emotion_type: chapterData.emotionType || '爽',\r\n        catharsis_level: chapterData.catharsisLevel || 1,\r\n        stage: chapterData.stage || 'hero',\r\n        characters: chapterData.characters || [],\r\n        settings: chapterData.settings || [],\r\n        summary: chapterData.summary || '',\r\n      };\r\n      \r\n      const frontmatterStr = this.stringify(frontmatterObj);\r\n      return `---\\n${frontmatterStr}---\\n${content}`;\r\n    } catch (error: any) {\r\n      throw new Error(`章节YAML序列化失败: ${error.message}`);\r\n    }\r\n  }\r\n\r\n  /**\r\n   * 解析多文档YAML字符串\r\n   * @param content YAML字符串\r\n   * @returns 文档数组\r\n   * @throws 如果YAML格式无效\r\n   */\r\n  static parseAll(content: string): any[] {\r\n    try {\r\n      return yaml.loadAll(content);\r\n    } catch (error: any) {\r\n      throw new Error(`多文档YAML解析失败: ${error.message}`);\r\n    }\r\n  }\r\n\r\n  /**\r\n   * 将项目配置序列化为YAML字符串\r\n   * @param config 项目配置对象\r\n   * @returns YAML字符串\r\n   */\r\n  static stringifyProjectConfig(config: any): string {\r\n    try {\r\n      return this.stringify(config);\r\n    } catch (error: any) {\r\n      throw new Error(`项目配置YAML序列化失败: ${error.message}`);\r\n    }\r\n  }\r\n\r\n  /**\r\n   * 清理对象中的undefined值\r\n   * @param obj 要清理的对象\r\n   * @returns 清理后的对象\r\n   */\r\n  private static cleanUndefined(obj: any): any {\r\n    if (Array.isArray(obj)) {\r\n      return obj\r\n        .map(item => this.cleanUndefined(item))\r\n        .filter(item => item !== undefined);\r\n    }\r\n    \r\n    if (obj !== null && typeof obj === 'object') {\r\n      const result: any = {};\r\n      for (const key in obj) {\r\n        if (obj.hasOwnProperty(key)) {\r\n          const cleaned = this.cleanUndefined(obj[key]);\r\n          if (cleaned !== undefined) {\r\n            result[key] = cleaned;\r\n          }\r\n        }\r\n      }\r\n      return Object.keys(result).length > 0 ? result : undefined;\r\n    }\r\n    \r\n    return obj !== undefined ? obj : undefined;\r\n  }\r\n\r\n  /**\r\n   * 验证YAML文件格式\r\n   * @param content YAML字符串\r\n   * @returns 验证结果\r\n   */\r\n  static validate(content: string): { valid: boolean; error?: string } {\r\n    try {\r\n      this.parse(content);\r\n      return { valid: true };\r\n    } catch (error: any) {\r\n      return { valid: false, error: error.message };\r\n    }\r\n  }\r\n\r\n  /**\r\n   * 安全的YAML解析，返回解析结果或默认值\r\n   * @param content YAML字符串\r\n   * @param defaultValue 解析失败时的默认值\r\n   * @returns 解析结果或默认值\r\n   */\r\n  static safeParse<T>(content: string, defaultValue: T): T {\r\n    try {\r\n      const result = this.parse(content);\r\n      return result as T;\r\n    } catch {\r\n      return defaultValue;\r\n    }\r\n  }\r\n\r\n  /**\r\n   * 从文件内容中提取YAML frontmatter\r\n   * @param content 文件内容\r\n   * @returns frontmatter字符串和剩余内容\r\n   */\r\n  static extractFrontmatter(content: string): { frontmatter: string; content: string } {\r\n    const match = content.match(/^---\\n([\\s\\S]*?)\\n---\\n([\\s\\S]*)$/);\r\n    if (match) {\r\n      return {\r\n        frontmatter: match[1],\r\n        content: match[2],\r\n      };\r\n    }\r\n    return {\r\n      frontmatter: '',\r\n      content: content,\r\n    };\r\n  }\r\n}\r\n\r\n// 默认导出\r\nexport default YamlParser;\r\n"}],"isError":false,"timestamp":1775232922581}}
