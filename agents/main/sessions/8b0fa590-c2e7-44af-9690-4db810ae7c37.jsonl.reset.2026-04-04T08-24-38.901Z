{"type":"message","id":"43a9baa5","parentId":"684968de","timestamp":"2026-04-03T17:31:11.647Z","message":{"role":"toolResult","toolCallId":"019d546562ba694b9da311bb3b374d35","toolName":"exec","content":[{"type":"text","text":"// 对于豆包服务，使用接入点ID作为model参数\r\n  let requestModel = modelName;\r\n  if (service === 'doubao') {\r\n    try {\r\n      const endpointId = getDoubaoEndpointId(modelName);\r\n      if (!endpointId) {\r\n        throw new Error(`未配置豆包模型 ${modelName} 的接入点ID，请在设置中添加`);\r\n      }\r\n      requestModel = endpointId;\r\n    } catch (error: any) {\r\n      // 如果getDoubaoEndpointId抛出了不支持的模型错误，直接传递\r\n      throw error;\r\n    }\r\n  }\r\n  \r\n  // 构建请求体，豆包API需要包含top_p参数\r\n  // 双重保险：确保数字参数类型正确，即使传入的是字符串也能转换\r\n  const requestBody: any = {\r\n    model: requestModel,\r\n    messages,\r\n    max_tokens: typeof (maxTokens || config.maxTokens) === 'string' \r\n      ? parseInt(String(maxTokens || config.maxTokens), 10) || DEFAULT_CONFIG.maxTokens\r\n      : maxTokens || config.maxTokens,\r\n    temperature: typeof (temperature ?? config.temperature) === 'string'\r\n      ? parseFloat(String(temperature ?? config.temperature)) || DEFAULT_CONFIG.temperature\r\n      : temperature ?? config.temperature,\r\n    stream: true,\r\n  };\r\n  \r\n  // 豆包API建议包含top_p参数\r\n  if (service === 'doubao') {\r\n    requestBody.top_p = 0.95;\r\n  }\r\n  \r\n  const response = await fetch(`${baseUrl}/chat/completions`, {\r\n    method: 'POST',\r\n    headers: {\r\n      'Content-Type': 'application/json',\r\n      'Authorization': `Bearer ${apiKey}`,\r\n    },\r\n    body: JSON.stringify(requestBody),\r\n    signal,\r\n  });\r\n\r\n  if (!response.ok) {\r\n    let errorText = '';\r\n    try {\r\n      errorText = await response.text();\r\n    } catch (e) {\r\n      errorText = '无法读取错误信息';"}],"details":{"status":"completed","exitCode":0,"durationMs":13,"aggregated":"// 对于豆包服务，使用接入点ID作为model参数\r\n  let requestModel = modelName;\r\n  if (service === 'doubao') {\r\n    try {\r\n      const endpointId = getDoubaoEndpointId(modelName);\r\n      if (!endpointId) {\r\n        throw new Error(`未配置豆包模型 ${modelName} 的接入点ID，请在设置中添加`);\r\n      }\r\n      requestModel = endpointId;\r\n    } catch (error: any) {\r\n      // 如果getDoubaoEndpointId抛出了不支持的模型错误，直接传递\r\n      throw error;\r\n    }\r\n  }\r\n  \r\n  // 构建请求体，豆包API需要包含top_p参数\r\n  // 双重保险：确保数字参数类型正确，即使传入的是字符串也能转换\r\n  const requestBody: any = {\r\n    model: requestModel,\r\n    messages,\r\n    max_tokens: typeof (maxTokens || config.maxTokens) === 'string' \r\n      ? parseInt(String(maxTokens || config.maxTokens), 10) || DEFAULT_CONFIG.maxTokens\r\n      : maxTokens || config.maxTokens,\r\n    temperature: typeof (temperature ?? config.temperature) === 'string'\r\n      ? parseFloat(String(temperature ?? config.temperature)) || DEFAULT_CONFIG.temperature\r\n      : temperature ?? config.temperature,\r\n    stream: true,\r\n  };\r\n  \r\n  // 豆包API建议包含top_p参数\r\n  if (service === 'doubao') {\r\n    requestBody.top_p = 0.95;\r\n  }\r\n  \r\n  const response = await fetch(`${baseUrl}/chat/completions`, {\r\n    method: 'POST',\r\n    headers: {\r\n      'Content-Type': 'application/json',\r\n      'Authorization': `Bearer ${apiKey}`,\r\n    },\r\n    body: JSON.stringify(requestBody),\r\n    signal,\r\n  });\r\n\r\n  if (!response.ok) {\r\n    let errorText = '';\r\n    try {\r\n      errorText = await response.text();\r\n    } catch (e) {\r\n      errorText = '无法读取错误信息';","cwd":"/home/ai/.openclaw/workspace"},"isError":false,"timestamp":1775237471644}}
