\n            \"name\": \"DeepSeek-R1\",\n            \"reasoning\": true,\n            \"input\": [\n              \"text\"\n            ],\n            \"contextWindow\": 65536,\n            \"maxTokens\": 8192\n          }\n        ]\n      },\n      \"codingplan\": {\n        \"baseUrl\": \"https://zhenze-huhehaote.cmecloud.cn/api/coding/v1\",\n        \"apiKey\": \"J99ouXWKXO8Zg5tLqv92YVsPNFhwuZc-z6z2ioeg7VE\",\n        \"api\": \"openai-completions\",\n        \"models\": [\n          {\n            \"id\": \"minimax-m2.5\",\n            \"name\": \"minimax-m2.5 (Custom Provider)\",\n            \"reasoning\": false,\n            \"input\": [\n              \"text\"\n            ],\n            \"cost\": {\n              \"input\": 0,\n              \"output\": 0,\n              \"cacheRead\": 0,\n              \"cacheWrite\": 0\n            },\n            \"contextWindow\": 204800,\n            \"maxTokens\": 4096\n          }\n        ]\n      }\n    }\n  },\n  \"agents\": {\n    \"defaults\": {\n      \"model\": {\n        \"primary\": \"codingplan/minimax-m2.5\"\n      },\n      \"models\": {\n        \"deepseek/deepseek-chat\": {\n          \"alias\": \"cloud\"\n        },\n        \"deepseek/deepseek-reasoner\": {},\n        \"ollama/qwen2.5:14b\": {\n          \"alias\": \"local\"\n        },\n        \"codingplan/minimax-m2.5\": {\n          \"alias\": \"coding\"\n        }\n      },\n      \"workspace\": \"/home/ai/.openclaw/workspace\",\n      \"compaction\": {\n        \"mode\": \"safeguard\"\n      }\n    }\n  },\n  \"tools\": {\n    \"profile\": \"coding\"\n  },\n  \"bindings\": [\n    {\n      \"agentId\": \"main\",\n      \"match\": {\n        \"channel\": \"feishu\",\n        \"accountId\": \"default\"\n      }\n    }\n  ],\n  \"commands\": {\n    \"native\": \"auto\",\n    \"nativeSkills\": \"auto\",\n    \"restart\": true,\n    \"ownerDisplay\": \"raw\"\n  },\n  \"session\": {\n    \"dmScope\": \"per-channel-peer\"\n  },\n  \"hooks\": {\n   